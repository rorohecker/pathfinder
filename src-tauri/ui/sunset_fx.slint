// Lean Sunset atmosphere for Pathfinder.
// Horizon sun moves across the sky and drives warm radiance — no ray streaks.
// Theme-gated by the caller via `active`. No TouchArea: clicks pass through.

export component SunsetAtmosphere inherits Rectangle {
    in property <bool> active: false;
    in property <bool> running: true;
    // Sun state driven by the host (MainWindow) so the content-pane sky
    // gradient can stay in sync without a second timer.
    in property <float> sun_cx: 0.48;
    in property <float> sun_cy: 0.12;
    in property <float> sun_glow: 1.0;
    in property <bool> setting: false;

    width: 100%;
    height: 100%;
    background: transparent;
    visible: root.active;

    property <bool> anim_on: root.active && root.running;

    // Soft sky wash — warmer/brighter near the sun, dusk deeper as it sets.
    // Sits under the disc/halos; low opacity so chrome stays readable.
    Rectangle {
        x: 0;
        y: 0;
        width: root.width;
        height: root.height;
        background: @linear-gradient(165deg,
            rgba(255, 176, 96, 0.16) 0%,
            rgba(232, 98, 63, 0.08) 38%,
            rgba(90, 40, 72, 0.04) 72%,
            rgba(22, 10, 26, 0.0) 100%);
        opacity: 0.35 + root.sun_glow * 0.45;
        animate opacity { duration: 14000ms; easing: ease-in-out; }
    }

    // Horizon glow band — brighter when the sun is lower (setting).
    Rectangle {
        x: 0;
        y: root.height * 0.68;
        width: root.width;
        height: root.height * 0.32;
        background: @linear-gradient(180deg,
            rgba(232, 98, 63, 0.0) 0%,
            rgba(242, 161, 61, 0.16) 55%,
            rgba(242, 112, 138, 0.12) 100%);
        opacity: root.setting ? 1.0 : 0.50;
        animate opacity { duration: 14000ms; easing: ease-in-out; }
    }

    // Warm radiance halo around the sun (the light source) — no ray spikes.
    Rectangle {
        width: 260px;
        height: 260px;
        border-radius: 130px;
        x: root.sun_cx * root.width - self.width / 2;
        y: root.sun_cy * root.height - self.height / 2;
        background: @radial-gradient(circle,
            rgba(255, 200, 90, 0.46) 0%,
            rgba(255, 120, 70, 0.16) 42%,
            rgba(255, 80, 100, 0.0) 72%);
        opacity: 0.30 + root.sun_glow * 0.50;
        animate x { duration: 14000ms; easing: ease-in-out; }
        animate y { duration: 14000ms; easing: ease-in-out; }
        animate opacity { duration: 14000ms; easing: ease-in-out; }
    }

    // Mid halo — tighter pulse tied to sun brightness.
    Rectangle {
        width: 120px;
        height: 120px;
        border-radius: 60px;
        x: root.sun_cx * root.width - self.width / 2;
        y: root.sun_cy * root.height - self.height / 2;
        background: @radial-gradient(circle,
            rgba(255, 224, 120, 0.72) 0%,
            rgba(255, 140, 60, 0.22) 50%,
            rgba(255, 100, 80, 0.0) 100%);
        opacity: 0.38 + root.sun_glow * 0.50;
        animate x { duration: 14000ms; easing: ease-in-out; }
        animate y { duration: 14000ms; easing: ease-in-out; }
        animate opacity { duration: 14000ms; easing: ease-in-out; }
    }

    // Sun disc.
    Rectangle {
        width: 36px;
        height: 36px;
        border-radius: 18px;
        background: #ffe066;
        opacity: 0.18 + root.sun_glow * 0.16;
        x: root.sun_cx * root.width - 18px;
        y: root.sun_cy * root.height - 18px;
        animate x { duration: 14000ms; easing: ease-in-out; }
        animate y { duration: 14000ms; easing: ease-in-out; }
        animate opacity { duration: 14000ms; easing: ease-in-out; }
    }

    // Two birds gliding across (sparse — not a flock).
    for bird[i] in [
        { x0: 0.08, y: 0.14, dx: 0.72, dur: 9000ms },
        { x0: 0.70, y: 0.28, dx: -0.55, dur: 7000ms },
    ]: Rectangle {
        width: 6px;
        height: 2px;
        background: #241428;
        opacity: 0.35;
        y: bird.y * root.height;
        property <bool> flown: Math.mod(i, 2) == 0;
        Timer {
            interval: bird.dur;
            running: root.anim_on;
            triggered => { flown = !flown; }
        }
        x: (flown ? bird.x0 + bird.dx : bird.x0) * root.width;
        animate x { duration: bird.dur; easing: linear; }
    }
}
