import { LineEdit, ListView, ScrollView, Slider } from "std-widgets.slint";

export struct FileItem {
    name: string,
    file_path: string,
    is_dir: bool,
    size_text: string,
    modified_text: string,
    type_text: string,
    extension: string,
    has_tag: bool,
    tag_color: color,
    git_badge: string,
    git_color: color,
    has_note: bool,
    is_selected: bool,
    has_thumbnail: bool,
    thumbnail: image,
}

export struct SideItem {
    label: string,
    path: string,
    icon: string,
    count: string,
    color: color,
    is_header: bool,
    active: bool,
}

export struct TabItem {
    title: string,
    path: string,
    active: bool,
}

export struct ChoiceItem {
    id: string,
    label: string,
    description: string,
    color: color,
}

export struct CommandItem {
    group: string,
    label: string,
    hint: string,
    command: string,
}

export global ThemePalette {
    in-out property <color> bg: #101318;
    in-out property <color> bg_soft: #171b22;
    in-out property <color> panel: rgba(28, 33, 42, 0.82);
    in-out property <color> panel_solid: #1c212a;
    in-out property <color> panel_alt: #232936;
    in-out property <color> titlebar: rgba(18, 22, 29, 0.92);
    in-out property <color> sidebar: rgba(22, 26, 34, 0.84);
    in-out property <color> border: rgba(157, 172, 196, 0.16);
    in-out property <color> border_strong: rgba(185, 198, 220, 0.26);
    in-out property <color> text: #f2f6fb;
    in-out property <color> text_muted: #b5c0cf;
    in-out property <color> text_faint: #7f8b9d;
    in-out property <color> accent: #4f9cff;
    in-out property <color> accent_soft: rgba(79, 156, 255, 0.16);
    in-out property <color> accent_strong: #72b3ff;
    in-out property <color> danger: #e5484d;
    in-out property <color> success: #37b26c;
    in-out property <color> warning: #e3a524;
    in-out property <color> icon_folder_1: #ffd86a;
    in-out property <color> icon_folder_2: #e2a934;
}

component SvgIcon {
    in property <string> data;
    in property <color> tint: ThemePalette.text_muted;
    in property <length> icon_size: 16px;
    width: root.icon_size;
    height: root.icon_size;

    Path {
        width: root.icon_size;
        height: root.icon_size;
        commands: root.data;
        fill: rgba(0, 0, 0, 0);
        stroke: root.tint;
        stroke-width: 1.6px;
        stroke-line-cap: round;
        stroke-line-join: round;
    }
}

component ToolButton inherits Rectangle {
    in property <string> icon_data;
    in property <string> text_label;
    in property <string> tooltip;
    in property <bool> active;
    in property <bool> danger;
    in property <length> button_width: 31px;
    in property <length> button_height: 31px;
    callback clicked();

    width: root.button_width;
    height: root.button_height;
    border-radius: AppMetrics.radius_small;
    border-width: root.active ? 1px : 0px;
    border-color: root.active ? ThemePalette.accent : rgba(0, 0, 0, 0);
    background: root.danger && touch.has-hover ? ThemePalette.danger : (root.active ? ThemePalette.accent_soft : (touch.has-hover ? rgba(255, 255, 255, 0.06) : rgba(0, 0, 0, 0)));

    SvgIcon {
        x: (parent.width - 16px) / 2;
        y: (parent.height - 16px) / 2;
        icon_size: 16px;
        data: root.icon_data;
        tint: root.danger && touch.has-hover ? white : (root.active || touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text_muted);
    }

    Text {
        visible: root.icon_data == "";
        text: root.text_label;
        color: root.danger && touch.has-hover ? white : (root.active || touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text_muted);
        font-size: 16px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    if root.tooltip != "" && touch.has-hover: Rectangle {
        x: (parent.width - (tip_text.preferred-width + 16px)) / 2;
        y: parent.height + 6px;
        width: tip_text.preferred-width + 16px;
        height: 26px;
        border-radius: AppMetrics.radius_small;
        border-width: 1px;
        border-color: ThemePalette.border_strong;
        background: ThemePalette.panel_solid;
        drop-shadow-blur: 18px;
        drop-shadow-color: rgba(0, 0, 0, 0.35);

        tip_text := Text {
            x: 8px;
            width: parent.width - 16px;
            height: parent.height;
            text: root.tooltip;
            color: ThemePalette.text;
            font-size: 11.5px;
            vertical-alignment: center;
        }
    }
}

component TabButton inherits Rectangle {
    in property <TabItem> tab;
    in property <int> index;
    callback activated(int);
    callback closed(int);

    width: 132px;
    height: 30px;
    border-radius: 7px;
    border-width: root.tab.active ? 1px : 0px;
    border-color: ThemePalette.border;
    background: root.tab.active ? ThemePalette.panel : (touch.has-hover ? ThemePalette.panel_alt : rgba(0, 0, 0, 0));

    Text {
        x: 10px;
        y: 0;
        width: parent.width - 38px;
        height: parent.height;
        text: root.tab.title;
        color: root.tab.active ? ThemePalette.text : ThemePalette.text_muted;
        font-size: 12px;
        overflow: elide;
        vertical-alignment: center;
    }

    ToolButton {
        x: parent.width - 28px;
        y: 3px;
        button_width: 24px;
        button_height: 24px;
        icon_data: "M18 6L6 18 M6 6l12 12";
        tooltip: "Close tab";
        visible: touch.has-hover || root.tab.active;
        clicked => { root.closed(root.index); }
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.activated(root.index); }
    }
}

component SideRow inherits Rectangle {
    in property <SideItem> item;
    in property <int> index;
    callback activated(int);

    height: root.item.is_header ? 24px : 32px;
    border-radius: AppMetrics.radius_small;
    background: !root.item.is_header && root.item.active ? ThemePalette.accent_soft : (!root.item.is_header && touch.has-hover ? rgba(255, 255, 255, 0.06) : rgba(0, 0, 0, 0));

    Text {
        visible: root.item.is_header;
        x: 8px;
        width: parent.width - 16px;
        height: parent.height;
        text: root.item.label;
        color: ThemePalette.text_faint;
        font-size: 11px;
        font-weight: 700;
        vertical-alignment: center;
    }

    Rectangle {
        visible: !root.item.is_header && root.item.icon == "tag";
        x: 12px;
        y: (parent.height - 9px) / 2;
        width: 9px;
        height: 9px;
        border-radius: 5px;
        background: root.item.color;
        border-width: 1px;
        border-color: rgba(0, 0, 0, 0.14);
    }

    SvgIcon {
        visible: !root.item.is_header && root.item.icon != "tag";
        x: 9px;
        y: (parent.height - 16px) / 2;
        icon_size: 16px;
        data: root.item.icon == "drive" ? "M22 12H2 M5.5 5.2 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.5-6.8A2 2 0 0 0 16.7 4H7.3a2 2 0 0 0-1.8 1.2z" :
              root.item.icon == "home" ? "M3 10l9-7 9 7v10a2 2 0 0 1-2 2h-4v-7H9v7H5a2 2 0 0 1-2-2z" :
              root.item.icon == "download" ? "M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M7 10l5 5 5-5 M12 15V3" :
              root.item.icon == "image" ? "M21 15V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2z M8 11a2 2 0 1 0 0-4 2 2 0 0 0 0 4z M21 19l-6-6-9 9" :
              "M3 7.5A2.5 2.5 0 0 1 5.5 5H10l2 2h6.5A2.5 2.5 0 0 1 21 9.5v7A2.5 2.5 0 0 1 18.5 19h-13A2.5 2.5 0 0 1 3 16.5z";
        tint: root.item.active ? ThemePalette.accent_strong : ThemePalette.text_muted;
    }

    Text {
        visible: !root.item.is_header;
        x: 38px;
        width: parent.width - 78px;
        height: parent.height;
        text: root.item.label;
        color: root.item.active ? ThemePalette.accent_strong : (touch.has-hover ? ThemePalette.text : ThemePalette.text_muted);
        font-size: 13px;
        overflow: elide;
        vertical-alignment: center;
    }

    Text {
        visible: !root.item.is_header;
        x: parent.width - 46px;
        width: 38px;
        height: parent.height;
        text: root.item.count;
        color: ThemePalette.text_faint;
        font-family: AppMetrics.mono_font;
        font-size: 10px;
        horizontal-alignment: right;
        vertical-alignment: center;
        overflow: elide;
    }

    touch := TouchArea {
        enabled: !root.item.is_header;
        mouse-cursor: pointer;
        clicked => { root.activated(root.index); }
    }
}

component NodeVisual {
    in property <bool> is_dir;
    in property <string> extension;
    in property <length> visual_width: root.is_dir ? 54px : 46px;
    in property <length> visual_height: root.is_dir ? 44px : 54px;

    width: root.visual_width;
    height: root.visual_height;

    if root.is_dir: Rectangle {
        x: 4px;
        y: 8px;
        width: parent.width - 8px;
        height: parent.height - 11px;
        border-radius: 5px;
        background: @linear-gradient(180deg, ThemePalette.icon_folder_1 0%, ThemePalette.icon_folder_2 100%);
    }

    if root.is_dir: Rectangle {
        x: 8px;
        y: 1px;
        width: 22px;
        height: 10px;
        border-radius: 5px;
        background: ThemePalette.icon_folder_1;
    }

    if !root.is_dir: Rectangle {
        x: 7px;
        y: 3px;
        width: parent.width - 14px;
        height: parent.height - 6px;
        border-width: 1px;
        border-color: ThemePalette.border_strong;
        border-radius: 4px;
        background: ThemePalette.panel_solid;
    }

    if !root.is_dir: Rectangle {
        x: parent.width - 20px;
        y: 4px;
        width: 13px;
        height: 13px;
        background: ThemePalette.panel_alt;
        border-width: 1px;
        border-color: ThemePalette.border_strong;
    }

    if !root.is_dir: Rectangle {
        x: 7px;
        y: parent.height - 18px;
        width: parent.width - 14px;
        height: 15px;
        background: ThemePalette.accent;
        Text {
            text: root.extension == "" ? "FILE" : root.extension;
            color: white;
            font-family: AppMetrics.mono_font;
            font-size: 8px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

component FileRow inherits Rectangle {
    in property <FileItem> item;
    in property <int> index;
    in property <string> view_mode;
    in property <int> rename_index: -1;
    callback selected(int, bool, bool);
    callback opened(int);
    callback context(int, length, length);
    callback rename_commit(int, string);

    property <bool> ctrl_held: false;
    property <bool> shift_held: false;
    property <bool> is_renaming: root.rename_index == root.index;

    height: root.view_mode == "list" ? AppMetrics.row_h : (root.view_mode == "gallery" ? 154px : AppMetrics.grid_h);
    border-radius: AppMetrics.radius;
    border-width: root.item.is_selected ? 1px : 0px;
    border-color: root.item.is_selected ? ThemePalette.accent : rgba(0, 0, 0, 0);
    background: root.item.is_selected ? ThemePalette.accent_soft : (touch.has-hover ? rgba(255, 255, 255, 0.06) : rgba(0, 0, 0, 0));

    if root.view_mode == "list": NodeVisual {
        x: 10px;
        y: (parent.height - 22px) / 2;
        visual_width: 24px;
        visual_height: root.item.is_dir ? 20px : 26px;
        is_dir: root.item.is_dir;
        extension: root.item.extension;
    }

    // List view: name as text (not renaming)
    if root.view_mode == "list" && !root.is_renaming: Text {
        x: 44px;
        y: 0;
        width: parent.width - 486px;
        height: parent.height;
        text: root.item.name;
        color: root.item.is_selected ? ThemePalette.text : ThemePalette.text_muted;
        font-size: 12.5px;
        overflow: elide;
        vertical-alignment: center;
    }

    // List view: inline rename input
    if root.view_mode == "list" && root.is_renaming: rename_list := LineEdit {
        x: 44px;
        y: 4px;
        width: parent.width - 490px;
        height: parent.height - 8px;
        text: root.item.name;
        font-size: 12.5px;
        accepted(val) => { root.rename_commit(root.index, val); }
        key-pressed(event) => {
            if (event.text == Key.Escape) { root.rename_commit(root.index, ""); accept }
            else { reject }
        }
    }

    if root.view_mode == "list": Text {
        x: parent.width - 428px;
        width: 112px;
        height: parent.height;
        text: root.item.size_text;
        color: ThemePalette.text_faint;
        font-family: AppMetrics.mono_font;
        font-size: 11.5px;
        overflow: elide;
        vertical-alignment: center;
    }

    if root.view_mode == "list": Text {
        x: parent.width - 306px;
        width: 146px;
        height: parent.height;
        text: root.item.modified_text;
        color: ThemePalette.text_faint;
        font-family: AppMetrics.mono_font;
        font-size: 11.5px;
        overflow: elide;
        vertical-alignment: center;
    }

    if root.view_mode == "list": Text {
        x: parent.width - 150px;
        width: 90px;
        height: parent.height;
        text: root.item.type_text;
        color: ThemePalette.text_faint;
        font-size: 11.5px;
        overflow: elide;
        vertical-alignment: center;
    }

    if root.view_mode == "list": Rectangle {
        visible: root.item.has_tag;
        x: parent.width - 44px;
        y: (parent.height - 9px) / 2;
        width: 9px;
        height: 9px;
        border-radius: 5px;
        background: root.item.tag_color;
    }

    if root.view_mode != "list" && root.item.has_thumbnail: Rectangle {
        x: (parent.width - (root.view_mode == "gallery" ? 64px : 54px)) / 2;
        y: root.view_mode == "gallery" ? 18px : 12px;
        width: root.view_mode == "gallery" ? 64px : 54px;
        height: root.view_mode == "gallery" ? 70px : 54px;
        border-radius: 4px;
        clip: true;
        Image {
            width: parent.width;
            height: parent.height;
            source: root.item.thumbnail;
            image-fit: cover;
        }
    }

    if root.view_mode != "list" && !root.item.has_thumbnail: NodeVisual {
        x: (parent.width - 64px) / 2;
        y: root.view_mode == "gallery" ? 18px : 12px;
        visual_width: root.view_mode == "gallery" ? 64px : 54px;
        visual_height: root.view_mode == "gallery" ? 70px : 54px;
        is_dir: root.item.is_dir;
        extension: root.item.extension;
    }

    // Grid/gallery: name as text (not renaming)
    if root.view_mode != "list" && !root.is_renaming: Text {
        x: 18px;
        y: parent.height - 38px;
        width: parent.width - 36px;
        height: 30px;
        text: root.item.name;
        color: root.item.is_selected ? ThemePalette.text : ThemePalette.text_muted;
        font-size: 12px;
        wrap: word-wrap;
        horizontal-alignment: center;
    }

    // Grid/gallery: inline rename input
    if root.view_mode != "list" && root.is_renaming: rename_grid := LineEdit {
        x: 8px;
        y: parent.height - 40px;
        width: parent.width - 16px;
        height: 32px;
        text: root.item.name;
        font-size: 12px;
        horizontal-alignment: center;
        accepted(val) => { root.rename_commit(root.index, val); }
        key-pressed(event) => {
            if (event.text == Key.Escape) { root.rename_commit(root.index, ""); accept }
            else { reject }
        }
    }

    Rectangle {
        visible: root.item.has_tag && root.view_mode != "list";
        x: parent.width - 22px;
        y: 8px;
        width: 9px;
        height: 9px;
        border-radius: 5px;
        background: root.item.tag_color;
    }

    Rectangle {
        visible: root.item.git_badge != "";
        x: 8px;
        y: 8px;
        height: 15px;
        width: 10px + git-text.preferred-width;
        border-radius: 3px;
        background: root.item.git_color;
        git-text := Text {
            x: 5px;
            y: 0;
            height: parent.height;
            text: root.item.git_badge;
            color: white;
            font-family: AppMetrics.mono_font;
            font-size: 9px;
            font-weight: 700;
            vertical-alignment: center;
        }
    }

    Rectangle {
        visible: root.item.has_note;
        x: parent.width - 15px;
        y: parent.height - 15px;
        width: 6px;
        height: 6px;
        border-radius: 3px;
        background: ThemePalette.accent_strong;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.selected(root.index, root.ctrl_held, root.shift_held); }
        double-clicked => { root.opened(root.index); }
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                root.ctrl_held = event.modifiers.control;
                root.shift_held = event.modifiers.shift;
            }
            if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                root.context(root.index,
                    self.absolute-position.x + self.mouse-x,
                    self.absolute-position.y + self.mouse-y);
            }
        }
    }
}

component ListHeader inherits Rectangle {
    in property <string> sort_by: "name";
    in property <string> sort_dir: "asc";
    callback sort_col(string);

    height: 32px;
    background: ThemePalette.panel_solid;
    border-width: 0px;

    // NAME
    Rectangle {
        x: 44px; width: parent.width - 486px; height: parent.height;
        background: nh.has-hover ? rgba(255,255,255,0.04) : transparent;
        Text { x: 0; width: parent.width - 14px; height: parent.height; text: "NAME"; color: root.sort_by == "name" ? ThemePalette.text_muted : ThemePalette.text_faint; font-size: 11px; font-weight: 700; vertical-alignment: center; }
        Text { visible: root.sort_by == "name"; x: parent.width - 13px; width: 12px; height: parent.height; text: root.sort_dir == "asc" ? "↑" : "↓"; color: ThemePalette.accent; font-size: 10px; vertical-alignment: center; }
        nh := TouchArea { mouse-cursor: pointer; clicked => { root.sort_col("name"); } }
    }
    // SIZE
    Rectangle {
        x: parent.width - 428px; width: 112px; height: parent.height;
        background: sh.has-hover ? rgba(255,255,255,0.04) : transparent;
        Text { x: 0; width: 98px; height: parent.height; text: "SIZE"; color: root.sort_by == "size" ? ThemePalette.text_muted : ThemePalette.text_faint; font-size: 11px; font-weight: 700; vertical-alignment: center; }
        Text { visible: root.sort_by == "size"; x: 98px; width: 12px; height: parent.height; text: root.sort_dir == "asc" ? "↑" : "↓"; color: ThemePalette.accent; font-size: 10px; vertical-alignment: center; }
        sh := TouchArea { mouse-cursor: pointer; clicked => { root.sort_col("size"); } }
    }
    // MODIFIED
    Rectangle {
        x: parent.width - 306px; width: 146px; height: parent.height;
        background: mh.has-hover ? rgba(255,255,255,0.04) : transparent;
        Text { x: 0; width: 132px; height: parent.height; text: "MODIFIED"; color: root.sort_by == "modified" ? ThemePalette.text_muted : ThemePalette.text_faint; font-size: 11px; font-weight: 700; vertical-alignment: center; }
        Text { visible: root.sort_by == "modified"; x: 132px; width: 12px; height: parent.height; text: root.sort_dir == "asc" ? "↑" : "↓"; color: ThemePalette.accent; font-size: 10px; vertical-alignment: center; }
        mh := TouchArea { mouse-cursor: pointer; clicked => { root.sort_col("modified"); } }
    }
    // TYPE
    Rectangle {
        x: parent.width - 150px; width: 90px; height: parent.height;
        background: th.has-hover ? rgba(255,255,255,0.04) : transparent;
        Text { x: 0; width: 78px; height: parent.height; text: "TYPE"; color: root.sort_by == "type" ? ThemePalette.text_muted : ThemePalette.text_faint; font-size: 11px; font-weight: 700; vertical-alignment: center; }
        Text { visible: root.sort_by == "type"; x: 78px; width: 12px; height: parent.height; text: root.sort_dir == "asc" ? "↑" : "↓"; color: ThemePalette.accent; font-size: 10px; vertical-alignment: center; }
        th := TouchArea { mouse-cursor: pointer; clicked => { root.sort_col("type"); } }
    }

    Rectangle { y: parent.height - 1px; height: 1px; width: parent.width; background: ThemePalette.border; }
}

component ChoiceChip inherits Rectangle {
    in property <ChoiceItem> item;
    in property <bool> active;
    callback picked(string);

    height: 46px;
    border-radius: AppMetrics.radius_small;
    border-width: 1px;
    border-color: root.active ? ThemePalette.accent : ThemePalette.border;
    background: root.active ? ThemePalette.accent_soft : (touch.has-hover ? ThemePalette.panel_alt : ThemePalette.panel);

    Rectangle {
        x: 10px;
        y: 11px;
        width: 24px;
        height: 24px;
        border-radius: 12px;
        background: root.item.color;
        border-width: 1px;
        border-color: ThemePalette.border_strong;
    }

    Text {
        x: 44px;
        y: 6px;
        width: parent.width - 54px;
        height: 18px;
        text: root.item.label;
        color: ThemePalette.text;
        font-size: 13px;
        font-weight: 700;
        overflow: elide;
    }

    Text {
        x: 44px;
        y: 24px;
        width: parent.width - 54px;
        height: 16px;
        text: root.item.description;
        color: ThemePalette.text_faint;
        font-size: 11px;
        overflow: elide;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.picked(root.item.id); }
    }
}

component ChoiceMenuRow inherits Rectangle {
    in property <string> label;
    in property <string> command_name;
    in property <bool> danger;
    callback picked(string);

    height: 30px;
    border-radius: AppMetrics.radius_small;
    background: touch.has-hover ? (root.danger ? ThemePalette.danger : ThemePalette.accent_soft) : rgba(0, 0, 0, 0);
    Text {
        x: 9px;
        width: parent.width - 18px;
        height: parent.height;
        text: root.label;
        color: touch.has-hover ? (root.danger ? white : ThemePalette.accent_strong) : ThemePalette.text_muted;
        font-size: 12.5px;
        vertical-alignment: center;
    }
    touch := TouchArea { mouse-cursor: pointer; clicked => { root.picked(root.command_name); } }
}

component CommandRow inherits Rectangle {
    in property <CommandItem> item;
    callback picked(string);

    height: 34px;
    border-radius: AppMetrics.radius_small;
    background: touch.has-hover ? ThemePalette.accent_soft : rgba(0, 0, 0, 0);
    Text { x: 10px; width: 90px; height: parent.height; text: root.item.group; color: ThemePalette.text_faint; font-size: 11px; font-weight: 700; vertical-alignment: center; overflow: elide; }
    Text { x: 110px; width: parent.width - 220px; height: parent.height; text: root.item.label; color: touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text_muted; font-size: 13px; vertical-alignment: center; overflow: elide; }
    Text { x: parent.width - 100px; width: 90px; height: parent.height; text: root.item.hint; color: ThemePalette.text_faint; font-family: AppMetrics.mono_font; font-size: 11px; horizontal-alignment: right; vertical-alignment: center; overflow: elide; }
    touch := TouchArea { mouse-cursor: pointer; clicked => { root.picked(root.item.command); } }
}

component DialogButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary;
    in property <bool> danger;
    callback clicked();

    width: 76px;
    height: 32px;
    border-radius: AppMetrics.radius_small;
    background: root.primary ? (root.danger ? ThemePalette.danger : ThemePalette.accent) : ThemePalette.panel_alt;
    Text {
        text: root.label;
        color: root.primary ? white : ThemePalette.text_muted;
        font-size: 12.5px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    TouchArea { mouse-cursor: pointer; clicked => { root.clicked(); } }
}

export component MainWindow inherits Window {
    no-frame: true;
    resize-border-width: 6px;
    title: "Pathfinder";
    preferred-width: 1280px;
    preferred-height: 800px;
    min-width: 900px;
    min-height: 550px;
    background: ThemePalette.bg;
    default-font-family: AppMetrics.ui_font;
    forward-focus: keys;

    in-out property <[FileItem]> files;
    in-out property <[SideItem]> side_items;
    in-out property <[TabItem]> tabs;
    in-out property <[ChoiceItem]> theme_choices;
    in-out property <[ChoiceItem]> accent_choices;
    in-out property <[ChoiceItem]> density_choices;
    in-out property <[ChoiceItem]> index_choices;
    in-out property <[CommandItem]> command_items;

    in-out property <string> current_path: "";
    in-out property <string> address_text: "";
    in-out property <string> search_text: "";
    in-out property <string> active_theme: "mica-dark";
    in-out property <string> active_accent: "blue";
    in-out property <string> active_density: "cozy";
    in-out property <string> active_index_mode: "low";
    in-out property <string> index_status: "";
    in-out property <string> thumbnail_status: "";
    in-out property <string> view_mode: "grid";
    in-out property <bool> preview_visible: true;
    in-out property <bool> dual_pane: false;
    in-out property <bool> show_hidden: false;
    in-out property <bool> settings_visible: false;
    in-out property <string> settings_tab: "appearance";
    in-out property <bool> command_visible: false;
    in-out property <bool> context_visible: false;
    in-out property <bool> confirm_visible: false;
    in-out property <bool> prompt_visible: false;
    in-out property <bool> address_editing: false;
    in-out property <[string]> addr_suggestions: [];
    in-out property <int> selected_index: -1;
    in-out property <string> selected_name: "";
    in-out property <string> preview_title: "";
    in-out property <string> preview_body: "";
    in-out property <string> preview_meta: "";
    in-out property <bool> preview_is_image: false;
    in-out property <image> preview_image;
    in-out property <string> status_left: "Ready";
    in-out property <string> status_right: "";
    in-out property <string> toast_text: "";
    in-out property <string> ai_label: "CPU Fallback";
    in-out property <string> ai_device: "Detecting";
    in-out property <string> prompt_title: "";
    in-out property <string> prompt_value: "";
    in-out property <string> confirm_text: "";
    in-out property <length> context_x: 0px;
    in-out property <length> context_y: 0px;
    in-out property <string> command_filter: "";
    in-out property <int> rename_index: -1;
    in-out property <[ChoiceItem]> breadcrumbs;

    in-out property <string> empty_state: "";
    in-out property <string> sort_by: "name";
    in-out property <string> sort_dir: "asc";
    in-out property <string> toast_kind: "info";
    in-out property <bool> op_drawer_visible: false;
    in-out property <string> op_drawer_text: "";

    callback filter_commands(string);
    callback navigate(string);
    callback crumb_navigate(int);
    callback rename_file(int, string);
    callback side_activated(int);
    callback file_selected(int, bool, bool);
    callback file_opened(int);
    callback file_context(int);
    callback tab_activated(int);
    callback tab_closed(int);
    callback new_tab();
    callback go_back();
    callback go_forward();
    callback go_up();
    callback refresh();
    callback search_requested(string);
    callback search_immediate(string);
    callback address_changed(string);
    callback set_view(string);
    callback toggle_preview();
    callback toggle_dual_pane();
    callback toggle_hidden();
    callback command(string);
    callback theme_selected(string);
    callback accent_selected(string);
    callback density_selected(string);
    callback index_mode_selected(string);
    callback clear_thumbnail_cache();
    callback rebuild_index();
    callback minimize();
    callback maximize();
    callback close();
    callback drag_window();
    callback confirm_delete();
    callback prompt_accept(string);
    callback sort_column(string);

    // Custom theme editor state
    in-out property <string> ce_name: "My Theme";
    in-out property <[color]> ce_token_colors: [];
    in-out property <[string]> ce_token_hexes: [];
    in-out property <[string]> ce_saved_themes: [];
    in-out property <int> ce_selected_token: -1;
    in-out property <string> ce_token_hex: "";
    in-out property <string> ce_token_label: "";
    in-out property <float> ce_radius: 8;
    in-out property <float> ce_anim_speed: 1.0;
    in-out property <string> ce_finish: "mica-dark";
    in-out property <string> ce_ui_font: "Segoe UI";
    in-out property <string> ce_mono_font: "Cascadia Mono";
    in-out property <int> ce_font_size_delta: 0;
    in-out property <string> ce_icon_folder_hex: "#e2a934";
    in-out property <string> ce_icon_set: "";

    callback ce_select_token(int);
    callback ce_color_changed(int, string);
    callback ce_radius_changed(float);
    callback ce_anim_changed(float);
    callback ce_finish_changed(string);
    callback ce_font_changed(string, string);
    callback ce_font_size_changed(int);
    callback ce_icon_tint_changed(string);
    callback ce_save(string);
    callback ce_load(string);
    callback ce_delete(string);
    callback ce_reset_to_active();

    property <length> sidebar_w: 238px;
    property <length> title_h: 36px;
    property <length> toolbar_h: 44px;
    property <length> status_h: 26px;
    property <length> preview_w: root.preview_visible ? 326px : 0px;
    property <length> file_area_w: root.width - root.sidebar_w - root.preview_w - AppMetrics.pad * 2;
    property <int> grid_columns: Math.max(1, Math.floor(root.file_area_w / AppMetrics.grid_w));
    property <length> grid_cell_w: root.file_area_w / root.grid_columns;
    property <length> grid_item_h: root.view_mode == "gallery" ? 154px : AppMetrics.grid_h;
    property <int> grid_rows: (root.files.length + root.grid_columns - 1) / root.grid_columns;
    // gap on each side of each grid cell for uniform spacing
    property <length> grid_gap: 8px;

    in-out property <float> nav_opacity: 1.0;
    animate nav_opacity { duration: 160ms; easing: ease-in-out; }

    app := Rectangle {
        width: parent.width;
        height: parent.height;
        background: ThemePalette.panel;
        border-width: AppMetrics.outer_border;
        border-color: ThemePalette.border_strong;

        // Titlebar
        Rectangle {
            x: 0;
            y: 0;
            width: parent.width;
            height: root.title_h;
            background: ThemePalette.titlebar;
            border-width: 0px;

            TouchArea {
                x: 0;
                y: 0;
                width: parent.width - 170px;
                height: parent.height;
                mouse-cursor: move;
                clicked => { }
                moved => { if (self.pressed) { root.drag_window(); } }
            }

            Rectangle {
                x: 14px;
                y: 12px;
                width: 18px;
                height: 15px;
                border-radius: 3px;
                background: @linear-gradient(180deg, ThemePalette.accent_strong 0%, ThemePalette.accent 100%);
            }

            Rectangle {
                x: 16px;
                y: 9px;
                width: 8px;
                height: 5px;
                border-radius: 3px;
                background: ThemePalette.accent_strong;
            }

            Text {
                x: 40px;
                y: 0;
                width: 160px;
                height: parent.height;
                text: "Pathfinder";
                color: ThemePalette.text_muted;
                font-size: 12px;
                font-weight: 600;
                vertical-alignment: center;
            }

            HorizontalLayout {
                x: root.sidebar_w;
                y: 6px;
                width: parent.width - root.sidebar_w - 170px;
                height: 30px;
                spacing: 2px;
                for tab[index] in root.tabs: TabButton {
                    tab: tab;
                    index: index;
                    activated(i) => { root.tab_activated(i); }
                    closed(i) => { root.tab_closed(i); }
                }
            }

            ToolButton {
                x: parent.width - 164px;
                y: 6px;
                button_width: 24px;
                button_height: 24px;
                icon_data: "M12 5v14 M5 12h14";
                tooltip: "New tab";
                clicked => { root.new_tab(); }
            }

            ToolButton {
                x: parent.width - 138px;
                y: 0;
                button_width: 46px;
                button_height: 36px;
                icon_data: "M5 12h14";
                tooltip: "Minimize";
                clicked => { root.minimize(); }
            }

            ToolButton {
                x: parent.width - 92px;
                y: 0;
                button_width: 46px;
                button_height: 36px;
                icon_data: "M7 7h10v10H7z";
                tooltip: "Maximize";
                clicked => { root.maximize(); }
            }

            ToolButton {
                x: parent.width - 46px;
                y: 0;
                button_width: 46px;
                button_height: 36px;
                icon_data: "M18 6L6 18 M6 6l12 12";
                tooltip: "Close";
                danger: true;
                clicked => { root.close(); }
            }

            Rectangle { y: parent.height - 1px; width: parent.width; height: 1px; background: ThemePalette.border; }
        }

        // Sidebar
        Rectangle {
            x: 0;
            y: root.title_h;
            width: root.sidebar_w;
            height: parent.height - root.title_h - root.status_h;
            background: ThemePalette.sidebar;
            border-width: 0px;

            ListView {
                x: 10px;
                y: 14px;
                width: parent.width - 20px;
                height: parent.height - 28px;
                for item[index] in root.side_items: SideRow {
                    item: item;
                    index: index;
                    activated(i) => { root.side_activated(i); }
                }
            }

            Rectangle { x: parent.width - 1px; width: 1px; height: parent.height; background: ThemePalette.border; }
        }

        // Toolbar
        Rectangle {
            x: root.sidebar_w;
            y: root.title_h;
            width: parent.width - root.sidebar_w;
            height: root.toolbar_h;
            background: ThemePalette.panel;

            ToolButton { x: 10px; y: 6px; icon_data: "M15 18l-6-6 6-6"; tooltip: "Back"; clicked => { root.go_back(); } }
            ToolButton { x: 45px; y: 6px; icon_data: "M9 18l6-6-6-6"; tooltip: "Forward"; clicked => { root.go_forward(); } }
            ToolButton { x: 80px; y: 6px; icon_data: "M12 19V5 M5 12l7-7 7 7"; tooltip: "Up"; clicked => { root.go_up(); } }
            ToolButton { x: 115px; y: 6px; icon_data: "M3 12a9 9 0 0 1 15-6.7L21 8 M21 3v5h-5 M21 12a9 9 0 0 1-15 6.7L3 16 M3 21v-5h5"; tooltip: "Refresh"; clicked => { root.refresh(); } }

            Rectangle { x: 156px; y: 12px; width: 1px; height: 20px; background: ThemePalette.border; }

            Rectangle {
                x: 167px;
                y: 6px;
                width: parent.width - 718px;
                height: 31px;
                border-width: 1px;
                border-color: ThemePalette.border;
                border-radius: AppMetrics.radius_small;
                background: AppMetrics.light_controls ? rgba(255, 255, 255, 0.50) : rgba(0, 0, 0, 0.12);

                // Breadcrumb row (replaces plain path text)
                HorizontalLayout {
                    visible: !root.address_editing;
                    x: 6px;
                    y: 0;
                    width: parent.width - 12px;
                    height: parent.height;
                    spacing: 0px;
                    alignment: start;
                    for crumb[ci] in root.breadcrumbs: HorizontalLayout {
                        spacing: 0px;
                        alignment: start;
                        Text {
                            visible: ci > 0;
                            text: " › ";
                            color: ThemePalette.text_faint;
                            font-size: 12px;
                            font-family: AppMetrics.mono_font;
                            vertical-alignment: center;
                        }
                        crumb_touch := Rectangle {
                            height: parent.height;
                            width: Math.min(crumb_label.preferred-width + 10px, 160px);
                            border-radius: 4px;
                            background: ct.has-hover ? ThemePalette.accent_soft : rgba(0, 0, 0, 0);
                            crumb_label := Text {
                                x: 5px;
                                width: parent.width - 10px;
                                height: parent.height;
                                text: crumb.label;
                                color: ct.has-hover ? ThemePalette.accent_strong : ThemePalette.text_muted;
                                font-size: 12px;
                                overflow: elide;
                                vertical-alignment: center;
                            }
                            ct := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.crumb_navigate(ci); }
                            }
                        }
                    }
                }

                addr := LineEdit {
                    visible: root.address_editing;
                    x: 0;
                    y: 0;
                    width: parent.width;
                    height: parent.height;
                    text: root.address_text;
                    font-size: 12px;
                    font-family: AppMetrics.mono_font;
                    edited(value) => {
                        root.address_text = value;
                        root.address_changed(value);
                    }
                    accepted(path) => {
                        root.addr_suggestions = [];
                        root.address_editing = false;
                        root.navigate(path);
                    }
                    key-pressed(event) => {
                        if (event.text == Key.Escape) {
                            root.addr_suggestions = [];
                            root.address_editing = false;
                            accept
                        } else {
                            reject
                        }
                    }
                }

                // Autocomplete dropdown
                if root.address_editing && root.addr_suggestions.length > 0: Rectangle {
                    x: 0;
                    y: parent.height;
                    width: parent.width;
                    height: min(root.addr_suggestions.length * 28px + 4px, 168px);
                    background: ThemePalette.panel_solid;
                    border-width: 1px;
                    border-color: ThemePalette.border_strong;
                    border-radius: AppMetrics.radius;
                    drop-shadow-blur: 12px;
                    drop-shadow-color: rgba(0, 0, 0, 0.3);
                    clip: true;
                    VerticalLayout {
                        padding: 2px;
                        spacing: 0;
                        for sug[i] in root.addr_suggestions: Rectangle {
                            height: 28px;
                            width: parent.width - 4px;
                            x: 2px;
                            border-radius: AppMetrics.radius - 1px;
                            background: sug_ta.has-hover ? rgba(255, 255, 255, 0.07) : transparent;
                            Text {
                                x: 8px;
                                width: parent.width - 16px;
                                height: parent.height;
                                text: sug;
                                color: ThemePalette.text;
                                font-size: 12px;
                                font-family: AppMetrics.mono_font;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                            sug_ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.addr_suggestions = [];
                                    root.address_editing = false;
                                    root.navigate(sug);
                                }
                            }
                        }
                    }
                }

                TouchArea {
                    enabled: !root.address_editing;
                    mouse-cursor: text;
                    clicked => {
                        root.address_text = root.current_path;
                        root.address_editing = true;
                        addr.focus();
                        addr.select-all();
                    }
                }
            }

            Rectangle {
                x: parent.width - 541px;
                y: 6px;
                width: 280px;
                height: 31px;
                border-width: 1px;
                border-color: search.has-focus ? ThemePalette.accent : ThemePalette.border;
                border-radius: AppMetrics.radius_small;
                background: AppMetrics.light_controls ? rgba(255, 255, 255, 0.50) : rgba(0, 0, 0, 0.12);

                SvgIcon { x: 8px; y: 8px; icon_size: 15px; data: "M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16z M21 21l-4.3-4.3"; tint: ThemePalette.text_faint; }
                search := LineEdit {
                    x: 30px;
                    y: 0;
                    width: parent.width - 82px;
                    height: parent.height;
                    text: root.search_text;
                    placeholder-text: "Search ext:pdf size:>1mb";
                    font-size: 12.5px;
                    edited(value) => {
                        root.search_text = value;
                        root.search_requested(value);
                    }
                    accepted(value) => { root.search_immediate(value); }
                }
                Text { x: parent.width - 48px; width: 40px; height: parent.height; text: "Ctrl+F"; color: ThemePalette.text_faint; font-family: AppMetrics.mono_font; font-size: 10px; vertical-alignment: center; horizontal-alignment: right; }
            }

            Rectangle { x: parent.width - 249px; y: 12px; width: 1px; height: 20px; background: ThemePalette.border; }
            ToolButton { x: parent.width - 238px; y: 6px; icon_data: "M3 3h7v7H3z M14 3h7v7h-7z M3 14h7v7H3z M14 14h7v7h-7z"; tooltip: "Icon view"; active: root.view_mode == "grid"; clicked => { root.set_view("grid"); } }
            ToolButton { x: parent.width - 204px; y: 6px; icon_data: "M8 6h13 M8 12h13 M8 18h13 M3 6h.01 M3 12h.01 M3 18h.01"; tooltip: "Details view"; active: root.view_mode == "list"; clicked => { root.set_view("list"); } }
            ToolButton { x: parent.width - 170px; y: 6px; icon_data: "M4 5h16v14H4z M4 15l4-4 4 4 3-3 5 5 M9 9h.01"; tooltip: "Gallery view"; active: root.view_mode == "gallery"; clicked => { root.set_view("gallery"); } }
            ToolButton { x: parent.width - 136px; y: 6px; icon_data: "M3 4h18v16H3z M14 4v16"; tooltip: "Preview pane"; active: root.preview_visible; clicked => { root.toggle_preview(); } }
            ToolButton { x: parent.width - 102px; y: 6px; icon_data: "M4 5h7v14H4z M13 5h7v14h-7z"; tooltip: "Dual pane"; active: root.dual_pane; clicked => { root.toggle_dual_pane(); } }
            ToolButton { x: parent.width - 68px; y: 6px; icon_data: "M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"; tooltip: "Command palette"; clicked => { root.command_visible = true; } }
            ToolButton { x: parent.width - 34px; y: 6px; icon_data: "M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20z M12 8v4 M12 16h.01"; tooltip: "Settings"; clicked => { root.settings_visible = true; } }

            Rectangle { y: parent.height - 1px; width: parent.width; height: 1px; background: ThemePalette.border; }
        }

        // Main area
        Rectangle {
            x: root.sidebar_w;
            y: root.title_h + root.toolbar_h;
            width: parent.width - root.sidebar_w;
            height: parent.height - root.title_h - root.toolbar_h - root.status_h;
            background: ThemePalette.bg;

            Rectangle {
                x: 0;
                y: 0;
                width: parent.width - root.preview_w;
                height: parent.height;
                background: rgba(0, 0, 0, 0);
                opacity: root.nav_opacity;

                empty_context := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    pointer-event(event) => {
                        if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                            root.context_x = (self.absolute-position.x + self.mouse-x).clamp(0px, root.width - 240px);
                            root.context_y = (self.absolute-position.y + self.mouse-y).clamp(0px, root.height - 440px);
                            root.context_visible = true;
                            root.file_context(-1);
                        }
                    }
                }

                if root.view_mode == "list": ListHeader {
                    x: AppMetrics.pad;
                    y: AppMetrics.pad;
                    width: parent.width - AppMetrics.pad * 2;
                    sort_by: root.sort_by;
                    sort_dir: root.sort_dir;
                    sort_col(col) => { root.sort_column(col); }
                }

                if root.view_mode == "list": ListView {
                    x: AppMetrics.pad;
                    y: AppMetrics.pad + 32px;
                    width: parent.width - AppMetrics.pad * 2;
                    height: parent.height - AppMetrics.pad * 2 - 32px;
                    for file[index] in root.files: FileRow {
                        width: parent.width;
                        item: file;
                        index: index;
                        view_mode: root.view_mode;
                        rename_index: root.rename_index;
                        selected(i, ctrl, shift) => { root.file_selected(i, ctrl, shift); }
                        opened(i) => { root.file_opened(i); }
                        context(i, cx, cy) => {
                            root.context_x = cx.clamp(0px, root.width - 240px);
                            root.context_y = cy.clamp(0px, root.height - 440px);
                            root.context_visible = true;
                            root.file_context(i);
                        }
                        rename_commit(i, val) => {
                            root.rename_index = -1;
                            if (val != "") { root.rename_file(i, val); }
                        }
                    }
                }

                if root.view_mode != "list": ScrollView {
                    x: AppMetrics.pad;
                    y: AppMetrics.pad;
                    width: parent.width - AppMetrics.pad * 2;
                    height: parent.height - AppMetrics.pad * 2;
                    viewport-width: parent.width - AppMetrics.pad * 2;
                    viewport-height: Math.max(parent.height - AppMetrics.pad * 2, root.grid_rows * (root.grid_item_h + root.grid_gap));

                    for file[index] in root.files: FileRow {
                        x: Math.mod(index, root.grid_columns) * root.grid_cell_w + root.grid_gap / 2;
                        y: (index / root.grid_columns) * (root.grid_item_h + root.grid_gap);
                        width: root.grid_cell_w - root.grid_gap;
                        item: file;
                        index: index;
                        view_mode: root.view_mode;
                        rename_index: root.rename_index;
                        selected(i, ctrl, shift) => { root.file_selected(i, ctrl, shift); }
                        opened(i) => { root.file_opened(i); }
                        context(i, cx, cy) => {
                            root.context_x = cx.clamp(0px, root.width - 240px);
                            root.context_y = cy.clamp(0px, root.height - 440px);
                            root.context_visible = true;
                            root.file_context(i);
                        }
                        rename_commit(i, val) => {
                            root.rename_index = -1;
                            if (val != "") { root.rename_file(i, val); }
                        }
                    }
                }

                Rectangle {
                    visible: root.files.length == 0;
                    width: parent.width;
                    height: parent.height;
                    VerticalLayout {
                        alignment: center;
                        spacing: 8px;
                        SvgIcon {
                            x: (parent.width - 32px) / 2;
                            icon_size: 32px;
                            data: root.search_text != "" ?
                                "M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16z M21 21l-4.3-4.3" :
                                "M3 7.5A2.5 2.5 0 0 1 5.5 5H10l2 2h6.5A2.5 2.5 0 0 1 21 9.5v7A2.5 2.5 0 0 1 18.5 19h-13A2.5 2.5 0 0 1 3 16.5z";
                            tint: ThemePalette.text_faint;
                        }
                        Text {
                            width: parent.width;
                            text: root.empty_state != "" ? root.empty_state :
                                  root.search_text != "" ? "No results for \"" + root.search_text + "\"" :
                                  "This folder is empty";
                            color: ThemePalette.text_faint;
                            font-size: 13px;
                            horizontal-alignment: center;
                        }
                        Text {
                            visible: root.search_text != "";
                            width: parent.width;
                            text: "Try a different query or search in a parent folder";
                            color: ThemePalette.text_faint;
                            font-size: 11px;
                            horizontal-alignment: center;
                        }
                    }
                }
            }

            if root.preview_visible: Rectangle {
                x: parent.width - root.preview_w;
                y: 0;
                width: root.preview_w;
                height: parent.height;
                background: ThemePalette.panel_solid;
                border-width: 0px;

                Rectangle { width: 1px; height: parent.height; background: ThemePalette.border; }

                Rectangle {
                    x: 1px;
                    y: 0;
                    width: parent.width - 1px;
                    height: 46px;
                    background: ThemePalette.panel_solid;
                    NodeVisual {
                        x: 14px;
                        y: 11px;
                        visual_width: 24px;
                        visual_height: 24px;
                        is_dir: false;
                        extension: "";
                    }
                    Text {
                        x: 48px;
                        width: parent.width - 92px;
                        height: parent.height;
                        text: root.preview_title == "" ? "Preview" : root.preview_title;
                        color: ThemePalette.text;
                        font-size: 13px;
                        font-weight: 700;
                        overflow: elide;
                        vertical-alignment: center;
                    }
                    ToolButton {
                        x: parent.width - 37px;
                        y: 7px;
                        icon_data: "M18 6L6 18 M6 6l12 12";
                        tooltip: "Close preview";
                        clicked => { root.toggle_preview(); }
                    }
                    Rectangle { y: parent.height - 1px; height: 1px; width: parent.width; background: ThemePalette.border; }
                }

                ScrollView {
                    x: 0px;
                    y: 48px;
                    width: parent.width;
                    height: parent.height - 48px;

                    VerticalLayout {
                        width: parent.width;
                        padding: 0;
                        spacing: 0;

                        // Image preview area
                        if root.preview_is_image: Rectangle {
                            width: parent.width;
                            height: 150px;
                            background: ThemePalette.bg;
                            border-width: 0;
                            Image {
                                x: (parent.width - 150px) / 2;
                                y: 10px;
                                width: 150px;
                                height: 130px;
                                source: root.preview_image;
                                image-fit: contain;
                            }
                        }

                        // Meta info block (path, type, size, modified)
                        if root.preview_meta != "": Rectangle {
                            width: parent.width;
                            height: 8px;
                        }
                        if root.preview_meta != "": Text {
                            x: 16px;
                            width: parent.width - 32px;
                            text: root.preview_meta;
                            color: ThemePalette.text_faint;
                            font-size: 10.5px;
                            font-family: AppMetrics.mono_font;
                            wrap: word-wrap;
                        }

                        // Divider + body content
                        if root.preview_body != "" && root.preview_meta != "": Rectangle {
                            width: parent.width - 32px;
                            x: 16px;
                            height: 1px;
                            background: ThemePalette.border;
                        }
                        if root.preview_body != "" && root.preview_meta != "": Rectangle {
                            width: parent.width; height: 8px;
                        }

                        if root.preview_body != "": Text {
                            x: 16px;
                            width: parent.width - 32px;
                            text: root.preview_body;
                            color: ThemePalette.text_muted;
                            font-size: 11.5px;
                            font-family: AppMetrics.mono_font;
                            wrap: word-wrap;
                        }

                        // Empty state
                        if root.preview_body == "" && root.preview_meta == "": Text {
                            x: 16px;
                            width: parent.width - 32px;
                            height: 200px;
                            text: "Select a file to preview details.";
                            color: ThemePalette.text_faint;
                            font-size: 12.5px;
                            font-family: AppMetrics.ui_font;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                    }
                }
            }
        }

        // Status
        Rectangle {
            x: 0;
            y: parent.height - root.status_h;
            width: parent.width;
            height: root.status_h;
            background: ThemePalette.titlebar;
            Rectangle { width: parent.width; height: 1px; background: ThemePalette.border; }
            Text { x: 12px; width: parent.width / 2; height: parent.height; text: root.status_left; color: ThemePalette.text_faint; font-size: 11px; vertical-alignment: center; overflow: elide; }
            Text { x: parent.width / 2; width: parent.width / 2 - 12px; height: parent.height; text: root.status_right; color: ThemePalette.text_faint; font-size: 11px; horizontal-alignment: right; vertical-alignment: center; overflow: elide; }
        }
    }

    // Context menu
    if root.context_visible: Rectangle {
        x: root.context_x;
        y: root.context_y;
        width: 226px;
        height: 610px;
        border-width: 1px;
        border-color: ThemePalette.border_strong;
        border-radius: AppMetrics.radius;
        background: ThemePalette.panel_solid;
        drop-shadow-blur: 24px;
        drop-shadow-color: rgba(0, 0, 0, 0.38);

        VerticalLayout {
            padding: 5px;
            spacing: 2px;
            ChoiceMenuRow { width: parent.width; label: "Open"; command_name: "open"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Rename"; command_name: "rename"; picked(_c) => { root.context_visible = false; root.rename_index = root.selected_index; } }
            ChoiceMenuRow { width: parent.width; label: "Copy"; command_name: "copy"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Cut"; command_name: "cut"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Paste"; command_name: "paste"; picked(c) => { root.context_visible = false; root.command(c); } }
            Rectangle { height: 1px; background: ThemePalette.border; }
            ChoiceMenuRow { width: parent.width; label: "Batch Rename"; command_name: "batch-rename"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Checksum"; command_name: "checksum"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Add Note"; command_name: "note"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Locked File Inspector"; command_name: "locked-file"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Properties"; command_name: "properties"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Show More Options"; command_name: "show-more-options"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Open With"; command_name: "open-with"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Defender Scan"; command_name: "defender-scan"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Cloud State"; command_name: "cloud-state"; picked(c) => { root.context_visible = false; root.command(c); } }
            Rectangle { height: 1px; background: ThemePalette.border; }
            ChoiceMenuRow { width: parent.width; label: "Run as Administrator"; command_name: "run-as-admin"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Take Ownership"; command_name: "take-ownership"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Previous Versions"; command_name: "previous-versions"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Pin to Taskbar"; command_name: "pin-to-taskbar"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Pin to Start"; command_name: "pin-to-start"; picked(c) => { root.context_visible = false; root.command(c); } }
            Rectangle { height: 1px; background: ThemePalette.border; }
            ChoiceMenuRow { width: parent.width; label: "Copy as Path"; command_name: "copy-as-path"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Copy as PowerShell Path"; command_name: "copy-as-powershell"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Open in Terminal"; command_name: "open-terminal"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Archive Browser"; command_name: "archive-browser"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Extract Here"; command_name: "extract-here"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Create ZIP"; command_name: "create-zip"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Image Tools"; command_name: "image-tools"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Delete"; command_name: "delete"; danger: true; picked(c) => { root.context_visible = false; root.command(c); } }
        }
    }

    if root.command_visible: Rectangle {
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0.42);

        Rectangle {
            x: (parent.width - 620px) / 2;
            y: 82px;
            width: 620px;
            height: 512px;
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            drop-shadow-blur: 32px;
            drop-shadow-color: rgba(0, 0, 0, 0.38);

            Rectangle {
                x: 16px;
                y: 14px;
                width: parent.width - 32px;
                height: 38px;
                border-width: 1px;
                border-color: cmd_search.has-focus ? ThemePalette.accent : ThemePalette.border;
                border-radius: AppMetrics.radius_small;
                background: ThemePalette.bg_soft;
                SvgIcon { x: 10px; y: 11px; icon_size: 16px; data: "M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16z M21 21l-4.3-4.3"; tint: ThemePalette.text_faint; }
                cmd_search := LineEdit {
                    x: 34px;
                    y: 0;
                    width: parent.width - 34px;
                    height: parent.height;
                    placeholder-text: "Type a command...";
                    font-size: 14px;
                    edited(value) => { root.command_filter = value; root.filter_commands(value); }
                    accepted(value) => { }
                    key-pressed(event) => {
                        if (event.text == Key.Escape) {
                            root.command_visible = false;
                            accept
                        } else { reject }
                    }
                }
            }

            ListView {
                x: 6px;
                y: 64px;
                width: parent.width - 12px;
                height: parent.height - 70px;
                for cmd[index] in root.command_items: CommandRow {
                    width: parent.width;
                    item: cmd;
                    picked(name) => {
                        root.command_visible = false;
                        root.command(name);
                    }
                }
            }
        }
    }

    if root.settings_visible: Rectangle {
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0.42);
        TouchArea { clicked => { root.settings_visible = false; } }

        Rectangle {
            x: (parent.width - 780px) / 2;
            y: (parent.height - 680px) / 2;
            width: 780px;
            height: 680px;
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            drop-shadow-blur: 36px;
            drop-shadow-color: rgba(0, 0, 0, 0.45);
            TouchArea {}

            Text { x: 20px; y: 18px; width: parent.width - 80px; height: 28px; text: "Settings"; color: ThemePalette.text; font-size: 18px; font-weight: 700; }
            ToolButton { x: parent.width - 46px; y: 14px; icon_data: "M18 6L6 18 M6 6l12 12"; tooltip: "Close settings"; clicked => { root.settings_visible = false; } }

            Rectangle {
                y: 56px;
                width: parent.width;
                height: 44px;
                background: transparent;
                Rectangle { y: parent.height - 1px; width: parent.width; height: 1px; background: ThemePalette.border; }

                for tab_label[ti] in ["Appearance", "View", "Performance", "Themes", "AI"]: Rectangle {
                    property <string> tid: ti == 0 ? "appearance" : (ti == 1 ? "view" : (ti == 2 ? "performance" : (ti == 3 ? "themes" : "ai")));
                    property <bool> is_active: root.settings_tab == self.tid;
                    x: 20px + ti * 102px;
                    y: 0;
                    width: 98px;
                    height: parent.height;
                    background: transparent;
                    Text {
                        width: parent.width;
                        height: parent.height - 2px;
                        text: tab_label;
                        color: parent.is_active ? ThemePalette.text : ThemePalette.text_muted;
                        font-size: 13px;
                        font-weight: parent.is_active ? 600 : 400;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    Rectangle {
                        y: parent.height - 2px;
                        width: parent.width;
                        height: 2px;
                        background: parent.is_active ? ThemePalette.accent : transparent;
                        animate background { duration: 120ms; easing: ease; }
                    }
                    TouchArea { clicked => { root.settings_tab = tid; } }
                }
            }

            if root.settings_tab == "appearance": ScrollView {
                x: 20px;
                y: 112px;
                width: parent.width - 40px;
                height: parent.height - 124px;
                viewport-width: parent.width - 40px;

                VerticalLayout {
                    width: parent.width;
                    spacing: 18px;
                    padding-bottom: 16px;

                    Text { text: "THEME"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        width: parent.width;
                        height: Math.ceil(root.theme_choices.length / 2) * (AppMetrics.row_h + 6px);
                        for theme[i] in root.theme_choices: ChoiceChip {
                            x: Math.mod(i, 2) == 0 ? 0px : (parent.width / 2 + 3px);
                            y: Math.floor(i / 2) * (AppMetrics.row_h + 6px);
                            width: parent.width / 2 - 3px;
                            item: theme;
                            active: root.active_theme == theme.id;
                            picked(id) => { root.theme_selected(id); }
                        }
                    }

                    Text { text: "ACCENT COLOR"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        width: parent.width;
                        height: Math.ceil(root.accent_choices.length / 3) * (AppMetrics.row_h + 6px);
                        for accent[i] in root.accent_choices: ChoiceChip {
                            x: Math.mod(i, 3) * (parent.width / 3 + 2px);
                            y: Math.floor(i / 3) * (AppMetrics.row_h + 6px);
                            width: parent.width / 3 - 4px;
                            item: accent;
                            active: root.active_accent == accent.id;
                            picked(id) => { root.accent_selected(id); }
                        }
                    }

                    Text { text: "DENSITY"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        width: parent.width;
                        height: Math.ceil(root.density_choices.length / 3) * (AppMetrics.row_h + 6px);
                        for density[i] in root.density_choices: ChoiceChip {
                            x: Math.mod(i, 3) * (parent.width / 3 + 2px);
                            y: Math.floor(i / 3) * (AppMetrics.row_h + 6px);
                            width: parent.width / 3 - 4px;
                            item: density;
                            active: root.active_density == density.id;
                            picked(id) => { root.density_selected(id); }
                        }
                    }
                }
            }

            if root.settings_tab == "view": VerticalLayout {
                x: 20px;
                y: 112px;
                width: parent.width - 40px;
                height: parent.height - 124px;
                spacing: 12px;
                padding-bottom: 16px;

                Text { text: "DEFAULT VIEW MODE"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                HorizontalLayout {
                    spacing: 6px;
                    height: AppMetrics.row_h;
                    for vm_label[vi] in ["Grid", "List", "Gallery"]: Rectangle {
                        property <string> vm_id: vi == 0 ? "grid" : (vi == 1 ? "list" : "gallery");
                        border-width: 1px;
                        border-color: root.view_mode == self.vm_id ? ThemePalette.accent : ThemePalette.border;
                        border-radius: AppMetrics.radius;
                        background: root.view_mode == self.vm_id ? ThemePalette.accent_soft : ThemePalette.panel;
                        Text {
                            width: parent.width;
                            height: parent.height;
                            text: vm_label;
                            color: root.view_mode == parent.vm_id ? ThemePalette.accent_strong : ThemePalette.text_muted;
                            font-size: 13px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        TouchArea { clicked => { root.set_view(vm_id); } }
                    }
                }

                Text { text: "OPTIONS"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                Rectangle {
                    height: AppMetrics.row_h;
                    border-radius: AppMetrics.radius;
                    background: ThemePalette.panel;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    Text { x: 14px; width: parent.width - 60px; height: parent.height; text: "Show hidden files"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                    Rectangle {
                        x: parent.width - 52px;
                        y: (parent.height - 22px) / 2;
                        width: 40px;
                        height: 22px;
                        border-radius: 11px;
                        background: root.show_hidden ? ThemePalette.accent : ThemePalette.border_strong;
                        animate background { duration: 130ms; easing: ease; }
                        Rectangle {
                            x: root.show_hidden ? 20px : 2px;
                            y: 2px;
                            width: 18px;
                            height: 18px;
                            border-radius: 9px;
                            background: white;
                            animate x { duration: 130ms; easing: ease; }
                        }
                        TouchArea { clicked => { root.toggle_hidden(); } }
                    }
                }
                Rectangle {
                    height: AppMetrics.row_h;
                    border-radius: AppMetrics.radius;
                    background: ThemePalette.panel;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    Text { x: 14px; width: parent.width - 60px; height: parent.height; text: "Show preview panel"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                    Rectangle {
                        x: parent.width - 52px;
                        y: (parent.height - 22px) / 2;
                        width: 40px;
                        height: 22px;
                        border-radius: 11px;
                        background: root.preview_visible ? ThemePalette.accent : ThemePalette.border_strong;
                        animate background { duration: 130ms; easing: ease; }
                        Rectangle {
                            x: root.preview_visible ? 20px : 2px;
                            y: 2px;
                            width: 18px;
                            height: 18px;
                            border-radius: 9px;
                            background: white;
                            animate x { duration: 130ms; easing: ease; }
                        }
                        TouchArea { clicked => { root.toggle_preview(); } }
                    }
                }
            }

            if root.settings_tab == "themes": ScrollView {
                x: 20px;
                y: 112px;
                width: parent.width - 40px;
                height: parent.height - 124px;
                viewport-width: parent.width - 40px;

                VerticalLayout {
                    width: parent.width;
                    spacing: 16px;
                    padding-bottom: 20px;

                    // Saved themes
                    Text { text: "SAVED THEMES"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        clip: true;
                        if root.ce_saved_themes.length == 0: Text {
                            x: 14px;
                            width: parent.width - 28px;
                            height: parent.height;
                            text: "No saved themes yet";
                            color: ThemePalette.text_faint;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                        for saved_name[ni] in root.ce_saved_themes: Rectangle {
                            x: 8px + ni * (saved_chip_text.preferred-width + 28px);
                            y: 7px;
                            height: 24px;
                            width: saved_chip_text.preferred-width + 20px;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: ThemePalette.border_strong;
                            background: saved_chip_ta.has-hover ? ThemePalette.panel_alt : ThemePalette.panel_solid;
                            saved_chip_text := Text {
                                x: 8px;
                                width: parent.width - 16px;
                                height: parent.height;
                                text: saved_name;
                                color: ThemePalette.text_muted;
                                font-size: 11.5px;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                            saved_chip_ta := TouchArea {
                                clicked => { root.ce_load(saved_name); }
                            }
                        }
                    }

                    // Name
                    Text { text: "THEME NAME"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    LineEdit {
                        height: 34px;
                        text: root.ce_name;
                        placeholder-text: "My Theme";
                        font-size: 13px;
                        edited(val) => { root.ce_name = val; }
                    }

                    // Colors
                    Text { text: "COLORS"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Text {
                        text: "Click a swatch to select it, then edit the hex value below.";
                        color: ThemePalette.text_faint;
                        font-size: 11px;
                    }
                    Rectangle {
                        height: 44px;
                        for col[ci] in root.ce_token_colors: Rectangle {
                            x: ci * 62px;
                            y: 8px;
                            width: 28px;
                            height: 28px;
                            border-radius: 14px;
                            background: col;
                            border-width: root.ce_selected_token == ci ? 2px : 1px;
                            border-color: root.ce_selected_token == ci ? ThemePalette.accent : ThemePalette.border_strong;
                            TouchArea {
                                clicked => { root.ce_select_token(ci); }
                            }
                        }
                    }
                    if root.ce_selected_token >= 0: Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text {
                            x: 14px;
                            width: 140px;
                            height: parent.height;
                            text: root.ce_token_label;
                            color: ThemePalette.text;
                            font-size: 13px;
                            vertical-alignment: center;
                        }
                        LineEdit {
                            x: 154px;
                            y: 6px;
                            width: 130px;
                            height: 26px;
                            text: root.ce_token_hex;
                            font-family: AppMetrics.mono_font;
                            font-size: 12px;
                            placeholder-text: "#rrggbb";
                            edited(val) => { root.ce_color_changed(root.ce_selected_token, val); }
                        }
                        Rectangle {
                            x: parent.width - 46px;
                            y: 7px;
                            width: 24px;
                            height: 24px;
                            border-radius: 12px;
                            background: root.ce_token_colors.length > root.ce_selected_token && root.ce_selected_token >= 0
                                ? root.ce_token_colors[root.ce_selected_token]
                                : ThemePalette.border_strong;
                            border-width: 1px;
                            border-color: ThemePalette.border_strong;
                        }
                    }

                    // Feel
                    Text { text: "FEEL"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; width: 140px; height: parent.height; text: "Corner radius"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                        Slider {
                            x: 158px;
                            y: 9px;
                            width: parent.width - 230px;
                            height: 20px;
                            minimum: 0;
                            maximum: 16;
                            value: root.ce_radius;
                            changed(v) => { root.ce_radius_changed(v); }
                        }
                        Text {
                            x: parent.width - 60px;
                            width: 50px;
                            height: parent.height;
                            text: Math.round(root.ce_radius) + "px";
                            color: ThemePalette.text_muted;
                            font-family: AppMetrics.mono_font;
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                    }
                    Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; width: 130px; height: parent.height; text: "Animations"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                        HorizontalLayout {
                            x: 148px;
                            y: 6px;
                            width: parent.width - 162px;
                            height: parent.height - 12px;
                            spacing: 4px;
                            for speed_label[si] in ["Off", "Fast", "Normal", "Slow"]: Rectangle {
                                property <float> sv: si == 0 ? 0.0 : (si == 1 ? 0.5 : (si == 2 ? 1.0 : 2.0));
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: root.ce_anim_speed == self.sv ? ThemePalette.accent : ThemePalette.border;
                                background: root.ce_anim_speed == self.sv ? ThemePalette.accent_soft : ThemePalette.panel_solid;
                                Text {
                                    width: parent.width;
                                    height: parent.height;
                                    text: speed_label;
                                    color: root.ce_anim_speed == parent.sv ? ThemePalette.accent_strong : ThemePalette.text_muted;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                TouchArea { clicked => { root.ce_anim_changed(sv); } }
                            }
                        }
                    }

                    // Finish
                    Text { text: "FINISH"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    HorizontalLayout {
                        height: 38px;
                        spacing: 6px;
                        for finish_label[fi] in ["Mica Dark", "Mica Light", "Flat", "Solid"]: Rectangle {
                            property <string> fid: fi == 0 ? "mica-dark" : (fi == 1 ? "mica-light" : (fi == 2 ? "flat" : "solid"));
                            border-radius: AppMetrics.radius_small;
                            border-width: 1px;
                            border-color: root.ce_finish == self.fid ? ThemePalette.accent : ThemePalette.border;
                            background: root.ce_finish == self.fid ? ThemePalette.accent_soft : ThemePalette.panel;
                            Text {
                                width: parent.width;
                                height: parent.height;
                                text: finish_label;
                                color: root.ce_finish == parent.fid ? ThemePalette.accent_strong : ThemePalette.text_muted;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            TouchArea { clicked => { root.ce_finish_changed(fid); } }
                        }
                    }

                    // Typography
                    Text { text: "TYPOGRAPHY"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; width: 100px; height: parent.height; text: "UI Font"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                        LineEdit {
                            x: 114px;
                            y: 6px;
                            width: parent.width - 128px;
                            height: 26px;
                            text: root.ce_ui_font;
                            font-size: 12px;
                            placeholder-text: "Segoe UI";
                            edited(val) => { root.ce_font_changed(val, root.ce_mono_font); }
                        }
                    }
                    Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; width: 100px; height: parent.height; text: "Mono Font"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                        LineEdit {
                            x: 114px;
                            y: 6px;
                            width: parent.width - 128px;
                            height: 26px;
                            text: root.ce_mono_font;
                            font-size: 12px;
                            placeholder-text: "Cascadia Mono";
                            edited(val) => { root.ce_font_changed(root.ce_ui_font, val); }
                        }
                    }
                    Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; width: 100px; height: parent.height; text: "Size"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                        HorizontalLayout {
                            x: 114px;
                            y: 6px;
                            width: parent.width - 128px;
                            height: parent.height - 12px;
                            spacing: 4px;
                            for size_label[sz] in ["Small", "Normal", "Large"]: Rectangle {
                                property <int> sdv: sz - 1;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: root.ce_font_size_delta == self.sdv ? ThemePalette.accent : ThemePalette.border;
                                background: root.ce_font_size_delta == self.sdv ? ThemePalette.accent_soft : ThemePalette.panel_solid;
                                Text {
                                    width: parent.width;
                                    height: parent.height;
                                    text: size_label;
                                    color: root.ce_font_size_delta == parent.sdv ? ThemePalette.accent_strong : ThemePalette.text_muted;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                TouchArea { clicked => { root.ce_font_size_changed(sdv); } }
                            }
                        }
                    }

                    // Icons
                    Text { text: "ICONS"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; width: 120px; height: parent.height; text: "Folder color"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                        LineEdit {
                            x: 134px;
                            y: 6px;
                            width: 130px;
                            height: 26px;
                            text: root.ce_icon_folder_hex;
                            font-family: AppMetrics.mono_font;
                            font-size: 12px;
                            placeholder-text: "#e2a934";
                            edited(val) => { root.ce_icon_tint_changed(val); }
                        }
                        Rectangle {
                            x: parent.width - 46px;
                            y: 7px;
                            width: 24px;
                            height: 24px;
                            border-radius: 12px;
                            background: ThemePalette.icon_folder_2;
                            border-width: 1px;
                            border-color: ThemePalette.border_strong;
                        }
                    }
                    Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; width: 100px; height: parent.height; text: "Icon set"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                        LineEdit {
                            x: 114px;
                            y: 6px;
                            width: parent.width - 128px;
                            height: 26px;
                            text: root.ce_icon_set;
                            placeholder-text: "Path to icon set folder...";
                            font-size: 11.5px;
                            edited(val) => { root.ce_icon_set = val; }
                        }
                    }

                    // Actions
                    HorizontalLayout {
                        height: 36px;
                        spacing: 8px;
                        alignment: end;
                        DialogButton {
                            label: "Reset";
                            clicked => { root.ce_reset_to_active(); }
                        }
                        DialogButton {
                            label: "Delete";
                            danger: true;
                            visible: root.ce_saved_themes.length > 0;
                            clicked => { root.ce_delete(root.ce_name); }
                        }
                        DialogButton {
                            label: "Save Theme";
                            primary: true;
                            clicked => { root.ce_save(root.ce_name); }
                        }
                    }
                }
            }

            if root.settings_tab == "performance": ScrollView {
                x: 20px;
                y: 112px;
                width: parent.width - 40px;
                height: parent.height - 124px;
                viewport-width: parent.width - 40px;

                VerticalLayout {
                    width: parent.width;
                    spacing: 14px;
                    padding-bottom: 16px;

                    Text { text: "SEARCH PERFORMANCE"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        width: parent.width;
                        height: Math.ceil(root.index_choices.length / 2) * (AppMetrics.row_h + 16px);
                        for mode[i] in root.index_choices: ChoiceChip {
                            x: Math.mod(i, 2) == 0 ? 0px : (parent.width / 2 + 3px);
                            y: Math.floor(i / 2) * (AppMetrics.row_h + 16px);
                            width: parent.width / 2 - 3px;
                            item: mode;
                            active: root.active_index_mode == mode.id;
                            picked(id) => { root.index_mode_selected(id); }
                        }
                    }

                    Rectangle {
                        height: 92px;
                        border-radius: AppMetrics.radius;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; y: 12px; width: parent.width - 28px; height: 20px; text: "Index estimate"; color: ThemePalette.text; font-size: 13px; font-weight: 700; }
                        Text { x: 14px; y: 36px; width: parent.width - 28px; height: 44px; text: root.index_status; color: ThemePalette.text_muted; font-size: 12px; wrap: word-wrap; }
                    }

                    Text { text: "THUMBNAIL CACHE"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        height: 76px;
                        border-radius: AppMetrics.radius;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; y: 12px; width: parent.width - 112px; height: 20px; text: "Automatic thumbnail cleanup"; color: ThemePalette.text; font-size: 13px; font-weight: 700; }
                        Text { x: 14px; y: 36px; width: parent.width - 112px; height: 22px; text: root.thumbnail_status; color: ThemePalette.text_muted; font-size: 12px; overflow: elide; }
                        DialogButton { x: parent.width - 92px; y: 22px; label: "Clear"; clicked => { root.clear_thumbnail_cache(); } }
                    }

                    HorizontalLayout {
                        height: 34px;
                        spacing: 8px;
                        DialogButton { label: "Rebuild"; primary: true; clicked => { root.rebuild_index(); } }
                        DialogButton { label: "Debug"; clicked => { root.command("performance-debug"); } }
                    }
                }
            }

            if root.settings_tab == "ai": VerticalLayout {
                x: 20px;
                y: 112px;
                width: parent.width - 40px;
                height: parent.height - 124px;
                spacing: 14px;
                padding-bottom: 16px;

                Text { text: "AI CAPABILITIES"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                Rectangle {
                    height: 100px;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    border-radius: AppMetrics.radius;
                    background: ThemePalette.panel;
                    Text { x: 14px; y: 14px; width: parent.width - 28px; height: 22px; text: root.ai_label; color: ThemePalette.text; font-size: 14px; font-weight: 700; }
                    Text { x: 14px; y: 40px; width: parent.width - 28px; height: 20px; text: root.ai_device; color: ThemePalette.accent_strong; font-size: 12px; font-family: AppMetrics.mono_font; overflow: elide; }
                    Text { x: 14px; y: 66px; width: parent.width - 28px; height: 20px; text: "Thumbnails, content search, and image analysis use the best detected device."; color: ThemePalette.text_muted; font-size: 12px; overflow: elide; }
                }

                Text { text: "FEATURES"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                Rectangle {
                    height: 58px;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    border-radius: AppMetrics.radius;
                    background: ThemePalette.panel;
                    Text { x: 14px; y: 10px; width: parent.width - 28px; height: 18px; text: "AI thumbnail generation"; color: ThemePalette.text; font-size: 13px; font-weight: 600; }
                    Text { x: 14px; y: 32px; width: parent.width - 28px; height: 16px; text: "Generate rich previews for documents and media files"; color: ThemePalette.text_muted; font-size: 11.5px; overflow: elide; }
                }
                Rectangle {
                    height: 58px;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    border-radius: AppMetrics.radius;
                    background: ThemePalette.panel;
                    Text { x: 14px; y: 10px; width: parent.width - 28px; height: 18px; text: "Semantic content search"; color: ThemePalette.text; font-size: 13px; font-weight: 600; }
                    Text { x: 14px; y: 32px; width: parent.width - 28px; height: 16px; text: "Search by meaning, not just filename"; color: ThemePalette.text_muted; font-size: 11.5px; overflow: elide; }
                }
                Rectangle {
                    height: 58px;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    border-radius: AppMetrics.radius;
                    background: ThemePalette.panel;
                    Text { x: 14px; y: 10px; width: parent.width - 28px; height: 18px; text: "Image analysis"; color: ThemePalette.text; font-size: 13px; font-weight: 600; }
                    Text { x: 14px; y: 32px; width: parent.width - 28px; height: 16px; text: "Understand and tag photos automatically"; color: ThemePalette.text_muted; font-size: 11.5px; overflow: elide; }
                }
            }
        }
    }

    if root.confirm_visible: Rectangle {
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0.42);
        Rectangle {
            x: (parent.width - 420px) / 2;
            y: (parent.height - 180px) / 2;
            width: 420px;
            height: 180px;
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            Text { x: 18px; y: 16px; width: parent.width - 36px; height: 26px; text: "Confirm delete"; color: ThemePalette.text; font-size: 18px; font-weight: 700; }
            Text { x: 18px; y: 58px; width: parent.width - 36px; height: 48px; text: root.confirm_text; color: ThemePalette.text_muted; font-size: 13px; wrap: word-wrap; }
            DialogButton { x: parent.width - 180px; y: parent.height - 48px; label: "Cancel"; clicked => { root.confirm_visible = false; } }
            DialogButton { x: parent.width - 90px; y: parent.height - 48px; label: "Delete"; primary: true; danger: true; clicked => { root.confirm_visible = false; root.confirm_delete(); } }
        }
    }

    if root.prompt_visible: Rectangle {
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0.42);
        Rectangle {
            x: (parent.width - 420px) / 2;
            y: (parent.height - 190px) / 2;
            width: 420px;
            height: 190px;
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            Text { x: 18px; y: 16px; width: parent.width - 36px; height: 26px; text: root.prompt_title; color: ThemePalette.text; font-size: 18px; font-weight: 700; }
            prompt := LineEdit { x: 18px; y: 66px; width: parent.width - 36px; height: 34px; text: root.prompt_value; accepted(value) => { root.prompt_visible = false; root.prompt_accept(value); } }
            DialogButton { x: parent.width - 180px; y: parent.height - 48px; label: "Cancel"; clicked => { root.prompt_visible = false; } }
            DialogButton { x: parent.width - 90px; y: parent.height - 48px; label: "OK"; primary: true; clicked => { root.prompt_visible = false; root.prompt_accept(prompt.text); } }
        }
    }

    if root.op_drawer_visible: Rectangle {
        x: (parent.width - 420px) / 2;
        y: parent.height - 124px;
        width: 420px;
        height: 52px;
        border-width: 1px;
        border-color: ThemePalette.border_strong;
        border-radius: AppMetrics.radius;
        background: ThemePalette.panel_solid;
        drop-shadow-blur: 18px;
        drop-shadow-color: rgba(0, 0, 0, 0.35);

        Rectangle {
            x: 0; y: 0; width: 3px; height: parent.height;
            border-radius: AppMetrics.radius;
            background: ThemePalette.accent;
        }

        SvgIcon {
            x: 14px; y: (parent.height - 16px) / 2;
            icon_size: 16px;
            data: "M12 2v4 M12 18v4 M4.93 4.93l2.83 2.83 M16.24 16.24l2.83 2.83 M2 12h4 M18 12h4 M4.93 19.07l2.83-2.83 M16.24 7.76l2.83-2.83";
            tint: ThemePalette.accent;
        }

        Text {
            x: 38px;
            width: parent.width - 74px;
            height: parent.height;
            text: root.op_drawer_text;
            color: ThemePalette.text;
            font-size: 12.5px;
            vertical-alignment: center;
            overflow: elide;
        }

        ToolButton {
            x: parent.width - 34px;
            y: (parent.height - 26px) / 2;
            button_width: 26px;
            button_height: 26px;
            icon_data: "M18 6L6 18 M6 6l12 12";
            clicked => { root.op_drawer_visible = false; }
        }
    }

    if root.toast_text != "": Rectangle {
        x: (parent.width - 360px) / 2;
        y: parent.height - 78px;
        width: 360px;
        height: 38px;
        border-width: 1px;
        border-color: root.toast_kind == "error" ? ThemePalette.danger :
                      root.toast_kind == "success" ? ThemePalette.success :
                      root.toast_kind == "warning" ? ThemePalette.warning :
                      ThemePalette.border_strong;
        border-radius: AppMetrics.radius;
        background: ThemePalette.panel_solid;
        drop-shadow-blur: 24px;
        drop-shadow-color: rgba(0, 0, 0, 0.38);

        Rectangle {
            x: 0; y: 0; width: 3px; height: parent.height;
            border-radius: AppMetrics.radius;
            background: root.toast_kind == "error" ? ThemePalette.danger :
                        root.toast_kind == "success" ? ThemePalette.success :
                        root.toast_kind == "warning" ? ThemePalette.warning :
                        ThemePalette.accent;
        }

        Text { x: 13px; width: parent.width - 26px; height: parent.height; text: root.toast_text; color: ThemePalette.text; font-size: 12.5px; vertical-alignment: center; overflow: elide; }
    }

    keys := FocusScope {
        KeyBinding { keys: @keys(Control+T); activated => { root.new_tab(); } }
        KeyBinding { keys: @keys(Control+W); activated => { root.tab_closed(-1); } }
        KeyBinding { keys: @keys(Control+L); activated => { root.address_text = root.current_path; root.address_editing = true; } }
        KeyBinding { keys: @keys(Control+F); activated => { root.command("focus-search"); } }
        KeyBinding { keys: @keys(Control+P); activated => { root.command_visible = true; } }
        KeyBinding { keys: @keys(Control+Comma); activated => { root.settings_visible = true; } }
        KeyBinding { keys: @keys(Control+"1"); activated => { root.set_view("grid"); } }
        KeyBinding { keys: @keys(Control+"2"); activated => { root.set_view("list"); } }
        KeyBinding { keys: @keys(Control+"3"); activated => { root.set_view("gallery"); } }
        KeyBinding { keys: @keys(Control+I); activated => { root.toggle_preview(); } }
        KeyBinding { keys: @keys(Control+C); activated => { root.command("copy"); } }
        KeyBinding { keys: @keys(Control+X); activated => { root.command("cut"); } }
        KeyBinding { keys: @keys(Control+V); activated => { root.command("paste"); } }
        KeyBinding { keys: @keys(Control+A); activated => { root.command("select-all"); } }
        KeyBinding { keys: @keys(Control+Z); activated => { root.command("undo"); } }
        KeyBinding { keys: @keys(Control+Shift+N); activated => { root.command("new-folder"); } }
        KeyBinding { keys: @keys(Alt+LeftArrow); activated => { root.go_back(); } }
        KeyBinding { keys: @keys(Alt+RightArrow); activated => { root.go_forward(); } }
        KeyBinding { keys: @keys(Alt+UpArrow); activated => { root.go_up(); } }
        KeyBinding { keys: @keys(F3); activated => { root.toggle_dual_pane(); } }
        KeyBinding { keys: @keys(F5); activated => { root.refresh(); } }
        KeyBinding { keys: @keys(Delete); activated => { root.command("delete"); } }
        KeyBinding { keys: @keys(F2); activated => { root.rename_index = root.selected_index; } }
        KeyBinding { keys: @keys(Return); activated => { root.file_opened(root.selected_index); } }
        KeyBinding { keys: @keys(Space); activated => { root.toggle_preview(); } }
        KeyBinding { keys: @keys(Control+D); activated => { root.command("duplicates"); } }
        KeyBinding { keys: @keys(Control+Shift+C); activated => { root.command("checksum"); } }
        KeyBinding { keys: @keys(UpArrow); activated => { root.file_selected(max(0, root.selected_index - 1), false, false); } }
        KeyBinding { keys: @keys(DownArrow); activated => { root.file_selected(min(root.files.length - 1, root.selected_index + 1), false, false); } }
        KeyBinding { keys: @keys(Escape); activated => { root.context_visible = false; root.command_visible = false; root.settings_visible = false; root.confirm_visible = false; root.prompt_visible = false; root.address_editing = false; root.addr_suggestions = []; } }
    }
}

export global AppMetrics {
    in-out property <length> radius: 8px;
    in-out property <length> radius_small: 5px;
    in-out property <length> row_h: 38px;
    in-out property <length> grid_w: 136px;
    in-out property <length> grid_h: 122px;
    in-out property <length> pad: 16px;
    in-out property <length> outer_border: 0px;
    in-out property <string> ui_font: "Segoe UI";
    in-out property <string> mono_font: "Cascadia Mono";
    in-out property <bool> light_controls: false;
}
