    if root.image_tools_visible: Rectangle {
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0.42);

        TouchArea {
            clicked => { root.image_tools_visible = false; }
        }

        Rectangle {
            x: (parent.width - 520px) / 2;
            y: 96px;
            width: 520px;
            height: 470px;
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            drop-shadow-blur: 18px;
            drop-shadow-color: rgba(0, 0, 0, 0.38);

            Text {
                x: 18px;
                y: 16px;
                width: parent.width - 70px;
                height: 24px;
                text: root.image_tools_title;
                color: ThemePalette.text;
                font-size: 18px;
                font-weight: 700;
                overflow: elide;
            }

            ToolButton {
                x: parent.width - 43px;
                y: 12px;
                icon_data: "M18 6L6 18 M6 6l12 12";
                tooltip: "Close";
                clicked => { root.image_tools_visible = false; }
            }

            Text {
                x: 18px;
                y: 45px;
                width: parent.width - 36px;
                height: 42px;
                text: root.image_tools_subtitle;
                color: ThemePalette.text_faint;
                font-size: 12px;
                wrap: word-wrap;
            }

            Rectangle { x: 18px; y: 96px; width: parent.width - 36px; height: 1px; background: ThemePalette.border; }

            Text { x: 18px; y: 112px; width: 225px; height: 18px; text: "Adjust"; color: ThemePalette.text_faint; font-size: 11px; font-weight: 700; }
            ChoiceMenuRow { x: 18px; y: 136px; width: 225px; label: "Rotate Left"; command_name: "image-rotate-left"; picked(c) => { root.image_tools_visible = false; root.command(c); } }
            ChoiceMenuRow { x: 18px; y: 170px; width: 225px; label: "Rotate Right"; command_name: "image-rotate-right"; picked(c) => { root.image_tools_visible = false; root.command(c); } }
            ChoiceMenuRow { x: 18px; y: 204px; width: 225px; label: "Resize to 50%"; command_name: "image-resize-half"; picked(c) => { root.image_tools_visible = false; root.command(c); } }
            ChoiceMenuRow { x: 18px; y: 238px; width: 225px; label: "Resize to 25%"; command_name: "image-resize-quarter"; picked(c) => { root.image_tools_visible = false; root.command(c); } }

            // Custom resize row
            Rectangle {
                x: 18px; y: 272px;
                width: 225px; height: 30px;
                border-radius: AppMetrics.radius_small;
                border-width: 1px;
                border-color: ThemePalette.border;
                background: ThemePalette.panel;
                property <string> resize_value: "";
                Text {
                    x: 9px; y: 0;
                    width: 70px; height: parent.height;
                    text: "Scale %:";
                    color: ThemePalette.text_muted;
                    font-size: 12px;
                    vertical-alignment: center;
                }
                resize_input := TextInput {
                    x: 76px; y: 1px;
                    width: 80px; height: parent.height - 2px;
                    font-size: 12.5px;
                    color: ThemePalette.text;
                    vertical-alignment: center;
                    accepted() => {
                        if self.text != "" {
                            root.image_tools_visible = false;
                            root.command("image-resize-pct-" + self.text);
                        }
                    }
                }
                if resize_input.text == "" && !resize_input.has-focus: Text {
                    x: 76px; y: 0;
                    width: 80px; height: parent.height;
                    text: "e.g. 75";
                    color: ThemePalette.text_faint;
                    font-size: 12px;
                    vertical-alignment: center;
                }
                Rectangle {
                    x: parent.width - 55px; y: 3px;
                    width: 50px; height: 24px;
                    border-radius: 5px;
                    background: apply_touch.has-hover ? ThemePalette.accent : ThemePalette.accent_soft;
                    Text {
                        width: parent.width; height: parent.height;
                        text: "Apply";
                        color: apply_touch.has-hover ? white : ThemePalette.accent_strong;
                        font-size: 11.5px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    apply_touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            if resize_input.text != "" {
                                root.image_tools_visible = false;
                                root.command("image-resize-pct-" + resize_input.text);
                            }
                        }
                    }
                }
            }

            Text { x: 277px; y: 112px; width: 225px; height: 18px; text: "Export"; color: ThemePalette.text_faint; font-size: 11px; font-weight: 700; }
            ChoiceMenuRow { x: 277px; y: 136px; width: 225px; label: "Convert to JPEG"; command_name: "image-convert-jpeg"; picked(c) => { root.image_tools_visible = false; root.command(c); } }
            ChoiceMenuRow { x: 277px; y: 170px; width: 225px; label: "Convert to PNG"; command_name: "image-convert-png"; picked(c) => { root.image_tools_visible = false; root.command(c); } }
            ChoiceMenuRow { x: 277px; y: 204px; width: 225px; label: "Convert to WebP"; command_name: "image-convert-webp"; picked(c) => { root.image_tools_visible = false; root.command(c); } }
            ChoiceMenuRow { x: 277px; y: 238px; width: 225px; label: "Compress JPEG Copy"; command_name: "image-compress-jpeg"; picked(c) => { root.image_tools_visible = false; root.command(c); } }

            Text { x: 18px; y: 334px; width: parent.width - 36px; height: 18px; text: "Privacy"; color: ThemePalette.text_faint; font-size: 11px; font-weight: 700; }
            ChoiceMenuRow { x: 18px; y: 356px; width: parent.width - 36px; label: "Strip Metadata Copy"; command_name: "image-strip-metadata"; picked(c) => { root.image_tools_visible = false; root.command(c); } }

            Text {
                x: 18px;
                y: 410px;
                width: parent.width - 36px;
                height: 34px;
                text: "Actions create new files next to the original and keep the source unchanged.";
                color: ThemePalette.text_faint;
                font-size: 11.5px;
                wrap: word-wrap;
            }
        }
    }

    if root.command_visible: Rectangle {
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0.42);
        TouchArea { mouse-cursor: pointer; clicked => { root.command_visible = false; } }

        Rectangle {
            x: (parent.width - 620px) / 2;
            y: 82px;
            width: 620px;
            height: 512px;
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            drop-shadow-blur: 18px;
            drop-shadow-color: rgba(0, 0, 0, 0.38);

            Rectangle {
                x: 16px;
                y: 14px;
                width: parent.width - 32px;
                height: 38px;
                border-width: 1px;
                border-color: cmd_search.has-focus ? ThemePalette.accent : ThemePalette.border;
                border-radius: AppMetrics.radius_small;
                background: ThemePalette.bg_soft;
                SvgIcon { x: 10px; y: 11px; icon_size: 16px; data: "M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16z M21 21l-4.3-4.3"; tint: ThemePalette.text_faint; }
                cmd_search := LineEdit {
                    x: 34px;
                    y: 0;
                    width: parent.width - 64px;
                    height: parent.height;
                    text: root.command_filter;
                    placeholder-text: "Type a command...";
                    font-size: 14px;
                    edited(value) => { root.command_filter = value; root.filter_commands(value); }
                    accepted(value) => { }
                    key-pressed(event) => {
                        if (event.text == Key.Escape) {
                            root.command_visible = false;
                            accept
                        } else { reject }
                    }
                }
                ToolButton {
                    x: parent.width - 30px;
                    y: 4px;
                    button_width: 26px;
                    button_height: 26px;
                    text_label: "✕";
                    clicked => {
                        if (root.command_filter != "") {
                            root.command_filter = "";
                            root.filter_commands("");
                        } else {
                            root.command_visible = false;
                        }
                    }
                }
            }

            ListView {
                x: 6px;
                y: 64px;
                width: parent.width - 12px;
                height: parent.height - 70px;
                for cmd[index] in root.command_items: CommandRow {
                    width: parent.width;
                    item: cmd;
                    picked(name) => {
                        root.command_visible = false;
                        root.command(name);
                    }
                }
            }
        }
    }

    if root.settings_visible: Rectangle {
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0.42);
        TouchArea { clicked => { root.settings_visible = false; } }

        Rectangle {
            x: (parent.width - 780px) / 2;
            y: (parent.height - 680px) / 2;
            width: 780px;
            height: 680px;
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            drop-shadow-blur: 20px;
            drop-shadow-color: rgba(0, 0, 0, 0.45);
            TouchArea {}

            Text { x: 20px; y: 18px; width: parent.width - 80px; height: 28px; text: "Settings"; color: ThemePalette.text; font-size: 18px; font-weight: 700; }
            ToolButton { x: parent.width - 46px; y: 14px; icon_data: "M18 6L6 18 M6 6l12 12"; tooltip: "Close settings"; clicked => { root.settings_visible = false; } }

            Rectangle {
                y: 56px;
                width: parent.width;
                height: 44px;
                background: transparent;
                Rectangle { y: parent.height - 1px; width: parent.width; height: 1px; background: ThemePalette.border; }

                for tab_label[ti] in ["Appearance", "View", "Performance", "Themes", "AI"]: Rectangle {
                    property <string> tid: ti == 0 ? "appearance" : (ti == 1 ? "view" : (ti == 2 ? "performance" : (ti == 3 ? "themes" : "ai")));
                    property <bool> is_active: root.settings_tab == self.tid;
                    visible: !(root.is_simple && tab_label == "AI");
                    x: 20px + ti * 102px;
                    y: 0;
                    width: 98px;
                    height: parent.height;
                    background: transparent;
                    Text {
                        width: parent.width;
                        height: parent.height - 2px;
                        text: tab_label;
                        color: parent.is_active ? ThemePalette.text : ThemePalette.text_muted;
                        font-size: 13px;
                        font-weight: parent.is_active ? 600 : 400;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    Rectangle {
                        y: parent.height - 2px;
                        width: parent.width;
                        height: 2px;
                        background: parent.is_active ? ThemePalette.accent : transparent;
                        animate background { duration: 40ms; easing: ease-out; }
                    }
                    TouchArea { mouse-cursor: pointer; clicked => { root.settings_tab = tid; } }
                }
            }

            if root.settings_tab == "appearance": ScrollView {
                x: 20px;
                y: 112px;
                width: parent.width - 40px;
                height: parent.height - 124px;
                viewport-width: parent.width - 40px;

                VerticalLayout {
                    width: parent.width;
                    spacing: 18px;
                    padding-bottom: 16px;

                    Text { text: "THEME"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        width: parent.width;
                        height: Math.ceil(root.theme_choices.length / 2) * (AppMetrics.row_h + 6px);
                        for theme[i] in root.theme_choices: ChoiceChip {
                            x: Math.mod(i, 2) == 0 ? 0px : (parent.width / 2 + 3px);
                            y: Math.floor(i / 2) * (AppMetrics.row_h + 6px);
                            width: parent.width / 2 - 3px;
                            item: theme;
                            active: root.active_theme == theme.id;
                            picked(id) => { root.theme_selected(id); }
                        }
                    }

                    Text { text: "ACCENT COLOR"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        width: parent.width;
                        height: Math.ceil(root.accent_choices.length / 3) * (AppMetrics.row_h + 6px);
                        for accent[i] in root.accent_choices: ChoiceChip {
                            x: Math.mod(i, 3) * (parent.width / 3 + 2px);
                            y: Math.floor(i / 3) * (AppMetrics.row_h + 6px);
                            width: parent.width / 3 - 4px;
                            item: accent;
                            active: root.active_accent == accent.id;
                            picked(id) => { root.accent_selected(id); }
                        }
                    }

                    Text { text: "DENSITY"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        width: parent.width;
                        height: Math.ceil(root.density_choices.length / 3) * (AppMetrics.row_h + 6px);
                        for density[i] in root.density_choices: ChoiceChip {
                            x: Math.mod(i, 3) * (parent.width / 3 + 2px);
                            y: Math.floor(i / 3) * (AppMetrics.row_h + 6px);
                            width: parent.width / 3 - 4px;
                            item: density;
                            active: root.active_density == density.id;
                            picked(id) => { root.density_selected(id); }
                        }
                    }

                    Text { text: "INTERFACE MODE"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    HorizontalLayout {
                        spacing: 6px;
                        height: AppMetrics.row_h;
                        for mode_label[mi] in ["Simple", "Normal"]: Rectangle {
                            property <string> mode_id: mi == 0 ? "simple" : "normal";
                            border-width: 1px;
                            border-color: root.ui_mode == self.mode_id ? ThemePalette.accent : ThemePalette.border;
                            border-radius: AppMetrics.radius;
                            background: root.ui_mode == self.mode_id ? ThemePalette.accent_soft : ThemePalette.panel;
                            Text {
                                width: parent.width;
                                height: parent.height;
                                text: mode_label;
                                color: root.ui_mode == parent.mode_id ? ThemePalette.accent_strong : ThemePalette.text_muted;
                                font-size: 13px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            mode_touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.ui_mode = mode_id; root.set_ui_mode(mode_id); }
                            }
                        }
                    }
                    Text {
                        text: root.ui_mode == "simple" ? "Essential features only — hides dual pane, power tools, advanced menu, and AI settings." : "Full access to every feature including dual pane, power tools, and AI.";
                        color: ThemePalette.text_faint;
                        font-size: 11.5px;
                        wrap: word-wrap;
                        height: self.preferred-height;
                    }
                }
            }

            if root.settings_tab == "view": VerticalLayout {
                x: 20px;
                y: 112px;
                width: parent.width - 40px;
                height: parent.height - 124px;
                spacing: 12px;
                padding-bottom: 16px;

                Text { text: "DEFAULT VIEW MODE"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                HorizontalLayout {
                    spacing: 6px;
                    height: AppMetrics.row_h;
                    for vm_label[vi] in ["Grid", "List", "Gallery"]: Rectangle {
                        property <string> vm_id: vi == 0 ? "grid" : (vi == 1 ? "list" : "gallery");
                        border-width: 1px;
                        border-color: root.view_mode == self.vm_id ? ThemePalette.accent : ThemePalette.border;
                        border-radius: AppMetrics.radius;
                        background: root.view_mode == self.vm_id ? ThemePalette.accent_soft : ThemePalette.panel;
                        Text {
                            width: parent.width;
                            height: parent.height;
                            text: vm_label;
                            color: root.view_mode == parent.vm_id ? ThemePalette.accent_strong : ThemePalette.text_muted;
                            font-size: 13px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        TouchArea { mouse-cursor: pointer; clicked => { root.set_view(vm_id); } }
                    }
                }

                Text { text: "OPTIONS"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                Rectangle {
                    height: AppMetrics.row_h;
                    border-radius: AppMetrics.radius;
                    background: ThemePalette.panel;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    Text { x: 14px; width: parent.width - 60px; height: parent.height; text: "Show hidden files"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                    Rectangle {
                        x: parent.width - 52px;
                        y: (parent.height - 22px) / 2;
                        width: 40px;
                        height: 22px;
                        border-radius: 11px;
                        background: root.show_hidden ? ThemePalette.accent : ThemePalette.border_strong;
                        animate background { duration: 60ms; easing: ease-out; }
                        Rectangle {
                            x: root.show_hidden ? 20px : 2px;
                            y: 2px;
                            width: 18px;
                            height: 18px;
                            border-radius: 9px;
                            background: white;
                            animate x { duration: 60ms; easing: ease-out; }
                        }
                        TouchArea { mouse-cursor: pointer; clicked => { root.toggle_hidden(); } }
                    }
                }
                Rectangle {
                    height: AppMetrics.row_h;
                    border-radius: AppMetrics.radius;
                    background: ThemePalette.panel;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    Text { x: 14px; width: parent.width - 60px; height: parent.height; text: "Show preview panel"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                    Rectangle {
                        x: parent.width - 52px;
                        y: (parent.height - 22px) / 2;
                        width: 40px;
                        height: 22px;
                        border-radius: 11px;
                        background: root.preview_visible ? ThemePalette.accent : ThemePalette.border_strong;
                        animate background { duration: 60ms; easing: ease-out; }
                        Rectangle {
                            x: root.preview_visible ? 20px : 2px;
                            y: 2px;
                            width: 18px;
                            height: 18px;
                            border-radius: 9px;
                            background: white;
                            animate x { duration: 60ms; easing: ease-out; }
                        }
                        TouchArea { mouse-cursor: pointer; clicked => { root.toggle_preview(); } }
                    }
                }
            }

            if root.settings_tab == "themes": ScrollView {
                x: 20px;
                y: 112px;
                width: parent.width - 40px;
                height: parent.height - 124px;
                viewport-width: parent.width - 40px;

                VerticalLayout {
                    width: parent.width;
                    spacing: 16px;
                    padding-bottom: 20px;

                    // Saved themes
                    Text { text: "SAVED THEMES"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        clip: true;
                        if root.ce_saved_themes.length == 0: Text {
                            x: 14px;
                            width: parent.width - 28px;
                            height: parent.height;
                            text: "No saved themes yet";
                            color: ThemePalette.text_faint;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                        for saved_name[ni] in root.ce_saved_themes: Rectangle {
                            x: 8px + ni * (saved_chip_text.preferred-width + 28px);
                            y: 7px;
                            height: 24px;
                            width: saved_chip_text.preferred-width + 20px;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: ThemePalette.border_strong;
                            background: saved_chip_ta.has-hover ? ThemePalette.panel_alt : ThemePalette.panel_solid;
                            saved_chip_text := Text {
                                x: 8px;
                                width: parent.width - 16px;
                                height: parent.height;
                                text: saved_name;
                                color: ThemePalette.text_muted;
                                font-size: 11.5px;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                            saved_chip_ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.ce_load(saved_name); }
                            }
                        }
                    }

                    // Name
                    Text { text: "THEME NAME"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    LineEdit {
                        height: 34px;
                        text: root.ce_name;
                        placeholder-text: "My Theme";
                        font-size: 13px;
                        edited(val) => { root.ce_name = val; }
                    }

                    // Live preview
                    Text { text: "LIVE PREVIEW"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        height: 142px;
                        border-radius: Math.max(2px, root.ce_radius * 1px);
                        border-width: 1px;
                        border-color: root.ce_token_colors.length > 4 ? root.ce_token_colors[4] : ThemePalette.border_strong;
                        background: root.ce_token_colors.length > 0 ? root.ce_token_colors[0] : ThemePalette.bg;
                        clip: true;

                        Rectangle {
                            x: 12px;
                            y: 12px;
                            width: parent.width - 24px;
                            height: parent.height - 24px;
                            border-radius: Math.max(2px, root.ce_radius * 1px);
                            border-width: 1px;
                            border-color: root.ce_token_colors.length > 3 ? root.ce_token_colors[3] : ThemePalette.border;
                            background: root.ce_token_colors.length > 2 ? root.ce_token_colors[2] : ThemePalette.panel;
                        }

                        Rectangle {
                            x: 12px;
                            y: 12px;
                            width: parent.width - 24px;
                            height: 30px;
                            background: root.ce_token_colors.length > 1 ? root.ce_token_colors[1] : ThemePalette.bg_soft;
                            Text {
                                x: 12px;
                                width: 170px;
                                height: parent.height;
                                text: root.ce_name == "" ? "Custom Theme" : root.ce_name;
                                color: root.ce_token_colors.length > 5 ? root.ce_token_colors[5] : ThemePalette.text;
                                font-size: 12px;
                                font-weight: 700;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                            Rectangle {
                                x: parent.width - 78px;
                                y: 7px;
                                width: 58px;
                                height: 16px;
                                border-radius: 8px;
                                background: root.ce_token_colors.length > 8 ? root.ce_token_colors[8] : ThemePalette.accent;
                            }
                        }

                        Rectangle {
                            x: 28px;
                            y: 58px;
                            width: 150px;
                            height: 56px;
                            border-radius: Math.max(2px, root.ce_radius * 1px);
                            background: root.ce_token_colors.length > 1 ? root.ce_token_colors[1] : ThemePalette.bg_soft;
                            Text { x: 12px; y: 8px; width: parent.width - 24px; height: 18px; text: "Sidebar Item"; color: root.ce_token_colors.length > 6 ? root.ce_token_colors[6] : ThemePalette.text_muted; font-size: 12px; overflow: elide; }
                            Rectangle { x: 12px; y: 34px; width: parent.width - 24px; height: 8px; border-radius: 4px; background: root.ce_token_colors.length > 8 ? root.ce_token_colors[8] : ThemePalette.accent; }
                        }

                        Rectangle {
                            x: 196px;
                            y: 58px;
                            width: parent.width - 230px;
                            height: 56px;
                            border-radius: Math.max(2px, root.ce_radius * 1px);
                            border-width: 1px;
                            border-color: root.ce_token_colors.length > 3 ? root.ce_token_colors[3] : ThemePalette.border;
                            background: root.ce_token_colors.length > 2 ? root.ce_token_colors[2] : ThemePalette.panel;
                            NodeVisual { x: 12px; y: 10px; visual_width: 34px; visual_height: 28px; is_dir: true; extension: ""; }
                            Text { x: 56px; y: 8px; width: parent.width - 70px; height: 18px; text: "Long filename preview.txt"; color: root.ce_token_colors.length > 5 ? root.ce_token_colors[5] : ThemePalette.text; font-size: 12px; overflow: elide; }
                            Text { x: 56px; y: 30px; width: parent.width - 70px; height: 16px; text: "Shows colors, radius, contrast"; color: root.ce_token_colors.length > 7 ? root.ce_token_colors[7] : ThemePalette.text_faint; font-size: 10.5px; overflow: elide; }
                        }
                    }

                    // Colors
                    Text { text: "COLORS"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Text {
                        text: "Click a token, then pick a color below. Hex is still available for exact values.";
                        color: ThemePalette.text_faint;
                        font-size: 11px;
                    }
                    HorizontalLayout {
                        height: 44px;
                        spacing: 8px;
                        alignment: start;
                        padding-top: 8px;
                        padding-bottom: 8px;
                        for col[ci] in root.ce_token_colors: Rectangle {
                            width: 28px;
                            border-radius: 14px;
                            background: col;
                            border-width: root.ce_selected_token == ci ? 2px : 1px;
                            border-color: root.ce_selected_token == ci ? ThemePalette.accent : ThemePalette.border_strong;
                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.ce_select_token(ci); }
                            }
                        }
                    }
                    if root.ce_selected_token >= 0: Rectangle {
                        height: 34px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 12px; width: 96px; height: parent.height; text: "Quick colors"; color: ThemePalette.text_muted; font-size: 12px; vertical-alignment: center; }
                        Rectangle { x: 112px; y: 7px; width: 20px; height: 20px; border-radius: 10px; background: #101318; TouchArea { mouse-cursor: pointer; clicked => { root.ce_color_changed(root.ce_selected_token, "#101318"); } } }
                        Rectangle { x: 140px; y: 7px; width: 20px; height: 20px; border-radius: 10px; background: #f6f8fb; TouchArea { mouse-cursor: pointer; clicked => { root.ce_color_changed(root.ce_selected_token, "#f6f8fb"); } } }
                        Rectangle { x: 168px; y: 7px; width: 20px; height: 20px; border-radius: 10px; background: #4f9cff; TouchArea { mouse-cursor: pointer; clicked => { root.ce_color_changed(root.ce_selected_token, "#4f9cff"); } } }
                        Rectangle { x: 196px; y: 7px; width: 20px; height: 20px; border-radius: 10px; background: #8b6cff; TouchArea { mouse-cursor: pointer; clicked => { root.ce_color_changed(root.ce_selected_token, "#8b6cff"); } } }
                        Rectangle { x: 224px; y: 7px; width: 20px; height: 20px; border-radius: 10px; background: #e45578; TouchArea { mouse-cursor: pointer; clicked => { root.ce_color_changed(root.ce_selected_token, "#e45578"); } } }
                        Rectangle { x: 252px; y: 7px; width: 20px; height: 20px; border-radius: 10px; background: #d98a24; TouchArea { mouse-cursor: pointer; clicked => { root.ce_color_changed(root.ce_selected_token, "#d98a24"); } } }
                        Rectangle { x: 280px; y: 7px; width: 20px; height: 20px; border-radius: 10px; background: #2aa96b; TouchArea { mouse-cursor: pointer; clicked => { root.ce_color_changed(root.ce_selected_token, "#2aa96b"); } } }
                        Rectangle { x: 308px; y: 7px; width: 20px; height: 20px; border-radius: 10px; background: #1aa6a6; TouchArea { mouse-cursor: pointer; clicked => { root.ce_color_changed(root.ce_selected_token, "#1aa6a6"); } } }
                        Rectangle { x: 336px; y: 7px; width: 20px; height: 20px; border-radius: 10px; background: #f2f6fb; TouchArea { mouse-cursor: pointer; clicked => { root.ce_color_changed(root.ce_selected_token, "#f2f6fb"); } } }
                        Rectangle { x: 364px; y: 7px; width: 20px; height: 20px; border-radius: 10px; background: #19202a; TouchArea { mouse-cursor: pointer; clicked => { root.ce_color_changed(root.ce_selected_token, "#19202a"); } } }
                    }
                    if root.ce_selected_token >= 0: Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text {
                            x: 14px;
                            width: 136px;
                            height: parent.height;
                            text: root.ce_token_label;
                            color: ThemePalette.text;
                            font-size: 13px;
                            overflow: elide;
                            vertical-alignment: center;
                        }
                        LineEdit {
                            x: 158px;
                            y: 6px;
                            width: 130px;
                            height: 26px;
                            text: root.ce_token_hex;
                            font-family: AppMetrics.mono_font;
                            font-size: 12px;
                            placeholder-text: "#rrggbb";
                            edited(val) => { root.ce_color_changed(root.ce_selected_token, val); }
                        }
                        Rectangle {
                            x: parent.width - 46px;
                            y: 7px;
                            width: 24px;
                            height: 24px;
                            border-radius: 12px;
                            background: root.ce_token_colors.length > root.ce_selected_token && root.ce_selected_token >= 0
                                ? root.ce_token_colors[root.ce_selected_token]
                                : ThemePalette.border_strong;
                            border-width: 1px;
                            border-color: ThemePalette.border_strong;
                        }
                    }

                    // Feel
                    Text { text: "FEEL"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; width: 140px; height: parent.height; text: "Corner radius"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                        Slider {
                            x: 158px;
                            y: 9px;
                            width: parent.width - 230px;
                            height: 20px;
                            minimum: 0;
                            maximum: 16;
                            value: root.ce_radius;
                            changed(v) => { root.ce_radius_changed(v); }
                        }
                        Text {
                            x: parent.width - 60px;
                            width: 50px;
                            height: parent.height;
                            text: Math.round(root.ce_radius) + "px";
                            color: ThemePalette.text_muted;
                            font-family: AppMetrics.mono_font;
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                    }
                    Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; width: 130px; height: parent.height; text: "Animations"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                        HorizontalLayout {
                            x: 148px;
                            y: 6px;
                            width: parent.width - 162px;
                            height: parent.height - 12px;
                            spacing: 4px;
                            for speed_label[si] in ["Off", "Fast", "Normal", "Slow"]: Rectangle {
                                property <float> sv: si == 0 ? 0.0 : (si == 1 ? 0.5 : (si == 2 ? 1.0 : 2.0));
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: root.ce_anim_speed == self.sv ? ThemePalette.accent : ThemePalette.border;
                                background: root.ce_anim_speed == self.sv ? ThemePalette.accent_soft : ThemePalette.panel_solid;
                                Text {
                                    width: parent.width;
                                    height: parent.height;
                                    text: speed_label;
                                    color: root.ce_anim_speed == parent.sv ? ThemePalette.accent_strong : ThemePalette.text_muted;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                TouchArea { mouse-cursor: pointer; clicked => { root.ce_anim_changed(sv); } }
                            }
                        }
                    }

                    // Finish
                    Text { text: "FINISH"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    HorizontalLayout {
                        height: 38px;
                        spacing: 6px;
                        for finish_label[fi] in ["Mica Dark", "Mica Light", "Flat", "Solid"]: Rectangle {
                            property <string> fid: fi == 0 ? "mica-dark" : (fi == 1 ? "mica-light" : (fi == 2 ? "flat" : "solid"));
                            border-radius: AppMetrics.radius_small;
                            border-width: 1px;
                            border-color: root.ce_finish == self.fid ? ThemePalette.accent : ThemePalette.border;
                            background: root.ce_finish == self.fid ? ThemePalette.accent_soft : ThemePalette.panel;
                            Text {
                                width: parent.width;
                                height: parent.height;
                                text: finish_label;
                                color: root.ce_finish == parent.fid ? ThemePalette.accent_strong : ThemePalette.text_muted;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            TouchArea { mouse-cursor: pointer; clicked => { root.ce_finish_changed(fid); } }
                        }
                    }

                    // Typography
                    Text { text: "TYPOGRAPHY"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; width: 100px; height: parent.height; text: "UI Font"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                        LineEdit {
                            x: 114px;
                            y: 6px;
                            width: parent.width - 128px;
                            height: 26px;
                            text: root.ce_ui_font;
                            font-size: 12px;
                            placeholder-text: "Segoe UI";
                            edited(val) => { root.ce_font_changed(val, root.ce_mono_font); }
                        }
                    }
                    Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; width: 100px; height: parent.height; text: "Mono Font"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                        LineEdit {
                            x: 114px;
                            y: 6px;
                            width: parent.width - 128px;
                            height: 26px;
                            text: root.ce_mono_font;
                            font-size: 12px;
                            placeholder-text: "Cascadia Mono";
                            edited(val) => { root.ce_font_changed(root.ce_ui_font, val); }
                        }
                    }
                    Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; width: 100px; height: parent.height; text: "Size"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                        HorizontalLayout {
                            x: 114px;
                            y: 6px;
                            width: parent.width - 128px;
                            height: parent.height - 12px;
                            spacing: 4px;
                            for size_label[sz] in ["Small", "Normal", "Large"]: Rectangle {
                                property <int> sdv: sz - 1;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: root.ce_font_size_delta == self.sdv ? ThemePalette.accent : ThemePalette.border;
                                background: root.ce_font_size_delta == self.sdv ? ThemePalette.accent_soft : ThemePalette.panel_solid;
                                Text {
                                    width: parent.width;
                                    height: parent.height;
                                    text: size_label;
                                    color: root.ce_font_size_delta == parent.sdv ? ThemePalette.accent_strong : ThemePalette.text_muted;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                TouchArea { mouse-cursor: pointer; clicked => { root.ce_font_size_changed(sdv); } }
                            }
                        }
                    }

                    // Icons
                    Text { text: "ICONS"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        height: 72px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; y: 0; width: 120px; height: 38px; text: "Folder color"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                        LineEdit {
                            x: 134px;
                            y: 6px;
                            width: 130px;
                            height: 26px;
                            text: root.ce_icon_folder_hex;
                            font-family: AppMetrics.mono_font;
                            font-size: 12px;
                            placeholder-text: "#e2a934";
                            edited(val) => { root.ce_icon_tint_changed(val); }
                        }
                        Rectangle {
                            x: parent.width - 46px;
                            y: 7px;
                            width: 24px;
                            height: 24px;
                            border-radius: 12px;
                            background: ThemePalette.icon_folder_2;
                            border-width: 1px;
                            border-color: ThemePalette.border_strong;
                        }
                        Text { x: 14px; y: 41px; width: 90px; height: 20px; text: "Presets"; color: ThemePalette.text_faint; font-size: 11px; vertical-alignment: center; }
                        Rectangle { x: 104px; y: 42px; width: 20px; height: 20px; border-radius: 10px; background: #e2a934; TouchArea { mouse-cursor: pointer; clicked => { root.ce_icon_tint_changed("#e2a934"); } } }
                        Rectangle { x: 132px; y: 42px; width: 20px; height: 20px; border-radius: 10px; background: #4f9cff; TouchArea { mouse-cursor: pointer; clicked => { root.ce_icon_tint_changed("#4f9cff"); } } }
                        Rectangle { x: 160px; y: 42px; width: 20px; height: 20px; border-radius: 10px; background: #2aa96b; TouchArea { mouse-cursor: pointer; clicked => { root.ce_icon_tint_changed("#2aa96b"); } } }
                        Rectangle { x: 188px; y: 42px; width: 20px; height: 20px; border-radius: 10px; background: #8b6cff; TouchArea { mouse-cursor: pointer; clicked => { root.ce_icon_tint_changed("#8b6cff"); } } }
                        Rectangle { x: 216px; y: 42px; width: 20px; height: 20px; border-radius: 10px; background: #e45578; TouchArea { mouse-cursor: pointer; clicked => { root.ce_icon_tint_changed("#e45578"); } } }
                        Rectangle { x: 244px; y: 42px; width: 20px; height: 20px; border-radius: 10px; background: #1aa6a6; TouchArea { mouse-cursor: pointer; clicked => { root.ce_icon_tint_changed("#1aa6a6"); } } }
                    }
                    Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; width: 100px; height: parent.height; text: "Icon set"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                        LineEdit {
                            x: 114px;
                            y: 6px;
                            width: parent.width - 128px;
                            height: 26px;
                            text: root.ce_icon_set;
                            placeholder-text: "Path to icon set folder...";
                            font-size: 11.5px;
                            edited(val) => { root.ce_icon_set = val; }
                        }
                    }

                    // Actions
                    HorizontalLayout {
                        height: 36px;
                        spacing: 8px;
                        alignment: end;
                        DialogButton {
                            label: "Reset";
                            clicked => { root.ce_reset_to_active(); }
                        }
                        DialogButton {
                            label: "Delete";
                            danger: true;
                            visible: root.ce_saved_themes.length > 0;
                            clicked => { root.ce_delete(root.ce_name); }
                        }
                        DialogButton {
                            label: "Save Theme";
                            primary: true;
                            clicked => { root.ce_save(root.ce_name); }
                        }
                    }
                }
            }

            if root.settings_tab == "performance": ScrollView {
                x: 20px;
                y: 112px;
                width: parent.width - 40px;
                height: parent.height - 124px;
                viewport-width: parent.width - 40px;

                VerticalLayout {
                    width: parent.width;
                    spacing: 14px;
                    padding-bottom: 16px;

                    Text { text: "SEARCH PERFORMANCE"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        width: parent.width;
                        height: Math.ceil(root.index_choices.length / 2) * (AppMetrics.row_h + 16px);
                        for mode[i] in root.index_choices: ChoiceChip {
                            x: Math.mod(i, 2) == 0 ? 0px : (parent.width / 2 + 3px);
                            y: Math.floor(i / 2) * (AppMetrics.row_h + 16px);
                            width: parent.width / 2 - 3px;
                            item: mode;
                            active: root.active_index_mode == mode.id;
                            picked(id) => { root.index_mode_selected(id); }
                        }
                    }

                    Rectangle {
                        height: 92px;
                        border-radius: AppMetrics.radius;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; y: 12px; width: parent.width - 28px; height: 20px; text: "Index estimate"; color: ThemePalette.text; font-size: 13px; font-weight: 700; }
                        Text { x: 14px; y: 36px; width: parent.width - 28px; height: 44px; text: root.index_status; color: ThemePalette.text_muted; font-size: 12px; wrap: word-wrap; }
                    }

                    Text { text: "THUMBNAIL CACHE"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        height: 76px;
                        border-radius: AppMetrics.radius;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; y: 12px; width: parent.width - 112px; height: 20px; text: "Automatic thumbnail cleanup"; color: ThemePalette.text; font-size: 13px; font-weight: 700; }
                        Text { x: 14px; y: 36px; width: parent.width - 112px; height: 22px; text: root.thumbnail_status; color: ThemePalette.text_muted; font-size: 12px; overflow: elide; }
                        DialogButton { x: parent.width - 92px; y: 22px; label: "Clear"; clicked => { root.clear_thumbnail_cache(); } }
                    }

                    HorizontalLayout {
                        height: 34px;
                        spacing: 8px;
                        DialogButton { label: "Rebuild"; primary: true; clicked => { root.rebuild_index(); } }
                        DialogButton { label: "Debug"; clicked => { root.command("performance-debug"); } }
                    }
                }
            }

            if root.settings_tab == "ai" && !root.is_simple: VerticalLayout {
                x: 20px;
                y: 112px;
                width: parent.width - 40px;
                height: parent.height - 124px;
                spacing: 14px;
                padding-bottom: 16px;

                Text { text: "AI CAPABILITIES"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                Rectangle {
                    height: 100px;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    border-radius: AppMetrics.radius;
                    background: ThemePalette.panel;
                    Text { x: 14px; y: 14px; width: parent.width - 28px; height: 22px; text: root.ai_label; color: ThemePalette.text; font-size: 14px; font-weight: 700; }
                    Text { x: 14px; y: 40px; width: parent.width - 28px; height: 20px; text: root.ai_device; color: ThemePalette.accent_strong; font-size: 12px; font-family: AppMetrics.mono_font; overflow: elide; }
                    Text { x: 14px; y: 66px; width: parent.width - 28px; height: 20px; text: "Thumbnails, content search, and image analysis use the best detected device."; color: ThemePalette.text_muted; font-size: 12px; overflow: elide; }
                }

                Text { text: "FEATURES"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                Rectangle {
                    height: 58px;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    border-radius: AppMetrics.radius;
                    background: ThemePalette.panel;
                    Text { x: 14px; y: 10px; width: parent.width - 28px; height: 18px; text: "AI thumbnail generation"; color: ThemePalette.text; font-size: 13px; font-weight: 600; }
                    Text { x: 14px; y: 32px; width: parent.width - 28px; height: 16px; text: "Generate rich previews for documents and media files"; color: ThemePalette.text_muted; font-size: 11.5px; overflow: elide; }
                }
                Rectangle {
                    height: 58px;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    border-radius: AppMetrics.radius;
                    background: ThemePalette.panel;
                    Text { x: 14px; y: 10px; width: parent.width - 28px; height: 18px; text: "Semantic content search"; color: ThemePalette.text; font-size: 13px; font-weight: 600; }
                    Text { x: 14px; y: 32px; width: parent.width - 28px; height: 16px; text: "Search by meaning, not just filename"; color: ThemePalette.text_muted; font-size: 11.5px; overflow: elide; }
                }
                Rectangle {
                    height: 58px;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    border-radius: AppMetrics.radius;
                    background: ThemePalette.panel;
                    Text { x: 14px; y: 10px; width: parent.width - 28px; height: 18px; text: "Image analysis"; color: ThemePalette.text; font-size: 13px; font-weight: 600; }
                    Text { x: 14px; y: 32px; width: parent.width - 28px; height: 16px; text: "Understand and tag photos automatically"; color: ThemePalette.text_muted; font-size: 11.5px; overflow: elide; }
                }
            }
        }
    }

    if root.confirm_visible: Rectangle {
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0.42);
        Rectangle {
            x: (parent.width - 420px) / 2;
            y: (parent.height - 180px) / 2;
            width: 420px;
            height: 180px;
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            Text { x: 18px; y: 16px; width: parent.width - 36px; height: 26px; text: "Confirm delete"; color: ThemePalette.text; font-size: 18px; font-weight: 700; }
            Text { x: 18px; y: 58px; width: parent.width - 36px; height: 48px; text: root.confirm_text; color: ThemePalette.text_muted; font-size: 13px; wrap: word-wrap; }
            DialogButton { x: parent.width - 180px; y: parent.height - 48px; label: "Cancel"; clicked => { root.confirm_visible = false; } }
            DialogButton { x: parent.width - 90px; y: parent.height - 48px; label: "Delete"; primary: true; danger: true; clicked => { root.confirm_visible = false; root.confirm_delete(); } }
        }
    }

    if root.prompt_visible: Rectangle {
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0.42);

        // Conflict-resolution dialog — three explicit buttons, no text input.
        if root.prompt_kind == "conflict": Rectangle {
            x: (parent.width - 460px) / 2;
            y: (parent.height - 220px) / 2;
            width: 460px;
            height: 220px;
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            Text { x: 18px; y: 16px; width: parent.width - 36px; height: 26px; text: root.prompt_title; color: ThemePalette.text; font-size: 18px; font-weight: 700; }
            Text {
                x: 18px; y: 50px; width: parent.width - 36px; height: 88px;
                text: "A file with the same name already exists.\n\nKeep both: save with a new name like \"file (1).txt\".\nReplace: overwrite the existing file.\nSkip: don't copy this file.";
                color: ThemePalette.text_muted;
                font-size: 12.5px;
                wrap: word-wrap;
            }
            DialogButton { x: 18px; y: parent.height - 48px; label: "Skip"; clicked => { root.prompt_visible = false; root.prompt_kind = "text"; root.prompt_accept("skip"); } }
            DialogButton { x: parent.width - 240px; y: parent.height - 48px; label: "Replace"; clicked => { root.prompt_visible = false; root.prompt_kind = "text"; root.prompt_accept("replace"); } }
            DialogButton { x: parent.width - 120px; y: parent.height - 48px; label: "Keep both"; primary: true; clicked => { root.prompt_visible = false; root.prompt_kind = "text"; root.prompt_accept("keep"); } }
        }

        // Standard text-input prompt (rename / new folder / etc.)
        if root.prompt_kind != "conflict": Rectangle {
            x: (parent.width - 420px) / 2;
            y: (parent.height - 190px) / 2;
            width: 420px;
            height: 190px;
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            Text { x: 18px; y: 16px; width: parent.width - 36px; height: 26px; text: root.prompt_title; color: ThemePalette.text; font-size: 18px; font-weight: 700; }
            prompt := LineEdit {
                x: 18px; y: 66px; width: parent.width - 36px; height: 34px;
                text: root.prompt_value;
                accepted(value) => { root.prompt_visible = false; root.prompt_accept(value); }
                key-pressed(e) => {
                    if (e.text == Key.Escape) { root.prompt_visible = false; return accept; }
                    return reject;
                }
            }
            DialogButton { x: parent.width - 180px; y: parent.height - 48px; label: "Cancel"; clicked => { root.prompt_visible = false; } }
            DialogButton { x: parent.width - 90px; y: parent.height - 48px; label: "OK"; primary: true; clicked => { root.prompt_visible = false; root.prompt_accept(prompt.text); } }
        }
    }

    if root.op_drawer_visible: Rectangle {
        x: (parent.width - 420px) / 2;
        y: parent.height - 124px;
        width: 420px;
        height: 60px;
        border-width: 1px;
        border-color: ThemePalette.border_strong;
        border-radius: AppMetrics.radius;
        background: ThemePalette.panel_solid;
        drop-shadow-blur: 18px;
        drop-shadow-color: rgba(0, 0, 0, 0.35);

        Rectangle {
            x: 0; y: 0; width: 3px; height: parent.height;
            border-radius: AppMetrics.radius;
            background: ThemePalette.accent;
        }

        SvgIcon {
            x: 14px; y: 12px;
            icon_size: 16px;
            data: "M12 2v4 M12 18v4 M4.93 4.93l2.83 2.83 M16.24 16.24l2.83 2.83 M2 12h4 M18 12h4 M4.93 19.07l2.83-2.83 M16.24 7.76l2.83-2.83";
            tint: ThemePalette.accent;
        }

        Text {
            x: 38px;
            y: 8px;
            width: parent.width - 74px;
            height: 22px;
            text: root.op_drawer_text;
            color: ThemePalette.text;
            font-size: 12.5px;
            vertical-alignment: center;
            overflow: elide;
        }

        // Progress track + fill. Determinate when progress is between 0 and 1,
        // indeterminate (a moving 30% bar) when negative.
        Rectangle {
            x: 38px;
            y: parent.height - 18px;
            width: parent.width - 80px;
            height: 6px;
            border-radius: 3px;
            background: rgba(127, 127, 127, 0.18);
            clip: true;
            if root.op_drawer_progress >= 0: Rectangle {
                x: 0; y: 0;
                width: parent.width * Math.clamp(root.op_drawer_progress, 0, 1);
                height: parent.height;
                border-radius: 3px;
                background: ThemePalette.accent;
                animate width { duration: 120ms; easing: ease-out; }
            }
            if root.op_drawer_progress < 0: Rectangle {
                width: parent.width * 0.30;
                height: parent.height;
                border-radius: 3px;
                background: ThemePalette.accent;
                x: 0;
                animate x { duration: 1200ms; easing: ease-in-out; }
            }
        }

        ToolButton {
            x: parent.width - 34px;
            y: 8px;
            button_width: 26px;
            button_height: 26px;
            icon_data: "M18 6L6 18 M6 6l12 12";
            clicked => { root.op_drawer_visible = false; }
        }
    }

    if root.toast_text != "": Rectangle {
        x: (parent.width - 360px) / 2;
        y: parent.height - 78px;
        width: 360px;
        height: 38px;
        border-width: 1px;
        border-color: root.toast_kind == "error" ? ThemePalette.danger :
                      root.toast_kind == "success" ? ThemePalette.success :
                      root.toast_kind == "warning" ? ThemePalette.warning :
                      ThemePalette.border_strong;
        border-radius: AppMetrics.radius;
        background: ThemePalette.panel_solid;
        drop-shadow-blur: 14px;
        drop-shadow-color: rgba(0, 0, 0, 0.38);

        Rectangle {
            x: 0; y: 0; width: 3px; height: parent.height;
            border-radius: AppMetrics.radius;
            background: root.toast_kind == "error" ? ThemePalette.danger :
                        root.toast_kind == "success" ? ThemePalette.success :
                        root.toast_kind == "warning" ? ThemePalette.warning :
                        ThemePalette.accent;
        }

        Text { x: 13px; width: parent.width - 26px; height: parent.height; text: root.toast_text; color: ThemePalette.text; font-size: 12.5px; vertical-alignment: center; overflow: elide; }
    }

    // ── DRAG INDICATOR ───────────────────────────────────────────────
    if ThemePalette.is_dragging: Rectangle {
        x: parent.width - 168px;
        y: parent.height - 96px;
        width: 152px;
        height: 52px;
        border-radius: AppMetrics.radius;
        background: ThemePalette.accent;
        drop-shadow-blur: 18px;
        drop-shadow-color: rgba(0, 0, 0, 0.50);
        z: 60;

        // left icon strip
        Rectangle {
            x: 0; y: 0; width: 44px; height: parent.height;
            border-radius: AppMetrics.radius;
            background: rgba(0, 0, 0, 0.18);
            Text {
                width: parent.width; height: parent.height;
                text: ThemePalette.drag_count > 1 ? "⬡⬡" : "⬡";
                color: rgba(255, 255, 255, 0.90);
                font-size: ThemePalette.drag_count > 1 ? 11px : 14px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Text {
            x: 52px; y: 0;
            width: parent.width - 60px; height: parent.height;
            text: ThemePalette.drag_count == 1
                ? "1 item"
                : ThemePalette.drag_count + " items";
            color: rgba(255, 255, 255, 0.96);
            font-size: 13px;
            font-weight: 600;
            vertical-alignment: center;
        }
        Text {
            x: 52px; y: 16px;
            width: parent.width - 60px; height: parent.height - 20px;
            text: "dragging…";
            color: rgba(255, 255, 255, 0.68);
            font-size: 10.5px;
            vertical-alignment: center;
        }
    }

    // ── UI mode first-run prompt ──────────────────────────────────────
    if root.ui_mode_prompt_visible: Rectangle {
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0.46);
        z: 120;

        Rectangle {
            x: (parent.width - 500px) / 2;
            y: (parent.height - 310px) / 2;
            width: 500px;
            height: 310px;
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            drop-shadow-blur: 20px;
            drop-shadow-color: rgba(0, 0, 0, 0.45);
            TouchArea {}

            Text {
                x: 24px; y: 22px;
                width: parent.width - 48px; height: 28px;
                text: "Choose your experience";
                color: ThemePalette.text;
                font-size: 18px; font-weight: 700;
            }
            Text {
                x: 24px; y: 62px;
                width: parent.width - 48px; height: 44px;
                text: "Pick how much of Pathfinder you want to see. You can change this anytime in Settings → Appearance.";
                color: ThemePalette.text_muted;
                font-size: 12.5px;
                wrap: word-wrap;
            }

            Rectangle {
                x: 24px; y: 122px;
                width: (parent.width - 64px) / 2; height: 130px;
                border-width: 1px;
                border-color: simple_card_touch.has-hover ? ThemePalette.accent : ThemePalette.border;
                border-radius: AppMetrics.radius;
                background: simple_card_touch.has-hover ? ThemePalette.accent_soft : ThemePalette.panel;
                animate background { duration: 40ms; easing: ease-out; }
                Text {
                    x: 16px; y: 16px; width: parent.width - 32px; height: 22px;
                    text: "Simple";
                    color: simple_card_touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text;
                    font-size: 14px; font-weight: 700;
                }
                Text {
                    x: 16px; y: 44px; width: parent.width - 32px;
                    text: "Essential features only.\nClean, focused experience.\nNo dual pane or power tools.";
                    color: ThemePalette.text_muted; font-size: 12px; wrap: word-wrap;
                    height: self.preferred-height;
                }
                simple_card_touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.ui_mode_prompt_visible = false;
                        root.ui_mode = "simple";
                        root.ui_mode_prompt_choice("simple");
                    }
                }
            }

            Rectangle {
                x: parent.width / 2 + 8px; y: 122px;
                width: (parent.width - 64px) / 2; height: 130px;
                border-width: 1px;
                border-color: normal_card_touch.has-hover ? ThemePalette.accent : ThemePalette.border;
                border-radius: AppMetrics.radius;
                background: normal_card_touch.has-hover ? ThemePalette.accent_soft : ThemePalette.panel;
                animate background { duration: 40ms; easing: ease-out; }
                Text {
                    x: 16px; y: 16px; width: parent.width - 32px; height: 22px;
                    text: "Normal";
                    color: normal_card_touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text;
                    font-size: 14px; font-weight: 700;
                }
                Text {
                    x: 16px; y: 44px; width: parent.width - 32px;
                    text: "Full access to every feature:\ndual pane, power tools,\narchive tools, and AI.";
                    color: ThemePalette.text_muted; font-size: 12px; wrap: word-wrap;
                    height: self.preferred-height;
                }
                normal_card_touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.ui_mode_prompt_visible = false;
                        root.ui_mode = "normal";
                        root.ui_mode_prompt_choice("normal");
                    }
                }
            }
        }
    }

    keys := FocusScope {
        KeyBinding { keys: @keys(Control+T); activated => { root.new_tab(); } }
        KeyBinding { keys: @keys(Control+W); activated => { root.tab_closed(-1); } }
        KeyBinding { keys: @keys(Control+L); activated => { root.address_text = root.current_path; root.address_editing = true; } }
        KeyBinding { keys: @keys(Control+Shift+F); activated => { root.command("focus-search"); } }
        KeyBinding { keys: @keys(Control+P); activated => { root.command_filter = ""; root.filter_commands(""); root.command_visible = true; } }
        KeyBinding { keys: @keys(Control+Comma); activated => { root.settings_visible = true; } }
        KeyBinding { keys: @keys(Control+"1"); activated => { root.set_view("grid"); } }
        KeyBinding { keys: @keys(Control+"2"); activated => { root.set_view("list"); } }
        KeyBinding { keys: @keys(Control+"3"); activated => { root.set_view("gallery"); } }
        KeyBinding { keys: @keys(Control+I); activated => { root.toggle_preview(); } }
        KeyBinding { keys: @keys(Control+C); activated => { root.command("copy"); } }
        KeyBinding { keys: @keys(Control+X); activated => { root.command("cut"); } }
        KeyBinding { keys: @keys(Control+V); activated => { root.command("paste"); } }
        KeyBinding { keys: @keys(Control+A); activated => { root.command("select-all"); } }
        KeyBinding { keys: @keys(Control+Z); activated => { root.command("undo"); } }
        KeyBinding { keys: @keys(Control+Shift+N); activated => { root.command("new-folder"); } }
        KeyBinding { keys: @keys(Alt+LeftArrow); activated => { root.go_back(); } }
        KeyBinding { keys: @keys(Alt+RightArrow); activated => { root.go_forward(); } }
        KeyBinding { keys: @keys(Alt+UpArrow); activated => { root.go_up(); } }
        KeyBinding { keys: @keys(F3); activated => { root.toggle_dual_pane(); } }
        KeyBinding { keys: @keys(F5); activated => { root.refresh(); } }
        KeyBinding { keys: @keys(Delete); activated => { root.command("delete"); } }
        KeyBinding { keys: @keys(F2); activated => { root.rename_index = root.selected_index; } }
        KeyBinding { keys: @keys(Return); activated => { root.file_opened(root.selected_index); } }
        KeyBinding { keys: @keys(Space); activated => { root.toggle_preview(); } }
        KeyBinding { keys: @keys(Control+D); activated => { root.command("duplicates"); } }
        KeyBinding { keys: @keys(Control+Shift+C); activated => { root.command("checksum"); } }
        KeyBinding { keys: @keys(UpArrow); activated => { root.file_selected(max(0, root.selected_index - 1), false, false); } }
        KeyBinding { keys: @keys(DownArrow); activated => { root.file_selected(min(root.files.length - 1, root.selected_index + 1), false, false); } }
        KeyBinding { keys: @keys(Escape); activated => { root.context_visible = false; root.image_tools_visible = false; root.command_visible = false; root.settings_visible = false; root.confirm_visible = false; root.prompt_visible = false; root.address_editing = false; root.addr_suggestions = []; root.clear_selection(); if (root.search_text != "") { root.search_text = ""; root.search_requested(""); } } }
    }
}

export global AppMetrics {
    in-out property <length> radius: 8px;
    in-out property <length> radius_small: 5px;
    in-out property <length> row_h: 38px;
    in-out property <length> grid_w: 136px;
    in-out property <length> grid_h: 122px;
    in-out property <length> pad: 16px;
    in-out property <length> outer_border: 0px;
    in-out property <string> ui_font: "Segoe UI";
    in-out property <string> mono_font: "Cascadia Mono";
    in-out property <bool> light_controls: false;
    in-out property <string> icon_set: "";
}
