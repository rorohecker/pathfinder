            ChoiceMenuRow { visible: !root.is_simple; width: parent.width; label: "Batch Rename"; command_name: "batch-rename"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { visible: !root.is_simple; width: parent.width; label: "Checksum"; command_name: "checksum"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Add Note"; command_name: "note"; picked(c) => { root.context_visible = false; root.command(c); } }
            Rectangle { height: 1px; background: ThemePalette.border; }
            Rectangle {
                width: parent.width;
                height: 30px;
                border-radius: AppMetrics.radius_small;
                background: tag_touch.has-hover ? ThemePalette.accent_soft : rgba(0, 0, 0, 0);
                border-width: 1px;
                border-color: tag_touch.has-hover ? ThemePalette.accent : rgba(0, 0, 0, 0);
                SvgIcon {
                    x: 9px;
                    y: (parent.height - 14px) / 2;
                    icon_size: 14px;
                    data: "M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z M7 7h.01";
                    tint: tag_touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text_faint;
                }
                Text {
                    x: 30px;
                    width: parent.width - 104px;
                    height: parent.height;
                    text: "Tags";
                    color: tag_touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text_muted;
                    font-size: 12.5px;
                    vertical-alignment: center;
                }
                // Inline color key (which tag colors exist)
                Rectangle { x: parent.width - 84px; y: (parent.height - 7px) / 2; width: 5px; height: 5px; border-radius: 3px; background: #e05252; border-width: 1px; border-color: rgba(0,0,0,0.12); }
                Rectangle { x: parent.width - 76px; y: (parent.height - 7px) / 2; width: 5px; height: 5px; border-radius: 3px; background: #e08c3a; border-width: 1px; border-color: rgba(0,0,0,0.12); }
                Rectangle { x: parent.width - 68px; y: (parent.height - 7px) / 2; width: 5px; height: 5px; border-radius: 3px; background: #d4b024; border-width: 1px; border-color: rgba(0,0,0,0.12); }
                Rectangle { x: parent.width - 60px; y: (parent.height - 7px) / 2; width: 5px; height: 5px; border-radius: 3px; background: #4caf6a; border-width: 1px; border-color: rgba(0,0,0,0.12); }
                Rectangle { x: parent.width - 52px; y: (parent.height - 7px) / 2; width: 5px; height: 5px; border-radius: 3px; background: #4a90d9; border-width: 1px; border-color: rgba(0,0,0,0.12); }
                Rectangle { x: parent.width - 44px; y: (parent.height - 7px) / 2; width: 5px; height: 5px; border-radius: 3px; background: #8b5cf6; border-width: 1px; border-color: rgba(0,0,0,0.12); }
                SvgIcon {
                    x: parent.width - 22px;
                    y: (parent.height - 14px) / 2;
                    icon_size: 13px;
                    data: root.context_tags_expanded
                        ? "M18 15l-6-6-6 6"
                        : "M6 9l6 6 6-6";
                    tint: tag_touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text_faint;
                }
                tag_touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.context_tags_expanded = !root.context_tags_expanded; }
                }
            }
            if root.context_tags_expanded: TagMenuRow { width: parent.width; label: root.tag_names[0]; dot_color: #e05252; command_name: "tag-red"; picked(c) => { root.context_visible = false; root.context_tags_expanded = false; root.command(c); } }
            if root.context_tags_expanded: TagMenuRow { width: parent.width; label: root.tag_names[1]; dot_color: #e08c3a; command_name: "tag-orange"; picked(c) => { root.context_visible = false; root.context_tags_expanded = false; root.command(c); } }
            if root.context_tags_expanded: TagMenuRow { width: parent.width; label: root.tag_names[2]; dot_color: #d4b024; command_name: "tag-yellow"; picked(c) => { root.context_visible = false; root.context_tags_expanded = false; root.command(c); } }
            if root.context_tags_expanded: TagMenuRow { width: parent.width; label: root.tag_names[3]; dot_color: #4caf6a; command_name: "tag-green"; picked(c) => { root.context_visible = false; root.context_tags_expanded = false; root.command(c); } }
            if root.context_tags_expanded: TagMenuRow { width: parent.width; label: root.tag_names[4]; dot_color: #4a90d9; command_name: "tag-blue"; picked(c) => { root.context_visible = false; root.context_tags_expanded = false; root.command(c); } }
            if root.context_tags_expanded: TagMenuRow { width: parent.width; label: root.tag_names[5]; dot_color: #8b5cf6; command_name: "tag-violet"; picked(c) => { root.context_visible = false; root.context_tags_expanded = false; root.command(c); } }
            if root.context_tags_expanded: ChoiceMenuRow { width: parent.width; label: "Clear Tag"; command_name: "tag-clear"; picked(c) => { root.context_visible = false; root.context_tags_expanded = false; root.command(c); } }
            Rectangle { height: 1px; background: ThemePalette.border; }
            ChoiceMenuRow { width: parent.width; label: "Copy as Path"; command_name: "copy-as-path"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Open in Terminal"; command_name: "open-terminal"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Open With"; command_name: "open-with"; picked(c) => { root.context_visible = false; root.command(c); } }
            Rectangle { visible: !root.is_simple; height: 1px; background: ThemePalette.border; }
            ChoiceMenuRow { visible: !root.is_simple; width: parent.width; label: "Image Tools"; command_name: "image-tools"; picked(c) => { root.context_visible = false; root.command(c); } }
            Rectangle { height: 1px; background: ThemePalette.border; }
            ChoiceMenuRow { width: parent.width; label: "Properties"; command_name: "properties"; picked(c) => { root.context_visible = false; root.command(c); } }

            Rectangle { visible: !root.is_simple; height: 1px; background: ThemePalette.border; }
            ChoiceMenuRow { visible: !root.is_simple; width: parent.width; label: "Create ZIP"; command_name: "create-zip"; picked(c) => { root.context_visible = false; root.command(c); } }

            // ── Advanced toggle (ZIP lives above; this expands power / Windows tools) ──────────────
            Rectangle {
                visible: !root.is_simple;
                width: parent.width;
                height: 26px;
                background: adv_touch.has-hover ? ThemePalette.panel_alt : transparent;
                border-radius: AppMetrics.radius_small;
                adv_touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.context_advanced = !root.context_advanced; }
                }
                Text {
                    width: parent.width - 18px;
                    x: 9px;
                    height: parent.height;
                    text: root.context_advanced ? "▲ Hide advanced" : "▼ Advanced & Windows tools";
                    color: ThemePalette.text_faint;
                    font-size: 11px;
                    vertical-alignment: center;
                }
            }

            // ── Advanced items (hidden by default, never shown in simple mode) ────────────────────
            if root.context_is_archive: Rectangle { height: 1px; background: ThemePalette.border; }
            if root.context_is_archive: ChoiceMenuRow { width: parent.width; label: "Archive Browser"; command_name: "archive-browser"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.context_is_archive: ChoiceMenuRow { width: parent.width; label: "Extract Here"; command_name: "extract-here"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.context_advanced && !root.is_simple: Rectangle { height: 1px; background: ThemePalette.border; }
            if root.context_advanced && !root.is_simple: ChoiceMenuRow { width: parent.width; label: "Copy as PowerShell Path"; command_name: "copy-as-powershell"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.context_advanced && !root.is_simple: ChoiceMenuRow { width: parent.width; label: "Locked File Inspector"; command_name: "locked-file"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.context_advanced && !root.is_simple: ChoiceMenuRow { width: parent.width; label: "Defender Scan"; command_name: "defender-scan"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.context_advanced && !root.is_simple: ChoiceMenuRow { width: parent.width; label: "Cloud State"; command_name: "cloud-state"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.context_advanced && !root.is_simple: ChoiceMenuRow { width: parent.width; label: "Show More Options"; command_name: "show-more-options"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.context_advanced && !root.is_simple: Rectangle { height: 1px; background: ThemePalette.border; }
            if root.context_advanced && !root.is_simple: ChoiceMenuRow { width: parent.width; label: "Run as Administrator"; command_name: "run-as-admin"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.context_advanced && !root.is_simple: ChoiceMenuRow { width: parent.width; label: "Take Ownership"; command_name: "take-ownership"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.context_advanced && !root.is_simple: ChoiceMenuRow { width: parent.width; label: "Previous Versions"; command_name: "previous-versions"; picked(c) => { root.context_visible = false; root.command(c); } }

            Rectangle { height: 1px; background: ThemePalette.border; }
            ChoiceMenuRow { width: parent.width; label: "Delete"; command_name: "delete"; danger: true; picked(c) => { root.context_visible = false; root.command(c); } }
        }
        }
    }

    // Context menu — empty area
    if root.context_visible && !root.context_on_file: Rectangle {
        x: root.context_x;
