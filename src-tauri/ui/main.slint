import { LineEdit, ListView, ScrollView, Slider, Palette } from "std-widgets.slint";
export { Palette }
import { FantasyAtmosphere, FantasyChestSparkles } from "fantasy_fx.slint";
import {
    FantasyIconGallery,
    FantasyEmptyOrnament,
    FantasyChestGlyph,
    FantasyPixel,
} from "fantasy_icons.slint";

// Bundled OFL fonts (embedded via build.rs). Family names come from font metadata.
import "fonts/PressStart2P-Regular.ttf";
import "fonts/NotoSans-Regular.ttf";
import "fonts/NotoSansMono-Regular.ttf";
import "fonts/JetBrainsMono-Variable.ttf";
import "fonts/Inter-Regular.ttf";
import "fonts/Lora-Regular.ttf";
import "fonts/FiraCode-Regular.ttf";

export struct FileItem {
    name: string,
    file_path: string,
    is_dir: bool,
    size_text: string,
    // Relative size 0..1 within the current folder (for details size bar).
    size_ratio: float,
    modified_text: string,
    type_text: string,
    extension: string,
    has_tag: bool,
    tag_color: color,
    git_badge: string,
    git_color: color,
    has_note: bool,
    is_selected: bool,
    has_thumbnail: bool,
    thumbnail: image,
    // System-extracted icon (the file's actual shell icon - .exe embedded
    // icons, .lnk targets, type associations for .docx / .pdf / etc.).
    // When non-empty (width > 0), NodeVisual draws this instead of the
    // procedural file glyph so executables and document types look correct.
    has_system_icon: bool,
    system_icon: image,
    // Date grouping for the details view when sorted by Date Modified. Mirrors
    // what File Explorer does: each row carries the bucket it falls into
    // (Today, Yesterday, This week, etc) and a flag that is true on the first
    // row of a new bucket so the list view can draw a section divider above it.
    date_group_text: string,
    show_date_group_header: bool,
    // True while the path is on the cut clipboard (Ctrl+X) and not yet pasted.
    is_cut_pending: bool,
    // Filename stem shown in the inline rename box (extension omitted for files).
    rename_label: string,
}

export struct SideItem {
    label: string,
    path: string,
    icon: string,
    count: string,
    color: color,
    is_header: bool,
    active: bool,
    // Nested folder-tree indent (0 = top level).
    indent: int,
    // Drive usage 0..1; negative hides the bar.
    usage: float,
    expandable: bool,
    expanded: bool,
}

export struct TabItem {
    title: string,
    path: string,
    active: bool,
}

export struct ChoiceItem {
    id: string,
    label: string,
    description: string,
    color: color,
}

export struct CommandItem {
    group: string,
    label: string,
    hint: string,
    command: string,
}

export struct ToolListItem {
    id: string,
    title: string,
    subtitle: string,
    meta: string,
    enabled: bool,
    accent: color,
}

export struct ShortcutEditItem {
    command: string,
    label: string,
    hint: string,
    group: string,
}

export struct CompareRowItem {
    path: string,
    status: string,
    left_size: string,
    right_size: string,
}

export struct DupeGroupItem {
    id: string,
    title: string,
    detail: string,
    count: int,
    reclaimable: string,
    keep_path: string,
    paths_preview: string,
    keep_size: string,
}

export struct StorageBucketUi {
    id: string,
    name: string,
    bytes_text: string,
    file_count_text: string,
    percent: float,
    icon: string,
    color: color,
}

export struct StorageEntryUi {
    name: string,
    path: string,
    bytes_text: string,
    modified_text: string,
    bucket: string,
    is_dir: bool,
    bar_pct: float,
    bucket_color: color,
}

// One recommendation card on the storage overview. Severity drives
// the left accent: "info" (neutral blue), "tip" (green - actionable
// cleanup), "warn" (amber - large or stale).
export struct StorageTipUi {
    icon: string,
    title: string,
    detail: string,
    bytes_text: string,
    severity: string,
    path: string,
    action: string,
    accent: color,
}

export global ThemePalette {
    in-out property <color> bg: #101318;
    in-out property <color> bg_soft: #171b22;
    in-out property <color> panel: rgba(28, 33, 42, 0.82);
    in-out property <color> panel_solid: #1c212a;
    in-out property <color> panel_alt: #232936;
    in-out property <color> titlebar: rgba(18, 22, 29, 0.92);
    in-out property <color> sidebar: rgba(22, 26, 34, 0.84);
    in-out property <color> border: rgba(157, 172, 196, 0.16);
    in-out property <color> border_strong: rgba(185, 198, 220, 0.26);
    in-out property <color> text: #f2f6fb;
    in-out property <color> text_muted: #b5c0cf;
    in-out property <color> text_faint: #7f8b9d;
    in-out property <color> accent: #4f9cff;
    in-out property <color> accent_soft: rgba(79, 156, 255, 0.16);
    in-out property <color> accent_strong: #72b3ff;
    in-out property <color> danger: #e5484d;
    in-out property <color> success: #37b26c;
    in-out property <color> warning: #e3a524;
    in-out property <color> icon_folder_1: #ffd86a;
    in-out property <color> icon_folder_2: #e2a934;
    in-out property <string> active_theme: "mica-dark";
    // Custom themes: soft vertical gradient between bg_soft and bg instead of flat bg.
    in-out property <bool> bg_gradient_enabled: false;
    // When true, window background gradient blends toward accent at the bottom.
    in-out property <bool> bg_gradient_accent_tip: false;
    // Runtime-loaded folder icon image. Set from Rust by reading
    // %APPDATA%\Pathfinder\theme_icons\{theme}.png. If width is 0px the
    // file wasn't found and NodeVisual falls back to its drawn shape.
    in-out property <image> folder_icon_image;
    // Text that sits on accent / danger fills (primary buttons, active chips).
    in-out property <color> on_accent: #ffffff;
    // True while DoDragDrop is blocking the UI thread - selected items show glow
    in-out property <bool> is_dragging: false;
    in-out property <int> drag_count: 0;
}

// Pixel banks for High Fantasy animated icons (filled from Rust once at startup).
export global FantasyIconBank {
    in-out property <[FantasyPixel]> chest: [];
    in-out property <[FantasyPixel]> scroll: [];
    in-out property <[FantasyPixel]> gem_a: [];
    in-out property <[FantasyPixel]> gem_b: [];
    in-out property <[FantasyPixel]> potion: [];
    in-out property <[FantasyPixel]> tower_a: [];
    in-out property <[FantasyPixel]> tower_b: [];
    in-out property <[FantasyPixel]> cauldron: [];
}

component SvgIcon {
    in property <string> data;
    in property <color> tint: ThemePalette.text_muted;
    in property <length> icon_size: 16px;
    width: root.icon_size;
    height: root.icon_size;

    Path {
        width: root.icon_size;
        height: root.icon_size;
        commands: root.data;
        fill: rgba(0, 0, 0, 0);
        stroke: root.tint;
        stroke-width: 1.5px;
        stroke-line-cap: round;
        stroke-line-join: miter;
    }
}

component HoverTip inherits Rectangle {
    in property <string> tip_text;
    in property <length> tip_max_width: 340px;

    width: Math.min(root.tip_max_width, text_node.preferred-width + 16px);
    height: 26px;
    border-radius: AppMetrics.radius_small;
    border-width: 1px;
    border-color: ThemePalette.border_strong;
    background: ThemePalette.panel_solid;
    drop-shadow-blur: 18px;
    drop-shadow-color: rgba(0, 0, 0, 0.35);

    text_node := Text {
        x: 8px;
        width: parent.width - 16px;
        height: parent.height;
        text: root.tip_text;
        color: ThemePalette.text;
        font-size: 11.5px;
        vertical-alignment: center;
        overflow: elide;
    }
}

component ToolButton inherits Rectangle {
    in property <string> icon_data;
    in property <string> text_label;
    in property <string> tooltip;
    in property <bool> active;
    in property <bool> danger;
    // In simple mode the main window sets this true so every toolbar button
    // shows its label under the icon at all times instead of only on hover.
    in property <bool> show_caption;
    in property <bool> tooltip_above;
    in property <length> button_width: 31px;
    in property <length> button_height: 31px;
    callback clicked();

    width: root.button_width;
    height: root.button_height;
    border-radius: AppMetrics.radius_small;
    border-width: root.active ? 1px : 0px;
    border-color: root.active ? ThemePalette.accent : rgba(0, 0, 0, 0);
    background: root.danger && touch.has-hover ? ThemePalette.danger :
        (touch.pressed ? rgba(255, 255, 255, 0.12) :
        (root.active ? ThemePalette.accent_soft :
        (touch.has-hover ? rgba(255, 255, 255, 0.06) : rgba(0, 0, 0, 0))));

    // Two captioned layouts:
    //   - Wide button (width >= 72 px): icon on the left, label to the
    //     right. Used by the simple-mode toolbar where each button is 88x38 and
    //     the caption needs to read like a normal button label.
    //   - Tall button (narrower slots): icon on top, label beneath.
    property <bool> caption_inline: root.show_caption && root.width >= 72px;

    SvgIcon {
        x: root.caption_inline ? 10px : (parent.width - 16px) / 2;
        y: root.caption_inline
            ? (parent.height - 16px) / 2
            : (root.show_caption ? 4px : (parent.height - 16px) / 2);
        icon_size: 16px;
        data: root.icon_data;
        tint: root.danger && touch.has-hover ? white : (root.active || touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text_muted);
    }

    // Icon-less button: centered glyph or letter.
    Text {
        visible: root.icon_data == "" && !root.show_caption;
        text: root.text_label;
        color: root.danger && touch.has-hover ? white : (root.active || touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text_muted);
        font-size: 16px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    // Inline caption (icon-left layout) - wider buttons use this form so the
    // text has breathing room and reads naturally.
    if root.show_caption && root.text_label != "" && root.caption_inline: Text {
        x: 32px;
        y: 0;
        width: parent.width - 36px;
        height: parent.height;
        text: root.text_label;
        color: root.active || touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text_muted;
        font-size: 12px;
        font-weight: 600;
        horizontal-alignment: left;
        vertical-alignment: center;
        overflow: elide;
    }

    // Stacked caption (icon-on-top layout) - kept for narrow captioned buttons
    // where there isn't room for the inline form.
    if root.show_caption && root.text_label != "" && !root.caption_inline: Text {
        x: 0;
        y: 22px;
        width: parent.width;
        height: parent.height - 22px;
        text: root.text_label;
        color: root.active || touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text_muted;
        font-size: 9.5px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: top;
        overflow: elide;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    if root.tooltip != "" && touch.has-hover: Rectangle {
        z: 500;
        // Selection bar and bottom toolbar rows clip or cover downward
        // tooltips; flip above the button when requested.
        x: root.tooltip_above
            ? Math.max(-40px, (parent.width - (tip_text.preferred-width + 16px)) / 2)
            : Math.min(0px, parent.width - (tip_text.preferred-width + 16px));
        y: root.tooltip_above ? -34px : parent.height + 6px;
        width: tip_text.preferred-width + 16px;
        height: 26px;
        border-radius: AppMetrics.radius_small;
        border-width: 1px;
        border-color: ThemePalette.border_strong;
        background: ThemePalette.panel_solid;
        drop-shadow-blur: 18px;
        drop-shadow-color: rgba(0, 0, 0, 0.35);

        tip_text := Text {
            x: 8px;
            width: parent.width - 16px;
            height: parent.height;
            text: root.tooltip;
            color: ThemePalette.text;
            font-size: 11.5px;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

component TabButton inherits Rectangle {
    in property <TabItem> tab;
    in property <int> index;
    in property <string> drag_target_path;
    in property <int> tab_drag_from: -1;
    in property <int> tab_drag_over: -1;
    callback activated(int);
    callback closed(int);
    callback context_menu(int);
    callback tab_drag_start(int);
    callback tab_drag_hover(int);
    callback tab_drag_end(int, int);

    property <bool> is_drop_target: (root.tab_drag_from >= 0 && root.tab_drag_over == root.index && root.tab_drag_from != root.index)
        || (root.drag_target_path != "" && root.drag_target_path == root.tab.path);

    // Use preferred-width + min/max-width (not `width`) so HorizontalLayout's
    // sizing pass and the rendered visual stay in sync. Setting `width`
    // directly on a layout child mixed badly with the layout algorithm and
    // gave clicks vs visible-position mismatches on some tabs.
    preferred-width: Math.min(240px, Math.max(132px, title_text.preferred-width + 50px));
    min-width: 132px;
    max-width: 240px;
    horizontal-stretch: 0;
    height: 30px;
    border-radius: 7px;
    border-width: root.is_drop_target ? 2px : (root.tab.active ? 1px : 0px);
    border-color: root.is_drop_target ? ThemePalette.accent_strong : ThemePalette.border;
    background: root.is_drop_target
        ? ThemePalette.accent_soft
        : (root.tab.active ? ThemePalette.panel : (touch.has-hover ? ThemePalette.panel_alt : rgba(0, 0, 0, 0)));
    animate background { duration: 40ms; easing: linear; }
    animate border-color { duration: 120ms; easing: ease-out; }

    title_text := Text {
        x: 10px;
        y: 0;
        width: parent.width - 38px;
        height: parent.height;
        text: root.tab.title;
        color: root.tab.active ? ThemePalette.text : ThemePalette.text_muted;
        font-size: 12px;
        overflow: elide;
        vertical-alignment: center;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        property <length> press_x: 0;
        property <bool> dragging: false;
        clicked => {
            if (!self.dragging) { root.activated(root.index); }
        }
        moved => {
            if (self.pressed && !self.dragging && abs(self.mouse-x - self.press_x) > 8px) {
                self.dragging = true;
                root.tab_drag_start(root.index);
            }
            if (self.pressed && self.dragging) {
                root.tab_drag_hover(root.index);
            }
        }
        pointer-event(event) => {
            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                self.press_x = self.mouse-x;
                self.dragging = false;
            }
            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                if (self.dragging) {
                    root.tab_drag_end(root.tab_drag_from, root.tab_drag_over >= 0 ? root.tab_drag_over : root.index);
                }
                self.dragging = false;
            }
            if (event.button == PointerEventButton.middle && event.kind == PointerEventKind.up) {
                root.closed(root.index);
            }
            if (event.button == PointerEventButton.right && event.kind == PointerEventKind.up) {
                root.context_menu(root.index);
            }
        }
    }

    ToolButton {
        x: parent.width - 28px;
        y: 3px;
        button_width: 24px;
        button_height: 24px;
        icon_data: "M18 6L6 18 M6 6l12 12";
        tooltip: "Close tab";
        visible: touch.has-hover || root.tab.active;
        clicked => { root.closed(root.index); }
    }

    if touch.has-hover && root.tab.path != "": HoverTip {
        x: 4px;
        y: -32px;
        tip_max_width: 420px;
        tip_text: root.tab.path;
    }
}

component SideRow inherits Rectangle {
    in property <SideItem> item;
    in property <int> index;
    in property <string> drag_target_path;
    callback activated(int);
    callback rename_activated(string);
    callback expand_toggled(string);

    property <bool> is_drop_target: !root.item.is_header
        && root.drag_target_path != ""
        && root.drag_target_path == root.item.path;

    height: root.item.is_header ? 24px : 32px;
    background: rgba(0, 0, 0, 0);

    // Visual highlight pill. Sits inside the row but pulls a 20 px gutter
    // in from the right edge so the sidebar ListView's scroll bar paints
    // in its own lane with visible breathing room from the pill. When this
    // row is the current drop target, a brighter accent_soft fills the pill
    // and a thin accent border outlines it so the user can tell exactly
    // where the file will land.
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width - 20px;
        height: parent.height;
        border-radius: AppMetrics.radius_small;
        border-width: root.is_drop_target ? 2px : 0px;
        border-color: root.is_drop_target ? ThemePalette.accent_strong : rgba(0, 0, 0, 0);
        background: root.is_drop_target
            ? ThemePalette.accent_soft
            : (!root.item.is_header && root.item.active
                ? ThemePalette.accent_soft
                : (!root.item.is_header && touch.has-hover
                    ? rgba(255, 255, 255, 0.06)
                    : rgba(0, 0, 0, 0)));
        animate background { duration: 120ms; easing: ease-out; }
        animate border-color { duration: 120ms; easing: ease-out; }
    }

    Text {
        visible: root.item.is_header;
        x: 8px;
        width: parent.width - 16px;
        height: parent.height;
        text: root.item.label;
        color: ThemePalette.text_faint;
        font-size: 11px;
        font-weight: 700;
        vertical-alignment: center;
    }

    Rectangle {
        visible: !root.item.is_header && root.item.icon == "tag";
        x: 12px;
        y: (parent.height - 9px) / 2;
        width: 9px;
        height: 9px;
        border-radius: 5px;
        background: root.item.color;
        border-width: 1px;
        border-color: rgba(0, 0, 0, 0.14);
    }

    // Expand/collapse chevron for folder tree rows (SVG caret — no empty boxes).
    if !root.item.is_header && root.item.expandable: TouchArea {
        x: 2px + root.item.indent * 12px;
        y: (parent.height - 18px) / 2;
        width: 18px;
        height: 18px;
        mouse-cursor: pointer;
        clicked => { root.expand_toggled(root.item.path); }
        SvgIcon {
            x: 3px; y: 3px; icon_size: 12px;
            data: root.item.expanded
                ? "M6 9l6 6 6-6"
                : "M9 6l6 6-6 6";
            tint: ThemePalette.text_faint;
        }
    }

    // High Fantasy: map known sidebar icons to animated pixel relics.
    // Sparse (sidebar rows only — never ListView file rows). Timers pause off-theme.
    property <bool> fantasy_side: ThemePalette.active_theme == "fantasy" && !root.item.is_header && root.item.icon != "tag";
    property <string> fantasy_kind:
        root.item.icon == "trash" ? "cauldron" :
        (root.item.icon == "home" || root.item.icon == "drive") ? "tower" :
        root.item.icon == "download" ? "potion" :
        root.item.icon == "documents" ? "scroll" :
        (root.item.icon == "search" || root.item.icon == "image") ? "gem" :
        root.item.icon == "folder" ? "chest" :
        "";
    property <bool> fantasy_glyph: root.fantasy_side && root.fantasy_kind != "";

    if root.fantasy_glyph: FantasyEmptyOrnament {
        x: (root.item.expandable ? 18px : 7px) + root.item.indent * 12px;
        y: (parent.height - self.height) / 2;
        cell: 1.5px;
        kind: root.fantasy_kind;
        running: ThemePalette.active_theme == "fantasy";
        hovered: touch.has-hover;
        chest: FantasyIconBank.chest;
        scroll: FantasyIconBank.scroll;
        gem_a: FantasyIconBank.gem_a;
        gem_b: FantasyIconBank.gem_b;
        potion: FantasyIconBank.potion;
        tower_a: FantasyIconBank.tower_a;
        tower_b: FantasyIconBank.tower_b;
        cauldron: FantasyIconBank.cauldron;
    }

    SvgIcon {
        visible: !root.item.is_header && root.item.icon != "tag" && !root.fantasy_glyph;
        x: (root.item.expandable ? 20px : 9px) + root.item.indent * 12px;
        y: (parent.height - 16px) / 2;
        icon_size: 16px;
        data: root.item.icon == "drive" ? "M22 12H2 M5.5 5.2 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.5-6.8A2 2 0 0 0 16.7 4H7.3a2 2 0 0 0-1.8 1.2z" :
              root.item.icon == "home" ? "M3 10l9-7 9 7v10a2 2 0 0 1-2 2h-4v-7H9v7H5a2 2 0 0 1-2-2z" :
              root.item.icon == "download" ? "M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M7 10l5 5 5-5 M12 15V3" :
              root.item.icon == "image" ? "M21 15V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2z M8 11a2 2 0 1 0 0-4 2 2 0 0 0 0 4z M21 19l-6-6-9 9" :
              // Music: eighth note (Lucide "music" glyph)
              root.item.icon == "music" ? "M9 18V5l12-2v13 M9 18a3 3 0 1 1-6 0 3 3 0 0 1 6 0z M21 16a3 3 0 1 1-6 0 3 3 0 0 1 6 0z" :
              // Video: filmstrip / play screen (Lucide "video" glyph)
              root.item.icon == "video" ? "M22 8l-6 4 6 4V8z M14 6H4a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2z" :
              // Documents: page with text lines (Lucide "file-text" glyph)
              root.item.icon == "documents" ? "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8" :
              // Trash: bin with lid + handle (Lucide "trash-2" glyph)
              root.item.icon == "trash" ? "M3 6h18 M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6 M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2 M10 11v6 M14 11v6" :
              // Storage analyzer icon (Lucide "pie-chart" glyph).
              root.item.icon == "storage" ? "M21.21 15.89A10 10 0 1 1 8 2.83 M22 12A10 10 0 0 0 12 2v10z" :
              "M3 7.5A2.5 2.5 0 0 1 5.5 5H10l2 2h6.5A2.5 2.5 0 0 1 21 9.5v7A2.5 2.5 0 0 1 18.5 19h-13A2.5 2.5 0 0 1 3 16.5z";
        tint: root.item.active ? ThemePalette.accent_strong : ThemePalette.text_muted;
    }

    Text {
        visible: !root.item.is_header;
        x: 38px + root.item.indent * 12px + (root.item.expandable ? 10px : 0px);
        width: parent.width - 86px - root.item.indent * 12px;
        height: parent.height;
        text: root.item.label;
        color: root.item.active ? ThemePalette.accent_strong : (touch.has-hover ? ThemePalette.text : ThemePalette.text_muted);
        font-size: 13px;
        overflow: elide;
        vertical-alignment: center;
    }

    Text {
        visible: !root.item.is_header && !(root.item.icon == "tag" && touch.has-hover);
        // Count text (tag counts, drive labels like "local") sits inside the
        // highlight pill, not past its right edge. The pill ends 20 px from
        // the row's right edge, so the count is anchored to parent.width - 62
        // and ends at parent.width - 24, leaving a small inset inside the pill.
        x: parent.width - 62px;
        width: 38px;
        height: parent.height;
        text: root.item.count;
        color: ThemePalette.text_faint;
        font-family: AppMetrics.mono_font;
        font-size: 10px;
        horizontal-alignment: right;
        vertical-alignment: center;
        overflow: elide;
    }

    // Rename button - shown on hover for tag items; click handled via touch.mouse-x
    // Positioned inside the highlight pill so the click target is visible
    // when the row is highlighted.
    if !root.item.is_header && root.item.icon == "tag" && touch.has-hover: Rectangle {
        x: parent.width - 44px;
        y: (parent.height - 22px) / 2;
        width: 22px; height: 22px;
        border-radius: AppMetrics.radius_small;
        background: rgba(255, 255, 255, 0.1);
        SvgIcon {
            x: 4px; y: 4px;
            icon_size: 14px;
            data: "M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7 M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z";
            tint: ThemePalette.text_muted;
        }
    }

    // Match the highlight pill's width (which reserves 20px on the right for
    // the sidebar scrollbar). Previously this TouchArea covered the full row,
    // so hovering the rightmost 20px registered hover but the pill rendered
    // only over the first parent.width-20 - the highlight looked broken in
    // that lane. Shrinking the hit area keeps hover and visual highlight
    // exactly aligned across the full clickable region.
    touch := TouchArea {
        x: 0;
        y: 0;
        width: parent.width - 20px;
        height: parent.height;
        enabled: !root.item.is_header;
        mouse-cursor: pointer;
        clicked => {
            if (root.item.icon == "tag" && touch.mouse-x >= touch.width - 28px) {
                root.rename_activated(root.item.path);
            } else {
                root.activated(root.index);
            }
        }
        double-clicked => {
            if (root.item.icon == "tag") { root.rename_activated(root.item.path); }
        }
    }

}

component NodeVisual {
    in property <bool> is_dir;
    in property <string> extension;
    // Hover from the parent FileRow — drives fantasy chest sparkles only.
    in property <bool> hovered: false;
    // Folders use a clearly wider-than-tall outline so they read as a folder
    // silhouette and not a square tile. Iterations: 54x44 (1.23) was near square,
    // 62x40 (1.55) was wider but still chunky, 68x36 (1.89) is closer to the
    // proportions of a real manila folder.
    in property <length> visual_width: root.is_dir ? 68px : 46px;
    in property <length> visual_height: root.is_dir ? 36px : 54px;

    width: root.visual_width;
    height: root.visual_height;

    property <color> ext_color:
        root.extension == "pdf" ? #e5474c :
        (root.extension == "doc" || root.extension == "docx" || root.extension == "odt" || root.extension == "rtf" ? #4f9cff :
        (root.extension == "xls" || root.extension == "xlsx" || root.extension == "csv" || root.extension == "ods" ? #2db87c :
        (root.extension == "ppt" || root.extension == "pptx" || root.extension == "odp" ? #e3a524 :
        (root.extension == "png" || root.extension == "jpg" || root.extension == "jpeg" || root.extension == "gif" || root.extension == "svg" || root.extension == "webp" || root.extension == "bmp" || root.extension == "ico" ? #a87ef8 :
        (root.extension == "rs" || root.extension == "js" || root.extension == "ts" || root.extension == "py" || root.extension == "c" || root.extension == "cpp" || root.extension == "h" || root.extension == "hpp" || root.extension == "go" || root.extension == "java" || root.extension == "kt" || root.extension == "cs" || root.extension == "rb" || root.extension == "lua" || root.extension == "zig" ? #2dd4bf :
        (root.extension == "zip" || root.extension == "tar" || root.extension == "gz" || root.extension == "7z" || root.extension == "rar" || root.extension == "xz" ? #f59e0b :
        (root.extension == "mp3" || root.extension == "mp4" || root.extension == "wav" || root.extension == "flac" || root.extension == "ogg" || root.extension == "mkv" || root.extension == "avi" || root.extension == "mov" ? #f472b6 :
        (root.extension == "exe" || root.extension == "msi" || root.extension == "bat" || root.extension == "cmd" ? #fb923c :
        ThemePalette.accent))))))));

    // True when a per-theme PNG is loaded - shapes below are skipped so transparent
    // areas of the PNG don't reveal the standard yellow folder underneath.
    property <bool> use_image: ThemePalette.folder_icon_image.width > 0;

    // -- IMAGE OVERLAY -----------------------------------------------------
    // PNG saved to %APPDATA%\Pathfinder\theme_icons\<theme>.png renders here.
    if root.is_dir && root.use_image: Image {
        x: 0; y: 0;
        width: parent.width; height: parent.height;
        source: ThemePalette.folder_icon_image;
        image-fit: contain;
    }

    // Standard folder shape - used by every theme except terminal and
    // cyberpunk (which have non-folder custom shapes whose black border
    // can't be removed). Each theme provides its own color pair via
    // ThemePalette.icon_folder_1 / icon_folder_2 so the result reads as a
    // folder but matches the theme palette.
    property <bool> uses_standard_folder:
        ThemePalette.active_theme != "terminal" &&
        ThemePalette.active_theme != "cyberpunk" &&
        ThemePalette.active_theme != "retro" &&
        ThemePalette.active_theme != "fantasy";

    // Standard folder. Modeled on the reference shape: a rounded rectangular
    // body with a darker tab in the upper-left that has a diagonal right edge.
    // Drawn in three layers so the silhouette reads at any size and renders
    // crisply on HiDPI without rasterised assets.
    //
    //   1. Darker back edge - thin strip at the bottom that peeks below the
    //      body, suggesting the rear flap of a manila folder.
    //   2. Tab - darker amber rectangle at top-left, ~42% wide, with the right
    //      edge angled by a 1.5x-wide triangle-ish rectangle slanted in.
    //   3. Body - full-width rounded rectangle covering ~80% of the height,
    //      overlapping the bottom edge of the tab so only the tab's top sticks
    //      up like an actual manila folder tab.
    //   4. Subtle top highlight stripe inside the body for depth.

    // Back edge strip (a darker tone showing under the body)
    if root.is_dir && !root.use_image && root.uses_standard_folder: Rectangle {
        x: 0; y: parent.height - 4px;
        width: parent.width; height: 4px;
        border-radius: 3px;
        background: ThemePalette.icon_folder_2.darker(0.25);
    }
    // Tab on top-left, darker than the body
    if root.is_dir && !root.use_image && root.uses_standard_folder: Rectangle {
        x: 0; y: 0;
        width: parent.width * 0.42;
        height: parent.height * 0.28;
        border-radius: 4px;
        background: ThemePalette.icon_folder_2.darker(0.15);
    }
    // Tab right-edge taper - a smaller rectangle just to the right of the tab
    // body extends it with a stepped silhouette that reads as an angled cut.
    if root.is_dir && !root.use_image && root.uses_standard_folder: Rectangle {
        x: parent.width * 0.42 - 6px;
        y: 0;
        width: parent.width * 0.10;
        height: parent.height * 0.20;
        border-radius: 3px;
        background: ThemePalette.icon_folder_2.darker(0.15);
    }
    // Body - overlaps the tab from below so only the tab's top sticks up.
    if root.is_dir && !root.use_image && root.uses_standard_folder: Rectangle {
        x: 0;
        y: parent.height * 0.20;
        width: parent.width;
        height: parent.height * 0.78;
        border-radius: 6px;
        background: @linear-gradient(180deg,
            ThemePalette.icon_folder_1 0%,
            ThemePalette.icon_folder_2 100%);
        // Subtle inner top highlight for depth.
        Rectangle {
            x: 2px; y: 1px;
            width: parent.width - 4px;
            height: parent.height * 0.22;
            border-radius: 4px;
            background: rgba(255, 255, 255, 0.18);
        }
    }

    // -- TERMINAL: CRT monitor ---------------------------------------------
    if root.is_dir && !root.use_image && ThemePalette.active_theme == "terminal": Rectangle {
        x: 0; y: 0; width: parent.width; height: parent.height * 0.74;
        border-radius: 3px; background: #1c2820;
        Rectangle {
            x: parent.width * 0.09; y: parent.height * 0.10;
            width: parent.width * 0.82; height: parent.height * 0.62;
            background: #041008;
            Rectangle { x: parent.width * 0.07; y: parent.height * 0.16; width: parent.width * 0.58; height: 1px; background: #7cff9d; }
            Rectangle { x: parent.width * 0.07; y: parent.height * 0.28; width: parent.width * 0.38; height: 1px; background: #7cff9d; opacity: 0.85; }
            Rectangle { x: parent.width * 0.07; y: parent.height * 0.40; width: parent.width * 0.48; height: 1px; background: #7cff9d; opacity: 0.75; }
            Rectangle { x: parent.width * 0.07; y: parent.height * 0.52; width: parent.width * 0.28; height: 1px; background: #7cff9d; opacity: 0.60; }
        }
        Rectangle { x: parent.width * 0.07; y: parent.height * 0.83; width: 3px; height: 3px; border-radius: 1.5px; background: #7cff9d; }
    }
    if root.is_dir && !root.use_image && ThemePalette.active_theme == "terminal": Rectangle {
        x: parent.width * 0.39; y: parent.height * 0.74; width: parent.width * 0.22; height: parent.height * 0.09; background: #1c2820;
    }
    if root.is_dir && !root.use_image && ThemePalette.active_theme == "terminal": Rectangle {
        x: parent.width * 0.12; y: parent.height * 0.83; width: parent.width * 0.76; height: parent.height * 0.17; border-radius: 2px; background: #1c2820;
    }

    // -- CYBERPUNK: data terminal ------------------------------------------
    if root.is_dir && !root.use_image && ThemePalette.active_theme == "cyberpunk": Rectangle {
        x: 0; y: 0; width: parent.width; height: parent.height; border-radius: 2px; background: #080220; border-width: 1px; border-color: #00fff2;
        Rectangle { x: parent.width*0.34; y: parent.height*0.30; width: parent.width*0.32; height: parent.height*0.40; border-radius: 1px; background: #1a0440; border-width: 1px; border-color: #00fff2; }
    }

    // -- RETRO: chunky pixel-art folder with floppy disk centerpiece ------
    // Reads as a folder silhouette but rendered with visible blocky pixels,
    // a magenta-on-yellow palette, and a tiny 8-bit floppy disk dropped on top.
    if root.is_dir && !root.use_image && ThemePalette.active_theme == "retro": Rectangle {
        x: 0; y: 0; width: parent.width; height: parent.height;
        // Folder tab - chunky block on top-left
        Rectangle {
            x: parent.width * 0.06;
            y: parent.height * 0.08;
            width: parent.width * 0.46;
            height: parent.height * 0.20;
            background: ThemePalette.icon_folder_1;
            border-width: 2px;
            border-color: #12081c;
        }
        // Folder body - main yellow block with thick pixel border
        Rectangle {
            x: parent.width * 0.04;
            y: parent.height * 0.22;
            width: parent.width * 0.92;
            height: parent.height * 0.72;
            background: ThemePalette.icon_folder_2;
            border-width: 2px;
            border-color: #12081c;
            // Top highlight pixel row (lighter)
            Rectangle {
                x: 2px; y: 2px;
                width: parent.width - 4px;
                height: parent.height * 0.16;
                background: ThemePalette.icon_folder_1;
            }
            // Bottom shadow pixel row (darker)
            Rectangle {
                x: 2px;
                y: parent.height - parent.height * 0.18 - 2px;
                width: parent.width - 4px;
                height: parent.height * 0.14;
                background: #c02890;
                opacity: 0.55;
            }
            // Floppy disk centerpiece
            Rectangle {
                x: parent.width * 0.30;
                y: parent.height * 0.30;
                width: parent.width * 0.40;
                height: parent.height * 0.44;
                background: #2a1840;
                border-width: 1px;
                border-color: #12081c;
                // Disk label
                Rectangle {
                    x: parent.width * 0.16;
                    y: parent.height * 0.18;
                    width: parent.width * 0.68;
                    height: parent.height * 0.36;
                    background: #f8f0d4;
                }
                // Metal shutter
                Rectangle {
                    x: parent.width * 0.30;
                    y: parent.height * 0.62;
                    width: parent.width * 0.40;
                    height: parent.height * 0.22;
                    background: #cfd8e8;
                }
            }
        }
    }

    // -- FANTASY: ornate wooden treasure chest with gold bands ------------
    // Clearly distinct from a folder shape: rounded lid on top of trapezoidal
    // body, two gold horizontal bands, and a small gold lock plate.
    // Hover bounce + gold sparkles adapted from fantasy-explorer-icons (zip);
    // no per-pixel Rectangle grid (too heavy for ListView).
    if root.is_dir && !root.use_image && ThemePalette.active_theme == "fantasy": Rectangle {
        x: 0;
        y: root.hovered ? -2px : 0px;
        width: parent.width;
        height: parent.height;
        background: transparent;
        animate y { duration: 180ms; easing: ease-out; }
        // Lid (rounded top half)
        Rectangle {
            x: parent.width * 0.06;
            y: parent.height * 0.10;
            width: parent.width * 0.88;
            height: parent.height * 0.42;
            border-radius: parent.width * 0.30;
            background: @linear-gradient(180deg, #6b4520 0%, #4a2c12 100%);
            border-width: 1px;
            border-color: #2a1808;
        }
        // Cover the bottom half of the lid so it sits flat on the body
        Rectangle {
            x: parent.width * 0.06;
            y: parent.height * 0.40;
            width: parent.width * 0.88;
            height: parent.height * 0.14;
            background: #4a2c12;
        }
        // Chest body
        Rectangle {
            x: parent.width * 0.04;
            y: parent.height * 0.48;
            width: parent.width * 0.92;
            height: parent.height * 0.48;
            border-radius: 2px;
            background: @linear-gradient(180deg, #5a3818 0%, #36200c 100%);
            border-width: 1px;
            border-color: #1a0c04;
        }
        // Gold band - top of body
        Rectangle {
            x: parent.width * 0.04;
            y: parent.height * 0.50;
            width: parent.width * 0.92;
            height: parent.height * 0.07;
            background: @linear-gradient(180deg, ThemePalette.icon_folder_1 0%, ThemePalette.icon_folder_2 100%);
            border-width: 1px;
            border-color: rgba(0, 0, 0, 0.35);
        }
        // Gold band - bottom of body
        Rectangle {
            x: parent.width * 0.04;
            y: parent.height * 0.86;
            width: parent.width * 0.92;
            height: parent.height * 0.07;
            background: @linear-gradient(180deg, ThemePalette.icon_folder_1 0%, ThemePalette.icon_folder_2 100%);
            border-width: 1px;
            border-color: rgba(0, 0, 0, 0.35);
        }
        // Lock plate
        Rectangle {
            x: parent.width * 0.42;
            y: parent.height * 0.56;
            width: parent.width * 0.16;
            height: parent.height * 0.24;
            border-radius: 2px;
            background: @linear-gradient(180deg, ThemePalette.icon_folder_1 0%, ThemePalette.icon_folder_2 100%);
            border-width: 1px;
            border-color: rgba(0, 0, 0, 0.40);
            // Keyhole dot
            Rectangle {
                x: parent.width / 2 - 1.5px;
                y: parent.height / 2 - 1.5px;
                width: 3px; height: 3px;
                border-radius: 1.5px;
                background: #2a1808;
            }
        }
        FantasyChestSparkles {
            width: parent.width;
            height: parent.height;
            lit: root.hovered;
        }
    }

    // -- SHELL-EXTRACTED ICON (replaces procedural icon when available) ---
    // Used for .exe (embedded icons), .lnk (target icon), and registered
    // file types like .docx/.pdf/.xlsx where the shell knows the brand icon.
    in property <image> system_icon;
    in property <bool> has_system_icon: false;
    if !root.is_dir && root.has_system_icon: Image {
        x: 3px; y: 1px;
        width: parent.width - 6px;
        height: parent.height - 2px;
        source: root.system_icon;
        image-fit: contain;
    }

    // -- FILE ICON (same for all themes - used when no shell icon exists) -
    if !root.is_dir && !root.has_system_icon: Rectangle {
        x: 7px; y: 3px;
        width: parent.width - 18px;
        height: parent.height - 6px;
        border-radius: 4px;
        border-width: 1px;
        border-color: rgba(0, 0, 0, 0.08);
        background: #cfd8e8;
    }
    if !root.is_dir && !root.has_system_icon: Rectangle {
        x: parent.width - 20px; y: 4px;
        width: 13px; height: 13px;
        background: ThemePalette.bg;
        border-width: 1px;
        border-color: rgba(0, 0, 0, 0.08);
    }
    if !root.is_dir && !root.has_system_icon: Rectangle {
        x: 7px;
        y: parent.height - 18px;
        width: parent.width - 18px;
        height: 15px;
        border-radius: 3px;
        background: root.ext_color;
        Text {
            text: root.extension == "" ? "FILE" : root.extension;
            color: white;
            font-family: AppMetrics.mono_font;
            font-size: 8px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // Type-specific glyph overlay on the file body. Small vector marks that
    // make at-a-glance recognition faster than reading the extension label.
    // EXE / MSI / BAT / CMD: triangle "play" mark (executable)
    if !root.is_dir && !root.has_system_icon && (root.extension == "exe" || root.extension == "msi" || root.extension == "bat" || root.extension == "cmd"): Rectangle {
        x: parent.width / 2 - 6px;
        y: parent.height / 2 - 9px;
        width: 12px; height: 12px;
        background: transparent;
        Rectangle { x: 1px; y: 0; width: 0px; height: 0px;
            border-width: 6px;
            border-color: #fb923c;
        }
        // Triangle approximated by two stacked thin rectangles + a wider middle bar.
        Rectangle { x: 3px; y: 0; width: 2px; height: 12px; background: #ffffff; }
        Rectangle { x: 5px; y: 2px; width: 2px; height: 8px; background: #ffffff; }
        Rectangle { x: 7px; y: 4px; width: 2px; height: 4px; background: #ffffff; }
    }
    // DLL / SYS: gear-like circle + cross marks (library)
    if !root.is_dir && !root.has_system_icon && (root.extension == "dll" || root.extension == "sys" || root.extension == "drv" || root.extension == "lib"): Rectangle {
        x: parent.width / 2 - 7px;
        y: parent.height / 2 - 9px;
        width: 14px; height: 14px;
        border-radius: 7px;
        background: transparent;
        border-width: 2px; border-color: #ffffff;
        Rectangle { x: parent.width / 2 - 1px; y: parent.height / 2 - 1px; width: 2px; height: 2px; border-radius: 1px; background: #ffffff; }
        Rectangle { x: parent.width / 2 - 4px; y: -2px; width: 2px; height: 4px; background: #ffffff; }
        Rectangle { x: parent.width / 2 + 2px; y: -2px; width: 2px; height: 4px; background: #ffffff; }
        Rectangle { x: parent.width / 2 - 4px; y: parent.height - 2px; width: 2px; height: 4px; background: #ffffff; }
        Rectangle { x: parent.width / 2 + 2px; y: parent.height - 2px; width: 2px; height: 4px; background: #ffffff; }
    }
    // ZIP / 7Z / RAR / TAR / GZ: zipper teeth (archive)
    if !root.is_dir && !root.has_system_icon && (root.extension == "zip" || root.extension == "7z" || root.extension == "rar" || root.extension == "tar" || root.extension == "gz" || root.extension == "xz"): Rectangle {
        x: parent.width / 2 - 1px;
        y: parent.height / 2 - 10px;
        width: 2px; height: 16px;
        background: #ffffff;
        Rectangle { x: -3px; y: 1px; width: 8px; height: 2px; background: #ffffff; }
        Rectangle { x: -3px; y: 5px; width: 8px; height: 2px; background: #ffffff; }
        Rectangle { x: -3px; y: 9px; width: 8px; height: 2px; background: #ffffff; }
        Rectangle { x: -3px; y: 13px; width: 8px; height: 2px; background: #ffffff; }
    }
    // PDF: bold red corner badge stays as the colored band - also add a folded corner mark
    if !root.is_dir && !root.has_system_icon && root.extension == "pdf": Rectangle {
        x: parent.width / 2 - 6px;
        y: parent.height / 2 - 8px;
        width: 12px; height: 12px;
        background: #ffffff;
        border-radius: 1px;
        Text {
            width: parent.width; height: parent.height;
            text: "P";
            color: #e5474c;
            font-size: 10px;
            font-weight: 900;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
    // CODE: angle brackets
    if !root.is_dir && !root.has_system_icon && (root.extension == "rs" || root.extension == "js" || root.extension == "ts" || root.extension == "tsx" || root.extension == "jsx" || root.extension == "py" || root.extension == "c" || root.extension == "cpp" || root.extension == "h" || root.extension == "hpp" || root.extension == "go" || root.extension == "java" || root.extension == "kt" || root.extension == "cs" || root.extension == "rb" || root.extension == "lua" || root.extension == "zig" || root.extension == "html" || root.extension == "css"): Rectangle {
        x: parent.width / 2 - 8px;
        y: parent.height / 2 - 7px;
        width: 16px; height: 12px;
        background: transparent;
        // Left chevron <
        Rectangle { x: 0; y: 5px; width: 2px; height: 2px; background: #ffffff; }
        Rectangle { x: 2px; y: 3px; width: 2px; height: 2px; background: #ffffff; }
        Rectangle { x: 2px; y: 7px; width: 2px; height: 2px; background: #ffffff; }
        Rectangle { x: 4px; y: 1px; width: 2px; height: 2px; background: #ffffff; }
        Rectangle { x: 4px; y: 9px; width: 2px; height: 2px; background: #ffffff; }
        // Right chevron >
        Rectangle { x: 14px; y: 5px; width: 2px; height: 2px; background: #ffffff; }
        Rectangle { x: 12px; y: 3px; width: 2px; height: 2px; background: #ffffff; }
        Rectangle { x: 12px; y: 7px; width: 2px; height: 2px; background: #ffffff; }
        Rectangle { x: 10px; y: 1px; width: 2px; height: 2px; background: #ffffff; }
        Rectangle { x: 10px; y: 9px; width: 2px; height: 2px; background: #ffffff; }
    }
    // VIDEO: play triangle
    if !root.is_dir && !root.has_system_icon && (root.extension == "mp4" || root.extension == "mkv" || root.extension == "avi" || root.extension == "mov" || root.extension == "webm"): Rectangle {
        x: parent.width / 2 - 5px;
        y: parent.height / 2 - 7px;
        width: 12px; height: 12px;
        background: transparent;
        Rectangle { x: 2px; y: 0; width: 2px; height: 12px; background: #ffffff; }
        Rectangle { x: 4px; y: 2px; width: 2px; height: 8px; background: #ffffff; }
        Rectangle { x: 6px; y: 4px; width: 2px; height: 4px; background: #ffffff; }
    }
    // AUDIO: eighth-note (eighth note simplified)
    if !root.is_dir && !root.has_system_icon && (root.extension == "mp3" || root.extension == "wav" || root.extension == "flac" || root.extension == "ogg" || root.extension == "m4a" || root.extension == "aac"): Rectangle {
        x: parent.width / 2 - 6px;
        y: parent.height / 2 - 8px;
        width: 12px; height: 14px;
        background: transparent;
        Rectangle { x: 8px; y: 0; width: 2px; height: 10px; background: #ffffff; }
        Rectangle { x: 2px; y: 8px; width: 6px; height: 4px; border-radius: 2px; background: #ffffff; }
    }
    // IMAGE: small landscape rectangle with sun
    if !root.is_dir && !root.has_system_icon && (root.extension == "png" || root.extension == "jpg" || root.extension == "jpeg" || root.extension == "gif" || root.extension == "webp" || root.extension == "bmp" || root.extension == "ico" || root.extension == "tiff" || root.extension == "tif"): Rectangle {
        x: parent.width / 2 - 7px;
        y: parent.height / 2 - 7px;
        width: 14px; height: 12px;
        border-radius: 1px;
        background: transparent;
        border-width: 1px; border-color: #ffffff;
        Rectangle { x: 8px; y: 1px; width: 3px; height: 3px; border-radius: 1.5px; background: #ffffff; }
        Rectangle { x: 1px; y: 7px; width: 4px; height: 2px; background: #ffffff; }
        Rectangle { x: 5px; y: 5px; width: 4px; height: 4px; background: #ffffff; }
        Rectangle { x: 9px; y: 6px; width: 4px; height: 3px; background: #ffffff; }
    }
    // DOC / DOCX / TXT / MD: text lines
    if !root.is_dir && !root.has_system_icon && (root.extension == "doc" || root.extension == "docx" || root.extension == "txt" || root.extension == "md" || root.extension == "rtf" || root.extension == "odt"): Rectangle {
        x: parent.width / 2 - 6px;
        y: parent.height / 2 - 7px;
        width: 12px; height: 12px;
        background: transparent;
        Rectangle { x: 0; y: 1px; width: 10px; height: 1px; background: #ffffff; }
        Rectangle { x: 0; y: 4px; width: 12px; height: 1px; background: #ffffff; }
        Rectangle { x: 0; y: 7px; width: 8px; height: 1px; background: #ffffff; }
        Rectangle { x: 0; y: 10px; width: 11px; height: 1px; background: #ffffff; }
    }
    // SPREADSHEET: grid pattern
    if !root.is_dir && !root.has_system_icon && (root.extension == "xls" || root.extension == "xlsx" || root.extension == "csv" || root.extension == "ods"): Rectangle {
        x: parent.width / 2 - 6px;
        y: parent.height / 2 - 6px;
        width: 12px; height: 10px;
        background: transparent;
        border-width: 1px; border-color: #ffffff;
        Rectangle { x: 5px; y: 0; width: 1px; height: parent.height; background: #ffffff; }
        Rectangle { x: 0; y: 4px; width: parent.width; height: 1px; background: #ffffff; }
    }
}

component FileRow inherits Rectangle {
    in property <FileItem> item;
    in property <int> index;
    in property <string> view_mode;
    in property <int> rename_index: -1;
    callback selected(int, bool, bool);
    callback opened(int);
    callback context(int, length, length);
    callback rename_commit(int, string);
    callback file_drag_requested(int);

    // Drag-target path comes from the MainWindow root and a FileRow renders a
    // pulsing accent border when its own file_path matches. Drop highlight only
    // applies to folder rows since dropping onto a file is a no-op.
    in property <string> drag_target_path;

    property <bool> ctrl_held: false;
    property <bool> shift_held: false;
    property <bool> is_renaming: root.rename_index == root.index;
    // Bumped when rename mode starts so the LineEdit can grab keyboard focus.
    property <int> rename_focus_nonce: 0;
    changed is_renaming => {
        if (root.is_renaming) { root.rename_focus_nonce += 1; }
    }
    property <bool> drag_started: false;
    property <bool> is_drop_target: root.item.is_dir
        && root.drag_target_path != ""
        && root.drag_target_path == root.item.file_path;
    // Date grouping header sits above the row in the details view only. The
    // backend sets show_date_group_header=true on the first row of every new
    // bucket (Today, Yesterday, This week, etc) when sorted by Date modified.
    property <bool> has_group_header: root.view_mode == "list" && root.item.show_date_group_header;
    property <length> group_header_h: root.has_group_header ? 26px : 0px;
    // Explorer-style ghosting for cut items waiting to be pasted.
    property <float> content_opacity: root.item.is_cut_pending ? 0.38 : 1.0;

    height: (root.view_mode == "list" ? AppMetrics.row_h : (root.view_mode == "gallery" ? 154px : (root.view_mode == "compact" ? 32px : AppMetrics.grid_h))) + root.group_header_h;
    opacity: root.content_opacity;

    // Group header at the top of the row, only when this row starts a new bucket.
    if root.has_group_header: Rectangle {
        x: 0; y: 0;
        width: parent.width; height: root.group_header_h;
        Text {
            x: 6px;
            y: 0;
            width: parent.width - 12px;
            height: parent.height - 4px;
            text: root.item.date_group_text;
            color: ThemePalette.text_faint;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.5px;
            vertical-alignment: bottom;
            overflow: elide;
        }
        Rectangle {
            x: 6px;
            y: parent.height - 3px;
            width: parent.width - 12px;
            height: 1px;
            background: ThemePalette.text_faint;
            opacity: 0.35;
        }
    }
    // The root has no background or border. Selection and hover paint into
    // inner rectangles that start BELOW the date-group header strip, so the
    // highlight visually matches the file row rather than spilling over the
    // "Today" / "Yesterday" / "This week" label above it.
    border-radius: 0px;
    border-width: 0px;
    background: rgba(0, 0, 0, 0);

    if root.item.is_selected: Rectangle {
        x: 0;
        y: root.group_header_h;
        width: parent.width;
        height: parent.height - root.group_header_h;
        border-radius: AppMetrics.radius;
        border-width: 1px;
        border-color: ThemePalette.accent;
        background: ThemePalette.accent_soft;
    }

    // Hover glow - instant on, instant off. File Explorer doesn't fade either.
    // Wrapped in `if` so non-hovered rows skip rendering this entirely.
    if touch.has-hover && !root.item.is_selected: Rectangle {
        x: 0;
        y: root.group_header_h;
        width: parent.width;
        height: parent.height - root.group_header_h;
        border-radius: AppMetrics.radius;
        background: rgba(255, 255, 255, 0.07);
    }

    // Drag glow - shown on selected items while DoDragDrop is active
    if ThemePalette.is_dragging && root.item.is_selected: Rectangle {
        x: -3px; y: -3px;
        width: parent.width + 6px; height: parent.height + 6px;
        border-radius: parent.border-radius + 2px;
        border-width: 2px;
        border-color: ThemePalette.accent_strong;
        background: ThemePalette.accent_soft;
    }

    // Drop-target glow - pulses on the folder row the cursor is currently over
    // during a drag, so the user can tell exactly where the drop will land. The
    // ScaleEffect-style pulse is approximated with a static accent border for
    // now since Slint 1.x does not have a built-in keyframe animation property
    // for repeating glows.
    if root.is_drop_target: Rectangle {
        x: -3px; y: root.group_header_h - 3px;
        width: parent.width + 6px;
        height: parent.height - root.group_header_h + 6px;
        border-radius: parent.border-radius + 2px;
        border-width: 2px;
        border-color: ThemePalette.accent_strong;
        background: ThemePalette.accent_soft;
        animate border-color { duration: 240ms; easing: ease-in-out; }
    }

    if root.view_mode == "list": NodeVisual {
        x: 8px;
        y: root.group_header_h + (parent.height - root.group_header_h - self.height) / 2;
        visual_width: ThemePalette.is_dragging && root.item.is_selected ? 32px : 28px;
        visual_height: root.item.is_dir
            ? (ThemePalette.is_dragging && root.item.is_selected ? 26px : 22px)
            : (ThemePalette.is_dragging && root.item.is_selected ? 32px : 28px);
        is_dir: root.item.is_dir;
        extension: root.item.extension;
        has_system_icon: root.item.has_system_icon;
        system_icon: root.item.system_icon;
        hovered: touch.has-hover;
    }

    // List view responsive layout - give Name room first; meta columns shrink
    // gracefully instead of crushing Type to unreadably short widths.
    property <length> col_size_w: min(88px, max(56px, root.width * 0.14));
    property <length> col_modified_w: min(132px, max(84px, root.width * 0.22));
    property <length> col_type_w: min(120px, max(72px, root.width * 0.18));
    property <length> col_gap: 10px;
    property <bool> show_list_size: root.width >= 280px;
    property <bool> show_list_modified: root.width >= 380px;
    property <bool> show_list_type: root.width >= 480px;
    property <length> list_right_zone:
        root.show_list_type ? (root.col_size_w + root.col_gap + root.col_modified_w + root.col_gap + root.col_type_w) :
        (root.show_list_modified ? (root.col_size_w + root.col_gap + root.col_modified_w) :
        (root.show_list_size ? root.col_size_w : 0px));
    property <length> list_name_font: root.width < 340px ? 11px : (root.width < 460px ? 11.5px : 12.5px);
    property <length> list_meta_font: root.width < 340px ? 10px : 11px;

    if root.view_mode == "list" && !root.is_renaming: Text {
        x: 44px;
        y: root.group_header_h;
        // Name always gets at least 80px; right column slides in when the row gets wider.
        width: max(80px, parent.width - 44px - root.list_right_zone - 16px);
        height: parent.height - root.group_header_h;
        text: root.item.name;
        color: root.item.is_selected ? ThemePalette.text : ThemePalette.text_muted;
        font-size: root.list_name_font;
        overflow: elide;
        vertical-alignment: center;
    }

    // SIZE column - right-aligned, monospaced
    if root.view_mode == "list" && root.show_list_size: Text {
        x: parent.width - root.list_right_zone;
        y: root.group_header_h;
        width: root.col_size_w;
        height: parent.height - root.group_header_h;
        text: root.item.size_text;
        color: ThemePalette.text_faint;
        font-family: AppMetrics.mono_font;
        font-size: root.list_meta_font;
        overflow: elide;
        vertical-alignment: center;
        horizontal-alignment: right;
    }

    // MODIFIED column
    if root.view_mode == "list" && root.show_list_modified: Text {
        x: parent.width - root.list_right_zone + root.col_size_w + root.col_gap;
        y: root.group_header_h;
        width: root.col_modified_w;
        height: parent.height - root.group_header_h;
        text: root.item.modified_text;
        color: ThemePalette.text_faint;
        font-family: AppMetrics.mono_font;
        font-size: root.list_meta_font;
        overflow: elide;
        vertical-alignment: center;
    }

    // TYPE column
    if root.view_mode == "list" && root.show_list_type: Text {
        x: parent.width - root.list_right_zone + root.col_size_w + root.col_gap + root.col_modified_w + root.col_gap;
        y: root.group_header_h;
        width: root.col_type_w;
        height: parent.height - root.group_header_h;
        text: root.item.type_text;
        color: ThemePalette.text_faint;
        font-size: root.list_meta_font;
        overflow: elide;
        vertical-alignment: center;
    }

    if root.view_mode == "list": Rectangle {
        visible: root.item.has_tag;
        // Pull the dot 28px in from the right edge so it does not get hidden
        // by the ListView's scroll bar (~14px wide on a Mica window).
        x: parent.width - 28px;
        y: root.group_header_h + (parent.height - root.group_header_h - 9px) / 2;
        width: 9px;
        height: 9px;
        border-radius: 5px;
        background: root.item.tag_color;
    }

    if root.view_mode != "list" && root.view_mode != "compact" && root.item.has_thumbnail: Rectangle {
        x: (parent.width - (root.view_mode == "gallery" ? 64px : 54px)) / 2;
        y: root.view_mode == "gallery" ? 18px : 12px;
        width: root.view_mode == "gallery" ? 64px : 54px;
        height: root.view_mode == "gallery" ? 70px : 54px;
        border-radius: 4px;
        clip: true;
        Image {
            width: parent.width;
            height: parent.height;
            source: root.item.thumbnail;
            image-fit: cover;
        }
    }

    if root.view_mode != "list" && root.view_mode != "compact" && !root.item.has_thumbnail: NodeVisual {
        x: (parent.width - (root.view_mode == "gallery"
            ? (ThemePalette.is_dragging && root.item.is_selected ? 72px : 64px)
            : (ThemePalette.is_dragging && root.item.is_selected ? 62px : 54px))) / 2;
        y: (root.view_mode == "gallery" ? 18px : 12px) - (ThemePalette.is_dragging && root.item.is_selected ? 4px : 0px);
        visual_width: root.view_mode == "gallery"
            ? (ThemePalette.is_dragging && root.item.is_selected ? 72px : 64px)
            : (ThemePalette.is_dragging && root.item.is_selected ? 62px : 54px);
        visual_height: root.view_mode == "gallery"
            ? (ThemePalette.is_dragging && root.item.is_selected ? 78px : 70px)
            : (ThemePalette.is_dragging && root.item.is_selected ? 62px : 54px);
        is_dir: root.item.is_dir;
        extension: root.item.extension;
        has_system_icon: root.item.has_system_icon;
        system_icon: root.item.system_icon;
        hovered: touch.has-hover;
    }

    // Grid/gallery: scale caption with cell width so dual-pane columns stay readable.
    property <length> grid_name_font:
        root.width < 96px ? 9.5px :
        (root.width < 120px ? 10.5px :
        (root.width < 150px ? 11px : 12px));

    // Grid/gallery: name as text (not renaming)
    if root.view_mode != "list" && root.view_mode != "compact" && !root.is_renaming: Text {
        x: 18px;
        y: parent.height - 38px;
        width: parent.width - 36px;
        height: 30px;
        text: root.item.name;
        color: root.item.is_selected ? ThemePalette.text : ThemePalette.text_muted;
        font-size: root.grid_name_font;
        overflow: elide;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    Rectangle {
        visible: root.item.has_tag && root.view_mode != "list";
        x: parent.width - 22px;
        y: 8px;
        width: 9px;
        height: 9px;
        border-radius: 5px;
        background: root.item.tag_color;
    }

    Rectangle {
        visible: root.item.git_badge != "";
        x: 8px;
        y: 8px;
        height: 15px;
        width: 10px + git-text.preferred-width;
        border-radius: 3px;
        background: root.item.git_color;
        git-text := Text {
            x: 5px;
            y: 0;
            height: parent.height;
            text: root.item.git_badge;
            color: white;
            font-family: AppMetrics.mono_font;
            font-size: 9px;
            font-weight: 700;
            vertical-alignment: center;
        }
    }

    // Compact view: small icon + name in one horizontal row
    if root.view_mode == "compact": NodeVisual {
        x: 4px;
        y: (parent.height - 18px) / 2;
        visual_width: root.item.is_dir ? 22px : 18px;
        visual_height: 18px;
        is_dir: root.item.is_dir;
        extension: root.item.extension;
        has_system_icon: root.item.has_system_icon;
        system_icon: root.item.system_icon;
        hovered: touch.has-hover;
    }

    if root.view_mode == "compact" && !root.is_renaming: Text {
        x: 30px;
        y: 0;
        width: parent.width - 38px;
        height: parent.height;
        text: root.item.name;
        color: root.item.is_selected ? ThemePalette.text : ThemePalette.text_muted;
        font-size: root.width < 180px ? 10.5px : 12px;
        overflow: elide;
        vertical-alignment: center;
    }

    Rectangle {
        visible: root.item.has_note;
        x: parent.width - 15px;
        y: parent.height - 15px;
        width: 6px;
        height: 6px;
        border-radius: 3px;
        background: ThemePalette.accent_strong;
    }

    // TouchArea is constrained to the file-content area, NOT the date-group
    // header strip that sits above it. Without this constraint, clicks on the
    // "Today" / "Yesterday" / "This week" labels were treated as clicks on the
    // file below, making the click box appear misaligned from the visual row
    // when sorted by Date modified.
    //
    // Drag-start behaviour: SELECTED rows start a file drag-out (DoDragDrop).
    // UNSELECTED rows fire marquee_started/moved/finished so the parent pane
    // can rubber-band select from anywhere in the file list, not just the
    // empty strip above the list header. Absolute coordinates are reported
    // because the pane subtracts its own absolute position to translate them
    // into pane-local space for the marquee rect.
    callback marquee_started(length, length);
    callback marquee_moved(length, length);
    callback marquee_finished();

    touch := TouchArea {
        x: 0;
        y: root.group_header_h;
        width: parent.width;
        height: parent.height - root.group_header_h;
        enabled: !root.is_renaming;
        mouse-cursor: pointer;
        clicked => { root.selected(root.index, root.ctrl_held, root.shift_held); }
        double-clicked => { root.opened(root.index); }
        moved => {
            if (self.pressed) {
                if (!root.drag_started && (
                    (self.mouse-x - self.pressed-x > 6px) ||
                    (self.pressed-x - self.mouse-x > 6px) ||
                    (self.mouse-y - self.pressed-y > 6px) ||
                    (self.pressed-y - self.mouse-y > 6px))) {
                    root.drag_started = true;
                    if (root.item.is_selected) {
                        root.file_drag_requested(root.index);
                    } else {
                        root.marquee_started(
                            self.absolute-position.x + self.pressed-x,
                            self.absolute-position.y + self.pressed-y);
                    }
                }
                if (root.drag_started && !root.item.is_selected) {
                    root.marquee_moved(
                        self.absolute-position.x + self.mouse-x,
                        self.absolute-position.y + self.mouse-y);
                }
            }
        }
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                root.ctrl_held = event.modifiers.control;
                root.shift_held = event.modifiers.shift;
                root.drag_started = false;
            }
            if (event.kind == PointerEventKind.up && event.button == PointerEventButton.left) {
                if (root.drag_started && !root.item.is_selected) {
                    root.marquee_finished();
                }
                root.drag_started = false;
            }
            if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                root.context(root.index,
                    self.absolute-position.x + self.mouse-x,
                    self.absolute-position.y + self.mouse-y);
            }
        }
    }

    // Inline rename inputs sit above the row TouchArea so clicks and keyboard
    // focus reach the editor (otherwise F2 rename appears but cannot be edited).
    if root.view_mode == "list" && root.is_renaming: rename_list := LineEdit {
        z: 2;
        x: 44px;
        y: root.group_header_h + 4px;
        width: max(80px, parent.width - 48px - root.list_right_zone - 16px);
        height: parent.height - root.group_header_h - 8px;
        text: root.item.rename_label;
        font-size: root.list_name_font;
        property <int> focus_nonce: root.rename_focus_nonce;
        changed focus_nonce => { if (root.is_renaming) { self.focus(); } }
        accepted(val) => { root.rename_commit(root.index, val); }
        key-pressed(event) => {
            if (event.text == Key.Escape) { root.rename_commit(root.index, ""); accept }
            else { reject }
        }
    }

    if root.view_mode != "list" && root.view_mode != "compact" && root.is_renaming: rename_grid := LineEdit {
        z: 2;
        x: 8px;
        y: parent.height - 40px;
        width: parent.width - 16px;
        height: 32px;
        text: root.item.rename_label;
        font-size: 12px;
        horizontal-alignment: center;
        property <int> focus_nonce: root.rename_focus_nonce;
        changed focus_nonce => { if (root.is_renaming) { self.focus(); } }
        accepted(val) => { root.rename_commit(root.index, val); }
        key-pressed(event) => {
            if (event.text == Key.Escape) { root.rename_commit(root.index, ""); accept }
            else { reject }
        }
    }

    if root.view_mode == "compact" && root.is_renaming: rename_compact := LineEdit {
        z: 2;
        x: 30px;
        y: 3px;
        width: parent.width - 38px;
        height: parent.height - 6px;
        text: root.item.rename_label;
        font-size: 12px;
        property <int> focus_nonce: root.rename_focus_nonce;
        changed focus_nonce => { if (root.is_renaming) { self.focus(); } }
        accepted(val) => { root.rename_commit(root.index, val); }
        key-pressed(event) => {
            if (event.text == Key.Escape) { root.rename_commit(root.index, ""); accept }
            else { reject }
        }
    }

}

component ListHeader inherits Rectangle {
    in property <string> sort_by: "name";
    in property <string> sort_dir: "asc";
    callback sort_col(string);

    // Match FileRow's responsive layout exactly.
    property <length> col_size_w: min(88px, max(56px, root.width * 0.14));
    property <length> col_modified_w: min(132px, max(84px, root.width * 0.22));
    property <length> col_type_w: min(120px, max(72px, root.width * 0.18));
    property <length> col_gap: 10px;
    property <bool> show_size: root.width >= 280px;
    property <bool> show_modified: root.width >= 380px;
    property <bool> show_type: root.width >= 480px;
    property <length> right_zone:
        root.show_type ? (root.col_size_w + root.col_gap + root.col_modified_w + root.col_gap + root.col_type_w) :
        (root.show_modified ? (root.col_size_w + root.col_gap + root.col_modified_w) :
        (root.show_size ? root.col_size_w : 0px));

    height: 32px;
    background: ThemePalette.panel_solid;
    border-width: 0px;

    // NAME
    Rectangle {
        x: 44px;
        width: max(60px, parent.width - 44px - root.right_zone - 16px);
        height: parent.height;
        background: nh.has-hover ? rgba(255,255,255,0.04) : transparent;
        Text { x: 0; width: parent.width - 18px; height: parent.height; text: "NAME"; color: root.sort_by == "name" ? ThemePalette.text_muted : ThemePalette.text_faint; font-size: 11px; font-weight: 700; vertical-alignment: center; }
        Text { visible: root.sort_by == "name"; x: parent.width - 13px; width: 12px; height: parent.height; text: root.sort_dir == "asc" ? "^" : "v"; color: ThemePalette.accent; font-size: 10px; vertical-alignment: center; }
        nh := TouchArea { mouse-cursor: pointer; clicked => { root.sort_col("name"); } }
    }
    // SIZE - right-aligned to align with file size text
    if root.show_size: Rectangle {
        x: parent.width - root.right_zone;
        width: root.col_size_w;
        height: parent.height;
        background: sh.has-hover ? rgba(255,255,255,0.04) : transparent;
        Text { x: 0; width: parent.width - 18px; height: parent.height; text: "SIZE"; color: root.sort_by == "size" ? ThemePalette.text_muted : ThemePalette.text_faint; font-size: 11px; font-weight: 700; horizontal-alignment: right; vertical-alignment: center; }
        Text { visible: root.sort_by == "size"; x: parent.width - 12px; width: 12px; height: parent.height; text: root.sort_dir == "asc" ? "^" : "v"; color: ThemePalette.accent; font-size: 10px; vertical-alignment: center; }
        sh := TouchArea { mouse-cursor: pointer; clicked => { root.sort_col("size"); } }
    }
    // MODIFIED
    if root.show_modified: Rectangle {
        x: parent.width - root.right_zone + root.col_size_w + root.col_gap;
        width: root.col_modified_w;
        height: parent.height;
        background: mh.has-hover ? rgba(255,255,255,0.04) : transparent;
        Text { x: 0; width: parent.width - 18px; height: parent.height; text: "MODIFIED"; color: root.sort_by == "modified" ? ThemePalette.text_muted : ThemePalette.text_faint; font-size: 11px; font-weight: 700; vertical-alignment: center; }
        Text { visible: root.sort_by == "modified"; x: parent.width - 12px; width: 12px; height: parent.height; text: root.sort_dir == "asc" ? "^" : "v"; color: ThemePalette.accent; font-size: 10px; vertical-alignment: center; }
        mh := TouchArea { mouse-cursor: pointer; clicked => { root.sort_col("modified"); } }
    }
    // TYPE
    if root.show_type: Rectangle {
        x: parent.width - root.right_zone + root.col_size_w + root.col_gap + root.col_modified_w + root.col_gap;
        width: root.col_type_w;
        height: parent.height;
        background: th.has-hover ? rgba(255,255,255,0.04) : transparent;
        Text { x: 0; width: parent.width - 18px; height: parent.height; text: "TYPE"; color: root.sort_by == "type" ? ThemePalette.text_muted : ThemePalette.text_faint; font-size: 11px; font-weight: 700; vertical-alignment: center; }
        Text { visible: root.sort_by == "type"; x: parent.width - 12px; width: 12px; height: parent.height; text: root.sort_dir == "asc" ? "^" : "v"; color: ThemePalette.accent; font-size: 10px; vertical-alignment: center; }
        th := TouchArea { mouse-cursor: pointer; clicked => { root.sort_col("type"); } }
    }

    Rectangle { y: parent.height - 1px; height: 1px; width: parent.width; background: ThemePalette.border; }
}

component ChoiceChip inherits Rectangle {
    in property <ChoiceItem> item;
    in property <bool> active;
    callback picked(string);

    property <bool> no_desc: root.item.description == "";
    height: root.no_desc ? 34px : 46px;
    border-radius: AppMetrics.radius_small;
    border-width: 1px;
    border-color: root.active ? ThemePalette.accent : ThemePalette.border;
    background: root.active ? ThemePalette.accent_soft : (touch.has-hover ? ThemePalette.panel_alt : ThemePalette.panel);

    Rectangle {
        x: 10px;
        y: (parent.height - 24px) / 2;
        width: 24px;
        height: 24px;
        border-radius: 12px;
        background: root.item.color;
        border-width: 1px;
        border-color: ThemePalette.border_strong;
    }

    Text {
        // Pulled in from the icon circle (right edge at x=34) with a real
        // 14 px gap so the label can never lean on the icon, even with
        // long localized strings or wide-glyph theme fonts.
        x: 48px;
        y: root.no_desc ? 8px : 6px;
        width: parent.width - 58px;
        height: root.no_desc ? 20px : 18px;
        text: root.item.label;
        color: ThemePalette.text;
        font-size: root.no_desc ? 12.5px : 13px;
        font-weight: 700;
        vertical-alignment: root.no_desc ? center : top;
        overflow: elide;
    }

    Text {
        visible: !root.no_desc;
        x: 48px;
        y: 24px;
        width: parent.width - 58px;
        height: 16px;
        text: root.item.description;
        color: ThemePalette.text_faint;
        font-size: 11px;
        overflow: elide;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.picked(root.item.id); }
    }
}

component ChoiceMenuRow inherits Rectangle {
    in property <string> label;
    in property <string> command_name;
    in property <bool> danger;
    callback picked(string);

    property <string> cmd_icon: root.command_name == "open" ? "M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6 M15 3h6v6 M10 14L21 3"
        : root.command_name == "rename" ? "M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7 M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"
        : root.command_name == "copy" ? "M8 17.929H6c-1.105 0-2-.912-2-2.036V5.036C4 3.91 4.895 3 6 3h8c1.105 0 2 .911 2 2.036v1.866 M18 6.107h2c1.105 0 2 .911 2 2.036v10.857C22 20.09 21.105 21 20 21h-8c-1.105 0-2-.911-2-2.036V17"
        : root.command_name == "cut" ? "M6 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6z M6 9l7.5 7.5 M16.5 10.5 21 6 M6 15a3 3 0 1 0 0 6 3 3 0 0 0 0-6z M6 15l7.5-7.5"
        : root.command_name == "paste" ? "M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2 M9 2h6a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1z"
        : root.command_name == "delete" ? "M3 6h18 M8 6V4h8v2 M19 6l-1 14H6L5 6"
        : root.command_name == "new-folder" ? "M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z M12 11v6 M9 14h6"
        : root.command_name == "new-file" ? "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M12 11v6 M9 14h6"
        : root.command_name == "properties" ? "M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z M12 16v-4 M12 8h.01"
        : root.command_name == "batch-rename" ? "M4 7V4h16v3 M9 20h6 M12 4v16 M4 15h16"
        : root.command_name == "checksum" ? "M9 11l3 3L22 4 M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
        : root.command_name == "note" ? "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8"
        : root.command_name == "copy-as-path" ? "M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"
        : root.command_name == "open-terminal" ? "M4 17l6-6-6-6 M12 19h8"
        : root.command_name == "open-with" ? "M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
        : root.command_name == "image-tools" ? "M15 8h.01 M2 14l4.586-4.586a2 2 0 0 1 2.828 0L14 14 M14 14l1.586-1.586a2 2 0 0 1 2.828 0L21 15 M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2z"
        : root.command_name == "archive-browser" ? "M21 8v13H3V8 M1 3h22v5H1z M10 12h4"
        : root.command_name == "extract-here" ? "M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M7 10l5 5 5-5 M12 15V3"
        : root.command_name == "create-zip" ? "M21 8v13H3V8 M1 3h22v5H1z M12 12v6 M9 15l3 3 3-3"
        : root.command_name == "run-as-admin" ? "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
        : root.command_name == "take-ownership" ? "M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2 M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"
        : root.command_name == "defender-scan" ? "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z M9 12l2 2 4-4"
        : root.command_name == "share" ? "M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8 M16 6l-4-4-4 4 M12 2v13"
        : "";

    height: 30px;
    border-radius: AppMetrics.radius_small;
    background: touch.has-hover ? (root.danger ? ThemePalette.danger : ThemePalette.accent_soft) : rgba(0, 0, 0, 0);
    SvgIcon {
        x: 9px;
        y: (parent.height - 14px) / 2;
        icon_size: 14px;
        data: root.cmd_icon;
        tint: touch.has-hover ? (root.danger ? white : ThemePalette.accent_strong) : ThemePalette.text_faint;
        visible: root.cmd_icon != "";
    }
    Text {
        x: root.cmd_icon != "" ? 30px : 9px;
        width: parent.width - (root.cmd_icon != "" ? 39px : 18px);
        height: parent.height;
        text: root.label;
        color: touch.has-hover ? (root.danger ? white : ThemePalette.accent_strong) : ThemePalette.text_muted;
        font-size: 12.5px;
        vertical-alignment: center;
    }
    touch := TouchArea { mouse-cursor: pointer; clicked => { root.picked(root.command_name); } }
}

component TagMenuRow inherits Rectangle {
    in property <string> label;
    in property <string> command_name;
    in property <color> dot_color;
    callback picked(string);

    height: 30px;
    border-radius: AppMetrics.radius_small;
    background: touch.has-hover ? ThemePalette.accent_soft : rgba(0, 0, 0, 0);
    // Color dot
    Rectangle {
        x: 10px;
        y: (parent.height - 12px) / 2;
        width: 12px; height: 12px;
        border-radius: 6px;
        background: root.dot_color;
        border-width: 1px;
        border-color: rgba(0, 0, 0, 0.15);
    }
    Text {
        x: 30px;
        width: parent.width - 39px;
        height: parent.height;
        text: root.label;
        color: touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text_muted;
        font-size: 12.5px;
        vertical-alignment: center;
    }
    touch := TouchArea { mouse-cursor: pointer; clicked => { root.picked(root.command_name); } }
}

component CommandRow inherits Rectangle {
    in property <CommandItem> item;
    callback picked(string);

    height: 34px;
    border-radius: AppMetrics.radius_small;
    background: touch.has-hover ? ThemePalette.accent_soft : rgba(0, 0, 0, 0);
    Text { x: 10px; width: 90px; height: parent.height; text: root.item.group; color: ThemePalette.text_faint; font-size: 11px; font-weight: 700; vertical-alignment: center; overflow: elide; }
    Text { x: 110px; width: parent.width - 220px; height: parent.height; text: root.item.label; color: touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text_muted; font-size: 13px; vertical-alignment: center; overflow: elide; }
    Text { x: parent.width - 100px; width: 90px; height: parent.height; text: root.item.hint; color: ThemePalette.text_faint; font-family: AppMetrics.mono_font; font-size: 11px; horizontal-alignment: right; vertical-alignment: center; overflow: elide; }
    touch := TouchArea { mouse-cursor: pointer; clicked => { root.picked(root.item.command); } }
}

component DialogButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary;
    in property <bool> danger;
    callback clicked();

    // Auto-size to fit the label so long labels like "Set default folder handler"
    // don't get clipped. Callers can still override `width` explicitly.
    preferred-width: Math.max(76px, dlg_btn_label.preferred-width + 28px);
    width: self.preferred-width;
    height: 32px;
    border-radius: AppMetrics.radius_small;
    background: root.primary ? (root.danger ? ThemePalette.danger : ThemePalette.accent) : ThemePalette.panel_alt;
    dlg_btn_label := Text {
        x: 14px;
        width: parent.width - 28px;
        height: parent.height;
        text: root.label;
        color: root.primary ? ThemePalette.on_accent : ThemePalette.text_muted;
        font-size: 12.5px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    TouchArea { mouse-cursor: pointer; clicked => { root.clicked(); } }
}

// Selectable message body - select text and Ctrl+C, or use toast Copy button.
// When `expand` is true the block grows to the full wrapped height so a parent
// ScrollView can scroll through long content (preview Code/View). Text is used
// instead of TextInput in expand mode so mouse-wheel reaches the ScrollView.
component CopyableMessageText {
    in property <string> text;
    in property <length> content-width;
    in property <length> font-size: 12.5px;
    in property <color> text-color: ThemePalette.text_muted;
    in property <bool> mono: false;
    in property <length> cap-height: 280px;
    in property <bool> expand: false;

    preferred-width: root.content-width;
    property <length> natural_h: measure.preferred-height + 4px;
    preferred-height: root.expand ? root.natural_h : min(root.natural_h, root.cap-height);
    width: root.content-width;
    height: self.preferred-height;

    // Always present for height measurement; also the visible body when expand.
    measure := Text {
        width: parent.width;
        text: root.text;
        wrap: word-wrap;
        font-size: root.font-size;
        color: root.text-color;
        font-family: root.mono ? AppMetrics.mono_font : AppMetrics.ui_font;
        vertical-alignment: top;
        height: self.preferred-height;
        visible: root.expand;
    }

    if !root.expand: TextInput {
        width: parent.width;
        height: parent.height;
        text: root.text;
        read-only: true;
        wrap: word-wrap;
        font-size: root.font-size;
        color: root.text-color;
        font-family: root.mono ? AppMetrics.mono_font : AppMetrics.ui_font;
        vertical-alignment: top;
    }
}


// One row in the ranked-by-size list of the Storage view. v0.9.14:
// two-line name/path on the left, stacked size + modified on the right,
// usage bar pinned to the row bottom so columns never overlap.
component StorageEntryRow inherits Rectangle {
    in property <StorageEntryUi> entry;
    in property <bool> show_bucket_label: true;
    in property <length> col_category_w: 100px;
    in property <length> col_share_w: 120px;
    in property <length> col_size_w: 88px;
    callback open();
    callback more(string);
    callback open_with(string);
    height: 60px;
    clip: true;

    property <length> actions_w: 48px;
    property <length> right_pad: 10px;
    property <length> col_gap: 10px;
    property <length> content_right: root.width - root.right_pad - root.actions_w;
    property <length> size_x: root.content_right - root.col_size_w;
    property <length> share_x: root.size_x - root.col_gap - root.col_share_w;
    property <length> category_x: root.show_bucket_label && root.col_share_w > 0px
        ? root.share_x - root.col_gap - root.col_category_w
        : root.share_x;
    property <length> name_left: 50px;
    property <length> name_w: max(96px, root.category_x - root.col_gap - root.name_left);
    property <bool> show_actions: touch.has-hover;

    Rectangle {
        x: 8px; y: 1px;
        width: parent.width - 16px;
        height: parent.height - 2px;
        border-radius: AppMetrics.radius_small;
        background: touch.has-hover ? ThemePalette.panel_alt : rgba(0, 0, 0, 0);
        animate background { duration: 60ms; easing: ease-out; }
    }
    Rectangle {
        x: 10px;
        y: parent.height - 1px;
        width: parent.width - 20px;
        height: 1px;
        background: ThemePalette.border;
    }
    SvgIcon {
        x: 16px; y: 20px;
        width: 20px; height: 20px;
        icon_size: 20px;
        data: root.entry.is_dir
            ? "M3 7.5A2.5 2.5 0 0 1 5.5 5H10l2 2h6.5A2.5 2.5 0 0 1 21 9.5v7A2.5 2.5 0 0 1 18.5 19h-13A2.5 2.5 0 0 1 3 16.5z"
            : "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6";
        tint: root.entry.bucket_color;
    }
    Text {
        x: root.name_left;
        y: 10px;
        width: root.name_w;
        height: 18px;
        text: root.entry.name;
        color: ThemePalette.text;
        font-size: 13px;
        font-weight: 600;
        vertical-alignment: center;
        horizontal-alignment: left;
        overflow: elide;
    }
    Text {
        x: root.name_left;
        y: 32px;
        width: root.name_w;
        height: 14px;
        text: root.entry.path;
        color: ThemePalette.text_faint;
        font-size: 11px;
        vertical-alignment: center;
        horizontal-alignment: left;
        overflow: elide;
    }
    if root.show_bucket_label && root.col_category_w > 0px: Rectangle {
        x: root.category_x;
        y: 19px;
        width: root.col_category_w;
        height: 22px;
        border-radius: 11px;
        background: root.entry.bucket_color.with-alpha(0.22);
        Text {
            width: parent.width; height: parent.height;
            text: root.entry.bucket;
            color: root.entry.bucket_color;
            font-size: 11px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
    }
    if root.col_share_w > 0px: Rectangle {
        x: root.share_x;
        y: 46px;
        width: root.col_share_w;
        height: 6px;
        border-radius: 3px;
        background: ThemePalette.panel_solid;
        Rectangle {
            x: 0; y: 0;
            width: max(3px, parent.width * root.entry.bar_pct / 100);
            height: parent.height;
            border-radius: 3px;
            background: root.entry.bucket_color;
        }
    }
    Text {
        x: root.size_x;
        y: 11px;
        width: root.col_size_w;
        height: 16px;
        text: root.entry.bytes_text;
        color: ThemePalette.text;
        font-size: 13px;
        font-weight: 700;
        font-family: AppMetrics.mono_font;
        horizontal-alignment: right;
        vertical-alignment: center;
    }
    if root.entry.modified_text != "": Text {
        x: root.size_x;
        y: 32px;
        width: root.col_size_w;
        height: 14px;
        text: root.entry.modified_text;
        color: ThemePalette.text_faint;
        font-size: 10px;
        font-family: AppMetrics.mono_font;
        horizontal-alignment: right;
        vertical-alignment: center;
        overflow: elide;
    }
    touch := TouchArea {
        x: 0; y: 0;
        width: parent.width - root.actions_w;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.open(); }
    }
    if root.show_actions: Rectangle {
        x: parent.width - root.actions_w - 2px;
        y: 16px;
        width: root.actions_w;
        height: 28px;
        Rectangle {
            x: 22px; y: 0;
            width: 26px; height: 26px;
            border-radius: 4px;
            background: open_with_touch.has-hover ? ThemePalette.panel_solid : rgba(0, 0, 0, 0);
            Text {
                width: parent.width; height: parent.height;
                text: "↗";
                color: ThemePalette.text_muted;
                font-size: 13px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            open_with_touch := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.open_with(root.entry.path); }
            }
        }
        Rectangle {
            x: 0; y: 0;
            width: 26px; height: 26px;
            border-radius: 4px;
            background: more_touch.has-hover ? ThemePalette.panel_solid : rgba(0, 0, 0, 0);
            Text {
                width: parent.width; height: parent.height;
                text: "⋯";
                color: ThemePalette.text_muted;
                font-size: 13px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            more_touch := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.more(root.entry.path); }
            }
        }
    }
}

// Compact category row for the storage overview sidebar list.
component StorageBucketRow inherits Rectangle {
    in property <StorageBucketUi> bucket;
    in property <bool> is_active: false;
    callback select();
    height: 48px;
    clip: true;

    property <length> size_col_w: 76px;
    property <length> label_x: root.is_active ? 16px : 12px;

    Rectangle {
        x: 4px; y: 2px;
        width: parent.width - 8px;
        height: parent.height - 4px;
        border-radius: AppMetrics.radius_small;
        background: root.is_active
            ? ThemePalette.accent_soft
            : (touch.has-hover ? ThemePalette.panel_alt : rgba(0, 0, 0, 0));
        animate background { duration: 60ms; easing: ease-out; }
    }
    Rectangle {
        x: 0; y: parent.height - 1px;
        width: parent.width; height: 1px;
        background: ThemePalette.border;
    }
    if root.is_active: Rectangle {
        x: 4px; y: 10px;
        width: 3px; height: 28px;
        border-radius: 1px;
        background: bucket.color;
    }
    Text {
        x: root.label_x; y: 8px;
        width: parent.width - root.size_col_w - root.label_x - 8px; height: 16px;
        text: bucket.name;
        color: root.is_active ? ThemePalette.text : ThemePalette.text_muted;
        font-size: 12px;
        font-weight: 700;
        vertical-alignment: center;
        overflow: elide;
    }
    Text {
        x: root.label_x; y: 26px;
        width: parent.width - root.size_col_w - root.label_x - 8px; height: 14px;
        text: bucket.file_count_text + " · " + (bucket.percent > 0 && round(bucket.percent * 10) / 10 == 0
            ? "<0.1%"
            : (round(bucket.percent * 10) / 10 + "%"));
        color: bucket.color;
        font-size: 10px;
        font-weight: 600;
        vertical-alignment: center;
        overflow: elide;
    }
    Text {
        x: parent.width - root.size_col_w - 8px; y: 10px;
        width: root.size_col_w; height: 16px;
        text: bucket.bytes_text;
        color: ThemePalette.text;
        font-size: 12px;
        font-weight: 700;
        font-family: AppMetrics.mono_font;
        horizontal-alignment: right;
        vertical-alignment: center;
    }
    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.select(); }
    }
}

component StorageListHeader inherits Rectangle {
    in property <bool> show_bucket_label: true;
    in property <length> col_category_w: 100px;
    in property <length> col_share_w: 120px;
    in property <length> col_size_w: 88px;
    height: 28px;
    background: ThemePalette.panel_solid;
    Rectangle {
        x: 0; y: parent.height - 1px;
        width: parent.width; height: 1px;
        background: ThemePalette.border;
    }
    property <length> actions_w: 48px;
    property <length> right_pad: 10px;
    property <length> col_gap: 10px;
    property <length> content_right: root.width - root.right_pad - root.actions_w;
    property <length> size_x: root.content_right - root.col_size_w;
    property <length> share_x: root.size_x - root.col_gap - root.col_share_w;
    property <length> category_x: root.show_bucket_label && root.col_share_w > 0px
        ? root.share_x - root.col_gap - root.col_category_w
        : root.share_x;
    Text {
        x: 50px; y: 0;
        width: root.category_x - root.col_gap - 50px;
        height: parent.height;
        text: "Name";
        color: ThemePalette.text_faint;
        font-size: 10px;
        font-weight: 700;
        vertical-alignment: center;
    }
    if root.show_bucket_label && root.col_category_w > 0px: Text {
        x: root.category_x; y: 0;
        width: root.col_category_w; height: parent.height;
        text: "Category";
        color: ThemePalette.text_faint;
        font-size: 10px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    if root.col_share_w > 0px: Text {
        x: root.share_x; y: 0;
        width: root.col_share_w; height: parent.height;
        text: "Usage";
        color: ThemePalette.text_faint;
        font-size: 10px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    Text {
        x: root.size_x; y: 0;
        width: root.col_size_w; height: parent.height;
        text: "Size";
        color: ThemePalette.text_faint;
        font-size: 10px;
        font-weight: 700;
        horizontal-alignment: right;
        vertical-alignment: center;
    }
}

// Bottom recommendations — fills remaining column space, scrolls all tips.
component StorageTipsFooter inherits Rectangle {
    in property <[StorageTipUi]> tips;
    in property <bool> scanning;
    callback open_path(string);
    callback tip_action(string, string);
    property <bool> expanded: false;
    background: ThemePalette.panel_solid;
    vertical-stretch: 0;
    clip: true;
    preferred-height: root.expanded
        ? min(168px, 36px + root.tips.length * 52px)
        : (root.tips.length > 0 ? 30px : 0px);
    min-height: root.tips.length > 0 ? (root.expanded ? 96px : 30px) : 0px;
    max-height: root.expanded ? 168px : 30px;
    visible: root.tips.length > 0 || root.scanning;

    Rectangle {
        x: 0; y: 0;
        width: parent.width; height: 1px;
        background: ThemePalette.border;
    }
    Rectangle {
        x: 0; y: 0;
        width: parent.width; height: 30px;
        background: header_touch.has-hover ? ThemePalette.panel_alt : transparent;
        Text {
            x: 14px;
            width: parent.width - 28px;
            height: parent.height;
            text: root.tips.length > 0
                ? ("Suggestions · " + root.tips.length + (root.expanded ? "  ▴" : "  ▾"))
                : "Suggestions";
            color: ThemePalette.text_faint;
            font-size: 10px;
            font-weight: 700;
            vertical-alignment: center;
        }
        header_touch := TouchArea {
            mouse-cursor: root.tips.length > 0 ? pointer : default;
            clicked => { if (root.tips.length > 0) { root.expanded = !root.expanded; } }
        }
    }
    if root.expanded: ScrollView {
        x: 0; y: 30px;
        width: parent.width;
        height: parent.height - 30px;
        VerticalLayout {
            width: parent.width;
            spacing: 4px;
            padding: 4px;
            for tip[i] in root.tips: Rectangle {
                width: parent.width - 12px;
                height: 44px;
                border-radius: AppMetrics.radius_small;
                border-width: 1px;
                border-color: ThemePalette.border;
                background: tip_touch.has-hover ? ThemePalette.panel_alt : ThemePalette.bg;
                clip: true;
                Rectangle {
                    x: 0; y: 0;
                    width: 3px; height: parent.height;
                    background: tip.accent;
                }
                Text {
                    x: 10px; y: 0;
                    width: 22px; height: parent.height;
                    text: tip.icon;
                    color: tip.accent;
                    font-size: 11px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    font-family: AppMetrics.mono_font;
                }
                Text {
                    x: 36px; y: 6px;
                    width: parent.width - (tip.bytes_text != "" ? 108px : 44px); height: 16px;
                    text: tip.title;
                    color: ThemePalette.text;
                    font-size: 12px;
                    font-weight: 700;
                    vertical-alignment: center;
                    overflow: elide;
                }
                Text {
                    x: 36px; y: 24px;
                    width: parent.width - (tip.bytes_text != "" ? 108px : 44px); height: 14px;
                    text: tip.detail;
                    color: ThemePalette.text_muted;
                    font-size: 10px;
                    vertical-alignment: center;
                    overflow: elide;
                }
                if tip.bytes_text != "": Text {
                    x: parent.width - 100px; y: 6px;
                    width: 92px; height: 16px;
                    text: tip.bytes_text;
                    color: ThemePalette.text;
                    font-size: 11px;
                    font-weight: 700;
                    font-family: AppMetrics.mono_font;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                }
                tip_touch := TouchArea {
                    mouse-cursor: tip.path != "" || tip.action != "" ? pointer : default;
                    clicked => {
                        if (tip.action != "") {
                            root.tip_action(tip.action, tip.path);
                        } else if (tip.path != "") {
                            root.open_path(tip.path);
                        }
                    }
                }
            }
        }
    }
}

component StorageLargestPanel inherits Rectangle {
    in property <[StorageEntryUi]> top_items;
    in property <bool> scanning;
    in property <bool> show_bucket_label: true;
    in property <int> list_total: 0;
    in property <int> list_shown: 0;
    callback open_path(string);
    callback open_more(string);
    callback open_with(string);
    background: ThemePalette.bg;
    vertical-stretch: 1;
    min-height: 100px;
    clip: true;

    property <bool> compact: self.width < 720px;
    property <bool> tiny: self.width < 480px;
    property <bool> narrow: self.width < 600px;
    property <length> category_w: self.narrow ? 0px : (self.compact ? 88px : 100px);
    property <length> share_w: self.tiny ? 0px : (self.compact ? max(72px, self.width * 0.11) : max(100px, min(150px, self.width * 0.14)));
    property <length> size_w: self.tiny ? 72px : 88px;
    property <bool> show_headers: root.top_items.length > 0;
    property <length> header_block_h: 26px;
    property <length> list_header_h: 28px;
    property <length> list_gap: 4px;
    property <length> list_y: self.header_block_h + (self.show_headers ? self.list_header_h + self.list_gap : 0px);

    Text {
        x: 10px; y: 6px;
        width: parent.width - 20px; height: 16px;
        text: root.list_total > 0
            ? ("Largest items · " + root.list_shown + " of " + root.list_total)
            : (root.top_items.length > 0
                ? ("Largest items · " + root.top_items.length)
                : "Largest items");
        color: ThemePalette.text;
        font-size: 11px;
        font-weight: 700;
        vertical-alignment: center;
    }
    if root.show_headers: StorageListHeader {
        x: 0; y: root.header_block_h;
        width: parent.width;
        show_bucket_label: root.show_bucket_label && root.width >= 560px && !root.compact;
        col_category_w: root.category_w;
        col_share_w: root.share_w;
        col_size_w: root.size_w;
    }
    Rectangle {
        x: 0; y: root.list_y;
        width: parent.width; height: parent.height - root.list_y;
        background: ThemePalette.bg;
        clip: true;
        if root.top_items.length == 0: Text {
            x: 12px; y: 14px;
            width: parent.width - 24px;
            text: root.scanning
                ? "Largest items will appear once the scan completes."
                : "Nothing to list yet. Click Rescan to start.";
            color: ThemePalette.text_faint;
            font-size: 12px;
            wrap: word-wrap;
        }
        ListView {
            x: 0; y: 0;
            width: parent.width;
            height: parent.height;
            for entry[i] in root.top_items: StorageEntryRow {
                width: parent.width;
                entry: entry;
                show_bucket_label: root.show_bucket_label && root.width >= 560px && !root.compact;
                col_category_w: root.category_w;
                col_share_w: root.share_w;
                col_size_w: root.size_w;
                open => { root.open_path(entry.path); }
                more => { root.open_more(entry.path); }
                open_with => { root.open_with(entry.path); }
            }
        }
    }
}

// Storage overview: header, stats, category sidebar + largest-items split.
component StorageOverview inherits Rectangle {
    in property <bool> scanning;
    in property <string> root_label;
    in property <string> total_text;
    in property <string> subtitle;
    in property <[StorageBucketUi]> buckets;
    in property <[StorageEntryUi]> drives;
    in property <string> selected_bucket;
    in property <int> progress_files;
    in property <string> progress_bytes_text;
    in property <float> progress_percent;
    in property <string> disk_summary;
    in property <float> disk_used_pct;
    in property <string> breakdown_text;
    in property <float> scan_coverage_pct;
    in property <int> list_total;
    in property <int> list_shown;
    in property <[StorageTipUi]> tips;
    in property <[StorageEntryUi]> top_items;
    callback rescan();
    callback select_bucket(string);
    callback switch_root(string);
    callback show_full_list();
    callback open_path(string);
    callback tip_action(string, string);
    callback open_more(string);
    callback open_with(string);
    background: ThemePalette.bg;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        spacing: 0;
        alignment: stretch;

        // Header: title, disk summary, and actions on one compact row.
        Rectangle {
            preferred-height: root.drives.length > 1 ? 68px : 50px;
            min-height: self.preferred-height;
            max-height: self.preferred-height;
            vertical-stretch: 0;
            background: ThemePalette.panel_solid;
            Rectangle {
                x: 0; y: parent.height - 1px;
                width: parent.width; height: 1px;
                background: ThemePalette.border;
            }
            Text {
                x: 16px; y: 8px;
                width: parent.width - 220px; height: 18px;
                text: "Storage · " + root.root_label;
                color: ThemePalette.text;
                font-size: 15px;
                font-weight: 700;
                vertical-alignment: center;
                overflow: elide;
            }
            Text {
                x: 16px; y: 28px;
                width: parent.width - 220px; height: 14px;
                text: root.disk_summary != "" ? root.disk_summary : root.total_text;
                color: ThemePalette.text_muted;
                font-size: 11px;
                vertical-alignment: center;
                overflow: elide;
            }
            if root.drives.length > 1: HorizontalLayout {
                x: 16px; y: 46px;
                width: parent.width - 220px;
                height: 20px;
                spacing: 6px;
                alignment: start;
                for drv[i] in root.drives: Rectangle {
                    property <bool> is-active: drv.path == root.root_label;
                    width: max(88px, drvname.preferred-width + 28px);
                    height: 24px;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: self.is-active ? ThemePalette.accent : ThemePalette.border;
                    background: drvtouch.has-hover ? ThemePalette.accent_soft :
                        (self.is-active ? ThemePalette.accent_soft : ThemePalette.panel);
                    drvname := Text {
                        x: 10px;
                        width: parent.width - 20px;
                        height: parent.height;
                        text: drv.bytes_text != "" ? (drv.name + " · " + drv.bytes_text) : drv.name;
                        color: ThemePalette.text;
                        font-size: 11px;
                        font-weight: 600;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                    drvtouch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.switch_root(drv.path); }
                    }
                }
            }
            Rectangle {
                x: parent.width - 208px; y: 10px;
                width: 88px; height: 28px;
                border-radius: AppMetrics.radius_small;
                border-width: 1px;
                border-color: ThemePalette.border;
                background: full_touch.has-hover ? ThemePalette.accent_soft : ThemePalette.panel_alt;
                Text {
                    width: parent.width; height: parent.height;
                    text: "Full list";
                    color: ThemePalette.text;
                    font-size: 12px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                full_touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.show_full_list(); }
                }
            }
            Rectangle {
                x: parent.width - 112px; y: 10px;
                width: 84px; height: 28px;
                border-radius: AppMetrics.radius_small;
                border-width: 1px;
                border-color: ThemePalette.border;
                background: rescan_touch.has-hover ? ThemePalette.accent_soft : ThemePalette.panel_alt;
                Text {
                    width: parent.width; height: parent.height;
                    text: root.scanning ? "Scanning..." : "Rescan";
                    color: ThemePalette.text;
                    font-size: 12px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                rescan_touch := TouchArea {
                    enabled: !root.scanning;
                    mouse-cursor: pointer;
                    clicked => { root.rescan(); }
                }
            }
        }

        // Stats strip: category bar + scan summary on one slim row.
        Rectangle {
            preferred-height: root.buckets.length > 0 ? 36px : 28px;
            min-height: self.preferred-height;
            max-height: self.preferred-height;
            vertical-stretch: 0;
            background: ThemePalette.panel_solid;
            Rectangle {
                x: 0; y: parent.height - 1px;
                width: parent.width; height: 1px;
                background: ThemePalette.border;
            }
            Text {
                x: 16px; y: 4px;
                width: parent.width - 190px; height: 12px;
                text: root.breakdown_text != "" ? root.breakdown_text : root.subtitle;
                color: ThemePalette.text_muted;
                font-size: 10px;
                vertical-alignment: center;
                overflow: elide;
            }
            if root.buckets.length > 0: HorizontalLayout {
                x: 16px; y: 20px;
                width: parent.width - 32px;
                height: 6px;
                spacing: 2px;
                for bucket[i] in root.buckets: Rectangle {
                    horizontal-stretch: max(0.35, bucket.percent);
                    border-radius: 2px;
                    background: seg_touch.has-hover ? bucket.color : bucket.color.with-alpha(0.85);
                    seg_touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.select_bucket(bucket.id); }
                    }
                }
            }
            if root.disk_used_pct > 0 || (root.scan_coverage_pct > 0 && root.scan_coverage_pct < 100): Text {
                x: parent.width - 176px; y: 4px;
                width: 160px; height: 12px;
                text: (root.disk_used_pct > 0 ? (round(root.disk_used_pct) + "% disk used") : "")
                    + (root.disk_used_pct > 0 && root.scan_coverage_pct > 0 && root.scan_coverage_pct < 100 ? " · " : "")
                    + (root.scan_coverage_pct > 0 && root.scan_coverage_pct < 100 ? (round(root.scan_coverage_pct) + "% categorized") : "");
                color: ThemePalette.text_faint;
                font-size: 10px;
                font-weight: 600;
                horizontal-alignment: right;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        if root.scanning: Rectangle {
            preferred-height: 26px;
            min-height: 26px;
            max-height: 26px;
            vertical-stretch: 0;
            background: ThemePalette.panel_solid;
            Text {
                x: 18px; y: 4px;
                width: parent.width - 36px; height: 12px;
                text: "Scanning " + root.progress_files + " files · " + root.progress_bytes_text;
                color: ThemePalette.text_muted;
                font-size: 11px;
                vertical-alignment: center;
            }
            Rectangle {
                x: 18px; y: 20px;
                width: parent.width - 36px;
                height: 4px;
                border-radius: 2px;
                background: ThemePalette.panel_alt;
                Rectangle {
                    x: 0; y: 0;
                    width: max(4px, parent.width * root.progress_percent / 100);
                    height: parent.height;
                    border-radius: 2px;
                    background: ThemePalette.accent;
                    animate width { duration: 220ms; easing: ease-out; }
                }
            }
            Rectangle {
                x: 0; y: parent.height - 1px;
                width: parent.width; height: 1px;
                background: ThemePalette.border;
            }
        }

        // Main body: categories column + (largest items + suggestions) column.
        main_split := HorizontalLayout {
            vertical-stretch: 1;
            spacing: 0;
            alignment: stretch;
            property <bool> side_by_side: parent.width >= 760px;

            if root.buckets.length > 0 && self.side_by_side: Rectangle {
                width: min(260px, max(220px, parent.width * 0.26));
                vertical-stretch: 1;
                background: ThemePalette.bg;
                clip: true;
                Rectangle {
                    x: parent.width - 1px; y: 0;
                    width: 1px; height: parent.height;
                    background: ThemePalette.border;
                }
                Text {
                    x: 14px; y: 8px;
                    width: parent.width - 28px; height: 14px;
                    text: "Categories";
                    color: ThemePalette.text_faint;
                    font-size: 10px;
                    font-weight: 700;
                    letter-spacing: 0.5px;
                    vertical-alignment: center;
                }
                ScrollView {
                    x: 0; y: 26px;
                    width: parent.width;
                    height: parent.height - 28px;
                    VerticalLayout {
                        width: parent.width;
                        spacing: 0;
                        padding: 4px;
                        for bucket[i] in root.buckets: StorageBucketRow {
                            width: parent.width - 8px;
                            bucket: bucket;
                            is_active: bucket.id == root.selected_bucket;
                            select => { root.select_bucket(bucket.id); }
                        }
                    }
                }
            }

            VerticalLayout {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                spacing: 0;
                alignment: stretch;

                if root.buckets.length > 0 && !main_split.side_by_side: Rectangle {
                    preferred-height: min(200px, root.buckets.length * 44px + 32px);
                    min-height: 88px;
                    max-height: 200px;
                    vertical-stretch: 0;
                    background: ThemePalette.bg;
                    clip: true;
                    Text {
                        x: 14px; y: 8px;
                        width: parent.width - 28px; height: 14px;
                        text: "Categories";
                        color: ThemePalette.text_faint;
                        font-size: 10px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                    ScrollView {
                        x: 0; y: 26px;
                        width: parent.width;
                        height: parent.height - 28px;
                        VerticalLayout {
                            width: parent.width;
                            spacing: 0;
                            padding: 4px;
                            for bucket[i] in root.buckets: StorageBucketRow {
                                width: parent.width - 8px;
                                bucket: bucket;
                                is_active: bucket.id == root.selected_bucket;
                                select => { root.select_bucket(bucket.id); }
                            }
                        }
                    }
                    Rectangle {
                        x: 0; y: parent.height - 1px;
                        width: parent.width; height: 1px;
                        background: ThemePalette.border;
                    }
                }

                StorageLargestPanel {
                    vertical-stretch: 1;
                    min-height: 100px;
                    top_items: root.top_items;
                    scanning: root.scanning;
                    show_bucket_label: true;
                    list_total: root.list_total;
                    list_shown: root.list_shown;
                    open_path(p) => { root.open_path(p); }
                    open_more(p) => { root.open_more(p); }
                    open_with(p) => { root.open_with(p); }
                }

                StorageTipsFooter {
                    tips: root.tips;
                    scanning: root.scanning;
                    open_path(p) => { root.open_path(p); }
                    tip_action(action, path) => { root.tip_action(action, path); }
                }
            }
        }
    }
}

// Drill-in pane - shown in the preview pane area when a bucket is
// selected or "Full list" is active. Header bar with title + close,
// then the ranked-by-size list.
component StorageDrillIn inherits Rectangle {
    in property <[StorageEntryUi]> top_items;
    in property <bool> show_all;
    in property <string> selected_bucket;
    in property <string> selected_bucket_name;
    in property <bool> scanning;
    in property <int> list_total: 0;
    in property <int> list_shown: 0;
    in-out property <string> search_text: "";
    in property <string> sort_mode: "size";
    callback open_path(string);
    callback close();
    callback search_changed(string);
    callback set_sort_mode(string);
    // Bubble up row-level actions
    callback open_more(string);
    callback open_with(string);
    background: ThemePalette.bg;

    // v0.9.13: widened to match the rebuilt StorageEntryRow which
    // uses absolute right-aligned columns. Sizes here must mirror
    // the StorageEntryRow defaults so the header labels sit above
    // their cells.
    property <bool> compact: self.width < 720px;
    property <bool> tiny: self.width < 480px;
    property <bool> narrow: self.width < 600px;
    property <length> col_category_w: self.narrow ? 0px : (self.compact ? 88px : 100px);
    property <length> col_share_w: self.tiny ? 0px : (self.compact ? 72px : 120px);
    property <length> col_size_w: self.tiny ? 72px : 88px;
    property <bool> show_category_col: root.show_all && root.selected_bucket == "" && root.col_category_w > 0px;

    // v0.9.10: switched from VerticalLayout (which under conditional
    // children with vertical-stretch was producing a tiny ListView
    // viewport) to explicit absolute positioning. The list area now
    // always reaches the bottom of the pane.
    property <length> header_h: 56px;
    property <length> search_h: 40px;
    property <length> truncate_h: root.list_total > root.list_shown && root.list_shown > 0 ? 24px : 0px;
    property <length> labels_h: root.top_items.length > 0 ? 28px : 0px;
    property <length> list_y: root.header_h + root.search_h + root.truncate_h + root.labels_h;
    property <bool> show_sort_control: root.width >= 480px;
    property <bool> show_sort_compact: root.width >= 380px && root.width < 480px;

    // Header bar - back, title, close.
    Rectangle {
        x: 0; y: 0;
        width: parent.width; height: root.header_h;
        background: ThemePalette.panel_solid;
        Rectangle {
            x: 0; y: parent.height - 1px;
            width: parent.width; height: 1px;
            background: ThemePalette.border;
        }
        Rectangle {
            x: 10px; y: 8px;
            width: 28px; height: 28px;
            border-radius: 6px;
            background: back_touch.has-hover ? ThemePalette.panel_alt : rgba(0, 0, 0, 0);
            SvgIcon {
                x: 7px; y: 7px;
                icon_size: 14px;
                data: "M15 18l-6-6 6-6";
                tint: ThemePalette.text_muted;
            }
            back_touch := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.close(); }
            }
        }
        Text {
            x: 46px; y: 6px;
            width: parent.width - 90px; height: 18px;
            text: root.selected_bucket != ""
                ? root.selected_bucket_name
                : "All items by size";
            color: ThemePalette.text;
            font-size: 14px;
            font-weight: 700;
            vertical-alignment: center;
            overflow: elide;
        }
        Text {
            x: 46px; y: 24px;
            width: parent.width - 90px; height: 16px;
            text: root.list_total > 0
                ? ("Showing " + root.list_shown + " of " + root.list_total
                    + (root.selected_bucket != ""
                        ? " in this category"
                        : " ranked by size"))
                : (root.selected_bucket != ""
                    ? "Largest folders and files in this category"
                    : "Everything on the drive, ranked by size");
            color: ThemePalette.text_faint;
            font-size: 11px;
            vertical-alignment: center;
            overflow: elide;
        }
        Rectangle {
            x: parent.width - 38px; y: 8px;
            width: 28px; height: 28px;
            border-radius: 6px;
            background: close_touch.has-hover ? ThemePalette.panel_alt : rgba(0, 0, 0, 0);
            Text {
                width: parent.width; height: parent.height;
                text: "X";
                color: ThemePalette.text_muted;
                font-size: 14px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            close_touch := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.close(); }
            }
        }
    }

    // Search box - filter the visible list by name or path substring.
    // Rust handles the filter so the model stays bounded even for huge
    // buckets.
    Rectangle {
        x: 0; y: root.header_h;
        width: parent.width; height: root.search_h;
        background: ThemePalette.panel_solid;
        Rectangle {
            x: 0; y: parent.height - 1px;
            width: parent.width; height: 1px;
            background: ThemePalette.border;
        }
        Rectangle {
            x: 12px; y: 6px;
            width: root.show_sort_control ? parent.width - 24px - 212px
                : (root.show_sort_compact ? parent.width - 24px - 88px : parent.width - 24px);
            height: 28px;
            border-radius: 14px;
            border-width: 1px;
            border-color: search_input.has-focus ? ThemePalette.accent : ThemePalette.border;
            background: ThemePalette.bg;
            SvgIcon {
                x: 10px; y: 6px;
                icon_size: 14px;
                data: "M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16z M21 21l-4.3-4.3";
                tint: ThemePalette.text_faint;
            }
            search_input := TextInput {
                x: 32px; y: 0;
                width: parent.width - 64px; height: parent.height;
                text <=> root.search_text;
                color: ThemePalette.text;
                font-size: 12px;
                vertical-alignment: center;
                horizontal-alignment: left;
                edited => { root.search_changed(self.text); }
            }
            if root.search_text == "": Text {
                x: 32px; y: 0;
                width: parent.width - 64px; height: parent.height;
                text: "Search by name or path...";
                color: ThemePalette.text_faint;
                font-size: 12px;
                vertical-alignment: center;
            }
            if root.search_text != "": Rectangle {
                x: parent.width - 28px; y: 4px;
                width: 20px; height: 20px;
                border-radius: 10px;
                background: clear_touch.has-hover ? ThemePalette.panel_alt : rgba(0, 0, 0, 0);
                Text {
                    width: parent.width; height: parent.height;
                    text: "X";
                    color: ThemePalette.text_muted;
                    font-size: 11px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                clear_touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.search_text = "";
                        root.search_changed("");
                    }
                }
            }
        }
    }

    // Segmented sort control - overlaid at the right of the search row.
    // Lets the user pivot the same scan data by Size / Name / Recent
    // without a rescan (Rust re-sorts the bound model).
    if root.show_sort_control: Rectangle {
        x: parent.width - 12px - 206px;
        y: root.header_h + 6px;
        width: 206px;
        height: 28px;
        Rectangle {
            x: 0; y: 0; width: 66px; height: parent.height;
            border-radius: 14px;
            background: root.sort_mode == "size" ? ThemePalette.accent_soft : (sort_size_t.has-hover ? ThemePalette.panel_alt : rgba(0, 0, 0, 0));
            border-width: 1px;
            border-color: root.sort_mode == "size" ? ThemePalette.accent : ThemePalette.border;
            Text {
                width: parent.width; height: parent.height;
                text: "Size";
                font-size: 11px; font-weight: 600;
                color: root.sort_mode == "size" ? ThemePalette.accent_strong : ThemePalette.text_muted;
                horizontal-alignment: center; vertical-alignment: center;
            }
            sort_size_t := TouchArea { mouse-cursor: pointer; clicked => { root.set_sort_mode("size"); } }
        }
        Rectangle {
            x: 70px; y: 0; width: 66px; height: parent.height;
            border-radius: 14px;
            background: root.sort_mode == "name" ? ThemePalette.accent_soft : (sort_name_t.has-hover ? ThemePalette.panel_alt : rgba(0, 0, 0, 0));
            border-width: 1px;
            border-color: root.sort_mode == "name" ? ThemePalette.accent : ThemePalette.border;
            Text {
                width: parent.width; height: parent.height;
                text: "Name";
                font-size: 11px; font-weight: 600;
                color: root.sort_mode == "name" ? ThemePalette.accent_strong : ThemePalette.text_muted;
                horizontal-alignment: center; vertical-alignment: center;
            }
            sort_name_t := TouchArea { mouse-cursor: pointer; clicked => { root.set_sort_mode("name"); } }
        }
        Rectangle {
            x: 140px; y: 0; width: 66px; height: parent.height;
            border-radius: 14px;
            background: root.sort_mode == "recent" ? ThemePalette.accent_soft : (sort_recent_t.has-hover ? ThemePalette.panel_alt : rgba(0, 0, 0, 0));
            border-width: 1px;
            border-color: root.sort_mode == "recent" ? ThemePalette.accent : ThemePalette.border;
            Text {
                width: parent.width; height: parent.height;
                text: "Recent";
                font-size: 11px; font-weight: 600;
                color: root.sort_mode == "recent" ? ThemePalette.accent_strong : ThemePalette.text_muted;
                horizontal-alignment: center; vertical-alignment: center;
            }
            sort_recent_t := TouchArea { mouse-cursor: pointer; clicked => { root.set_sort_mode("recent"); } }
        }
    }

    // Compact sort: Size / Name only on medium-width panes.
    if root.show_sort_compact && !root.show_sort_control: Rectangle {
        x: parent.width - 12px - 86px;
        y: root.header_h + 6px;
        width: 86px;
        height: 28px;
        Rectangle {
            x: 0; y: 0; width: 40px; height: parent.height;
            border-radius: 14px;
            background: root.sort_mode == "size" ? ThemePalette.accent_soft : (sort_sz_t.has-hover ? ThemePalette.panel_alt : rgba(0, 0, 0, 0));
            border-width: 1px;
            border-color: root.sort_mode == "size" ? ThemePalette.accent : ThemePalette.border;
            Text {
                width: parent.width; height: parent.height;
                text: "Sz";
                font-size: 11px; font-weight: 700;
                color: root.sort_mode == "size" ? ThemePalette.accent_strong : ThemePalette.text_muted;
                horizontal-alignment: center; vertical-alignment: center;
            }
            sort_sz_t := TouchArea { mouse-cursor: pointer; clicked => { root.set_sort_mode("size"); } }
        }
        Rectangle {
            x: 44px; y: 0; width: 40px; height: parent.height;
            border-radius: 14px;
            background: root.sort_mode == "name" ? ThemePalette.accent_soft : (sort_nm_t.has-hover ? ThemePalette.panel_alt : rgba(0, 0, 0, 0));
            border-width: 1px;
            border-color: root.sort_mode == "name" ? ThemePalette.accent : ThemePalette.border;
            Text {
                width: parent.width; height: parent.height;
                text: "Az";
                font-size: 11px; font-weight: 700;
                color: root.sort_mode == "name" ? ThemePalette.accent_strong : ThemePalette.text_muted;
                horizontal-alignment: center; vertical-alignment: center;
            }
            sort_nm_t := TouchArea { mouse-cursor: pointer; clicked => { root.set_sort_mode("name"); } }
        }
    }

    if root.list_total > root.list_shown && root.list_shown > 0: Rectangle {
        x: 0; y: root.header_h + root.search_h;
        width: parent.width; height: root.truncate_h;
        background: ThemePalette.panel_alt;
        Text {
            x: 18px; y: 0;
            width: parent.width - 36px; height: parent.height;
            text: "Showing top " + root.list_shown + " of " + root.list_total + " — use search to narrow results";
            color: ThemePalette.text_faint;
            font-size: 10.5px;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    // Column labels
    if root.top_items.length > 0: StorageListHeader {
        x: 0; y: root.header_h + root.search_h + root.truncate_h;
        width: parent.width;
        show_bucket_label: root.show_category_col;
        col_category_w: root.col_category_w;
        col_share_w: root.col_share_w;
        col_size_w: root.col_size_w;
    }

    // Ranked list - explicitly reaches the bottom of the pane.
    if root.top_items.length > 0: Rectangle {
        x: 0; y: root.list_y;
        width: parent.width;
        height: parent.height - root.list_y;
        background: ThemePalette.bg;
        clip: true;
        ListView {
            x: 0; y: 0;
            width: parent.width;
            height: parent.height;
            for entry[idx] in root.top_items: StorageEntryRow {
                width: parent.width;
                entry: entry;
                show_bucket_label: root.show_category_col;
                col_category_w: root.col_category_w;
                col_share_w: root.col_share_w;
                col_size_w: root.col_size_w;
                open => { root.open_path(entry.path); }
                more => { root.open_more(entry.path); }
                open_with => { root.open_with(entry.path); }
            }
        }
    }
    // Empty state.
    if root.top_items.length == 0: Rectangle {
        x: 0; y: root.header_h + root.search_h;
        width: parent.width;
        height: parent.height - root.header_h - root.search_h;
        background: ThemePalette.bg;
        Text {
            x: 24px; y: 24px;
            width: parent.width - 48px;
            text: root.scanning
                ? "Still scanning - results will appear shortly."
                : (root.search_text != ""
                    ? ("No matches for \"" + root.search_text + "\" in this category.")
                    : (root.selected_bucket != ""
                        ? ("No large items found in " + root.selected_bucket_name + ".")
                        : "No items to show. Click Rescan to start."));
            color: ThemePalette.text_muted;
            font-size: 12px;
        }
    }
}


export component MainWindow inherits Window {
    // Keep Fluent std-widgets (LineEdit etc.) aligned with ThemePalette light/dark.
    public function sync_widget_palette(light: bool) {
        Palette.color-scheme = light ? ColorScheme.light : ColorScheme.dark;
    }

    no-frame: true;
    resize-border-width: 8px;
    title: "Pathfinder";
    preferred-width: 1280px;
    preferred-height: 800px;
    min-width: 900px;
    min-height: 550px;
    background: ThemePalette.bg_gradient_enabled
        ? (ThemePalette.bg_gradient_accent_tip
            ? @linear-gradient(165deg, ThemePalette.bg_soft 0%, ThemePalette.bg 42%, ThemePalette.accent 100%)
            : @linear-gradient(165deg, ThemePalette.bg_soft 0%, ThemePalette.bg 55%, ThemePalette.bg 100%))
        : ThemePalette.bg;
    default-font-family: AppMetrics.ui_font;
    forward-focus: keys;

    in-out property <[FileItem]> files;
    in-out property <[SideItem]> side_items;
    in-out property <[TabItem]> tabs;
    in-out property <[ChoiceItem]> theme_choices;
    in-out property <[ChoiceItem]> accent_choices;
    in-out property <[ChoiceItem]> density_choices;
    in-out property <[ChoiceItem]> index_choices;
    in-out property <[CommandItem]> command_items;

    in-out property <string> current_path: "";
    in-out property <string> address_text: "";
    in-out property <string> search_text: "";
    in-out property <bool> search_scope_all: false;
    in-out property <string> search_scope_label: "Folder";
    // When true, ranked by on-device embedding similarity (requires Local AI models).
    in-out property <bool> search_semantic_mode: false;
    in-out property <bool> semantic_search_available: false;
    // Experimental: CLIP-style description search (optional model; may be unavailable).
    in-out property <bool> clip_search_enabled: false;
    in-out property <string> active_theme: "mica-dark";
    in-out property <string> active_accent: "blue";
    in-out property <string> active_density: "cozy";
    in-out property <string> active_index_mode: "low";
    in-out property <string> index_status: "";
    in-out property <string> thumbnail_status: "";
    in-out property <string> performance_intro: "";
    in-out property <string> performance_footprint: "";
    in-out property <string> view_mode: "grid";
    in-out property <bool> preview_visible: true;
    in-out property <bool> dual_pane: false;
    // "primary" or "secondary" - which pane has focus (drives accent borders + paste target).
    in-out property <string> active_pane: "primary";
    // True when the active pane is showing the virtual `recycle://` bin -
    // the file context menu surfaces Restore / Permanently Delete in that mode.
    in-out property <bool> in_recycle_bin: false;
    // High Fantasy empty-pane ornament: chest|scroll|gem|potion|tower|cauldron.
    // Set from Rust on navigate; UI may override for search.
    in-out property <string> fantasy_empty_kind: "chest";
    // "primary" / "secondary" / "" - pane currently being hovered during a drag-drop;
    // overlays a thicker glowing border so the user can see where the drop will land.
    in-out property <string> drag_over_pane: "";
    // Exact destination folder path that a drop at the current cursor position
    // would land in (sidebar entry, subfolder row, or pane background). Set by
    // the Win32 DragOver handler and consumed by FileRow / SideRow to draw a
    // glowing border on the target while the drag is in progress.
    in-out property <string> drag_target_path: "";
    // Cursor position in logical-pixel client-space, updated by the IDropTarget
    // DragOver handler so the slint ghost overlay can track the cursor during
    // a drag. drag_label holds a short description of what is being dragged
    // (typically the first file's name + a +N marker for multi-file drags).
    in-out property <length> drag_cursor_x: 0;
    in-out property <length> drag_cursor_y: 0;
    // Storage view mode. When true, the main pane shows the storage analyzer
    // (categorized buckets + ranked-by-size list) instead of the file list.
    // Toggled from the "Storage" sidebar entry. Backed by a per-scan cache in
    // Rust so re-opening the tab doesn't trigger another whole-disk walk.
    in-out property <bool> is_storage_view: false;
    in-out property <bool> is_home_view: false;
    in-out property <bool> storage_scanning: false;
    in-out property <string> storage_root: "";
    in-out property <string> storage_total_text: "";
    in-out property <string> storage_subtitle: "";
    in-out property <[StorageBucketUi]> storage_buckets;
    in-out property <[StorageEntryUi]> storage_top_items;
    in-out property <[StorageEntryUi]> storage_drives;
    in-out property <bool> storage_show_all: false;
    in-out property <string> storage_selected_bucket: "";
    in-out property <string> storage_selected_bucket_name: "";
    in-out property <int> storage_progress_files: 0;
    in-out property <string> storage_progress_bytes_text: "";
    in-out property <float> storage_progress_percent: 0;
    // Drill-in search filter - user types here to narrow the bucket
    // drill-in list. Rust filters server-side so the model stays
    // bounded even on huge buckets.
    in-out property <string> storage_drill_search: "";
    callback storage_drill_search_changed(string);
    // Drill-in sort mode: "size" | "name" | "recent". Rust re-sorts the
    // bound model so huge buckets never sort on the UI thread.
    in-out property <string> storage_sort_mode: "size";
    callback storage_set_sort_mode(string);
    // Disk-wide totals shown in the overview's hero bar.
    in-out property <string> storage_disk_summary: "";
    in-out property <float> storage_disk_used_pct: 0;
    // Scanned vs system/unaccounted breakdown shown under the disk summary.
    in-out property <string> storage_breakdown_text: "";
    in-out property <float> storage_scan_coverage_pct: 100;
    // Item counts for the active list (overview largest / drill-in).
    in-out property <int> storage_list_total: 0;
    in-out property <int> storage_list_shown: 0;
    // Recommendations / explanations shown below the bucket grid on
    // the storage overview. Populated by the Rust storage scan.
    in-out property <[StorageTipUi]> storage_tips;
    callback storage_rescan();
    callback storage_open_path(string);
    callback storage_toggle_show_all();
    callback storage_select_bucket(string);
    callback storage_clear_bucket();
    callback storage_switch_root(string);
    callback storage_tip_action(string, string);
    // Entry context actions exposed for the storage panels.
    callback storage_entry_more(string);
    callback storage_entry_open_with(string);
    // Per-folder scroll memory. Rust saves the leaving folder's viewport-y and
    // restores the arriving folder's saved value on every navigate so back / up
    // / re-entering a folder land on the row the user was looking at, not the top.
    in-out property <length> primary_list_scroll_y: 0;
    in-out property <length> primary_grid_scroll_y: 0;
    in-out property <length> secondary_list_scroll_y: 0;
    in-out property <string> drag_label: "";
    in-out property <string> drag_ghost_ext: "";
    in-out property <bool> drag_ghost_is_dir: false;
    in-out property <bool> show_hidden: false;
    in-out property <bool> settings_visible: false;
    in-out property <string> settings_tab: "appearance";
    // Application version (pulled from CARGO_PKG_VERSION at startup).
    // Shown in the settings header as quick at-a-glance reference for
    // bug reports and update troubleshooting.
    in-out property <string> app_version: "";
    // Windows-only: shell integration (set from Rust at startup).
    in-out property <bool> show_windows_integration: false;

    // -- AI install/uninstall state ----------------------------------------
    // "not_installed" | "downloading" | "updating" | "installed" | "error"
    in-out property <string> ai_install_state: "not_installed";
    in-out property <float> ai_download_progress: 0;
    in-out property <string> ai_install_message: "";
    in-out property <bool> ai_install_explainer_visible: false;
    in-out property <int> ai_install_size_mb: 180;
    in-out property <string> ai_profile: "balanced";
    in-out property <string> ai_profile_label: "Balanced (recommended)";
    in-out property <bool> ai_auto_update: true;
    in-out property <string> ai_update_status: "";
    in-out property <string> ai_feature_semantic: "Install Local AI to enable";
    in-out property <string> ai_feature_classify: "Install Local AI to enable";
    in-out property <string> ai_feature_dupes: "Ready - near-duplicate detection uses a lightweight image hash";
    in-out property <string> ai_disk_usage: "";
    in-out property <string> ai_model_versions: "";
    callback ai_install_request();
    callback ai_install_confirm();
    callback ai_uninstall();
    callback ai_repair();
    callback ai_update_models();
    callback ai_set_profile(string);
    callback ai_toggle_auto_update();
    in-out property <bool> command_visible: false;
    in-out property <bool> context_visible: false;
    in-out property <bool> image_tools_visible: false;
    in-out property <bool> confirm_visible: false;
    in-out property <bool> prompt_visible: false;
    in-out property <bool> address_editing: false;
    in-out property <[string]> addr_suggestions: [];
    in-out property <int> selected_index: -1;
    // Number of selected items in the active pane. When > 0 the toolbar swaps
    // its navigation chrome for a contextual action row (copy / cut / delete /
    // rename / share). The Rust controller pushes this on every selection change.
    in-out property <int> selected_count: 0;
    // True when the current selection includes archive(s) — shows Extract Here in the selection bar.
    in-out property <bool> selection_has_archive: false;
    in-out property <string> selected_name: "";
    in-out property <string> preview_title: "";
    in-out property <string> preview_body: "";
    in-out property <string> preview_meta: "";
    in-out property <string> image_tools_title: "Image Tools";
    in-out property <string> image_tools_subtitle: "";
    in-out property <bool> preview_is_image: false;
    in-out property <image> preview_image;
    // Rasterized PDF first page shown at the top of the preview pane.
    in-out property <bool> preview_has_pdf_page: false;
    in-out property <image> preview_pdf_page;
    // HTML / Markdown preview toggle. When true, an extra button in the
    // preview header opens the file in the system default browser so the
    // user can see it rendered. The pane itself keeps showing source code.
    in-out property <bool> preview_is_html: false;
    // True for html/htm/md/markdown — shows the in-app Code/Rendered toggle.
    in-out property <bool> preview_can_render: false;
    // When true the pane shows the built-in rendered text instead of source.
    in-out property <bool> preview_show_rendered: false;
    // Rendered (tags-stripped) plain text produced by the Rust side.
    in-out property <string> preview_rendered: "";
    in-out property <bool> preview_is_media: false;
    in-out property <bool> preview_is_pdf: false;
    in-out property <bool> quick_look_visible: false;
    in-out property <string> quick_look_path: "";
    in-out property <string> batch_rename_find: "";
    in-out property <string> batch_rename_replace: "";
    in-out property <string> batch_rename_prefix: "";
    in-out property <string> batch_rename_suffix: "";
    in-out property <string> batch_rename_template: "";
    in-out property <string> batch_rename_preview: "";
    in-out property <bool> rename_presets_visible: false;
    in-out property <[string]> rename_preset_names: [];
    // Reusable tool overlay (rules / smart-folders / templates / shortcuts / workspaces).
    in-out property <bool> tool_overlay_visible: false;
    in-out property <string> tool_overlay_kind: "";
    in-out property <string> tool_overlay_title: "";
    in-out property <string> tool_overlay_subtitle: "";
    in-out property <[ToolListItem]> tool_overlay_items;
    in-out property <[ShortcutEditItem]> shortcut_edit_items;
    in-out property <bool> compare_overlay_visible: false;
    in-out property <string> compare_overlay_title: "";
    in-out property <string> compare_overlay_left: "";
    in-out property <string> compare_overlay_right: "";
    in-out property <bool> compare_overlay_hide_same: false;
    in-out property <[CompareRowItem]> compare_rows;
    in-out property <bool> dupe_overlay_visible: false;
    in-out property <string> dupe_overlay_title: "";
    in-out property <string> dupe_overlay_subtitle: "";
    in-out property <[DupeGroupItem]> dupe_groups;
    in-out property <bool> search_help_visible: false;
    in-out property <string> search_chip_hint: "";
    in-out property <bool> queue_busy: false;
    in-out property <string> queue_busy_text: "";
    in-out property <int> welcome_step: 0;
    in-out property <int> tab_drag_from: -1;
    in-out property <int> tab_drag_over: -1;
    callback open_preview_in_browser();
    callback toggle_quick_look();
    callback quick_look_play();
    callback quick_look_close();
    callback tab_reordered(int, int);
    callback rename_preset_picked(string);
    callback batch_rename_preview_refresh();
    callback tool_overlay_activate(string);
    callback tool_overlay_toggle(string);
    callback tool_overlay_secondary(string);
    callback tool_overlay_close();
    callback tool_overlay_primary_action();
    callback shortcut_hint_changed(string, string);
    callback compare_row_activate(string);
    callback compare_overlay_close();
    callback compare_toggle_hide_same();
    callback dupe_group_keep(string);
    callback dupe_group_delete_others(string);
    callback dupe_overlay_close();
    callback search_chip(string);
    callback search_save_requested();
    callback search_help_toggle();
    callback queue_pill_clicked();
    callback welcome_next_step();
    callback welcome_set_mode(string);
    in-out property <string> status_left: "Ready";
    in-out property <string> status_right: "";
    in-out property <string> toast_text: "";
    in-out property <string> ai_label: "CPU Fallback";
    in-out property <string> ai_device: "Detecting";
    in-out property <string> ai_gpu_status: "";
    in-out property <string> prompt_title: "";
    in-out property <string> prompt_value: "";
    // "text" = standard text-input prompt; "conflict" = three-button dialog
    // (Keep Both / Replace / Skip). Set by the controller when raising a
    // ConflictPaste prompt so the UI can show appropriate affordances.
    in-out property <string> prompt_kind: "text";
    in-out property <string> confirm_text: "";
    in-out property <length> context_x: 0px;
    in-out property <length> context_y: 0px;
    in-out property <string> command_filter: "";
    in-out property <int> rename_index: -1;
    in-out property <[ChoiceItem]> breadcrumbs;

    in-out property <string> empty_state: "";
    in-out property <string> sort_by: "modified";
    in-out property <string> sort_dir: "desc";
    in-out property <string> toast_kind: "info";
    // When non-empty, toast shows an action button (e.g. "Undo").
    in-out property <string> toast_action: "";
    in-out property <bool> folder_changed_banner: false;
    in-out property <string> search_source_pref: "auto";
    in-out property <float> thumb_size_scale: 1.0;
    in-out property <[ChoiceItem]> tag_chips: [];
    in-out property <[ChoiceItem]> crumb_sibling_items: [];
    in-out property <bool> crumb_siblings_visible: false;
    in-out property <int> crumb_siblings_index: -1;
    in-out property <bool> op_drawer_visible: false;
    in-out property <string> op_drawer_text: "";
    // Live progress for compress / extract operations. progress is 0.0 to 1.0;
    // a negative value means indeterminate (show a pulsing bar instead).
    in-out property <float> op_drawer_progress: -1;
    in-out property <[FileItem]> secondary_files;
    in-out property <string> secondary_path: "";
    in-out property <string> secondary_sort_by: "modified";
    in-out property <string> secondary_sort_dir: "desc";
    in-out property <string> filter_text: "";
    in-out property <bool> filter_bar_visible: false;
    in-out property <[string]> tag_names: ["Urgent", "Important", "Review", "Done", "Personal", "Code"];
    in-out property <bool> context_on_file: false;
    in-out property <bool> context_is_archive: false;
    in-out property <bool> context_advanced: false;
    in-out property <bool> context_tags_expanded: false;
    in-out property <bool> secondary_addr_editing: false;

    callback filter_commands(string);
    callback command_run_first(string);
    callback navigate(string);
    callback crumb_navigate(int);
    callback rename_file(int, string);
    callback side_activated(int);
    callback file_selected(int, bool, bool);
    callback file_opened(int);
    callback file_context(int);
    callback tab_activated(int);
    callback tab_closed(int);
    callback new_tab();
    callback go_back();
    callback go_forward();
    callback go_up();
    callback refresh();
    callback secondary_refresh();
    callback search_requested(string);
    callback search_immediate(string);
    callback toggle_search_scope();
    callback toggle_search_semantic_mode();
    callback set_clip_search_enabled(bool);
    callback address_changed(string);
    callback set_view(string);
    callback toggle_preview();
    callback toggle_dual_pane();
    callback toggle_hidden();
    callback command(string);
    in-out property <int> toolbar_search_focus_nonce: 0;
    callback theme_selected(string);
    callback accent_selected(string);
    callback density_selected(string);
    callback folder_color_changed(string);
    in-out property <string> folder_color_hex: "#e2a934";
    callback custom_accent_changed(string);
    in-out property <string> custom_accent_hex: "#4f9cff";
    callback index_mode_selected(string);
    callback clear_thumbnail_cache();
    callback rebuild_index();
    callback windows_set_default_folder_handler();
    callback windows_restore_folder_handler();
    callback welcome_set_default_handler();
    callback welcome_open_taskbar_settings();
    callback welcome_dismiss();
    callback toast_copy();
    callback toast_dismiss();
    callback toast_action_clicked();
    callback side_expand_toggled(string);
    callback crumb_siblings(int);
    callback preview_action(string);
    callback tab_middle_close(int);
    callback tab_context(int);
    callback apply_tag_chip(string);
    callback search_source_picked(string);
    callback dupe_keep_strategy(string);
    callback redo_command();
    callback batch_tag_selected();
    callback batch_note_selected();
    callback folder_changed_refresh();
    callback new_window();
    callback thumb_size_changed(float);
    callback file_diff_selected();
    in-out property <bool> welcome_visible: false;
    in-out property <string> welcome_default_status: "Click Set as default below to register Pathfinder for folder shortcuts in Explorer.";
    in-out property <bool> welcome_default_handler_set: false;
    callback minimize();
    callback maximize();
    callback close();
    callback drag_window();
    callback confirm_delete();
    callback prompt_accept(string);
    callback prompt_cancel();
    callback sort_column(string);
    callback clear_selection();
    // Drag-rectangle selection. Coordinates are in primary-pane local space
    // (origin at the pane's top-left). Rust converts them to file indices via
    // the same geometry (grid_columns / grid_cell_w / grid_item_h / row_h).
    callback marquee_select(length, length, length, length, bool);
    callback rename_tag_prompt(string);
    callback secondary_navigate(string);
    callback secondary_file_opened(int);
    callback secondary_file_selected(int, bool, bool);
    callback secondary_file_context(int);
    callback secondary_rename_file(int, string);
    callback secondary_go_up();
    callback secondary_go_back();
    callback secondary_sort_column(string);
    callback secondary_navigate_path(string);
    callback filter_changed(string);
    callback set_ui_mode(string);
    callback ui_mode_prompt_choice(string);
    callback start_file_drag(int, string);

    in-out property <string> ui_mode: "normal";
    in-out property <bool> ui_mode_prompt_visible: false;
    in-out property <[SideItem]> side_items_simple: [];

    property <bool> is_simple: root.ui_mode == "simple";

    // Custom theme editor state
    in-out property <string> ce_name: "My Theme";
    in-out property <[color]> ce_token_colors: [];
    in-out property <[string]> ce_token_hexes: [];
    in-out property <[string]> ce_saved_themes: [];
    in-out property <int> ce_selected_token: -1;
    in-out property <string> ce_token_hex: "";
    in-out property <string> ce_token_label: "";
    in-out property <float> ce_radius: 8;
    in-out property <float> ce_anim_speed: 1.0;
    in-out property <string> ce_finish: "mica-dark";
    // Bundled font preset ids (saved in theme JSON). Resolved families below.
    in-out property <string> ce_ui_font: "noto-sans";
    in-out property <string> ce_mono_font: "noto-sans-mono";
    in-out property <string> ce_preview_ui_font: "Noto Sans";
    in-out property <string> ce_preview_mono_font: "Noto Sans Mono";
    in-out property <int> ce_font_size_delta: 0;
    in-out property <string> ce_icon_folder_hex: "#e2a934";
    in-out property <string> ce_icon_set: "";
    in-out property <bool> ce_gradient_background: false;
    in-out property <bool> ce_gradient_accent: false;

    callback ce_select_token(int);
    callback ce_color_changed(int, string);
    callback ce_radius_changed(float);
    callback ce_anim_changed(float);
    callback ce_finish_changed(string);
    callback ce_font_preset(string, string);
    callback ce_font_changed(string, string);
    callback ce_font_size_changed(int);
    callback ce_icon_tint_changed(string);
    callback ce_gradient_changed(bool);
    callback ce_gradient_accent_changed(bool);
    callback ce_apply_preview();
    callback ce_save(string);
    callback ce_load(string);
    callback ce_delete(string);
    callback ce_reset_to_active();

    in-out property <bool> update_available: false;
    in-out property <string> update_version: "";
    in-out property <string> update_download_url: "";
    callback install_update();

    // Splitter targets update every frame while dragging; layout reads the
    // animated properties so panes ease instead of snapping pixel-by-pixel.
    property <length> sidebar_w_target: 238px;
    out property <length> sidebar_w: sidebar_w_target;
    animate sidebar_w {
        duration: 72ms;
        easing: ease-out;
    }

    property <float> split_ratio_target: 0.5;
    property <float> split_ratio: split_ratio_target;
    animate split_ratio {
        duration: 64ms;
        easing: ease-out;
    }
    property <length> title_h: 36px;
    // Simple mode uses a true two-row toolbar: navigation cluster + address bar
    // on top, view modes + actions underneath, each row a full 38 px tall with
    // wider buttons that have room for a readable caption next to the icon. The
    // captions stay visible at all times so users who don't recognise the glyphs
    // can read what each button does.
    property <length> toolbar_h: root.is_simple ? 88px : 44px;
    property <length> simple_row1_y: 4px;
    property <length> simple_row2_y: 48px;
    property <length> simple_btn_w: 88px;
    property <length> simple_btn_h: 38px;
    property <length> filter_bar_h: root.filter_bar_visible ? 36px : 0px;
    property <length> status_h: 26px;
    // User-set preview pane width (drag handle on its left edge writes here).
    // Clamped to a usable range so the preview never shrinks to nothing or
    // crowds the file area off-screen on narrow windows.
    property <length> preview_w_user_target: 326px;
    in-out property <length> preview_w_user: preview_w_user_target;
    animate preview_w_user {
        duration: 72ms;
        easing: ease-out;
    }
    property <length> preview_w: root.preview_visible ? max(220px, min(640px, root.preview_w_user)) : 0px;
    property <length> main_content_w: root.width - root.sidebar_w - root.preview_w;
    out property <length> pane_splitter_w: root.dual_pane ? 6px : 0px;
    out property <length> primary_pane_w: root.dual_pane ? (root.main_content_w - root.pane_splitter_w) * root.split_ratio : root.main_content_w;
    out property <length> secondary_pane_w: root.dual_pane ? root.main_content_w - root.primary_pane_w - root.pane_splitter_w : 0px;
    // Pane width minus padding on both sides, minus a 14px scroll bar
    // reserve on the right. Grid and gallery views compute column count and
    // cell width off this, so reserving here keeps the rightmost cell from
    // sitting under the scroll bar without needing per-view tweaks.
    property <length> file_area_w: root.primary_pane_w - AppMetrics.pad * 2 - 18px;
    property <length> secondary_file_area_w: root.secondary_pane_w - AppMetrics.pad * 2 - 18px;
    property <int> grid_columns: Math.max(1, Math.floor(root.file_area_w / (root.view_mode == "compact" ? 200px : AppMetrics.grid_w)));
    property <int> secondary_grid_columns: Math.max(1, Math.floor(root.secondary_file_area_w / (root.view_mode == "compact" ? 200px : AppMetrics.grid_w)));
    property <length> grid_cell_w: root.file_area_w / root.grid_columns;
    property <length> secondary_grid_cell_w: root.secondary_file_area_w / root.secondary_grid_columns;
    property <length> grid_item_h: root.view_mode == "gallery"
        ? (154px * root.thumb_size_scale)
        : (root.view_mode == "compact" ? 32px : (AppMetrics.grid_h * root.thumb_size_scale));
    property <length> secondary_grid_item_h: root.grid_item_h;
    property <int> grid_rows: (root.files.length + root.grid_columns - 1) / root.grid_columns;
    property <int> secondary_grid_rows: (root.secondary_files.length + root.secondary_grid_columns - 1) / root.secondary_grid_columns;
    // gap on each side of each grid cell for uniform spacing
    property <length> grid_gap: root.view_mode == "compact" ? 2px : 8px;
    property <length> secondary_grid_gap: root.grid_gap;

    in-out property <float> nav_opacity: 1.0;

    app := Rectangle {
        width: parent.width;
        height: parent.height;
        background: ThemePalette.panel;
        border-width: AppMetrics.outer_border;
        border-color: ThemePalette.border_strong;

        // Titlebar
        Rectangle {
            x: 0;
            y: 0;
            width: parent.width;
            height: root.title_h;
            background: ThemePalette.titlebar;
            border-width: 0px;

            // Titlebar chrome: layout positions tabs/+ so TouchAreas match visuals.
            // WM_NCHITTEST in lib.rs excludes this strip from HTCAPTION (logical
            // coords: padding-left 10, + 28, spacing 8, tab row y 6 h 30).
            title_chrome := HorizontalLayout {
                x: 0;
                y: 0;
                width: parent.width - 184px;
                height: parent.height;
                padding-left: 10px;
                padding-top: 4px;
                spacing: 8px;
                alignment: start;

                Rectangle {
                    width: 28px;
                    height: 28px;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: plus_touch.has-hover
                        ? ThemePalette.accent
                        : ThemePalette.border;
                    background: plus_touch.has-hover ? ThemePalette.panel_alt : ThemePalette.panel;
                    animate background { duration: 60ms; easing: ease-out; }
                    animate border-color { duration: 60ms; easing: ease-out; }
                    Rectangle {
                        x: (parent.width - 12px) / 2;
                        y: (parent.height - 2px) / 2;
                        width: 12px;
                        height: 2px;
                        border-radius: 1px;
                        background: ThemePalette.text;
                    }
                    Rectangle {
                        x: (parent.width - 2px) / 2;
                        y: (parent.height - 12px) / 2;
                        width: 2px;
                        height: 12px;
                        border-radius: 1px;
                        background: ThemePalette.text;
                    }
                    plus_touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.new_tab(); }
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                    height: 30px;
                    clip: true;
                    HorizontalLayout {
                        height: 30px;
                        spacing: 2px;
                        alignment: start;
                        for tab[index] in root.tabs: TabButton {
                            tab: tab;
                            index: index;
                            drag_target_path: root.drag_target_path;
                            tab_drag_from: root.tab_drag_from;
                            tab_drag_over: root.tab_drag_over;
                            activated(i) => { root.tab_activated(i); }
                            closed(i) => { root.tab_closed(i); }
                            context_menu(i) => { root.tab_context(i); }
                            tab_drag_start(i) => { root.tab_drag_from = i; }
                            tab_drag_hover(i) => { if (root.tab_drag_from >= 0) { root.tab_drag_over = i; } }
                            tab_drag_end(from, to) => {
                                root.tab_drag_from = -1;
                                root.tab_drag_over = -1;
                                if (from >= 0 && to >= 0 && from != to) { root.tab_reordered(from, to); }
                            }
                        }
                    }
                }

                // Empty strip to the right of tabs - window drag only here.
                Rectangle {
                    horizontal-stretch: 1;
                    height: parent.height;
                    drag_tail := TouchArea {
                        width: parent.width;
                        height: parent.height;
                        mouse-cursor: move;
                        property <length> px: 0;
                        property <length> py: 0;
                        property <bool> dragging: false;
                        pointer-event(event) => {
                            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                                self.px = self.mouse-x; self.py = self.mouse-y; self.dragging = false;
                            }
                            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                                if (root.tab_drag_from >= 0) {
                                    let from = root.tab_drag_from;
                                    let to = root.tab_drag_over >= 0 ? root.tab_drag_over : from;
                                    root.tab_drag_from = -1;
                                    root.tab_drag_over = -1;
                                    if (from >= 0 && to >= 0 && from != to) { root.tab_reordered(from, to); }
                                }
                                self.dragging = false;
                            }
                        }
                        moved => {
                            if (self.pressed && !self.dragging
                                && (abs(self.mouse-x - self.px) > 4px || abs(self.mouse-y - self.py) > 4px)) {
                                self.dragging = true;
                                root.drag_window();
                            }
                        }
                    }
                }
            }

            ToolButton {
                x: parent.width - 184px;
                y: 0;
                button_width: 46px;
                button_height: 36px;
                icon_data: "M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z";
                tooltip: "Settings";
                clicked => { root.settings_visible = true; }
            }

            ToolButton {
                x: parent.width - 138px;
                y: 0;
                button_width: 46px;
                button_height: 36px;
                icon_data: "M5 12h14";
                clicked => { root.minimize(); }
            }

            ToolButton {
                x: parent.width - 92px;
                y: 0;
                button_width: 46px;
                button_height: 36px;
                icon_data: "M7 7h10v10H7z";
                clicked => { root.maximize(); }
            }

            ToolButton {
                x: parent.width - 46px;
                y: 0;
                button_width: 46px;
                button_height: 36px;
                icon_data: "M18 6L6 18 M6 6l12 12";
                danger: true;
                clicked => { root.close(); }
            }

            Rectangle { y: parent.height - 1px; width: parent.width; height: 1px; background: ThemePalette.border; }
        }

        // Sidebar
        Rectangle {
            x: 0;
            y: root.title_h;
            width: root.sidebar_w;
            height: parent.height - root.title_h - root.status_h;
            background: ThemePalette.sidebar;
            border-width: 0px;

            if !root.is_simple: ListView {
                x: 10px;
                y: 14px;
                width: parent.width - 20px;
                height: parent.height - 28px;
                viewport-width: self.width;
                viewport-height: Math.max(self.height, root.side_items.length * 32px);
                for item[index] in root.side_items: SideRow {
                    item: item;
                    index: index;
                    drag_target_path: root.drag_target_path;
                    activated(i) => { root.side_activated(i); }
                    rename_activated(path) => { root.rename_tag_prompt(path); }
                    expand_toggled(path) => { root.side_expand_toggled(path); }
                }
            }
            if root.is_simple: ListView {
                x: 10px;
                y: 14px;
                width: parent.width - 20px;
                height: parent.height - 28px;
                viewport-width: self.width;
                viewport-height: Math.max(self.height, root.side_items_simple.length * 32px);
                for item[index] in root.side_items_simple: SideRow {
                    item: item;
                    index: index;
                    drag_target_path: root.drag_target_path;
                    activated(i) => { root.side_activated(i); }
                    rename_activated(path) => { root.rename_tag_prompt(path); }
                    expand_toggled(path) => { root.side_expand_toggled(path); }
                }
            }

            Rectangle { x: parent.width - 1px; width: 1px; height: parent.height; background: ThemePalette.border; }

            // Sidebar resize handle
            Rectangle {
                x: parent.width - 4px;
                y: 0;
                width: 8px;
                height: parent.height;
                z: 5;
                background: transparent;
                sidebar_drag := TouchArea {
                    mouse-cursor: ew-resize;
                    property <length> sw_at_press: 238px;
                    pointer-event(e) => {
                        if (e.kind == PointerEventKind.down) {
                            sw_at_press = root.sidebar_w;
                        }
                    }
                    moved => {
                        root.sidebar_w_target = (sw_at_press + self.mouse-x - self.pressed-x).clamp(160px, 380px);
                    }
                }
            }
        }

        // Selection action bar - replaces the toolbar contents whenever one
        // or more files are selected. Pinned at toolbar height/position so the
        // page layout below stays exactly the same and there is no jump.
        if root.selected_count > 0 && !root.is_storage_view: Rectangle {
            property <int> sel_shift: (root.selection_has_archive && !root.in_recycle_bin) ? 1 : 0;
            property <int> sel_btn_count: 10 + sel_shift;
            property <length> sel_gap: 4px;
            property <length> sel_clear_w: root.is_simple ? 54px : 44px;
            property <length> sel_norm_step: 34px;
            // The selection bar spans the full width from the sidebar to the
            // window edge, including across the top of the preview column. The
            // preview pane starts below the toolbar row, so this strip is empty
            // otherwise; filling it keeps the top of the app as one clean bar.
            // The action buttons are right-anchored to this wider width, so the
            // extra room only spaces them out - it never causes icon overlap.
            property <length> sel_bar_w: root.width - root.sidebar_w;
            property <length> sel_right: sel_bar_w - 10px;
            // Right edge for the numbered icon buttons. Sits one full step to the
            // left of the (wider) Clear button so the rightmost icon (Select all)
            // never lands on top of Clear.
            property <length> sel_r: sel_right - sel_clear_w - sel_norm_step;
            property <length> sel_btns_left: root.is_simple
                ? 0px
                : (sel_right - sel_clear_w - (8 + sel_shift) * sel_norm_step - sel_norm_step);
            // The label ("N items selected") shares the row with the action
            // buttons, which are anchored to the right. When the pane gets
            // narrow, collapse the label to zero so it never slides under the
            // leftmost button (previously the max(72px) floor forced an overlap
            // once an archive selection added the Extract button).
            property <length> sel_label_w: root.is_simple
                ? min(200px, max(96px, sel_bar_w * 0.20))
                : (sel_btns_left < 116px ? 0px : min(200px, sel_btns_left - 16px));
            // Drop lower-priority actions when the pane is narrow so icons
            // never stack on top of each other.
            property <bool> sel_show_select_all: !root.is_simple && sel_bar_w >= 500px;
            property <bool> sel_show_info: !root.is_simple && sel_bar_w >= 460px;
            property <bool> sel_show_open_with: !root.is_simple && root.selected_count == 1 && sel_bar_w >= 540px;
            property <bool> sel_show_cut: !root.is_simple && sel_bar_w >= 360px;
            property <bool> sel_show_paste: !root.is_simple && sel_bar_w >= 380px;
            property <bool> sel_show_rename: !root.is_simple && sel_bar_w >= 400px;
            property <int> sel_right_trim:
                (sel_show_select_all ? 0 : 1)
                + (sel_show_info ? 0 : 1)
                + ((root.selected_count == 1 && !sel_show_open_with) ? 1 : 0);
            property <int> sel_left_trim:
                (sel_show_cut ? 0 : 1)
                + (sel_show_paste ? 0 : 1)
                + (sel_show_rename ? 0 : 1);
            property <length> sel_btn_w: root.is_simple
                ? min(root.simple_btn_w, max(54px, (sel_bar_w - sel_label_w - sel_clear_w - 24px - (sel_btn_count - 1) * sel_gap) / sel_btn_count))
                : 31px;
            property <length> sel_step: root.is_simple ? (sel_btn_w + sel_gap) : sel_norm_step;
            property <length> sel_left: sel_label_w + 10px;
            property <bool> sel_tooltip_above: true;
            clip: true;

            x: root.sidebar_w;
            y: root.title_h;
            width: sel_bar_w;
            height: root.toolbar_h;
            z: 15;
            background: ThemePalette.panel_solid;
            Rectangle {
                x: 0; y: 0; width: parent.width; height: parent.height;
                background: ThemePalette.accent_soft;
            }
            TouchArea {
                width: parent.width; height: parent.height;
                clicked => {}
            }
            Rectangle { x: 0; y: 0; width: 3px; height: parent.height; background: ThemePalette.accent; }
            Text {
                x: 18px;
                visible: parent.sel_label_w > 8px;
                width: max(0px, parent.sel_label_w - 8px);
                height: parent.height;
                text: root.selected_count == 1 ? "1 item selected" : (root.selected_count + " items selected");
                color: ThemePalette.accent_strong;
                font-size: 13px;
                font-weight: 600;
                vertical-alignment: center;
                overflow: elide;
            }
            ToolButton { visible: parent.sel_show_cut; x: root.is_simple ? parent.sel_left : parent.sel_r - (8 + parent.sel_shift - parent.sel_left_trim) * parent.sel_norm_step; y: root.is_simple ? 16px : 6px; button_width: parent.sel_btn_w; tooltip_above: parent.sel_tooltip_above; icon_data: "M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2 M12 2v4 M9 2h6 M9 12l2 2 4-4"; text_label: "Copy"; show_caption: root.is_simple; button_height: root.is_simple ? 56px : 31px; tooltip: "Copy (Ctrl+C)"; clicked => { root.command("copy"); } }
            ToolButton { visible: parent.sel_show_cut; x: root.is_simple ? parent.sel_left + parent.sel_step : parent.sel_r - (7 + parent.sel_shift - parent.sel_left_trim) * parent.sel_norm_step; y: root.is_simple ? 16px : 6px; button_width: parent.sel_btn_w; tooltip_above: parent.sel_tooltip_above; icon_data: "M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z M17 21v-8H7v8 M7 3v5h8"; text_label: "Cut"; show_caption: root.is_simple; button_height: root.is_simple ? 56px : 31px; tooltip: "Cut (Ctrl+X)"; clicked => { root.command("cut"); } }
            ToolButton { visible: parent.sel_show_paste; x: root.is_simple ? parent.sel_left + 2 * parent.sel_step : parent.sel_r - (6 + parent.sel_shift - parent.sel_left_trim) * parent.sel_norm_step; y: root.is_simple ? 16px : 6px; button_width: parent.sel_btn_w; tooltip_above: parent.sel_tooltip_above; icon_data: "M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2 M12 2v4 M9 2h6"; text_label: "Paste"; show_caption: root.is_simple; button_height: root.is_simple ? 56px : 31px; tooltip: "Paste (Ctrl+V)"; clicked => { root.command("paste"); } }
            ToolButton { visible: parent.sel_show_rename; x: root.is_simple ? parent.sel_left + 3 * parent.sel_step : parent.sel_r - (5 + parent.sel_shift - parent.sel_left_trim) * parent.sel_norm_step; y: root.is_simple ? 16px : 6px; button_width: parent.sel_btn_w; tooltip_above: parent.sel_tooltip_above; icon_data: "M12 20h9 M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4 12.5-12.5z"; text_label: "Rename"; show_caption: root.is_simple; button_height: root.is_simple ? 56px : 31px; tooltip: "Rename (F2)"; clicked => { root.command("rename"); } }
            ToolButton { x: root.is_simple ? parent.sel_left + 4 * parent.sel_step : parent.sel_r - (4 + parent.sel_shift - parent.sel_left_trim) * parent.sel_norm_step; y: root.is_simple ? 16px : 6px; button_width: parent.sel_btn_w; tooltip_above: parent.sel_tooltip_above; icon_data: "M3 6h18 M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6 M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"; text_label: "Delete"; show_caption: root.is_simple; button_height: root.is_simple ? 56px : 31px; tooltip: root.in_recycle_bin ? "Delete permanently" : "Delete (Del)"; clicked => { root.command(root.in_recycle_bin ? "purge" : "delete"); } }
            if root.selection_has_archive && !root.in_recycle_bin: ToolButton {
                x: root.is_simple ? parent.sel_left + 5 * parent.sel_step : parent.sel_r - (4 - parent.sel_left_trim) * parent.sel_norm_step;
                y: root.is_simple ? 16px : 6px;
                button_width: parent.sel_btn_w; tooltip_above: parent.sel_tooltip_above;
                icon_data: "M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M7 10l5 5 5-5 M12 15V3";
                text_label: "Extract";
                show_caption: root.is_simple;
                button_height: root.is_simple ? 56px : 31px;
                tooltip: "Extract Here";
                clicked => { root.command("extract-here"); }
            }
            ToolButton { x: root.is_simple ? parent.sel_left + (5 + parent.sel_shift) * parent.sel_step : parent.sel_r - (3 - parent.sel_left_trim) * parent.sel_norm_step; y: root.is_simple ? 16px : 6px; button_width: parent.sel_btn_w; tooltip_above: parent.sel_tooltip_above; icon_data: "M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6 M15 3h6v6 M10 14L21 3"; text_label: "Open"; show_caption: root.is_simple; button_height: root.is_simple ? 56px : 31px; tooltip: "Open (Enter)"; clicked => { root.command("open"); } }
            ToolButton { visible: root.selected_count == 1 && parent.sel_show_open_with; x: root.is_simple ? parent.sel_left + (6 + parent.sel_shift) * parent.sel_step : parent.sel_r - (2 - parent.sel_right_trim) * parent.sel_norm_step; y: root.is_simple ? 16px : 6px; button_width: parent.sel_btn_w; tooltip_above: parent.sel_tooltip_above; icon_data: "M4 7h16 M9 20h6 M12 4v16"; text_label: "Open with"; show_caption: root.is_simple; button_height: root.is_simple ? 56px : 31px; tooltip: "Open With"; clicked => { root.command("open-with"); } }
            ToolButton { visible: parent.sel_show_info; x: root.is_simple ? parent.sel_left + (7 + parent.sel_shift) * parent.sel_step : parent.sel_r - (1 - parent.sel_right_trim) * parent.sel_norm_step; y: root.is_simple ? 16px : 6px; button_width: parent.sel_btn_w; tooltip_above: parent.sel_tooltip_above; icon_data: "M8 16h8 M16 12H8 M14 8H8 M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"; text_label: "Info"; show_caption: root.is_simple; button_height: root.is_simple ? 56px : 31px; tooltip: "Properties"; clicked => { root.command("properties"); } }
            ToolButton { visible: parent.sel_show_select_all; x: root.is_simple ? parent.sel_left + (8 + parent.sel_shift) * parent.sel_step : parent.sel_r - (0 - parent.sel_right_trim) * parent.sel_norm_step; y: root.is_simple ? 16px : 6px; button_width: parent.sel_btn_w; tooltip_above: parent.sel_tooltip_above; icon_data: "M9 11l3 3 8-8 M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"; text_label: "Select all"; show_caption: root.is_simple; button_height: root.is_simple ? 56px : 31px; tooltip: "Select All (Ctrl+A)"; clicked => { root.command("select-all"); } }
            ToolButton { x: parent.sel_right - parent.sel_clear_w; y: root.is_simple ? 16px : 6px; button_width: parent.sel_clear_w; tooltip_above: parent.sel_tooltip_above; icon_data: "M18 6L6 18 M6 6l12 12"; text_label: "Clear"; show_caption: root.is_simple; button_height: root.is_simple ? 56px : 31px; tooltip: "Clear selection (Esc)"; clicked => { root.clear_selection(); } }
        }

        // Toolbar - hidden while the selection bar is visible. Spans the full
        // width (sidebar edge to window edge) so the strip above the preview
        // column is filled instead of left as dead space. Its right-anchored
        // controls simply sit further right when the preview is open.
        toolbar := Rectangle {
            visible: root.selected_count == 0;
            x: root.sidebar_w;
            y: root.title_h;
            width: root.width - root.sidebar_w;
            height: root.toolbar_h;
            z: 10;
            background: ThemePalette.panel;
            // Normal-mode toolbar layout is computed right-to-left so address,
            // search, sort, and view controls never overlap at narrow widths.
            property <length> tb_gap: 8px;
            property <length> tb_search_w: 208px;
            property <length> tb_sort_w: 168px;
            property <length> tb_view_x: self.width - 306px;
            property <length> tb_min_w_search: 167px + 80px + tb_gap + tb_search_w + tb_gap + 306px;
            property <length> tb_min_w_sort: tb_min_w_search + tb_gap + tb_sort_w;
            property <bool> show_toolbar_search: !root.is_simple && self.width >= tb_min_w_search;
            property <bool> show_toolbar_sort: !root.is_simple && self.width >= tb_min_w_sort;
            property <length> tb_sort_x: tb_view_x - tb_gap - tb_sort_w;
            property <length> tb_search_x: (show_toolbar_sort ? tb_sort_x : tb_view_x) - tb_gap - tb_search_w;
            property <length> tb_addr_x: 167px;
            property <length> tb_addr_right: show_toolbar_search
                ? tb_search_x
                : (show_toolbar_sort ? tb_sort_x : tb_view_x);
            property <length> tb_addr_w: max(80px, tb_addr_right - tb_addr_x - tb_gap);
            property <bool> tb_clear_sort: show_toolbar_sort && (root.sort_by != "name" || root.sort_dir != "asc");
            // Simple-mode layout math. Row 2 packs six equal slots (five view
            // modes + Actions). Slot width shrinks on narrow toolbars so the
            // captioned buttons stop overlapping each other.
            property <length> simple_row_gap: 4px;
            property <int> simple_row2_slots: 6;
            property <length> simple_row2_slot_w: min(
                root.simple_btn_w,
                max(54px, (self.width - 20px - (self.simple_row2_slots - 1) * self.simple_row_gap) / self.simple_row2_slots));
            property <length> simple_row2_step: self.simple_row2_slot_w + self.simple_row_gap;
            property <int> simple_row1_slots: 4;
            property <length> simple_row1_budget: min(380px, max(240px, self.width * 0.42));
            property <length> simple_row1_slot_w: min(
                root.simple_btn_w,
                max(54px, (self.simple_row1_budget - 10px - (self.simple_row1_slots - 1) * self.simple_row_gap) / self.simple_row1_slots));
            property <length> simple_row1_step: self.simple_row1_slot_w + self.simple_row_gap;
            property <length> simple_addr_x: 10px + self.simple_row1_slots * self.simple_row1_step + 8px;
            property <bool> simple_show_search: root.is_simple && self.width >= 560px;
            property <length> simple_search_w: min(176px, max(120px, self.width - self.simple_addr_x - 20px - 80px));
            property <length> simple_addr_w: self.simple_show_search
                ? max(100px, self.width - self.simple_addr_x - self.simple_search_w - 12px)
                : max(120px, self.width - self.simple_addr_x - 10px);

            // Navigation cluster. Normal mode: compact 31x31 icons on a 44 px bar.
            // Simple mode: 88x38 buttons with an inline label, on row 1 of an 88 px bar.
            ToolButton {
                x: 10px;
                y: root.is_simple ? root.simple_row1_y : 6px;
                icon_data: "M15 18l-6-6 6-6";
                text_label: "Back";
                show_caption: root.is_simple;
                button_width: root.is_simple ? toolbar.simple_row1_slot_w : 31px;
                button_height: root.is_simple ? root.simple_btn_h : 31px;
                tooltip: "Back";
                clicked => { root.go_back(); }
            }
            ToolButton {
                x: root.is_simple ? 10px + toolbar.simple_row1_step : 45px;
                y: root.is_simple ? root.simple_row1_y : 6px;
                icon_data: "M9 18l6-6-6-6";
                text_label: "Forward";
                show_caption: root.is_simple;
                button_width: root.is_simple ? toolbar.simple_row1_slot_w : 31px;
                button_height: root.is_simple ? root.simple_btn_h : 31px;
                tooltip: "Forward";
                clicked => { root.go_forward(); }
            }
            ToolButton {
                x: root.is_simple ? 10px + 2 * toolbar.simple_row1_step : 80px;
                y: root.is_simple ? root.simple_row1_y : 6px;
                icon_data: "M12 19V5 M5 12l7-7 7 7";
                text_label: "Up";
                show_caption: root.is_simple;
                button_width: root.is_simple ? toolbar.simple_row1_slot_w : 31px;
                button_height: root.is_simple ? root.simple_btn_h : 31px;
                tooltip: "Up one level";
                clicked => { root.go_up(); }
            }
            ToolButton {
                x: root.is_simple ? 10px + 3 * toolbar.simple_row1_step : 115px;
                y: root.is_simple ? root.simple_row1_y : 6px;
                icon_data: "M3 12a9 9 0 0 1 15-6.7L21 8 M21 3v5h-5 M21 12a9 9 0 0 1-15 6.7L3 16 M3 21v-5h5";
                text_label: "Refresh";
                show_caption: root.is_simple;
                button_width: root.is_simple ? toolbar.simple_row1_slot_w : 31px;
                button_height: root.is_simple ? root.simple_btn_h : 31px;
                tooltip: "Refresh";
                clicked => { root.refresh(); }
            }

            // Subtle divider between the navigation cluster and the address bar.
            Rectangle {
                x: root.is_simple ? toolbar.simple_addr_x - 6px : 156px;
                y: root.is_simple ? 8px : 12px;
                width: 1px;
                height: root.is_simple ? 30px : 20px;
                background: ThemePalette.border;
            }

            Rectangle {
                x: root.is_simple ? toolbar.simple_addr_x : toolbar.tb_addr_x;
                y: root.is_simple ? 8px : 6px;
                width: root.is_simple
                    ? toolbar.simple_addr_w
                    : toolbar.tb_addr_w;
                height: root.is_simple ? 30px : 31px;
                border-width: 1px;
                border-color: ThemePalette.border;
                border-radius: AppMetrics.radius_small;
                background: AppMetrics.light_controls ? ThemePalette.panel_solid : rgba(0, 0, 0, 0.12);

                // Breadcrumb row (replaces plain path text)
                // Wrapped in a clipping Rectangle so long paths can't overflow into
                // the search box / sort buttons in narrow windows.
                Rectangle {
                    visible: !root.address_editing;
                    x: 6px;
                    y: 0;
                    width: parent.width - 12px;
                    height: parent.height;
                    clip: true;
                    HorizontalLayout {
                        x: 0;
                        y: 0;
                        width: parent.width;
                        height: parent.height;
                        spacing: 0px;
                        alignment: start;
                        for crumb[ci] in root.breadcrumbs: HorizontalLayout {
                            spacing: 0px;
                            alignment: start;
                            Text {
                                visible: ci > 0;
                                text: " > ";
                                color: ThemePalette.text_faint;
                                font-size: 12px;
                                font-family: AppMetrics.mono_font;
                                vertical-alignment: center;
                            }
                            crumb_touch := Rectangle {
                                // Highlight on hover OR when this chip's path is the
                                // current drag destination. The drag highlight uses a
                                // brighter fill plus a thin accent border so the user
                                // can spot it during a drag-and-drop.
                                property <bool> drop_target: root.drag_target_path != ""
                                    && root.drag_target_path == crumb.id;
                                height: parent.height;
                                width: Math.min(crumb_label.preferred-width + 10px, 160px);
                                border-radius: 4px;
                                border-width: drop_target ? 1px : 0px;
                                border-color: drop_target ? ThemePalette.accent_strong : rgba(0, 0, 0, 0);
                                background: drop_target
                                    ? ThemePalette.accent_soft
                                    : (ct.has-hover ? ThemePalette.accent_soft : rgba(0, 0, 0, 0));
                                crumb_label := Text {
                                    x: 5px;
                                    width: parent.width - 10px;
                                    height: parent.height;
                                    text: crumb.label;
                                    color: (parent.drop_target || ct.has-hover) ? ThemePalette.accent_strong : ThemePalette.text_muted;
                                    font-size: 12px;
                                    overflow: elide;
                                    vertical-alignment: center;
                                }
                                ct := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.crumb_navigate(ci); }
                                    pointer-event(event) => {
                                        if (event.button == PointerEventButton.right && event.kind == PointerEventKind.up) {
                                            root.crumb_siblings(ci);
                                        }
                                    }
                                }
                            }
                        }
                    }
                    if root.crumb_siblings_visible: Rectangle {
                        x: 0;
                        y: parent.height + 2px;
                        width: Math.min(280px, parent.width);
                        height: Math.min(280px, root.crumb_sibling_items.length * 28px + 8px);
                        z: 40;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel_solid;
                        drop-shadow-blur: 12px;
                        drop-shadow-color: rgba(0, 0, 0, 0.35);
                        VerticalLayout {
                            padding: 4px;
                            spacing: 1px;
                            for sib[si] in root.crumb_sibling_items: Rectangle {
                                height: 26px;
                                border-radius: 4px;
                                background: sib_touch.has-hover ? ThemePalette.accent_soft : rgba(0, 0, 0, 0);
                                Text {
                                    x: 8px; width: parent.width - 16px; height: parent.height;
                                    text: sib.label;
                                    color: ThemePalette.text;
                                    font-size: 12px;
                                    overflow: elide;
                                    vertical-alignment: center;
                                }
                                sib_touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.crumb_siblings_visible = false;
                                        root.navigate(sib.id);
                                    }
                                }
                            }
                        }
                    }
                }

                addr := LineEdit {
                    visible: root.address_editing;
                    x: 0;
                    y: 0;
                    width: parent.width;
                    height: parent.height;
                    text: root.address_text;
                    font-size: 12px;
                    font-family: AppMetrics.mono_font;
                    edited(value) => {
                        root.address_text = value;
                        root.address_changed(value);
                    }
                    accepted(path) => {
                        root.addr_suggestions = [];
                        root.address_editing = false;
                        root.navigate(path);
                    }
                    key-pressed(event) => {
                        if (event.text == Key.Escape) {
                            root.addr_suggestions = [];
                            root.address_editing = false;
                            accept
                        } else {
                            reject
                        }
                    }
                }

                // Autocomplete dropdown
                if root.address_editing && root.addr_suggestions.length > 0: Rectangle {
                    x: 0;
                    y: parent.height;
                    width: parent.width;
                    height: min(root.addr_suggestions.length * 28px + 4px, 168px);
                    background: ThemePalette.panel_solid;
                    border-width: 1px;
                    border-color: ThemePalette.border_strong;
                    border-radius: AppMetrics.radius;
                    drop-shadow-blur: 12px;
                    drop-shadow-color: rgba(0, 0, 0, 0.3);
                    clip: true;
                    VerticalLayout {
                        padding: 2px;
                        spacing: 0;
                        for sug[i] in root.addr_suggestions: Rectangle {
                            height: 28px;
                            width: parent.width - 4px;
                            x: 2px;
                            border-radius: AppMetrics.radius - 1px;
                            background: sug_ta.has-hover ? rgba(255, 255, 255, 0.07) : transparent;
                            Text {
                                x: 8px;
                                width: parent.width - 16px;
                                height: parent.height;
                                text: sug;
                                color: ThemePalette.text;
                                font-size: 12px;
                                font-family: AppMetrics.mono_font;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                            sug_ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.addr_suggestions = [];
                                    root.address_editing = false;
                                    root.navigate(sug);
                                }
                            }
                        }
                    }
                }

                TouchArea {
                    enabled: !root.address_editing;
                    mouse-cursor: text;
                    clicked => {
                        root.address_text = root.current_path;
                        root.address_editing = true;
                        addr.focus();
                        addr.select-all();
                    }
                }
            }

            if toolbar.simple_show_search: Rectangle {
                property <int> focus_nonce: root.toolbar_search_focus_nonce;
                changed focus_nonce => {
                    if (self.focus_nonce > 0) {
                        simple_search_input.focus();
                    }
                }
                x: toolbar.simple_addr_x + toolbar.simple_addr_w + 8px;
                y: 8px;
                width: toolbar.simple_search_w;
                height: 30px;
                border-width: 1px;
                border-color: simple_search_input.has-focus ? ThemePalette.accent : ThemePalette.border;
                border-radius: AppMetrics.radius_small;
                background: AppMetrics.light_controls ? ThemePalette.panel_solid : rgba(0, 0, 0, 0.12);
                SvgIcon { x: 8px; y: 7px; icon_size: 15px; data: "M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16z M21 21l-4.3-4.3"; tint: ThemePalette.text_faint; }
                simple_search_input := TextInput {
                    x: 30px;
                    y: 0;
                    width: parent.width - 58px;
                    height: parent.height;
                    text: root.search_text;
                    font-size: 12px;
                    color: ThemePalette.text;
                    vertical-alignment: center;
                    edited => {
                        root.search_text = self.text;
                        root.search_requested(self.text);
                    }
                    accepted => { root.search_immediate(self.text); }
                    key-pressed(event) => {
                        if (event.text == Key.Escape) {
                            self.text = "";
                            root.search_text = "";
                            root.search_requested("");
                            accept
                        } else { reject }
                    }
                }
                if root.search_text == "" && simple_search_input.text == "" && !simple_search_input.has-focus: Text {
                    x: 30px;
                    y: 0;
                    width: parent.width - 58px;
                    height: parent.height;
                    text: "Search folder";
                    color: ThemePalette.text_faint;
                    font-size: 12px;
                    vertical-alignment: center;
                }
                if root.search_text != "": ToolButton {
                    x: parent.width - 26px;
                    y: 4px;
                    button_width: 22px;
                    button_height: 22px;
                    icon_data: "M18 6L6 18 M6 6l12 12";
                    clicked => {
                        root.search_text = "";
                        root.search_requested("");
                    }
                }
            }

            search_box := Rectangle {
                // Hidden in simple mode - simple search lives on row 1 instead.
                visible: toolbar.show_toolbar_search;
                property <bool> semantic_available: root.semantic_search_available;
                property <int> focus_nonce: root.toolbar_search_focus_nonce;
                changed focus_nonce => {
                    if (self.focus_nonce > 0) {
                        search_input.focus();
                    }
                }
                x: toolbar.tb_search_x;
                y: 6px;
                width: 208px;
                height: 31px;
                border-width: 1px;
                border-color: search_input.has-focus ? ThemePalette.accent : ThemePalette.border;
                border-radius: AppMetrics.radius_small;
                background: AppMetrics.light_controls ? ThemePalette.panel_solid : rgba(0, 0, 0, 0.12);

                SvgIcon {
                    x: 8px; y: 8px; icon_size: 15px;
                    data: root.search_scope_all
                        ? "M22 12H2 M5.5 5.2 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.5-6.8A2 2 0 0 0 16.7 4H7.3a2 2 0 0 0-1.8 1.2z"
                        : "M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16z M21 21l-4.3-4.3";
                    tint: root.search_scope_all ? ThemePalette.accent : ThemePalette.text_faint;
                }
                scope_touch := TouchArea {
                    x: 2px; y: 2px; width: 26px; height: 26px;
                    mouse-cursor: pointer;
                    clicked => { root.toggle_search_scope(); }
                }
                if scope_touch.has-hover: HoverTip {
                    x: 0px;
                    y: parent.height + 6px;
                    tip_text: root.search_scope_all ? "Searching entire drive - click to search this folder only" : "Click to search the entire drive";
                }
                Text {
                    visible: search_box.semantic_available;
                    x: 30px;
                    y: 0;
                    width: 22px;
                    height: parent.height;
                    text: "S";
                    color: root.search_semantic_mode ? ThemePalette.accent_strong : ThemePalette.text_faint;
                    font-size: 14px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                sem_touch := TouchArea {
                    x: 28px; y: 2px; width: 26px; height: 26px;
                    enabled: search_box.semantic_available;
                    mouse-cursor: pointer;
                    clicked => { root.toggle_search_semantic_mode(); }
                }
                if search_box.semantic_available && sem_touch.has-hover: HoverTip {
                    x: 0px;
                    y: parent.height + 6px;
                    tip_text: root.search_semantic_mode ? "Semantic ranking on (filename embeddings, not OCR)" : "Semantic ranking off - click to rank by name embeddings";
                }
                search_input := TextInput {
                    x: search_box.semantic_available ? 56px : 30px;
                    y: 0;
                    width: parent.width - (search_box.semantic_available ? 84px : 58px);
                    height: parent.height;
                    text: root.search_text;
                    font-size: 12.5px;
                    color: ThemePalette.text;
                    vertical-alignment: center;
                    edited => {
                        root.search_text = self.text;
                        root.search_requested(self.text);
                    }
                    accepted => { root.search_immediate(self.text); }
                    key-pressed(event) => {
                        if (event.text == Key.Escape) {
                            self.text = "";
                            root.search_text = "";
                            root.search_requested("");
                            accept
                        } else { reject }
                    }
                }
                // Placeholder - only when BOTH the underlying TextInput and the
                // bound property are empty AND the field isn't focused. Checking
                // search_input.text explicitly prevents a flicker overlap when typing.
                if root.search_text == "" && search_input.text == "" && !search_input.has-focus: Text {
                    x: search_box.semantic_available ? 56px : 30px;
                    y: 0;
                    width: parent.width - (search_box.semantic_available ? 84px : 58px);
                    height: parent.height;
                    text: root.search_scope_all
                        ? "Path or name — e.g. %localappdata%\\App\\"
                        : "Path or name in this folder";
                    color: ThemePalette.text_faint;
                    font-size: 12.5px;
                    vertical-alignment: center;
                }

                if root.search_text != "": ToolButton {
                    x: parent.width - 28px;
                    y: 4px;
                    button_width: 22px;
                    button_height: 22px;
                    icon_data: "M18 6L6 18 M6 6l12 12";
                    clicked => {
                        root.search_text = "";
                        root.search_requested("");
                    }
                }
            }

            // Search help (?) + save bookmark + optional chip strip
            ToolButton {
                visible: toolbar.show_toolbar_search;
                x: toolbar.tb_search_x + toolbar.tb_search_w + 4px;
                y: 6px;
                button_width: 28px;
                button_height: 31px;
                active: root.search_help_visible;
                text_label: "?";
                tooltip: "Search operators";
                clicked => { root.search_help_toggle(); }
            }
            ToolButton {
                visible: toolbar.show_toolbar_search && root.search_text != "";
                x: toolbar.tb_search_x + toolbar.tb_search_w + 34px;
                y: 6px;
                button_width: 28px;
                button_height: 31px;
                icon_data: "M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z";
                tooltip: "Save search";
                clicked => { root.search_save_requested(); }
            }
            if toolbar.show_toolbar_search && root.search_help_visible: Rectangle {
                z: 40;
                x: toolbar.tb_search_x;
                y: 40px;
                width: min(460px, parent.width - toolbar.tb_search_x - 12px);
                height: root.search_chip_hint != "" ? 118px : 96px;
                border-radius: AppMetrics.radius_small;
                border-width: 1px;
                border-color: ThemePalette.border_strong;
                background: ThemePalette.panel_solid;
                drop-shadow-blur: 12px;
                drop-shadow-color: rgba(0, 0, 0, 0.3);
                HorizontalLayout {
                    x: 6px; y: 4px;
                    width: parent.width - 12px;
                    height: 26px;
                    spacing: 4px;
                    for chip_label[ci] in ["ext:", "kind:", "size:", "modified:", "tag:", "content:"]: Rectangle {
                        property <string> chip_op: chip_label;
                        preferred-width: chip_txt.preferred-width + 12px;
                        width: self.preferred-width;
                        height: 24px;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: chip_ta.has-hover ? ThemePalette.accent_soft : ThemePalette.panel_alt;
                        chip_txt := Text {
                            width: parent.width; height: parent.height;
                            text: chip_label;
                            color: ThemePalette.text_muted;
                            font-size: 10.5px;
                            font-family: AppMetrics.mono_font;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        chip_ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.search_chip(chip_op); }
                        }
                    }
                }
                HorizontalLayout {
                    x: 6px; y: 32px;
                    width: parent.width - 12px;
                    height: 24px;
                    spacing: 4px;
                    for src[si] in ["auto", "index", "live", "windows"]: Rectangle {
                        preferred-width: src_txt.preferred-width + 14px;
                        width: self.preferred-width;
                        height: 22px;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: root.search_source_pref == src ? ThemePalette.accent : ThemePalette.border;
                        background: root.search_source_pref == src ? ThemePalette.accent_soft : ThemePalette.panel_alt;
                        src_txt := Text {
                            width: parent.width; height: parent.height;
                            text: src;
                            color: ThemePalette.text_muted;
                            font-size: 10px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.search_source_picked(src); }
                        }
                    }
                }
                HorizontalLayout {
                    x: 6px; y: 58px;
                    width: parent.width - 12px;
                    height: 24px;
                    spacing: 4px;
                    for chip[ti] in root.tag_chips: Rectangle {
                        preferred-width: tag_chip_txt.preferred-width + 16px;
                        width: self.preferred-width;
                        height: 22px;
                        border-radius: 11px;
                        background: chip.color;
                        tag_chip_txt := Text {
                            width: parent.width; height: parent.height;
                            text: chip.label;
                            color: white;
                            font-size: 10px;
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.apply_tag_chip(chip.id); }
                        }
                    }
                }
                if root.search_chip_hint != "": Text {
                    x: 8px; y: 86px; width: parent.width - 16px; height: 18px;
                    text: root.search_chip_hint;
                    color: ThemePalette.text_faint;
                    font-size: 10.5px;
                    overflow: elide;
                }
            }

            Rectangle {
                visible: toolbar.show_toolbar_sort;
                x: toolbar.tb_sort_x;
                y: 6px;
                width: 168px;
                height: 31px;
                border-width: 1px;
                border-color: ThemePalette.border;
                border-radius: AppMetrics.radius_small;
                background: AppMetrics.light_controls ? ThemePalette.panel_solid : rgba(0, 0, 0, 0.12);

                Rectangle {
                    x: 4px; y: 4px; width: 42px; height: 23px;
                    border-radius: 4px;
                    border-width: root.sort_by == "name" ? 1px : 0px;
                    border-color: ThemePalette.accent;
                    background: sort_name_touch.has-hover || root.sort_by == "name" ? ThemePalette.accent_soft : rgba(0, 0, 0, 0);
                    Text { width: parent.width; height: parent.height; text: root.sort_by == "name" ? (root.sort_dir == "asc" ? "Name ^" : "Name v") : "Name"; color: root.sort_by == "name" ? ThemePalette.accent_strong : ThemePalette.text_muted; font-size: 10.5px; horizontal-alignment: center; vertical-alignment: center; overflow: elide; }
                    sort_name_touch := TouchArea { mouse-cursor: pointer; clicked => { root.sort_column("name"); } }
                }
                Rectangle {
                    x: 48px; y: 4px; width: 36px; height: 23px;
                    border-radius: 4px;
                    border-width: root.sort_by == "size" ? 1px : 0px;
                    border-color: ThemePalette.accent;
                    background: sort_size_touch.has-hover || root.sort_by == "size" ? ThemePalette.accent_soft : rgba(0, 0, 0, 0);
                    Text { width: parent.width; height: parent.height; text: root.sort_by == "size" ? (root.sort_dir == "asc" ? "Size ^" : "Size v") : "Size"; color: root.sort_by == "size" ? ThemePalette.accent_strong : ThemePalette.text_muted; font-size: 10.5px; horizontal-alignment: center; vertical-alignment: center; overflow: elide; }
                    sort_size_touch := TouchArea { mouse-cursor: pointer; clicked => { root.sort_column("size"); } }
                }
                Rectangle {
                    x: 86px; y: 4px; width: 38px; height: 23px;
                    border-radius: 4px;
                    border-width: root.sort_by == "modified" ? 1px : 0px;
                    border-color: ThemePalette.accent;
                    background: sort_date_touch.has-hover || root.sort_by == "modified" ? ThemePalette.accent_soft : rgba(0, 0, 0, 0);
                    Text { width: parent.width; height: parent.height; text: root.sort_by == "modified" ? (root.sort_dir == "asc" ? "Date ^" : "Date v") : "Date"; color: root.sort_by == "modified" ? ThemePalette.accent_strong : ThemePalette.text_muted; font-size: 10.5px; horizontal-alignment: center; vertical-alignment: center; overflow: elide; }
                    sort_date_touch := TouchArea { mouse-cursor: pointer; clicked => { root.sort_column("modified"); } }
                }
                Rectangle {
                    x: 126px; y: 4px; width: 38px; height: 23px;
                    border-radius: 4px;
                    border-width: root.sort_by == "type" ? 1px : 0px;
                    border-color: ThemePalette.accent;
                    background: sort_type_touch.has-hover || root.sort_by == "type" ? ThemePalette.accent_soft : rgba(0, 0, 0, 0);
                    Text { width: parent.width; height: parent.height; text: root.sort_by == "type" ? (root.sort_dir == "asc" ? "Type ^" : "Type v") : "Type"; color: root.sort_by == "type" ? ThemePalette.accent_strong : ThemePalette.text_muted; font-size: 10.5px; horizontal-alignment: center; vertical-alignment: center; overflow: elide; }
                    sort_type_touch := TouchArea { mouse-cursor: pointer; clicked => { root.sort_column("type"); } }
                }

                if sort_name_touch.has-hover || sort_size_touch.has-hover || sort_date_touch.has-hover || sort_type_touch.has-hover: HoverTip {
                    x: 2px;
                    y: parent.height + 6px;
                    tip_max_width: 280px;
                    tip_text: "Sort by name, size, date, or type. Click active column to toggle ^/v direction.";
                }
            }

            Rectangle { visible: !root.is_simple; x: toolbar.tb_view_x - 11px; y: 12px; width: 1px; height: 20px; background: ThemePalette.border; }
            // View-mode cluster. Normal mode: compact 31x31 icons right-aligned on
            // row 1. Simple mode: 88x38 captioned buttons left-aligned on row 2,
            // forming the second visual bar the user asked for.
            ToolButton {
                x: root.is_simple ? 10px : parent.width - 306px;
                y: root.is_simple ? root.simple_row2_y : 6px;
                tooltip_above: root.is_simple;
                icon_data: "M3 3h7v7H3z M14 3h7v7h-7z M3 14h7v7H3z M14 14h7v7h-7z";
                text_label: "Icons";
                show_caption: root.is_simple;
                button_width: root.is_simple ? toolbar.simple_row2_slot_w : 31px;
                button_height: root.is_simple ? root.simple_btn_h : 31px;
                tooltip: "Icon view";
                active: root.view_mode == "grid";
                clicked => { root.set_view("grid"); }
            }
            ToolButton {
                x: root.is_simple ? 10px + toolbar.simple_row2_step : parent.width - 272px;
                y: root.is_simple ? root.simple_row2_y : 6px;
                tooltip_above: root.is_simple;
                icon_data: "M3 5h4v4H3z M9 7h12 M3 13h4v4H3z M9 15h12";
                text_label: "Compact";
                show_caption: root.is_simple;
                button_width: root.is_simple ? toolbar.simple_row2_slot_w : 31px;
                button_height: root.is_simple ? root.simple_btn_h : 31px;
                tooltip: "Compact view";
                active: root.view_mode == "compact";
                clicked => { root.set_view("compact"); }
            }
            ToolButton {
                x: root.is_simple ? 10px + 2 * toolbar.simple_row2_step : parent.width - 238px;
                y: root.is_simple ? root.simple_row2_y : 6px;
                tooltip_above: root.is_simple;
                icon_data: "M8 6h13 M8 12h13 M8 18h13 M3 6h.01 M3 12h.01 M3 18h.01";
                text_label: "Details";
                show_caption: root.is_simple;
                button_width: root.is_simple ? toolbar.simple_row2_slot_w : 31px;
                button_height: root.is_simple ? root.simple_btn_h : 31px;
                tooltip: "Details view";
                active: root.view_mode == "list";
                clicked => { root.set_view("list"); }
            }
            if !root.is_simple && (root.view_mode == "gallery" || root.view_mode == "grid"): HorizontalLayout {
                x: parent.width - 168px;
                y: 8px;
                height: 26px;
                spacing: 4px;
                DialogButton {
                    label: "-";
                    clicked => { root.thumb_size_changed(root.thumb_size_scale - 0.15); }
                }
                DialogButton {
                    label: "+";
                    clicked => { root.thumb_size_changed(root.thumb_size_scale + 0.15); }
                }
            }
            ToolButton {
                x: root.is_simple ? 10px + 3 * toolbar.simple_row2_step : parent.width - 204px;
                y: root.is_simple ? root.simple_row2_y : 6px;
                tooltip_above: root.is_simple;
                icon_data: "M4 5h16v14H4z M4 15l4-4 4 4 3-3 5 5 M9 9h.01";
                text_label: "Gallery";
                show_caption: root.is_simple;
                button_width: root.is_simple ? toolbar.simple_row2_slot_w : 31px;
                button_height: root.is_simple ? root.simple_btn_h : 31px;
                tooltip: "Gallery view";
                active: root.view_mode == "gallery";
                clicked => { root.set_view("gallery"); }
            }
            ToolButton {
                x: root.is_simple ? 10px + 4 * toolbar.simple_row2_step : parent.width - 170px;
                y: root.is_simple ? root.simple_row2_y : 6px;
                tooltip_above: root.is_simple;
                icon_data: "M3 4h18v16H3z M14 4v16";
                text_label: "Preview";
                show_caption: root.is_simple;
                button_width: root.is_simple ? toolbar.simple_row2_slot_w : 31px;
                button_height: root.is_simple ? root.simple_btn_h : 31px;
                tooltip: "Preview pane";
                active: root.preview_visible;
                clicked => { root.toggle_preview(); }
            }
            ToolButton { visible: !root.is_simple; x: parent.width - 136px; y: 6px; icon_data: "M4 5h7v14H4z M13 5h7v14h-7z"; tooltip: "Dual pane"; active: root.dual_pane; clicked => { root.toggle_dual_pane(); } }
            // Clear-sort button - appears in the gap between Dual Pane and Command Palette
            // when any non-default sort is active. Resets to Name ^ (natural order).
            ToolButton {
                visible: toolbar.tb_clear_sort;
                x: parent.width - 101px;
                y: 6px;
                button_width: 26px;
                button_height: 31px;
                icon_data: "M18 6L6 18 M6 6l12 12";
                tooltip: "Clear sort (reset to Name ^)";
                clicked => { root.sort_column("reset"); }
            }
            ToolButton {
                x: root.is_simple ? 10px + 5 * toolbar.simple_row2_step : parent.width - 68px;
                y: root.is_simple ? root.simple_row2_y : 6px;
                tooltip_above: root.is_simple;
                icon_data: "M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z";
                text_label: "Actions";
                show_caption: root.is_simple;
                button_width: root.is_simple ? toolbar.simple_row2_slot_w : 31px;
                button_height: root.is_simple ? root.simple_btn_h : 31px;
                tooltip: "Command palette";
                clicked => { root.command_filter = ""; root.filter_commands(""); root.command_visible = true; }
            }

            Rectangle { y: parent.height - 1px; width: parent.width; height: 1px; background: ThemePalette.border; }
        }

        // Main area
        Rectangle {
            x: root.sidebar_w;
            y: root.title_h + root.toolbar_h;
            width: parent.width - root.sidebar_w;
            height: parent.height - root.title_h - root.toolbar_h - root.status_h;
            // Sunset uses a full-opacity sky gradient. Other themes use a flat bg.
            // Keeping this opaque (not a translucent overlay) stops icons and
            // text from looking washed out compared to Mica Dark.
            property <brush> pane_bg: root.active_theme == "sunset"
                ? @linear-gradient(180deg,
                    #5c2840  0%,
                    #3d1838 28%,
                    #22102a 58%,
                    #160a1a 100%)
                : ThemePalette.bg;
            background: pane_bg;

            if root.folder_changed_banner: Rectangle {
                x: 0;
                y: -2px;
                width: root.primary_pane_w;
                height: 28px;
                z: 8;
                background: ThemePalette.warning;
                Text {
                    x: 12px; width: parent.width - 100px; height: parent.height;
                    text: "Folder changed on disk — click to refresh";
                    color: white; font-size: 11.5px; font-weight: 600; vertical-alignment: center; overflow: elide;
                }
                TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.folder_changed_refresh(); }
                }
            }

            primary_pane_root := Rectangle {
                x: 0;
                y: root.folder_changed_banner ? 28px : 0;
                width: root.primary_pane_w;
                height: parent.height;
                background: parent.pane_bg;
                opacity: root.nav_opacity;

                // Marquee state for click-and-drag rectangle selection.
                // start_x/y are captured on left mouse-down; current_x/y track the
                // moved position. marquee_active toggles the overlay + selection.
                property <length> marquee_start_x: 0;
                property <length> marquee_start_y: 0;
                property <length> marquee_x: 0;
                property <length> marquee_y: 0;
                property <length> marquee_w: 0;
                property <length> marquee_h: 0;
                property <bool> marquee_active: false;

                empty_context := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    // Belt-and-suspenders click handler. The pointer-event up
                    // branch below clears selection when there was no drag,
                    // but Slint also fires `clicked` for plain non-drag
                    // taps. Wiring both means a click in empty space always
                    // clears, even when the pointer-event path is shadowed.
                    clicked => {
                        if (!primary_pane_root.marquee_active) {
                            root.clear_selection();
                        }
                    }
                    pointer-event(event) => {
                        if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                            root.context_on_file = false;
                            root.context_advanced = false;
                            root.context_tags_expanded = false;
                            root.context_x = (self.absolute-position.x + self.mouse-x).clamp(0px, root.width - 240px);
                            root.context_y = (self.absolute-position.y + self.mouse-y).clamp(0px, root.height - 226px);
                            root.context_visible = true;
                            root.file_context(-1);
                        }
                        if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                            primary_pane_root.marquee_start_x = self.mouse-x;
                            primary_pane_root.marquee_start_y = self.mouse-y;
                            primary_pane_root.marquee_x = self.mouse-x;
                            primary_pane_root.marquee_y = self.mouse-y;
                            primary_pane_root.marquee_w = 0;
                            primary_pane_root.marquee_h = 0;
                            primary_pane_root.marquee_active = false;
                        }
                        if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                            if (primary_pane_root.marquee_active) {
                                // Commit selection on release.
                                root.marquee_select(primary_pane_root.marquee_x, primary_pane_root.marquee_y,
                                                    primary_pane_root.marquee_w, primary_pane_root.marquee_h, true);
                            } else {
                                // No drag - treat as empty-space click.
                                root.clear_selection();
                            }
                            primary_pane_root.marquee_active = false;
                            primary_pane_root.marquee_w = 0;
                            primary_pane_root.marquee_h = 0;
                        }
                    }
                    moved => {
                        if (self.pressed) {
                            // 4px deadzone keeps a click from accidentally
                            // triggering a 1px marquee that latches onto the
                            // top row. Real drags pass this threshold instantly.
                            if (abs(self.mouse-x - primary_pane_root.marquee_start_x) > 4px ||
                                abs(self.mouse-y - primary_pane_root.marquee_start_y) > 4px) {
                                primary_pane_root.marquee_active = true;
                                primary_pane_root.marquee_x = min(primary_pane_root.marquee_start_x, self.mouse-x);
                                primary_pane_root.marquee_y = min(primary_pane_root.marquee_start_y, self.mouse-y);
                                primary_pane_root.marquee_w = abs(self.mouse-x - primary_pane_root.marquee_start_x);
                                primary_pane_root.marquee_h = abs(self.mouse-y - primary_pane_root.marquee_start_y);
                                // Live update - let Rust set the selection as the rect grows.
                                root.marquee_select(primary_pane_root.marquee_x, primary_pane_root.marquee_y,
                                                    primary_pane_root.marquee_w, primary_pane_root.marquee_h, false);
                            }
                        }
                    }
                }
                // Marquee overlay rectangle (only while dragging).
                if primary_pane_root.marquee_active: Rectangle {
                    x: primary_pane_root.marquee_x;
                    y: primary_pane_root.marquee_y;
                    width: primary_pane_root.marquee_w;
                    height: primary_pane_root.marquee_h;
                    background: rgba(79, 156, 255, 0.18);
                    border-width: 1px;
                    border-color: ThemePalette.accent;
                    z: 5;
                }

                if root.view_mode == "list": ListHeader {
                    x: AppMetrics.pad;
                    y: AppMetrics.pad;
                    // Match the ListView width below (which reserves 14px for
                    // its scroll bar) so the column headers line up with rows.
                    width: parent.width - AppMetrics.pad * 2 - 18px;
                    sort_by: root.sort_by;
                    sort_dir: root.sort_dir;
                    sort_col(col) => { root.sort_column(col); }
                }

                if root.view_mode == "list": ListView {
                    x: AppMetrics.pad;
                    y: AppMetrics.pad + 32px;
                    // Reserve 14px on the right for the scroll bar so column
                    // text and the tag dot never sit under it.
                    width: parent.width - AppMetrics.pad * 2 - 18px;
                    height: parent.height - AppMetrics.pad * 2 - 32px;
                    // Two-way binding so Rust can save/restore the scroll
                    // position per folder. Lets Back / Up land where the user
                    // was, not at the top of the new folder.
                    viewport-y <=> root.primary_list_scroll_y;
                    for file[index] in root.files: FileRow {
                        width: parent.width;
                        item: file;
                        index: index;
                        view_mode: root.view_mode;
                        rename_index: root.active_pane == "primary" ? root.rename_index : -1;
                        drag_target_path: root.drag_target_path;
                        selected(i, ctrl, shift) => { root.file_selected(i, ctrl, shift); }
                        opened(i) => { root.file_opened(i); }
                        context(i, cx, cy) => {
                            root.context_x = cx.clamp(0px, root.width - 240px);
                            root.context_y = cy.clamp(0px, root.height - 440px);
                            root.context_visible = true;
                            root.file_context(i);
                        }
                        rename_commit(i, val) => {
                            root.rename_index = -1;
                            if (val != "") { root.rename_file(i, val); }
                        }
                        file_drag_requested(i) => { root.start_file_drag(i, "primary"); }
                        marquee_started(ax, ay) => {
                            // Translate absolute window coords into pane-local
                            // space so the existing marquee logic (which uses
                            // pane-relative x/y) keeps working without changes.
                            primary_pane_root.marquee_start_x = ax - primary_pane_root.absolute-position.x;
                            primary_pane_root.marquee_start_y = ay - primary_pane_root.absolute-position.y;
                            primary_pane_root.marquee_x = primary_pane_root.marquee_start_x;
                            primary_pane_root.marquee_y = primary_pane_root.marquee_start_y;
                            primary_pane_root.marquee_w = 0;
                            primary_pane_root.marquee_h = 0;
                            primary_pane_root.marquee_active = true;
                        }
                        marquee_moved(ax, ay) => {
                            primary_pane_root.marquee_x = min(primary_pane_root.marquee_start_x, ax - primary_pane_root.absolute-position.x);
                            primary_pane_root.marquee_y = min(primary_pane_root.marquee_start_y, ay - primary_pane_root.absolute-position.y);
                            primary_pane_root.marquee_w = abs((ax - primary_pane_root.absolute-position.x) - primary_pane_root.marquee_start_x);
                            primary_pane_root.marquee_h = abs((ay - primary_pane_root.absolute-position.y) - primary_pane_root.marquee_start_y);
                            root.marquee_select(primary_pane_root.marquee_x, primary_pane_root.marquee_y,
                                                primary_pane_root.marquee_w, primary_pane_root.marquee_h, false);
                        }
                        marquee_finished => {
                            if (primary_pane_root.marquee_active) {
                                root.marquee_select(primary_pane_root.marquee_x, primary_pane_root.marquee_y,
                                                    primary_pane_root.marquee_w, primary_pane_root.marquee_h, true);
                            }
                            primary_pane_root.marquee_active = false;
                            primary_pane_root.marquee_w = 0;
                            primary_pane_root.marquee_h = 0;
                        }
                    }
                }

                // Empty list folders: ListView still captures hits when length is 0.
                // Also supports starting a marquee even though no rows exist, so a
                // future "deselect by drag" feels consistent with non-empty folders.
                if root.view_mode == "list" && root.files.length == 0: Rectangle {
                    z: 12;
                    x: AppMetrics.pad;
                    y: AppMetrics.pad + 32px;
                    width: parent.width - AppMetrics.pad * 2 - 18px;
                    height: parent.height - AppMetrics.pad * 2 - 32px;
                    TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => {
                            if (!primary_pane_root.marquee_active) {
                                root.clear_selection();
                            }
                        }
                        pointer-event(event) => {
                            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                                primary_pane_root.marquee_start_x = parent.x + self.mouse-x;
                                primary_pane_root.marquee_start_y = parent.y + self.mouse-y;
                                primary_pane_root.marquee_x = primary_pane_root.marquee_start_x;
                                primary_pane_root.marquee_y = primary_pane_root.marquee_start_y;
                                primary_pane_root.marquee_w = 0;
                                primary_pane_root.marquee_h = 0;
                                primary_pane_root.marquee_active = false;
                            }
                            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                                if (primary_pane_root.marquee_active) {
                                    root.marquee_select(primary_pane_root.marquee_x, primary_pane_root.marquee_y,
                                                        primary_pane_root.marquee_w, primary_pane_root.marquee_h, true);
                                }
                                primary_pane_root.marquee_active = false;
                                primary_pane_root.marquee_w = 0;
                                primary_pane_root.marquee_h = 0;
                            }
                            if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                                root.context_on_file = false;
                                root.context_advanced = false;
                                root.context_tags_expanded = false;
                                root.context_x = (self.absolute-position.x + self.mouse-x).clamp(0px, root.width - 240px);
                                root.context_y = (self.absolute-position.y + self.mouse-y).clamp(0px, root.height - 226px);
                                root.context_visible = true;
                                root.file_context(-1);
                            }
                        }
                        moved => {
                            if (self.pressed) {
                                // 4px deadzone matches empty_context behavior so a
                                // simple click stays a click instead of a 1px marquee.
                                if (abs((parent.x + self.mouse-x) - primary_pane_root.marquee_start_x) > 4px ||
                                    abs((parent.y + self.mouse-y) - primary_pane_root.marquee_start_y) > 4px) {
                                    primary_pane_root.marquee_active = true;
                                    primary_pane_root.marquee_x = min(primary_pane_root.marquee_start_x, parent.x + self.mouse-x);
                                    primary_pane_root.marquee_y = min(primary_pane_root.marquee_start_y, parent.y + self.mouse-y);
                                    primary_pane_root.marquee_w = abs((parent.x + self.mouse-x) - primary_pane_root.marquee_start_x);
                                    primary_pane_root.marquee_h = abs((parent.y + self.mouse-y) - primary_pane_root.marquee_start_y);
                                    root.marquee_select(primary_pane_root.marquee_x, primary_pane_root.marquee_y,
                                                        primary_pane_root.marquee_w, primary_pane_root.marquee_h, false);
                                }
                            }
                        }
                    }
                }

                // Marquee-and-deselect area covering all space below the last row.
                // Previously only handled click-to-deselect, which left users unable
                // to start a marquee from the bottom half of a sparsely populated
                // folder. Now mirrors empty_context so the rubber-band selection
                // works from any empty space in the file pane.
                // Use the worst-case per-row height (row_h + 26px date-group
                // header) so this overlay never shadows actual rows when sorted
                // by Date modified. The previous formula (row_h only) caused the
                // overlay to start a few rows above the real content end whenever
                // group headers were present, which ate hover and right-clicks
                // on the bottom rows. Slight gap of unclickable empty area below
                // the last row is acceptable; rows always win for hits now.
                if root.view_mode == "list": Rectangle {
                    property <length> est-content-end: AppMetrics.pad + 32px + root.files.length * (AppMetrics.row_h + 26px);
                    x: AppMetrics.pad;
                    y: min(parent.height - AppMetrics.pad, est-content-end);
                    width: parent.width - AppMetrics.pad * 2;
                    height: max(0px, parent.height - AppMetrics.pad - self.y);
                    TouchArea {
                        clicked => {
                            if (!primary_pane_root.marquee_active) {
                                root.clear_selection();
                            }
                        }
                        pointer-event(event) => {
                            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                                primary_pane_root.marquee_start_x = parent.x + self.mouse-x;
                                primary_pane_root.marquee_start_y = parent.y + self.mouse-y;
                                primary_pane_root.marquee_x = primary_pane_root.marquee_start_x;
                                primary_pane_root.marquee_y = primary_pane_root.marquee_start_y;
                                primary_pane_root.marquee_w = 0;
                                primary_pane_root.marquee_h = 0;
                                primary_pane_root.marquee_active = false;
                            }
                            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                                if (primary_pane_root.marquee_active) {
                                    root.marquee_select(primary_pane_root.marquee_x, primary_pane_root.marquee_y,
                                                        primary_pane_root.marquee_w, primary_pane_root.marquee_h, true);
                                }
                                primary_pane_root.marquee_active = false;
                                primary_pane_root.marquee_w = 0;
                                primary_pane_root.marquee_h = 0;
                            }
                            if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                                root.context_on_file = false;
                                root.context_advanced = false;
                                root.context_tags_expanded = false;
                                root.context_x = (self.absolute-position.x + self.mouse-x).clamp(0px, root.width - 240px);
                                root.context_y = (self.absolute-position.y + self.mouse-y).clamp(0px, root.height - 278px);
                                root.context_visible = true;
                                root.file_context(-1);
                            }
                        }
                        moved => {
                            if (self.pressed) {
                                if (abs((parent.x + self.mouse-x) - primary_pane_root.marquee_start_x) > 4px ||
                                    abs((parent.y + self.mouse-y) - primary_pane_root.marquee_start_y) > 4px) {
                                    primary_pane_root.marquee_active = true;
                                    primary_pane_root.marquee_x = min(primary_pane_root.marquee_start_x, parent.x + self.mouse-x);
                                    primary_pane_root.marquee_y = min(primary_pane_root.marquee_start_y, parent.y + self.mouse-y);
                                    primary_pane_root.marquee_w = abs((parent.x + self.mouse-x) - primary_pane_root.marquee_start_x);
                                    primary_pane_root.marquee_h = abs((parent.y + self.mouse-y) - primary_pane_root.marquee_start_y);
                                    root.marquee_select(primary_pane_root.marquee_x, primary_pane_root.marquee_y,
                                                        primary_pane_root.marquee_w, primary_pane_root.marquee_h, false);
                                }
                            }
                        }
                    }
                }

                if root.view_mode != "list": ScrollView {
                    x: AppMetrics.pad;
                    y: AppMetrics.pad;
                    width: parent.width - AppMetrics.pad * 2;
                    height: parent.height - AppMetrics.pad * 2;
                    viewport-y <=> root.primary_grid_scroll_y;
                    viewport-width: parent.width - AppMetrics.pad * 2;
                    viewport-height: Math.max(parent.height - AppMetrics.pad * 2, root.grid_rows * (root.grid_item_h + root.grid_gap));

                    // Background marquee + click-to-deselect underneath grid/gallery
                    // rows. Same drag-rectangle behavior as the list view; marquee
                    // coordinates are stored in pane-local space using each TouchArea's
                    // absolute position so scroll offset is implicit.
                    if root.files.length > 0: Rectangle {
                        x: 0; y: 0;
                        width: root.file_area_w;
                        height: Math.max(parent.height - AppMetrics.pad * 2, root.grid_rows * (root.grid_item_h + root.grid_gap));
                        TouchArea {
                            clicked => {
                                if (!primary_pane_root.marquee_active) {
                                    root.clear_selection();
                                }
                            }
                            pointer-event(event) => {
                                if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                                    primary_pane_root.marquee_start_x = self.absolute-position.x - primary_pane_root.absolute-position.x + self.mouse-x;
                                    primary_pane_root.marquee_start_y = self.absolute-position.y - primary_pane_root.absolute-position.y + self.mouse-y;
                                    primary_pane_root.marquee_x = primary_pane_root.marquee_start_x;
                                    primary_pane_root.marquee_y = primary_pane_root.marquee_start_y;
                                    primary_pane_root.marquee_w = 0;
                                    primary_pane_root.marquee_h = 0;
                                    primary_pane_root.marquee_active = false;
                                }
                                if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                                    if (primary_pane_root.marquee_active) {
                                        root.marquee_select(primary_pane_root.marquee_x, primary_pane_root.marquee_y,
                                                            primary_pane_root.marquee_w, primary_pane_root.marquee_h, true);
                                    }
                                    primary_pane_root.marquee_active = false;
                                    primary_pane_root.marquee_w = 0;
                                    primary_pane_root.marquee_h = 0;
                                }
                                if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                                    root.context_on_file = false;
                                    root.context_advanced = false;
                                    root.context_tags_expanded = false;
                                    root.context_x = (self.absolute-position.x + self.mouse-x).clamp(0px, root.width - 240px);
                                    root.context_y = (self.absolute-position.y + self.mouse-y).clamp(0px, root.height - 278px);
                                    root.context_visible = true;
                                    root.file_context(-1);
                                }
                            }
                            moved => {
                                if (self.pressed) {
                                    if (abs((self.absolute-position.x - primary_pane_root.absolute-position.x + self.mouse-x) - primary_pane_root.marquee_start_x) > 4px ||
                                        abs((self.absolute-position.y - primary_pane_root.absolute-position.y + self.mouse-y) - primary_pane_root.marquee_start_y) > 4px) {
                                        primary_pane_root.marquee_active = true;
                                        primary_pane_root.marquee_x = min(primary_pane_root.marquee_start_x, self.absolute-position.x - primary_pane_root.absolute-position.x + self.mouse-x);
                                        primary_pane_root.marquee_y = min(primary_pane_root.marquee_start_y, self.absolute-position.y - primary_pane_root.absolute-position.y + self.mouse-y);
                                        primary_pane_root.marquee_w = abs((self.absolute-position.x - primary_pane_root.absolute-position.x + self.mouse-x) - primary_pane_root.marquee_start_x);
                                        primary_pane_root.marquee_h = abs((self.absolute-position.y - primary_pane_root.absolute-position.y + self.mouse-y) - primary_pane_root.marquee_start_y);
                                        root.marquee_select(primary_pane_root.marquee_x, primary_pane_root.marquee_y,
                                                            primary_pane_root.marquee_w, primary_pane_root.marquee_h, false);
                                    }
                                }
                            }
                        }
                    }
                    if root.files.length == 0: Rectangle {
                        z: 12;
                        x: 0; y: 0;
                        width: root.file_area_w;
                        height: Math.max(parent.height - AppMetrics.pad * 2, root.grid_rows * (root.grid_item_h + root.grid_gap));
                        TouchArea {
                            clicked => { root.clear_selection(); }
                            pointer-event(event) => {
                                if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                                    root.context_on_file = false;
                                    root.context_advanced = false;
                                    root.context_tags_expanded = false;
                                    root.context_x = (self.absolute-position.x + self.mouse-x).clamp(0px, root.width - 240px);
                                    root.context_y = (self.absolute-position.y + self.mouse-y).clamp(0px, root.height - 278px);
                                    root.context_visible = true;
                                    root.file_context(-1);
                                }
                            }
                        }
                    }

                    for file[index] in root.files: FileRow {
                        x: Math.mod(index, root.grid_columns) * root.grid_cell_w + root.grid_gap / 2;
                        y: Math.floor(index / root.grid_columns) * (root.grid_item_h + root.grid_gap);
                        width: root.grid_cell_w - root.grid_gap;
                        item: file;
                        index: index;
                        view_mode: root.view_mode;
                        rename_index: root.active_pane == "primary" ? root.rename_index : -1;
                        drag_target_path: root.drag_target_path;
                        selected(i, ctrl, shift) => { root.file_selected(i, ctrl, shift); }
                        opened(i) => { root.file_opened(i); }
                        context(i, cx, cy) => {
                            root.context_x = cx.clamp(0px, root.width - 240px);
                            root.context_y = cy.clamp(0px, root.height - 440px);
                            root.context_visible = true;
                            root.file_context(i);
                        }
                        rename_commit(i, val) => {
                            root.rename_index = -1;
                            if (val != "") { root.rename_file(i, val); }
                        }
                        file_drag_requested(i) => { root.start_file_drag(i, "primary"); }
                        marquee_started(ax, ay) => {
                            // Translate absolute window coords into pane-local
                            // space so the existing marquee logic (which uses
                            // pane-relative x/y) keeps working without changes.
                            primary_pane_root.marquee_start_x = ax - primary_pane_root.absolute-position.x;
                            primary_pane_root.marquee_start_y = ay - primary_pane_root.absolute-position.y;
                            primary_pane_root.marquee_x = primary_pane_root.marquee_start_x;
                            primary_pane_root.marquee_y = primary_pane_root.marquee_start_y;
                            primary_pane_root.marquee_w = 0;
                            primary_pane_root.marquee_h = 0;
                            primary_pane_root.marquee_active = true;
                        }
                        marquee_moved(ax, ay) => {
                            primary_pane_root.marquee_x = min(primary_pane_root.marquee_start_x, ax - primary_pane_root.absolute-position.x);
                            primary_pane_root.marquee_y = min(primary_pane_root.marquee_start_y, ay - primary_pane_root.absolute-position.y);
                            primary_pane_root.marquee_w = abs((ax - primary_pane_root.absolute-position.x) - primary_pane_root.marquee_start_x);
                            primary_pane_root.marquee_h = abs((ay - primary_pane_root.absolute-position.y) - primary_pane_root.marquee_start_y);
                            root.marquee_select(primary_pane_root.marquee_x, primary_pane_root.marquee_y,
                                                primary_pane_root.marquee_w, primary_pane_root.marquee_h, false);
                        }
                        marquee_finished => {
                            if (primary_pane_root.marquee_active) {
                                root.marquee_select(primary_pane_root.marquee_x, primary_pane_root.marquee_y,
                                                    primary_pane_root.marquee_w, primary_pane_root.marquee_h, true);
                            }
                            primary_pane_root.marquee_active = false;
                            primary_pane_root.marquee_w = 0;
                            primary_pane_root.marquee_h = 0;
                        }
                    }
                }

                empty_pane := Rectangle {
                    visible: root.files.length == 0;
                    width: parent.width;
                    height: parent.height;
                    property <bool> fantasy_on: ThemePalette.active_theme == "fantasy";
                    // Contextual glyph for empty panes (one icon — never per-row).
                    property <string> fantasy_kind: root.search_text != "" ? "gem"
                        : (root.fantasy_empty_kind != "" ? root.fantasy_empty_kind : "chest");
                    // Soft fantasy glow behind empty-state copy (theme-gated).
                    if empty_pane.fantasy_on: Rectangle {
                        x: (parent.width - 120px) / 2;
                        y: (parent.height - 120px) / 2 - 40px;
                        width: 120px;
                        height: 120px;
                        border-radius: 60px;
                        background: ThemePalette.accent_soft;
                        opacity: 0.55;
                    }
                    VerticalLayout {
                        alignment: center;
                        spacing: 10px;
                        // High Fantasy: animated pixel ornament (single instance).
                        if empty_pane.fantasy_on: FantasyEmptyOrnament {
                            x: (parent.width - self.width) / 2;
                            cell: 6px;
                            kind: empty_pane.fantasy_kind;
                            running: empty_pane.fantasy_on;
                            hovered: empty_ta.has-hover;
                            chest: FantasyIconBank.chest;
                            scroll: FantasyIconBank.scroll;
                            gem_a: FantasyIconBank.gem_a;
                            gem_b: FantasyIconBank.gem_b;
                            potion: FantasyIconBank.potion;
                            tower_a: FantasyIconBank.tower_a;
                            tower_b: FantasyIconBank.tower_b;
                            cauldron: FantasyIconBank.cauldron;
                        }
                        // Non-fantasy: keep the compact SVG badge.
                        if !empty_pane.fantasy_on: Rectangle {
                            width: 56px;
                            height: 56px;
                            x: (parent.width - 56px) / 2;
                            border-radius: 14px;
                            background: ThemePalette.accent_soft;
                            SvgIcon {
                                x: (parent.width - 28px) / 2;
                                y: (parent.height - 28px) / 2;
                                icon_size: 28px;
                                data: root.in_recycle_bin ?
                                    "M3 6h18 M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6 M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" :
                                    root.is_home_view ?
                                    "M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z M9 22V12h6v10" :
                                    root.search_text != "" ?
                                    "M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16z M21 21l-4.3-4.3" :
                                    "M3 7.5A2.5 2.5 0 0 1 5.5 5H10l2 2h6.5A2.5 2.5 0 0 1 21 9.5v7A2.5 2.5 0 0 1 18.5 19h-13A2.5 2.5 0 0 1 3 16.5z";
                                tint: ThemePalette.accent_strong;
                            }
                        }
                        Text {
                            width: parent.width;
                            text: root.empty_state != "" ? root.empty_state :
                                  root.search_text != "" ? "No results for \"" + root.search_text + "\"" :
                                  root.filter_text != "" ? "No files match \"" + root.filter_text + "\"" :
                                  root.is_home_view ? "Your Home is quiet" :
                                  root.in_recycle_bin ? "Recycle Bin is empty" :
                                  "This folder is empty";
                            color: ThemePalette.text;
                            font-size: 15px;
                            font-weight: 600;
                            horizontal-alignment: center;
                        }
                        Text {
                            visible: root.search_text != "" || root.is_home_view || root.in_recycle_bin || root.empty_state == "Loading folder..." || root.empty_state == "Loading Recycle Bin..." || root.empty_state == "Searching..." || root.empty_state == "Searching drive...";
                            width: min(360px, parent.width - 48px);
                            x: (parent.width - self.width) / 2;
                            text: root.search_text != "" ? (root.search_scope_all ? "Try a different query or switch back to this folder" : "Try a different query or search the whole drive") :
                                  root.is_home_view ? "Pin folders from the sidebar or open a drive — shortcuts collect here." :
                                  root.in_recycle_bin ? "Deleted files appear here until you empty the bin." :
                                  root.empty_state == "Loading Recycle Bin..." ? "Reading the OS Recycle Bin…" :
                                  root.empty_state == "Loading folder..." ? "Reading folder contents…" :
                                  "Hang tight…";
                            color: ThemePalette.text_faint;
                            font-size: 12px;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                            height: self.preferred-height;
                        }
                        if root.in_recycle_bin && root.empty_state == "Recycle Bin is empty.": DialogButton {
                            x: (parent.width - self.preferred-width) / 2;
                            label: "Refresh";
                            clicked => { root.command("refresh"); }
                        }
                    }
                    // Covers the whole pane so clicks reach clear_selection even over the message.
                    // Also feeds hover into fantasy ornaments (no per-icon TouchArea).
                    empty_ta := TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => { root.clear_selection(); }
                    }
                }

                // Storage drill-in uses the full main pane (not the narrow preview strip).
                if root.is_storage_view && (root.storage_selected_bucket != "" || root.storage_show_all): StorageDrillIn {
                    z: 200;
                    x: 0; y: 0;
                    width: parent.width;
                    height: parent.height;
                    scanning: root.storage_scanning;
                    top_items: root.storage_top_items;
                    show_all: root.storage_show_all;
                    selected_bucket: root.storage_selected_bucket;
                    selected_bucket_name: root.storage_selected_bucket_name;
                    list_total: root.storage_list_total;
                    list_shown: root.storage_list_shown;
                    search_text <=> root.storage_drill_search;
                    sort_mode: root.storage_sort_mode;
                    open_path(p) => { root.storage_open_path(p); }
                    close => { root.storage_clear_bucket(); }
                    search_changed(q) => { root.storage_drill_search_changed(q); }
                    set_sort_mode(m) => { root.storage_set_sort_mode(m); }
                    open_more(p) => { root.storage_entry_more(p); }
                    open_with(p) => { root.storage_entry_open_with(p); }
                }

                // Storage overview (bucket grid) when no drill-in is active.
                if root.is_storage_view && root.storage_selected_bucket == "" && !root.storage_show_all: StorageOverview {
                    z: 200;
                    x: 0; y: 0;
                    width: parent.width;
                    height: parent.height;
                    scanning: root.storage_scanning;
                    root_label: root.storage_root;
                    total_text: root.storage_total_text;
                    subtitle: root.storage_subtitle;
                    buckets: root.storage_buckets;
                    drives: root.storage_drives;
                    selected_bucket: root.storage_selected_bucket;
                    progress_files: root.storage_progress_files;
                    progress_bytes_text: root.storage_progress_bytes_text;
                    progress_percent: root.storage_progress_percent;
                    disk_summary: root.storage_disk_summary;
                    disk_used_pct: root.storage_disk_used_pct;
                    breakdown_text: root.storage_breakdown_text;
                    scan_coverage_pct: root.storage_scan_coverage_pct;
                    list_total: root.storage_list_total;
                    list_shown: root.storage_list_shown;
                    tips: root.storage_tips;
                    top_items: root.storage_top_items;
                    rescan => { root.storage_rescan(); }
                    select_bucket(b) => { root.storage_select_bucket(b); }
                    switch_root(r) => { root.storage_switch_root(r); }
                    show_full_list => { root.storage_toggle_show_all(); }
                    open_path(p) => { root.storage_open_path(p); }
                    tip_action(action, path) => { root.storage_tip_action(action, path); }
                    open_more(p) => { root.storage_entry_more(p); }
                    open_with(p) => { root.storage_entry_open_with(p); }
                }
            }

            if root.dual_pane: Rectangle {
                x: root.primary_pane_w;
                y: 0;
                width: root.pane_splitter_w;
                height: parent.height;
                background: split_touch.has-hover || split_touch.pressed ? ThemePalette.accent : ThemePalette.panel;

                // Center divider line
                Rectangle {
                    x: (parent.width - 1px) / 2;
                    y: 0;
                    width: 1px;
                    height: parent.height;
                    background: split_touch.has-hover || split_touch.pressed ? ThemePalette.accent_strong : ThemePalette.border;
                }

                // Grip dots - three small dots at vertical center, more visible on hover
                Rectangle {
                    x: (parent.width - 2px) / 2;
                    y: parent.height / 2 - 12px;
                    width: 2px; height: 2px; border-radius: 1px;
                    background: split_touch.has-hover || split_touch.pressed ? white : ThemePalette.text_faint;
                }
                Rectangle {
                    x: (parent.width - 2px) / 2;
                    y: parent.height / 2 - 1px;
                    width: 2px; height: 2px; border-radius: 1px;
                    background: split_touch.has-hover || split_touch.pressed ? white : ThemePalette.text_faint;
                }
                Rectangle {
                    x: (parent.width - 2px) / 2;
                    y: parent.height / 2 + 10px;
                    width: 2px; height: 2px; border-radius: 1px;
                    background: split_touch.has-hover || split_touch.pressed ? white : ThemePalette.text_faint;
                }

                // Larger invisible touch area extending past the visible splitter
                // makes it easier to grab without pixel-perfect aim.
                split_touch := TouchArea {
                    x: -3px;
                    y: 0;
                    width: parent.width + 6px;
                    height: parent.height;
                    mouse-cursor: ew-resize;
                    property <float> ratio_at_press: 0.5;
                    pointer-event(e) => {
                        if (e.kind == PointerEventKind.down) {
                            ratio_at_press = root.split_ratio;
                        }
                    }
                    moved => {
                        root.split_ratio_target = (ratio_at_press + (self.mouse-x - self.pressed-x) / root.main_content_w).clamp(0.15, 0.85);
                    }
                    double-clicked => {
                        root.split_ratio_target = 0.5;
                    }
                }
            }

            // Active-pane indicator: subtle accent border around the focused pane
            // when dual-pane mode is active. Non-interactive overlay (no TouchArea).
            if root.dual_pane && root.active_pane == "primary": Rectangle {
                x: 1px; y: 1px;
                width: root.primary_pane_w - 2px;
                height: parent.height - 2px;
                background: transparent;
                border-width: 1px;
                border-color: ThemePalette.accent;
                border-radius: AppMetrics.radius;
            }
            if root.dual_pane && root.active_pane == "secondary": Rectangle {
                x: root.primary_pane_w + root.pane_splitter_w + 1px;
                y: 1px;
                width: root.secondary_pane_w - 2px;
                height: parent.height - 2px;
                background: transparent;
                border-width: 1px;
                border-color: ThemePalette.accent;
                border-radius: AppMetrics.radius;
            }

            // Drag-over indicator during OLE drag-drop (Explorer -> Pathfinder).
            if root.drag_over_pane == "primary": Rectangle {
                x: 0; y: 0;
                width: root.primary_pane_w;
                height: parent.height;
                background: transparent;
                border-width: 3px;
                border-color: ThemePalette.accent_strong;
                border-radius: AppMetrics.radius;
                drop-shadow-blur: 16px;
                drop-shadow-color: ThemePalette.accent;
            }
            if root.dual_pane && root.drag_over_pane == "secondary": Rectangle {
                x: root.primary_pane_w + root.pane_splitter_w;
                y: 0;
                width: root.secondary_pane_w;
                height: parent.height;
                background: transparent;
                border-width: 3px;
                border-color: ThemePalette.accent_strong;
                border-radius: AppMetrics.radius;
                drop-shadow-blur: 16px;
                drop-shadow-color: ThemePalette.accent;
            }

            if root.dual_pane && !root.is_simple: Rectangle {
                x: root.primary_pane_w + root.pane_splitter_w;
                y: 0;
                width: root.secondary_pane_w;
                height: parent.height;
                background: ThemePalette.bg_soft;
                border-width: 0px;

                // Header bar
                Rectangle {
                    x: 0; y: 0;
                    width: parent.width;
                    height: 38px;
                    background: ThemePalette.panel;

                    ToolButton {
                        x: 4px; y: 4px;
                        button_width: 28px; button_height: 28px;
                        icon_data: "M15 18l-6-6 6-6";
                        tooltip: "Back";
                        clicked => { root.secondary_go_back(); }
                    }
                    ToolButton {
                        x: 34px; y: 4px;
                        button_width: 28px; button_height: 28px;
                        icon_data: "M12 19V5 M5 12l7-7 7 7";
                        tooltip: "Up";
                        clicked => { root.secondary_go_up(); }
                    }
                    ToolButton {
                        x: 64px; y: 4px;
                        button_width: 28px; button_height: 28px;
                        icon_data: "M3 12h14 M10 5l7 7-7 7";
                        tooltip: "Open left folder here";
                        clicked => { root.secondary_navigate(root.current_path); }
                    }

                    // Secondary address bar - text when idle, LineEdit when editing
                    if !root.secondary_addr_editing: Rectangle {
                        x: 96px;
                        width: parent.width - 104px;
                        height: parent.height;
                        background: transparent;
                        sec_addr_touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.secondary_addr_editing = true; }
                        }
                        Text {
                            width: parent.width - 4px;
                            height: parent.height;
                            text: root.secondary_path == "" ? "-" : root.secondary_path;
                            color: sec_addr_touch.has-hover ? ThemePalette.text : ThemePalette.text_muted;
                            font-size: 11.5px;
                            overflow: elide;
                            vertical-alignment: center;
                        }
                    }
                    if root.secondary_addr_editing: Rectangle {
                        x: 94px;
                        width: parent.width - 100px;
                        height: 26px;
                        y: (38px - 26px) / 2;
                        background: ThemePalette.bg;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.accent;
                        sec_addr_input := LineEdit {
                            x: 4px; y: 0;
                            width: parent.width - 8px;
                            height: parent.height;
                            text: root.secondary_path;
                            font-size: 11.5px;
                            accepted(path) => {
                                root.secondary_addr_editing = false;
                                root.secondary_navigate_path(path);
                            }
                            key-pressed(e) => {
                                if (e.text == Key.Escape) {
                                    root.secondary_addr_editing = false;
                                    return accept;
                                }
                                return reject;
                            }
                        }
                    }
                    Rectangle { y: parent.height - 1px; width: parent.width; height: 1px; background: ThemePalette.border; }
                }

                // Sort header (list mode only)
                if root.view_mode == "list": ListHeader {
                    x: AppMetrics.pad;
                    y: 38px;
                    // Match the ListView width below (which reserves 14px for
                    // its scroll bar) so the column headers line up with rows.
                    width: parent.width - AppMetrics.pad * 2 - 18px;
                    sort_by: root.secondary_sort_by;
                    sort_dir: root.secondary_sort_dir;
                    sort_col(col) => { root.secondary_sort_column(col); }
                }

                // Empty-area click/right-click handler for the secondary pane.
                // Click clears selection; right-click opens context menu with index = -1
                // so the controller knows it's an empty-space context (paste, new folder, etc.).
                Rectangle {
                    x: 0;
                    y: 38px;
                    width: parent.width;
                    height: parent.height - 38px;
                    background: transparent;
                    sec_empty_touch := TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => {
                            // Activate the secondary pane on click anywhere in its area.
                            root.secondary_file_selected(-1, false, false);
                        }
                        pointer-event(event) => {
                            if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                                root.context_on_file = false;
                                root.context_advanced = false;
                                root.context_tags_expanded = false;
                                root.context_x = (self.absolute-position.x + self.mouse-x).clamp(0px, root.width - 240px);
                                root.context_y = (self.absolute-position.y + self.mouse-y).clamp(0px, root.height - 226px);
                                root.context_visible = true;
                                root.secondary_file_context(-1);
                            }
                        }
                    }
                }

                if root.view_mode == "list": ListView {
                    x: AppMetrics.pad;
                    y: 38px + 32px;
                    // Reserve 14px on the right for the scroll bar - matches
                    // the primary pane's list view so the rightmost column
                    // and tag dot stay clear of the scroll handle.
                    width: parent.width - AppMetrics.pad * 2 - 18px;
                    height: parent.height - 38px - 32px - AppMetrics.pad;
                    viewport-y <=> root.secondary_list_scroll_y;
                    for file[index] in root.secondary_files: FileRow {
                        width: parent.width;
                        item: file;
                        index: index;
                        view_mode: root.view_mode;
                        rename_index: root.active_pane == "secondary" ? root.rename_index : -1;
                        drag_target_path: root.drag_target_path;
                        selected(i, ctrl, shift) => { root.secondary_file_selected(i, ctrl, shift); }
                        opened(i) => { root.secondary_file_opened(i); }
                        context(i, cx, cy) => {
                            root.context_x = cx.clamp(0px, root.width - 240px);
                            root.context_y = cy.clamp(0px, root.height - 440px);
                            root.context_visible = true;
                            root.secondary_file_context(i);
                        }
                        rename_commit(i, val) => {
                            root.rename_index = -1;
                            if (val != "") { root.secondary_rename_file(i, val); }
                        }
                        file_drag_requested(i) => { root.start_file_drag(i, "secondary"); }
                    }
                }

                if root.view_mode != "list": ScrollView {
                    x: AppMetrics.pad;
                    y: 38px + AppMetrics.pad;
                    width: parent.width - AppMetrics.pad * 2;
                    height: parent.height - 38px - AppMetrics.pad * 2;
                    viewport-y <=> root.secondary_list_scroll_y;
                    viewport-width: parent.width - AppMetrics.pad * 2;
                    viewport-height: Math.max(parent.height - 38px - AppMetrics.pad * 2, root.secondary_grid_rows * (root.secondary_grid_item_h + root.secondary_grid_gap));

                    for file[index] in root.secondary_files: FileRow {
                        x: Math.mod(index, root.secondary_grid_columns) * root.secondary_grid_cell_w + root.secondary_grid_gap / 2;
                        y: Math.floor(index / root.secondary_grid_columns) * (root.secondary_grid_item_h + root.secondary_grid_gap);
                        width: root.secondary_grid_cell_w - root.secondary_grid_gap;
                        item: file;
                        index: index;
                        view_mode: root.view_mode;
                        rename_index: root.active_pane == "secondary" ? root.rename_index : -1;
                        drag_target_path: root.drag_target_path;
                        selected(i, ctrl, shift) => { root.secondary_file_selected(i, ctrl, shift); }
                        opened(i) => { root.secondary_file_opened(i); }
                        context(i, cx, cy) => {
                            root.context_x = cx.clamp(0px, root.width - 240px);
                            root.context_y = cy.clamp(0px, root.height - 440px);
                            root.context_visible = true;
                            root.secondary_file_context(i);
                        }
                        rename_commit(i, val) => {
                            root.rename_index = -1;
                            if (val != "") { root.secondary_rename_file(i, val); }
                        }
                        file_drag_requested(i) => { root.start_file_drag(i, "secondary"); }
                    }
                }

                if root.secondary_files.length == 0: Rectangle {
                    x: 0;
                    y: 38px + (root.view_mode == "list" ? 32px : 0px);
                    width: parent.width;
                    height: parent.height - 38px - (root.view_mode == "list" ? 32px : 0px);
                    property <bool> fantasy_on: ThemePalette.active_theme == "fantasy";
                    VerticalLayout {
                        alignment: center;
                        spacing: 8px;
                        if fantasy_on: FantasyEmptyOrnament {
                            x: (parent.width - self.width) / 2;
                            cell: 5px;
                            kind: root.secondary_path == "" ? "tower" : "chest";
                            running: fantasy_on;
                            chest: FantasyIconBank.chest;
                            scroll: FantasyIconBank.scroll;
                            gem_a: FantasyIconBank.gem_a;
                            gem_b: FantasyIconBank.gem_b;
                            potion: FantasyIconBank.potion;
                            tower_a: FantasyIconBank.tower_a;
                            tower_b: FantasyIconBank.tower_b;
                            cauldron: FantasyIconBank.cauldron;
                        }
                        Text {
                            width: parent.width;
                            text: root.secondary_path == "" ? "Enable dual pane to browse a second location" : "Empty folder";
                            color: ThemePalette.text_faint;
                            font-size: 12px;
                            horizontal-alignment: center;
                        }
                    }
                    TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => { root.secondary_file_selected(-1, false, false); }
                        pointer-event(event) => {
                            if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                                root.context_on_file = false;
                                root.context_advanced = false;
                                root.context_tags_expanded = false;
                                root.context_x = (self.absolute-position.x + self.mouse-x).clamp(0px, root.width - 240px);
                                root.context_y = (self.absolute-position.y + self.mouse-y).clamp(0px, root.height - 226px);
                                root.context_visible = true;
                                root.secondary_file_context(-1);
                            }
                        }
                    }
                }
            }

            if root.preview_visible: Rectangle {
                x: parent.width - root.preview_w;
                y: 0;
                width: root.preview_w;
                height: parent.height;
                background: ThemePalette.panel_solid;
                border-width: 0px;
                // Left-edge separator removed. The panel background already
                // contrasts enough with the file area to mark the boundary.

                // Draggable resize handle along the left edge. Wider hit
                // area than the visible line so it is easy to grab. Cursor
                // turns into a horizontal resize arrow on hover.
                Rectangle {
                    x: -3px; y: 0;
                    width: 6px; height: parent.height;
                    background: preview_resize.has-hover || preview_resize.pressed
                        ? ThemePalette.accent
                        : transparent;
                    preview_resize := TouchArea {
                        mouse-cursor: ew-resize;
                        property <length> w_at_press: 326px;
                        pointer-event(e) => {
                            if (e.kind == PointerEventKind.down) {
                                w_at_press = root.preview_w;
                            }
                        }
                        moved => {
                            // Dragging left widens the preview, right narrows it.
                            root.preview_w_user_target = w_at_press - (self.mouse-x - self.pressed-x);
                        }
                        double-clicked => {
                            // Double click resets to the default width.
                            root.preview_w_user_target = 326px;
                        }
                    }
                }

                Rectangle {
                    x: 1px;
                    y: 0;
                    width: parent.width - 1px;
                    height: 46px;
                    background: ThemePalette.panel_solid;
                    SvgIcon {
                        x: 14px;
                        y: (parent.height - 20px) / 2;
                        icon_size: 20px;
                        data: "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8";
                        tint: ThemePalette.text_faint;
                    }
                    Text {
                        x: 48px;
                        // Reserve room on the right so the title never slides
                        // under header controls:
                        //   close only → 92
                        //   + browser (svg / markup) → 125
                        //   + Code/View toggle → 152 (no browser) / 198 (with)
                        width: parent.width - (
                            root.preview_can_render
                                ? (root.preview_is_html ? 198px : 152px)
                                : (root.preview_is_html ? 125px : 92px)
                        );
                        height: parent.height;
                        text: root.preview_title == "" ? "Preview" : root.preview_title;
                        color: ThemePalette.text;
                        font-size: 13px;
                        font-weight: 700;
                        overflow: elide;
                        vertical-alignment: center;
                    }
                    // Built-in Code/View segmented control for HTML and
                    // Markdown. Must sit LEFT of the browser + close buttons —
                    // previously it shared the same x-band as the browser
                    // icon, so a red "open" glyph painted inside "View".
                    if root.preview_can_render: Rectangle {
                        // Browser at width-70 → leave 12px gap before it.
                        // No browser → leave 12px before close (width-37).
                        x: root.preview_is_html ? parent.width - 164px : parent.width - 125px;
                        y: 8px;
                        width: 80px;
                        height: 30px;
                        border-radius: 6px;
                        background: ThemePalette.bg;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        clip: true;
                        // Active segment highlight
                        Rectangle {
                            x: root.preview_show_rendered ? parent.width / 2 : 0px;
                            y: 0;
                            width: parent.width / 2;
                            height: parent.height;
                            background: ThemePalette.accent_soft;
                        }
                        // Hairline divider between Code and View
                        Rectangle {
                            x: parent.width / 2 - 0.5px;
                            y: 6px;
                            width: 1px;
                            height: parent.height - 12px;
                            background: ThemePalette.border;
                        }
                        Text {
                            x: 0; y: 0; width: parent.width / 2; height: parent.height;
                            text: "Code";
                            font-size: 11px;
                            font-weight: root.preview_show_rendered ? 400 : 700;
                            color: root.preview_show_rendered ? ThemePalette.text_muted : ThemePalette.accent_strong;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                        Text {
                            x: parent.width / 2; y: 0; width: parent.width / 2; height: parent.height;
                            text: "View";
                            font-size: 11px;
                            font-weight: root.preview_show_rendered ? 700 : 400;
                            color: root.preview_show_rendered ? ThemePalette.accent_strong : ThemePalette.text_muted;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                        TouchArea {
                            x: 0; width: parent.width / 2; height: parent.height;
                            mouse-cursor: pointer;
                            clicked => { root.preview_show_rendered = false; }
                        }
                        TouchArea {
                            x: parent.width / 2; width: parent.width / 2; height: parent.height;
                            mouse-cursor: pointer;
                            clicked => { root.preview_show_rendered = true; }
                        }
                    }
                    // Open-in-browser for HTML/Markdown/SVG. Kept clear of the
                    // Code/View toggle. tooltip_above so the tip is not covered
                    // by the actions row / ScrollView painted after this header.
                    if root.preview_is_html: ToolButton {
                        x: parent.width - 70px;
                        y: 7px;
                        button_width: 30px;
                        button_height: 30px;
                        icon_data: "M10 14L21 3 M21 3v7 M21 3h-7 M5 5h6 M5 19h14a2 2 0 0 0 2-2v-7";
                        tooltip: "Open rendered output in browser";
                        tooltip_above: true;
                        clicked => { root.open_preview_in_browser(); }
                    }
                    ToolButton {
                        x: parent.width - 37px;
                        y: 7px;
                        icon_data: "M18 6L6 18 M6 6l12 12";
                        tooltip: "Close preview";
                        tooltip_above: true;
                        clicked => { root.toggle_preview(); }
                    }
                }

                // Compact preview actions — single-line chips, no DialogButton overflow.
                Rectangle {
                    x: 1px;
                    y: 46px;
                    width: parent.width - 1px;
                    height: 30px;
                    background: ThemePalette.panel_solid;
                    HorizontalLayout {
                        x: 10px;
                        y: 3px;
                        height: 24px;
                        spacing: 4px;
                        Rectangle {
                            preferred-width: pa_open.preferred-width + 14px;
                            width: self.preferred-width; height: 24px;
                            border-radius: 4px;
                            background: pa_open_ta.has-hover ? ThemePalette.accent_soft : ThemePalette.panel_alt;
                            pa_open := Text {
                                width: parent.width; height: parent.height;
                                text: "Open"; color: ThemePalette.text_muted; font-size: 11px;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                            pa_open_ta := TouchArea { mouse-cursor: pointer; clicked => { root.preview_action("open"); } }
                        }
                        Rectangle {
                            preferred-width: pa_copy.preferred-width + 14px;
                            width: self.preferred-width; height: 24px;
                            border-radius: 4px;
                            background: pa_copy_ta.has-hover ? ThemePalette.accent_soft : ThemePalette.panel_alt;
                            pa_copy := Text {
                                width: parent.width; height: parent.height;
                                text: "Copy path"; color: ThemePalette.text_muted; font-size: 11px;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                            pa_copy_ta := TouchArea { mouse-cursor: pointer; clicked => { root.preview_action("copy-path"); } }
                        }
                        Rectangle {
                            preferred-width: pa_reveal.preferred-width + 14px;
                            width: self.preferred-width; height: 24px;
                            border-radius: 4px;
                            background: pa_reveal_ta.has-hover ? ThemePalette.accent_soft : ThemePalette.panel_alt;
                            pa_reveal := Text {
                                width: parent.width; height: parent.height;
                                text: "Reveal"; color: ThemePalette.text_muted; font-size: 11px;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                            pa_reveal_ta := TouchArea { mouse-cursor: pointer; clicked => { root.preview_action("reveal"); } }
                        }
                        Rectangle {
                            preferred-width: pa_tag.preferred-width + 14px;
                            width: self.preferred-width; height: 24px;
                            border-radius: 4px;
                            background: pa_tag_ta.has-hover ? ThemePalette.accent_soft : ThemePalette.panel_alt;
                            pa_tag := Text {
                                width: parent.width; height: parent.height;
                                text: "Tag"; color: ThemePalette.text_muted; font-size: 11px;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                            pa_tag_ta := TouchArea { mouse-cursor: pointer; clicked => { root.preview_action("tag"); } }
                        }
                    }
                    Rectangle {
                        y: parent.height - 1px; width: parent.width; height: 1px;
                        background: ThemePalette.border;
                    }
                }

                ScrollView {
                    x: 0px;
                    y: 76px;
                    width: parent.width;
                    height: parent.height - 76px;

                    VerticalLayout {
                        // Inner content shrinks by 20 px so the scroll bar has
                        // a visible gutter on the right. Setting viewport-width
                        // here caused the renderer to draw a visible divider at
                        // the viewport edge, so we shrink the layout instead.
                        x: 0;
                        width: parent.width - 20px;
                        padding: 0;
                        spacing: 0;

                        // Image preview area
                        if root.preview_is_image: Rectangle {
                            width: parent.width;
                            height: 220px;
                            background: ThemePalette.bg;
                            border-width: 0;
                            Image {
                                x: (parent.width - 200px) / 2;
                                y: 10px;
                                width: 200px;
                                height: 200px;
                                source: root.preview_image;
                                image-fit: contain;
                            }
                        }

                        // Rasterized PDF first page (rendered natively via the
                        // bundled pdfium). Shown above the extracted text.
                        if root.preview_has_pdf_page: Rectangle {
                            width: parent.width;
                            height: 380px;
                            background: ThemePalette.bg;
                            Image {
                                x: 10px;
                                y: 10px;
                                width: parent.width - 20px;
                                height: parent.height - 20px;
                                source: root.preview_pdf_page;
                                image-fit: contain;
                            }
                        }

                        if root.preview_is_media: Rectangle {
                            width: parent.width;
                            height: 48px;
                            DialogButton {
                                x: 16px; y: 8px;
                                label: "Play in default app";
                                primary: true;
                                clicked => { root.quick_look_play(); }
                            }
                        }

                        if root.preview_is_pdf: Rectangle {
                            x: 16px;
                            width: parent.width - 32px;
                            height: (root.preview_body == "" && !root.preview_has_pdf_page) ? 58px : 34px;
                            Text {
                                width: parent.width; height: parent.height;
                                text: root.preview_has_pdf_page
                                    ? "PDF · first page rendered above. Open the file for the full document."
                                    : (root.preview_body == ""
                                        ? "Rendering PDF page… if nothing appears it may be protected or image-only — open it to view the full document."
                                        : "PDF · first-page text extract shown below. Open the file for the full document.");
                                color: ThemePalette.text_muted; font-size: 12px; wrap: word-wrap; vertical-alignment: center;
                            }
                        }

                        // Renderable markup (html/htm/md): explain the toggle.
                        if root.preview_can_render: Rectangle {
                            width: parent.width;
                            height: 28px;
                            Text {
                                x: 16px; width: parent.width - 32px; height: parent.height;
                                text: root.preview_show_rendered
                                    ? "Rendered view (built-in). Switch to Code for raw source, or open in your browser."
                                    : "Source view. Switch to View for a built-in rendered version, or open in your browser.";
                                color: ThemePalette.text_faint; font-size: 11px; vertical-alignment: center; overflow: elide;
                            }
                        }

                        // Non-renderable markup (e.g. SVG): source only.
                        if root.preview_is_html && !root.preview_can_render: Rectangle {
                            width: parent.width;
                            height: 28px;
                            Text {
                                x: 16px; width: parent.width - 32px; height: parent.height;
                                text: "Source below — use the browser button to open rendered output.";
                                color: ThemePalette.text_faint; font-size: 11px; vertical-alignment: center; overflow: elide;
                            }
                        }

                        // Meta info block (path, type, size, modified)
                        if root.preview_meta != "": Rectangle {
                            width: parent.width;
                            height: 8px;
                        }
                        if root.preview_meta != "": Text {
                            x: 16px;
                            width: parent.width - 32px;
                            text: root.preview_meta;
                            color: ThemePalette.text_faint;
                            font-size: 10.5px;
                            font-family: AppMetrics.mono_font;
                            wrap: word-wrap;
                        }

                        // Body content
                        if root.preview_body != "" && root.preview_meta != "": Rectangle {
                            width: parent.width; height: 8px;
                        }

                        // Source (code) view — the default. Shown unless the
                        // built-in rendered view is active and available.
                        if root.preview_body != "" && !(root.preview_can_render && root.preview_show_rendered && root.preview_rendered != ""): CopyableMessageText {
                            x: 16px;
                            content-width: parent.width - 32px;
                            text: root.preview_body;
                            font-size: 11.5px;
                            text-color: ThemePalette.text_muted;
                            mono: true;
                            expand: true;
                        }

                        // Built-in rendered view for HTML / Markdown.
                        if root.preview_can_render && root.preview_show_rendered && root.preview_rendered != "": CopyableMessageText {
                            x: 16px;
                            content-width: parent.width - 32px;
                            text: root.preview_rendered;
                            font-size: 12.5px;
                            text-color: ThemePalette.text;
                            mono: false;
                            expand: true;
                        }

                        // Empty state
                        if root.preview_body == "" && root.preview_meta == "": VerticalLayout {
                            x: 16px;
                            width: parent.width - 32px;
                            height: 200px;
                            alignment: center;
                            spacing: 10px;
                            if ThemePalette.active_theme == "fantasy": FantasyEmptyOrnament {
                                x: (parent.width - self.width) / 2;
                                cell: 5px;
                                kind: "scroll";
                                running: ThemePalette.active_theme == "fantasy";
                                chest: FantasyIconBank.chest;
                                scroll: FantasyIconBank.scroll;
                                gem_a: FantasyIconBank.gem_a;
                                gem_b: FantasyIconBank.gem_b;
                                potion: FantasyIconBank.potion;
                                tower_a: FantasyIconBank.tower_a;
                                tower_b: FantasyIconBank.tower_b;
                                cauldron: FantasyIconBank.cauldron;
                            }
                            Text {
                                width: parent.width;
                                text: "Select a file to preview details.";
                                color: ThemePalette.text_faint;
                                font-size: 12.5px;
                                font-family: AppMetrics.ui_font;
                                horizontal-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        // Border line sits just above the status bar in its own Rectangle so
        // it never shares pixels with the text inside the bar. Earlier this
        // was a child of the status bar at y=0 and the rendering order meant
        // the line could pass through glyph ascenders.
        Rectangle {
            x: 0;
            y: parent.height - root.status_h - 1px;
            width: parent.width;
            height: 1px;
            background: ThemePalette.border;
        }
        // Status (single row, no overlap between left / update badge / right)
        Rectangle {
            x: 0;
            y: parent.height - root.status_h;
            width: parent.width;
            height: root.status_h;
            background: ThemePalette.titlebar;
            HorizontalLayout {
                x: 0;
                y: 0;
                width: parent.width;
                height: parent.height;
                padding-left: 12px;
                padding-right: 12px;
                spacing: 10px;
                alignment: stretch;
                Text {
                    horizontal-stretch: 2;
                    min-width: 80px;
                    height: parent.height;
                    text: root.status_left;
                    color: ThemePalette.text_faint;
                    font-size: 11px;
                    vertical-alignment: center;
                    overflow: elide;
                }
                if root.queue_busy: Rectangle {
                    horizontal-stretch: 0;
                    preferred-width: Math.max(72px, queue_pill_label.preferred-width + 20px);
                    width: self.preferred-width;
                    preferred-height: 18px;
                    height: self.preferred-height;
                    y: (parent.height - self.height) / 2;
                    border-radius: 9px;
                    background: ThemePalette.warning;
                    queue_pill_label := Text {
                        width: parent.width;
                        height: parent.height;
                        text: root.queue_busy_text != "" ? root.queue_busy_text : "Queue busy";
                        color: white;
                        font-size: 10px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                    TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.queue_pill_clicked(); }
                    }
                }
                Rectangle {
                    visible: root.update_available;
                    horizontal-stretch: 0;
                    preferred-width: root.update_download_url != "" ? 196px : 158px;
                    width: self.preferred-width;
                    preferred-height: 18px;
                    height: self.preferred-height;
                    y: (parent.height - self.height) / 2;
                    border-radius: 9px;
                    background: ThemePalette.success;
                    Text {
                        x: 0; width: root.update_download_url != "" ? parent.width - 54px : parent.width;
                        height: parent.height;
                        text: "Update v" + root.update_version + " available";
                        color: white;
                        font-size: 10px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    // Click anywhere on the banner OPENS the releases page.
                    // Declared BEFORE the Install button so it sits at lower z;
                    // also shrinks its width when the Install pill is shown so
                    // there's a generous gap that can't be misrouted.
                    TouchArea {
                        x: 0;
                        y: 0;
                        width: root.update_download_url != "" ? parent.width - 60px : parent.width;
                        height: parent.height;
                        mouse-cursor: pointer;
                        clicked => { root.command("open-releases"); }
                    }
                    // Install pill - declared AFTER the banner TouchArea so it
                    // wins z-order for clicks on its area. z is set explicitly
                    // too as belt-and-suspenders against any Slint hit-test
                    // ordering quirk. The TouchArea inside also extends a 4px
                    // grace area to the left of the visible pill so clicks
                    // near the button's left edge still land on Install.
                    if root.update_download_url != "": Rectangle {
                        z: 100;
                        x: parent.width - 52px; y: 1px;
                        width: 50px; height: parent.height - 2px;
                        border-radius: 8px;
                        background: rgba(0, 0, 0, 0.25);
                        Text {
                            width: parent.width; height: parent.height;
                            text: "Install";
                            color: white;
                            font-size: 10px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        TouchArea {
                            // Extend slightly outside the visible pill so the
                            // hit area is a few pixels larger than the paint.
                            x: -4px;
                            y: -2px;
                            width: parent.width + 8px;
                            height: parent.height + 4px;
                            mouse-cursor: pointer;
                            clicked => { root.install_update(); }
                        }
                    }
                }
                Text {
                    horizontal-stretch: 1;
                    min-width: 64px;
                    height: parent.height;
                    text: root.status_right;
                    color: ThemePalette.text_faint;
                    font-size: 11px;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }

        // High Fantasy atmosphere — divine wind + ember drift + star sparkles.
        // Inside `app` so it sits above opaque chrome but below MainWindow
        // modals (settings / welcome / dialogs). No TouchArea: clicks pass through.
        FantasyAtmosphere {
            x: 0;
            y: 0;
            width: parent.width;
            height: parent.height;
            z: 40;
            active: ThemePalette.active_theme == "fantasy";
            running: ThemePalette.active_theme == "fantasy";
        }
    }

    if root.context_visible: Rectangle {
        z: 90;
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0);
        TouchArea {
            clicked => { root.context_visible = false; root.context_advanced = false; root.context_tags_expanded = false; }
        }
    }

    // Context menu - file
    if root.context_visible && root.context_on_file: Rectangle {
        z: 100;
        x: root.context_x;
        y: root.context_y.clamp(0px, root.height - (root.is_simple ? 410px : 580px));
        width: 226px;
        height: root.is_simple ? 390px : 560px;
        border-width: 1px;
        border-color: ThemePalette.border_strong;
        border-radius: AppMetrics.radius;
        background: ThemePalette.panel_solid;
        drop-shadow-blur: 14px;
        drop-shadow-color: rgba(0, 0, 0, 0.38);
        clip: true;

        ScrollView {
            x: 0;
            y: 0;
            width: 226px;
            height: parent.height;
            viewport-width: 216px;

        VerticalLayout {
            width: 216px;
            padding: 5px;
            spacing: 2px;
            // -- Recycle-bin-only actions ------------------------------
            // Surfaced only when browsing `recycle://`; replace the standard
            // open/copy/cut chain because those don't apply to trash items.
            if root.in_recycle_bin: ChoiceMenuRow { width: parent.width; label: "Restore"; command_name: "restore"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.in_recycle_bin: ChoiceMenuRow { width: parent.width; label: "Delete Permanently"; command_name: "purge"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.in_recycle_bin: Rectangle { height: 1px; background: ThemePalette.border; }
            if root.in_recycle_bin: ChoiceMenuRow { width: parent.width; label: "Empty Recycle Bin"; command_name: "empty-trash"; picked(c) => { root.context_visible = false; root.command(c); } }

            // -- Core actions (regular folders) ------------------------
            if !root.in_recycle_bin: ChoiceMenuRow { width: parent.width; label: "Open"; command_name: "open"; picked(c) => { root.context_visible = false; root.command(c); } }
            if !root.in_recycle_bin: ChoiceMenuRow { width: parent.width; label: "Rename"; command_name: "rename"; picked(c) => { root.context_visible = false; root.command(c); } }
            if !root.in_recycle_bin: ChoiceMenuRow { width: parent.width; label: "Copy"; command_name: "copy"; picked(c) => { root.context_visible = false; root.command(c); } }
            if !root.in_recycle_bin: ChoiceMenuRow { width: parent.width; label: "Cut"; command_name: "cut"; picked(c) => { root.context_visible = false; root.command(c); } }
            if !root.in_recycle_bin: ChoiceMenuRow { width: parent.width; label: "Paste"; command_name: "paste"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.context_is_archive && !root.in_recycle_bin: Rectangle { height: 1px; background: ThemePalette.border; }
            if root.context_is_archive && !root.in_recycle_bin: ChoiceMenuRow { width: parent.width; label: "Archive Browser"; command_name: "archive-browser"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.context_is_archive && !root.in_recycle_bin: ChoiceMenuRow { width: parent.width; label: "Extract Here"; command_name: "extract-here"; picked(c) => { root.context_visible = false; root.command(c); } }
            Rectangle { height: 1px; background: ThemePalette.border; }
            ChoiceMenuRow { visible: !root.is_simple; width: parent.width; label: "Batch Rename"; command_name: "batch-rename"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Add Note"; command_name: "note"; picked(c) => { root.context_visible = false; root.command(c); } }
            Rectangle { height: 1px; background: ThemePalette.border; }
            Rectangle {
                width: parent.width;
                height: 30px;
                border-radius: AppMetrics.radius_small;
                background: tag_touch.has-hover ? ThemePalette.accent_soft : rgba(0, 0, 0, 0);
                border-width: 1px;
                border-color: tag_touch.has-hover ? ThemePalette.accent : rgba(0, 0, 0, 0);
                SvgIcon {
                    x: 9px;
                    y: (parent.height - 14px) / 2;
                    icon_size: 14px;
                    data: "M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z M7 7h.01";
                    tint: tag_touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text_faint;
                }
                Text {
                    x: 30px;
                    width: parent.width - 104px;
                    height: parent.height;
                    text: "Tags";
                    color: tag_touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text_muted;
                    font-size: 12.5px;
                    vertical-alignment: center;
                }
                // Inline color key (which tag colors exist)
                Rectangle { x: parent.width - 84px; y: (parent.height - 7px) / 2; width: 5px; height: 5px; border-radius: 3px; background: #e05252; border-width: 1px; border-color: rgba(0,0,0,0.12); }
                Rectangle { x: parent.width - 76px; y: (parent.height - 7px) / 2; width: 5px; height: 5px; border-radius: 3px; background: #e08c3a; border-width: 1px; border-color: rgba(0,0,0,0.12); }
                Rectangle { x: parent.width - 68px; y: (parent.height - 7px) / 2; width: 5px; height: 5px; border-radius: 3px; background: #d4b024; border-width: 1px; border-color: rgba(0,0,0,0.12); }
                Rectangle { x: parent.width - 60px; y: (parent.height - 7px) / 2; width: 5px; height: 5px; border-radius: 3px; background: #4caf6a; border-width: 1px; border-color: rgba(0,0,0,0.12); }
                Rectangle { x: parent.width - 52px; y: (parent.height - 7px) / 2; width: 5px; height: 5px; border-radius: 3px; background: #4a90d9; border-width: 1px; border-color: rgba(0,0,0,0.12); }
                Rectangle { x: parent.width - 44px; y: (parent.height - 7px) / 2; width: 5px; height: 5px; border-radius: 3px; background: #8b5cf6; border-width: 1px; border-color: rgba(0,0,0,0.12); }
                SvgIcon {
                    x: parent.width - 22px;
                    y: (parent.height - 13px) / 2;
                    icon_size: 13px;
                    data: root.context_tags_expanded
                        ? "M18 15l-6-6-6 6"
                        : "M6 9l6 6 6-6";
                    tint: tag_touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text_faint;
                }
                tag_touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.context_tags_expanded = !root.context_tags_expanded; }
                }
            }
            if root.context_tags_expanded: TagMenuRow { width: parent.width; label: root.tag_names[0]; dot_color: #e05252; command_name: "tag-red"; picked(c) => { root.context_visible = false; root.context_tags_expanded = false; root.command(c); } }
            if root.context_tags_expanded: TagMenuRow { width: parent.width; label: root.tag_names[1]; dot_color: #e08c3a; command_name: "tag-orange"; picked(c) => { root.context_visible = false; root.context_tags_expanded = false; root.command(c); } }
            if root.context_tags_expanded: TagMenuRow { width: parent.width; label: root.tag_names[2]; dot_color: #d4b024; command_name: "tag-yellow"; picked(c) => { root.context_visible = false; root.context_tags_expanded = false; root.command(c); } }
            if root.context_tags_expanded: TagMenuRow { width: parent.width; label: root.tag_names[3]; dot_color: #4caf6a; command_name: "tag-green"; picked(c) => { root.context_visible = false; root.context_tags_expanded = false; root.command(c); } }
            if root.context_tags_expanded: TagMenuRow { width: parent.width; label: root.tag_names[4]; dot_color: #4a90d9; command_name: "tag-blue"; picked(c) => { root.context_visible = false; root.context_tags_expanded = false; root.command(c); } }
            if root.context_tags_expanded: TagMenuRow { width: parent.width; label: root.tag_names[5]; dot_color: #8b5cf6; command_name: "tag-violet"; picked(c) => { root.context_visible = false; root.context_tags_expanded = false; root.command(c); } }
            if root.context_tags_expanded: ChoiceMenuRow { width: parent.width; label: "Clear Tag"; command_name: "tag-clear"; picked(c) => { root.context_visible = false; root.context_tags_expanded = false; root.command(c); } }
            Rectangle { height: 1px; background: ThemePalette.border; }
            ChoiceMenuRow { width: parent.width; label: "Copy as Path"; command_name: "copy-as-path"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Open in Terminal"; command_name: "open-terminal"; picked(c) => { root.context_visible = false; root.command(c); } }
            ChoiceMenuRow { width: parent.width; label: "Open With"; command_name: "open-with"; picked(c) => { root.context_visible = false; root.command(c); } }
            Rectangle { visible: !root.is_simple; height: 1px; background: ThemePalette.border; }
            ChoiceMenuRow { visible: !root.is_simple; width: parent.width; label: "Image Tools"; command_name: "image-tools"; picked(c) => { root.context_visible = false; root.command(c); } }
            Rectangle { height: 1px; background: ThemePalette.border; }
            ChoiceMenuRow { width: parent.width; label: "Properties"; command_name: "properties"; picked(c) => { root.context_visible = false; root.command(c); } }

            Rectangle { visible: !root.is_simple; height: 1px; background: ThemePalette.border; }
            ChoiceMenuRow { visible: !root.is_simple; width: parent.width; label: "Create ZIP"; command_name: "create-zip"; picked(c) => { root.context_visible = false; root.command(c); } }

            // -- Advanced toggle (ZIP lives above; this expands power / Windows tools) --------------
            Rectangle {
                visible: !root.is_simple;
                width: parent.width;
                height: 26px;
                background: adv_touch.has-hover ? ThemePalette.panel_alt : transparent;
                border-radius: AppMetrics.radius_small;
                adv_touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.context_advanced = !root.context_advanced; }
                }
                Text {
                    width: parent.width - 18px;
                    x: 9px;
                    height: parent.height;
                    text: root.context_advanced ? "^ Hide advanced" : "v Advanced & Windows tools";
                    color: ThemePalette.text_faint;
                    font-size: 11px;
                    vertical-alignment: center;
                }
            }

            // -- Advanced items (hidden by default, never shown in simple mode) --------------------
            if root.context_advanced && !root.is_simple: Rectangle { height: 1px; background: ThemePalette.border; }
            if root.context_advanced && !root.is_simple: ChoiceMenuRow { width: parent.width; label: "Checksum"; command_name: "checksum"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.context_advanced && !root.is_simple: ChoiceMenuRow { width: parent.width; label: "Copy as PowerShell Path"; command_name: "copy-as-powershell"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.context_advanced && !root.is_simple: ChoiceMenuRow { width: parent.width; label: "Locked File Inspector"; command_name: "locked-file"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.context_advanced && !root.is_simple: ChoiceMenuRow { width: parent.width; label: "Defender Scan"; command_name: "defender-scan"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.context_advanced && !root.is_simple: ChoiceMenuRow { width: parent.width; label: "Cloud State"; command_name: "cloud-state"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.context_advanced && !root.is_simple: ChoiceMenuRow { width: parent.width; label: "Show More Options"; command_name: "show-more-options"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.context_advanced && !root.is_simple: Rectangle { height: 1px; background: ThemePalette.border; }
            if root.context_advanced && !root.is_simple: ChoiceMenuRow { width: parent.width; label: "Run as Administrator"; command_name: "run-as-admin"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.context_advanced && !root.is_simple: ChoiceMenuRow { width: parent.width; label: "Take Ownership"; command_name: "take-ownership"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.context_advanced && !root.is_simple: ChoiceMenuRow { width: parent.width; label: "Previous Versions"; command_name: "previous-versions"; picked(c) => { root.context_visible = false; root.command(c); } }

            Rectangle { height: 1px; background: ThemePalette.border; }
            ChoiceMenuRow { width: parent.width; label: "Delete"; command_name: "delete"; danger: true; picked(c) => { root.context_visible = false; root.command(c); } }
        }
        }
    }

    // Context menu - empty area
    if root.context_visible && !root.context_on_file: Rectangle {
        z: 100;
        x: root.context_x;
        y: root.context_y.clamp(0px, root.height - 278px);
        width: 226px;
        height: 266px;
        border-width: 1px;
        border-color: ThemePalette.border_strong;
        border-radius: AppMetrics.radius;
        background: ThemePalette.panel_solid;
        drop-shadow-blur: 14px;
        drop-shadow-color: rgba(0, 0, 0, 0.38);
        clip: true;

        VerticalLayout {
            width: 216px;
            x: 5px;
            y: 5px;
            spacing: 2px;
            // Recycle-bin empty-area shortcut.
            if root.in_recycle_bin: ChoiceMenuRow { width: parent.width; label: "Empty Recycle Bin"; command_name: "empty-trash"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.in_recycle_bin: ChoiceMenuRow { width: parent.width; label: "Select All"; command_name: "select-all"; picked(c) => { root.context_visible = false; root.command(c); } }
            if root.in_recycle_bin: Rectangle { height: 1px; background: ThemePalette.border; }
            if root.in_recycle_bin: ChoiceMenuRow { width: parent.width; label: "Refresh"; command_name: "refresh"; picked(c) => { root.context_visible = false; root.command(c); } }

            if !root.in_recycle_bin: ChoiceMenuRow { width: parent.width; label: "New Folder"; command_name: "new-folder"; picked(c) => { root.context_visible = false; root.command(c); } }
            if !root.in_recycle_bin: ChoiceMenuRow { width: parent.width; label: "New File"; command_name: "new-file"; picked(c) => { root.context_visible = false; root.command(c); } }
            if !root.in_recycle_bin: Rectangle { height: 1px; background: ThemePalette.border; }
            if !root.in_recycle_bin: ChoiceMenuRow { width: parent.width; label: "Paste"; command_name: "paste"; picked(c) => { root.context_visible = false; root.command(c); } }
            if !root.in_recycle_bin: ChoiceMenuRow { width: parent.width; label: "Select All"; command_name: "select-all"; picked(c) => { root.context_visible = false; root.command(c); } }
            if !root.in_recycle_bin: Rectangle { height: 1px; background: ThemePalette.border; }
            if !root.in_recycle_bin: ChoiceMenuRow { width: parent.width; label: "Refresh"; command_name: "refresh"; picked(c) => { root.context_visible = false; root.command(c); } }
            if !root.in_recycle_bin: ChoiceMenuRow { width: parent.width; label: "Open in Terminal"; command_name: "open-terminal"; picked(c) => { root.context_visible = false; root.command(c); } }
            if !root.in_recycle_bin: Rectangle { height: 1px; background: ThemePalette.border; }
            if !root.in_recycle_bin: ChoiceMenuRow { width: parent.width; label: "Properties"; command_name: "properties"; picked(c) => { root.context_visible = false; root.command(c); } }
        }
    }

    if root.image_tools_visible: Rectangle {
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0.42);

        TouchArea {
            clicked => { root.image_tools_visible = false; }
        }

        Rectangle {
            x: (parent.width - 520px) / 2;
            y: 96px;
            width: 520px;
            height: 470px;
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            drop-shadow-blur: 18px;
            drop-shadow-color: rgba(0, 0, 0, 0.38);

            Text {
                x: 18px;
                y: 16px;
                width: parent.width - 70px;
                height: 24px;
                text: root.image_tools_title;
                color: ThemePalette.text;
                font-size: 18px;
                font-weight: 700;
                overflow: elide;
            }

            ToolButton {
                x: parent.width - 43px;
                y: 12px;
                icon_data: "M18 6L6 18 M6 6l12 12";
                tooltip: "Close";
                clicked => { root.image_tools_visible = false; }
            }

            Text {
                x: 18px;
                y: 45px;
                width: parent.width - 36px;
                height: 42px;
                text: root.image_tools_subtitle;
                color: ThemePalette.text_faint;
                font-size: 12px;
                wrap: word-wrap;
            }

            Rectangle { x: 18px; y: 96px; width: parent.width - 36px; height: 1px; background: ThemePalette.border; }

            Text { x: 18px; y: 112px; width: 225px; height: 18px; text: "Adjust"; color: ThemePalette.text_faint; font-size: 11px; font-weight: 700; }
            ChoiceMenuRow { x: 18px; y: 136px; width: 225px; label: "Rotate Left"; command_name: "image-rotate-left"; picked(c) => { root.image_tools_visible = false; root.command(c); } }
            ChoiceMenuRow { x: 18px; y: 170px; width: 225px; label: "Rotate Right"; command_name: "image-rotate-right"; picked(c) => { root.image_tools_visible = false; root.command(c); } }
            ChoiceMenuRow { x: 18px; y: 204px; width: 225px; label: "Resize to 50%"; command_name: "image-resize-half"; picked(c) => { root.image_tools_visible = false; root.command(c); } }
            ChoiceMenuRow { x: 18px; y: 238px; width: 225px; label: "Resize to 25%"; command_name: "image-resize-quarter"; picked(c) => { root.image_tools_visible = false; root.command(c); } }

            // Custom resize row
            Rectangle {
                x: 18px; y: 272px;
                width: 225px; height: 30px;
                border-radius: AppMetrics.radius_small;
                border-width: 1px;
                border-color: ThemePalette.border;
                background: ThemePalette.panel;
                property <string> resize_value: "";
                Text {
                    x: 9px; y: 0;
                    width: 70px; height: parent.height;
                    text: "Scale %:";
                    color: ThemePalette.text_muted;
                    font-size: 12px;
                    vertical-alignment: center;
                }
                resize_input := TextInput {
                    x: 76px; y: 1px;
                    width: 80px; height: parent.height - 2px;
                    font-size: 12.5px;
                    color: ThemePalette.text;
                    vertical-alignment: center;
                    accepted() => {
                        if self.text != "" {
                            root.image_tools_visible = false;
                            root.command("image-resize-pct-" + self.text);
                        }
                    }
                }
                if resize_input.text == "" && !resize_input.has-focus: Text {
                    x: 76px; y: 0;
                    width: 80px; height: parent.height;
                    text: "e.g. 75";
                    color: ThemePalette.text_faint;
                    font-size: 12px;
                    vertical-alignment: center;
                }
                Rectangle {
                    x: parent.width - 55px; y: 3px;
                    width: 50px; height: 24px;
                    border-radius: 5px;
                    background: apply_touch.has-hover ? ThemePalette.accent : ThemePalette.accent_soft;
                    Text {
                        width: parent.width; height: parent.height;
                        text: "Apply";
                        color: apply_touch.has-hover ? white : ThemePalette.accent_strong;
                        font-size: 11.5px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    apply_touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            if resize_input.text != "" {
                                root.image_tools_visible = false;
                                root.command("image-resize-pct-" + resize_input.text);
                            }
                        }
                    }
                }
            }

            Text { x: 277px; y: 112px; width: 225px; height: 18px; text: "Export"; color: ThemePalette.text_faint; font-size: 11px; font-weight: 700; }
            ChoiceMenuRow { x: 277px; y: 136px; width: 225px; label: "Convert to JPEG"; command_name: "image-convert-jpeg"; picked(c) => { root.image_tools_visible = false; root.command(c); } }
            ChoiceMenuRow { x: 277px; y: 170px; width: 225px; label: "Convert to PNG"; command_name: "image-convert-png"; picked(c) => { root.image_tools_visible = false; root.command(c); } }
            ChoiceMenuRow { x: 277px; y: 204px; width: 225px; label: "Convert to WebP"; command_name: "image-convert-webp"; picked(c) => { root.image_tools_visible = false; root.command(c); } }
            ChoiceMenuRow { x: 277px; y: 238px; width: 225px; label: "Compress JPEG Copy"; command_name: "image-compress-jpeg"; picked(c) => { root.image_tools_visible = false; root.command(c); } }

            Text { x: 18px; y: 334px; width: parent.width - 36px; height: 18px; text: "Privacy"; color: ThemePalette.text_faint; font-size: 11px; font-weight: 700; }
            ChoiceMenuRow { x: 18px; y: 356px; width: parent.width - 36px; label: "Strip Metadata Copy"; command_name: "image-strip-metadata"; picked(c) => { root.image_tools_visible = false; root.command(c); } }

            Text {
                x: 18px;
                y: 410px;
                width: parent.width - 36px;
                height: 34px;
                text: "Actions create new files next to the original and keep the source unchanged.";
                color: ThemePalette.text_faint;
                font-size: 11.5px;
                wrap: word-wrap;
            }
        }
    }

    if root.command_visible: Rectangle {
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0.42);
        TouchArea { mouse-cursor: pointer; clicked => { root.command_visible = false; } }

        Rectangle {
            x: max(16px, (parent.width - min(620px, parent.width - 32px)) / 2);
            y: max(16px, min(82px, (parent.height - min(512px, parent.height - 32px)) / 2));
            width: min(620px, parent.width - 32px);
            height: min(512px, parent.height - 32px);
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            drop-shadow-blur: 18px;
            drop-shadow-color: rgba(0, 0, 0, 0.38);

            Rectangle {
                x: 16px;
                y: 14px;
                width: parent.width - 32px;
                height: 38px;
                border-width: 1px;
                border-color: cmd_search.has-focus ? ThemePalette.accent : ThemePalette.border;
                border-radius: AppMetrics.radius_small;
                background: ThemePalette.bg_soft;
                SvgIcon { x: 10px; y: 11px; icon_size: 16px; data: "M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16z M21 21l-4.3-4.3"; tint: ThemePalette.text_faint; }
                cmd_search := LineEdit {
                    x: 34px;
                    y: 0;
                    width: parent.width - 64px;
                    height: parent.height;
                    text: root.command_filter;
                    placeholder-text: "Type a command...";
                    font-size: 14px;
                    edited(value) => { root.command_filter = value; root.filter_commands(value); }
                    accepted(value) => { root.command_run_first(value); }
                    key-pressed(event) => {
                        if (event.text == Key.Escape) {
                            root.command_visible = false;
                            accept
                        } else { reject }
                    }
                }
                ToolButton {
                    x: parent.width - 30px;
                    y: 4px;
                    button_width: 26px;
                    button_height: 26px;
                    text_label: "X";
                    clicked => {
                        if (root.command_filter != "") {
                            root.command_filter = "";
                            root.filter_commands("");
                        } else {
                            root.command_visible = false;
                        }
                    }
                }
            }

            ListView {
                x: 6px;
                y: 64px;
                width: parent.width - 12px;
                height: parent.height - 70px;
                for cmd[index] in root.command_items: CommandRow {
                    width: parent.width;
                    item: cmd;
                    picked(name) => {
                        root.command_visible = false;
                        root.command(name);
                    }
                }
            }
        }
    }

    if root.settings_visible: Rectangle {
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0.42);
        TouchArea { clicked => { root.settings_visible = false; } }

        Rectangle {
            x: (parent.width - min(780px, parent.width - 32px)) / 2;
            y: (parent.height - min(680px, parent.height - 32px)) / 2;
            width: min(780px, parent.width - 32px);
            height: min(680px, parent.height - 32px);
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            drop-shadow-blur: 20px;
            drop-shadow-color: rgba(0, 0, 0, 0.45);
            TouchArea {}

            Text { x: 20px; y: 18px; width: 100px; height: 28px; text: "Settings"; color: ThemePalette.text; font-size: 18px; font-weight: 700; }
            // Version label tucked next to the heading. Reads the value the
            // controller pushes from env!("CARGO_PKG_VERSION") at startup.
            Text {
                x: 124px; y: 22px; width: parent.width - 180px; height: 22px;
                text: "v" + root.app_version;
                color: ThemePalette.text_faint;
                font-size: 12px;
                font-family: AppMetrics.mono_font;
                vertical-alignment: center;
                overflow: elide;
            }
            ToolButton { x: parent.width - 46px; y: 14px; icon_data: "M18 6L6 18 M6 6l12 12"; tooltip: "Close settings"; clicked => { root.settings_visible = false; } }

            Text {
                x: 20px; y: 48px; width: parent.width - 40px; height: 16px;
                text: root.settings_tab == "ai" ? "On-device models · no cloud · no OCR"
                    : (root.settings_tab == "performance" ? "Index, cache, and scan budgets"
                    : (root.settings_tab == "view" ? "Layout density, panes, and defaults"
                    : "Theme, accent, fonts, and chrome"));
                color: ThemePalette.text_faint;
                font-size: 11px;
                overflow: elide;
            }

            Rectangle {
                y: 68px;
                width: parent.width;
                height: 44px;
                background: transparent;
                Rectangle { y: parent.height - 1px; width: parent.width; height: 1px; background: ThemePalette.border; }

                for tab_label[ti] in ["Appearance", "View", "Performance", "AI"]: Rectangle {
                    property <string> tid: ti == 0 ? "appearance" : (ti == 1 ? "view" : (ti == 2 ? "performance" : "ai"));
                    property <bool> is_active: root.settings_tab == self.tid || (self.tid == "appearance" && root.settings_tab == "themes");
                    visible: !(root.is_simple && tab_label == "AI");
                    x: 20px + ti * 102px;
                    y: 0;
                    width: 98px;
                    height: parent.height;
                    background: transparent;
                    Text {
                        width: parent.width;
                        height: parent.height - 2px;
                        text: tab_label;
                        color: parent.is_active ? ThemePalette.text : ThemePalette.text_muted;
                        font-size: 13px;
                        font-weight: parent.is_active ? 600 : 400;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                    Rectangle {
                        y: parent.height - 2px;
                        width: parent.width;
                        height: 2px;
                        background: parent.is_active ? ThemePalette.accent : transparent;
                        animate background { duration: 40ms; easing: ease-out; }
                    }
                    TouchArea { mouse-cursor: pointer; clicked => { root.settings_tab = tid; } }
                }
            }

            if root.settings_tab == "appearance" || root.settings_tab == "themes": ScrollView {
                x: 20px;
                y: 124px;
                width: parent.width - 40px;
                height: parent.height - 136px;

                VerticalLayout {
                    // Inner content stops 20 px short of the ScrollView right
                    // edge so the scroll bar lives in its own gutter rather
                    // than painting on top of the theme tile right column.
                    width: parent.width - 20px;
                    spacing: 18px;
                    padding-bottom: 16px;

                    Text { text: "THEME"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        width: parent.width;
                        height: Math.ceil(root.theme_choices.length / 2) * AppMetrics.choice_chip_row_stride;
                        for theme[i] in root.theme_choices: ChoiceChip {
                            x: Math.mod(i, 2) == 0 ? 0px : (parent.width / 2 + 3px);
                            y: Math.floor(i / 2) * AppMetrics.choice_chip_row_stride;
                            width: parent.width / 2 - 3px;
                            item: theme;
                            active: root.active_theme == theme.id;
                            picked(id) => { root.theme_selected(id); }
                        }
                    }

                    // High Fantasy: live pixel-icon preview (hover + idle animations).
                    // Only mounted while the fantasy theme is active — timers pause otherwise.
                    if root.active_theme == "fantasy": Rectangle {
                        width: parent.width;
                        height: 92px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text {
                            x: 12px; y: 8px; width: parent.width - 24px; height: 14px;
                            text: "PIXEL RELICS";
                            color: ThemePalette.text_faint;
                            font-size: 10px;
                            font-weight: 700;
                            letter-spacing: 1px;
                        }
                        FantasyIconGallery {
                            x: max(8px, (parent.width - self.width) / 2);
                            y: 26px;
                            cell: 4px;
                            gap: 8px;
                            running: root.active_theme == "fantasy" && root.settings_visible;
                            chest: FantasyIconBank.chest;
                            scroll: FantasyIconBank.scroll;
                            gem_a: FantasyIconBank.gem_a;
                            gem_b: FantasyIconBank.gem_b;
                            potion: FantasyIconBank.potion;
                            tower_a: FantasyIconBank.tower_a;
                            tower_b: FantasyIconBank.tower_b;
                            cauldron: FantasyIconBank.cauldron;
                        }
                    }

                    Text { text: "ACCENT COLOR"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        property <int> ac_cols: 4;
                        property <length> ac_gap: 6px;
                        property <length> ac_cell_w: (parent.width - (ac_cols - 1) * ac_gap) / ac_cols;
                        width: parent.width;
                        height: Math.ceil(root.accent_choices.length / ac_cols) * AppMetrics.choice_chip_row_stride;
                        for accent[i] in root.accent_choices: ChoiceChip {
                            x: Math.mod(i, ac_cols) * (ac_cell_w + ac_gap);
                            y: Math.floor(i / ac_cols) * AppMetrics.choice_chip_row_stride;
                            width: ac_cell_w;
                            item: accent;
                            active: root.active_accent == accent.id;
                            picked(id) => { root.accent_selected(id); }
                        }
                    }

                    // Custom accent hex input. Typing a valid 7-char hex (#rrggbb)
                    // here switches the active accent to "custom" and stores the
                    // exact colour. Invalid or partial entries are ignored, so the
                    // current accent stays unchanged while the user is typing.
                    Rectangle {
                        width: parent.width;
                        height: 42px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: root.active_accent == "custom" ? ThemePalette.accent : ThemePalette.border;
                        background: root.active_accent == "custom" ? ThemePalette.accent_soft : ThemePalette.panel;
                        Text {
                            x: 14px;
                            y: 0;
                            width: 132px;
                            height: parent.height;
                            text: "Custom hex";
                            color: ThemePalette.text;
                            font-size: 13px;
                            vertical-alignment: center;
                        }
                        LineEdit {
                            x: 150px;
                            y: 7px;
                            width: 132px;
                            height: 28px;
                            text: root.custom_accent_hex;
                            font-family: AppMetrics.mono_font;
                            font-size: 12px;
                            placeholder-text: "#4f9cff";
                            edited(val) => { root.custom_accent_changed(val); }
                        }
                        Rectangle {
                            x: 292px;
                            y: 11px;
                            width: 22px;
                            height: 22px;
                            border-radius: 11px;
                            background: root.active_accent == "custom" ? ThemePalette.accent : ThemePalette.border_strong;
                            border-width: 1px;
                            border-color: ThemePalette.border_strong;
                        }
                    }

                    Text { text: "FOLDER COLOR"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        width: parent.width;
                        height: 76px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; y: 10px; width: 130px; height: 30px; text: "Folder color"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                        LineEdit {
                            x: 150px;
                            y: 10px;
                            width: 140px;
                            height: 28px;
                            text: root.folder_color_hex;
                            font-family: AppMetrics.mono_font;
                            font-size: 12px;
                            placeholder-text: "#e2a934";
                            edited(val) => { root.folder_color_changed(val); }
                        }
                        Rectangle {
                            x: 300px;
                            y: 12px;
                            width: 26px;
                            height: 26px;
                            border-radius: 13px;
                            background: ThemePalette.icon_folder_2;
                            border-width: 1px;
                            border-color: ThemePalette.border_strong;
                        }
                        Text { x: 14px; y: 44px; width: 90px; height: 22px; text: "Presets"; color: ThemePalette.text_faint; font-size: 11px; vertical-alignment: center; }
                        Rectangle { x: 104px; y: 46px; width: 22px; height: 22px; border-radius: 11px; background: #e2a934; border-width: 1px; border-color: ThemePalette.border_strong; TouchArea { mouse-cursor: pointer; clicked => { root.folder_color_changed("#e2a934"); } } }
                        Rectangle { x: 134px; y: 46px; width: 22px; height: 22px; border-radius: 11px; background: #4f9cff; border-width: 1px; border-color: ThemePalette.border_strong; TouchArea { mouse-cursor: pointer; clicked => { root.folder_color_changed("#4f9cff"); } } }
                        Rectangle { x: 164px; y: 46px; width: 22px; height: 22px; border-radius: 11px; background: #2aa96b; border-width: 1px; border-color: ThemePalette.border_strong; TouchArea { mouse-cursor: pointer; clicked => { root.folder_color_changed("#2aa96b"); } } }
                        Rectangle { x: 194px; y: 46px; width: 22px; height: 22px; border-radius: 11px; background: #8b6cff; border-width: 1px; border-color: ThemePalette.border_strong; TouchArea { mouse-cursor: pointer; clicked => { root.folder_color_changed("#8b6cff"); } } }
                        Rectangle { x: 224px; y: 46px; width: 22px; height: 22px; border-radius: 11px; background: #e45578; border-width: 1px; border-color: ThemePalette.border_strong; TouchArea { mouse-cursor: pointer; clicked => { root.folder_color_changed("#e45578"); } } }
                        Rectangle { x: 254px; y: 46px; width: 22px; height: 22px; border-radius: 11px; background: #1aa6a6; border-width: 1px; border-color: ThemePalette.border_strong; TouchArea { mouse-cursor: pointer; clicked => { root.folder_color_changed("#1aa6a6"); } } }
                        Rectangle { x: 284px; y: 46px; width: 22px; height: 22px; border-radius: 11px; background: #c46f34; border-width: 1px; border-color: ThemePalette.border_strong; TouchArea { mouse-cursor: pointer; clicked => { root.folder_color_changed("#c46f34"); } } }
                        Rectangle { x: 314px; y: 46px; width: 22px; height: 22px; border-radius: 11px; background: #cfd5dc; border-width: 1px; border-color: ThemePalette.border_strong; TouchArea { mouse-cursor: pointer; clicked => { root.folder_color_changed("#cfd5dc"); } } }
                    }

                    Text { text: "DENSITY"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    // Stacked vertical layout instead of a 3-up grid. Cozy /
                    // Comfortable / Compact descriptions ran into each other
                    // at narrow widths because each tile was only ~196 px
                    // wide. Full-width rows give labels room to breathe and
                    // the descriptions can elide cleanly when needed.
                    Rectangle {
                        width: parent.width;
                        height: root.density_choices.length * (AppMetrics.row_h + 6px);
                        for density[i] in root.density_choices: ChoiceChip {
                            x: 0;
                            y: i * (AppMetrics.row_h + 6px);
                            width: parent.width;
                            item: density;
                            active: root.active_density == density.id;
                            picked(id) => { root.density_selected(id); }
                        }
                    }

                    Text { text: "INTERFACE MODE"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    HorizontalLayout {
                        spacing: 6px;
                        width: parent.width;
                        for mode_label[mi] in ["Simple", "Normal"]: Rectangle {
                            width: (parent.width - 6px) / 2;
                            height: AppMetrics.row_h;
                            property <string> mode_id: mi == 0 ? "simple" : "normal";
                            border-width: 1px;
                            border-color: root.ui_mode == self.mode_id ? ThemePalette.accent : ThemePalette.border;
                            border-radius: AppMetrics.radius;
                            background: root.ui_mode == self.mode_id ? ThemePalette.accent_soft : ThemePalette.panel;
                            Text {
                                width: parent.width;
                                height: parent.height;
                                text: mode_label;
                                color: root.ui_mode == parent.mode_id ? ThemePalette.accent_strong : ThemePalette.text_muted;
                                font-size: 13px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                            mode_touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.ui_mode = mode_id; root.set_ui_mode(mode_id); }
                            }
                        }
                    }
                    Text {
                        text: root.ui_mode == "simple" ? "Essential features only - hides dual pane, power tools, advanced menu, and AI settings." : "Full access to every feature including dual pane, power tools, and AI.";
                        color: ThemePalette.text_faint;
                        font-size: 11.5px;
                        wrap: word-wrap;
                        height: self.preferred-height;
                    }

                    Text { text: "CUSTOM THEME"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }

                    // Build a custom theme below; Save adds it to the theme picker as Custom.
                    Text {
                        text: "Build a theme here, then Save. It appears above as Custom. Pick a color token, adjust hex or swatches, and watch the mini window below (it uses only your token colors, not the rest of Settings).";
                        color: ThemePalette.text_faint;
                        font-size: 11.5px;
                        wrap: word-wrap;
                        height: self.preferred-height;
                    }

                    // Saved themes
                    Text { text: "SAVED THEMES"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        clip: true;
                        if root.ce_saved_themes.length == 0: Text {
                            x: 14px;
                            width: parent.width - 28px;
                            height: parent.height;
                            text: "No saved themes yet";
                            color: ThemePalette.text_faint;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                        for saved_name[ni] in root.ce_saved_themes: Rectangle {
                            x: 8px + ni * (saved_chip_text.preferred-width + 28px);
                            y: 7px;
                            height: 24px;
                            width: saved_chip_text.preferred-width + 20px;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: ThemePalette.border_strong;
                            background: saved_chip_ta.has-hover ? ThemePalette.panel_alt : ThemePalette.panel_solid;
                            saved_chip_text := Text {
                                x: 8px;
                                width: parent.width - 16px;
                                height: parent.height;
                                text: saved_name;
                                color: ThemePalette.text_muted;
                                font-size: 11.5px;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                            saved_chip_ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.ce_load(saved_name); }
                            }
                        }
                    }

                    // Name
                    Text { text: "THEME NAME"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    LineEdit {
                        height: 34px;
                        text: root.ce_name;
                        placeholder-text: "My Theme";
                        font-size: 13px;
                        edited(val) => { root.ce_name = val; root.ce_apply_preview(); }
                    }

                    // Live preview
                    Text { text: "LIVE PREVIEW"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        height: 142px;
                        border-radius: Math.max(2px, root.ce_radius * 1px);
                        border-width: 1px;
                        border-color: root.ce_token_colors.length > 4 ? root.ce_token_colors[4] : ThemePalette.border_strong;
                        background: root.ce_gradient_background && root.ce_token_colors.length > 1
                            ? (root.ce_gradient_accent && root.ce_token_colors.length > 8
                                ? @linear-gradient(165deg, root.ce_token_colors[1] 0%, root.ce_token_colors[0] 42%, root.ce_token_colors[8] 100%)
                                : @linear-gradient(165deg, root.ce_token_colors[1] 0%, root.ce_token_colors[0] 100%))
                            : (root.ce_token_colors.length > 0 ? root.ce_token_colors[0] : ThemePalette.bg);
                        clip: true;

                        Rectangle {
                            x: 12px;
                            y: 12px;
                            width: parent.width - 24px;
                            height: parent.height - 24px;
                            border-radius: Math.max(2px, root.ce_radius * 1px);
                            border-width: 1px;
                            border-color: root.ce_token_colors.length > 3 ? root.ce_token_colors[3] : ThemePalette.border;
                            background: root.ce_token_colors.length > 2 ? root.ce_token_colors[2] : ThemePalette.panel;
                        }

                        Rectangle {
                            x: 12px;
                            y: 12px;
                            width: parent.width - 24px;
                            height: 30px;
                            background: root.ce_token_colors.length > 1 ? root.ce_token_colors[1] : ThemePalette.bg_soft;
                            Text {
                                x: 12px;
                                width: 170px;
                                height: parent.height;
                                text: root.ce_name == "" ? "Custom Theme" : root.ce_name;
                                color: root.ce_token_colors.length > 5 ? root.ce_token_colors[5] : ThemePalette.text;
                                font-family: root.ce_preview_ui_font;
                                font-size: 12px;
                                font-weight: 700;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                            Rectangle {
                                x: parent.width - 78px;
                                y: 7px;
                                width: 58px;
                                height: 16px;
                                border-radius: 8px;
                                background: root.ce_token_colors.length > 8 ? root.ce_token_colors[8] : ThemePalette.accent;
                            }
                        }

                        Rectangle {
                            x: 28px;
                            y: 58px;
                            width: 150px;
                            height: 56px;
                            border-radius: Math.max(2px, root.ce_radius * 1px);
                            background: root.ce_token_colors.length > 1 ? root.ce_token_colors[1] : ThemePalette.bg_soft;
                            Text { x: 12px; y: 8px; width: parent.width - 24px; height: 18px; text: "Sidebar Item"; color: root.ce_token_colors.length > 6 ? root.ce_token_colors[6] : ThemePalette.text_muted; font-family: root.ce_preview_ui_font; font-size: 12px; overflow: elide; }
                            Rectangle { x: 12px; y: 34px; width: parent.width - 24px; height: 8px; border-radius: 4px; background: root.ce_token_colors.length > 8 ? root.ce_token_colors[8] : ThemePalette.accent; }
                        }

                        Rectangle {
                            x: 196px;
                            y: 58px;
                            width: parent.width - 230px;
                            height: 56px;
                            border-radius: Math.max(2px, root.ce_radius * 1px);
                            border-width: 1px;
                            border-color: root.ce_token_colors.length > 3 ? root.ce_token_colors[3] : ThemePalette.border;
                            background: root.ce_token_colors.length > 2 ? root.ce_token_colors[2] : ThemePalette.panel;
                            NodeVisual { x: 12px; y: 10px; visual_width: 34px; visual_height: 28px; is_dir: true; extension: ""; }
                            Text { x: 56px; y: 8px; width: parent.width - 70px; height: 18px; text: "Long filename preview.txt"; color: root.ce_token_colors.length > 5 ? root.ce_token_colors[5] : ThemePalette.text; font-family: root.ce_preview_ui_font; font-size: 12px; overflow: elide; }
                            Text { x: 56px; y: 30px; width: parent.width - 70px; height: 16px; text: "12.4 MB - modified today"; color: root.ce_token_colors.length > 7 ? root.ce_token_colors[7] : ThemePalette.text_faint; font-family: root.ce_preview_mono_font; font-size: 10.5px; overflow: elide; }
                        }
                    }

                    // Colors
                    Text { text: "COLORS"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Text {
                        text: "Jump to a token, then use swatches or hex.";
                        color: ThemePalette.text_faint;
                        font-size: 11px;
                    }
                    HorizontalLayout {
                        spacing: 6px;
                        height: 30px;
                        Text { text: "Jump:"; color: ThemePalette.text_muted; font-size: 11px; vertical-alignment: center; }
                        Rectangle {
                            width: 44px;
                            height: 26px;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: root.ce_selected_token == 0 ? ThemePalette.accent : ThemePalette.border;
                            background: root.ce_selected_token == 0 ? ThemePalette.accent_soft : ThemePalette.panel_solid;
                            Text { width: parent.width; height: parent.height; text: "Bg"; color: root.ce_selected_token == 0 ? ThemePalette.accent_strong : ThemePalette.text_muted; font-size: 11px; vertical-alignment: center; horizontal-alignment: center; }
                            TouchArea { mouse-cursor: pointer; clicked => { root.ce_select_token(0); } }
                        }
                        Rectangle {
                            width: 64px;
                            height: 26px;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: root.ce_selected_token == 1 ? ThemePalette.accent : ThemePalette.border;
                            background: root.ce_selected_token == 1 ? ThemePalette.accent_soft : ThemePalette.panel_solid;
                            Text { width: parent.width; height: parent.height; text: "Surface"; color: root.ce_selected_token == 1 ? ThemePalette.accent_strong : ThemePalette.text_muted; font-size: 11px; vertical-alignment: center; horizontal-alignment: center; }
                            TouchArea { mouse-cursor: pointer; clicked => { root.ce_select_token(1); } }
                        }
                        Rectangle {
                            width: 52px;
                            height: 26px;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: root.ce_selected_token == 2 ? ThemePalette.accent : ThemePalette.border;
                            background: root.ce_selected_token == 2 ? ThemePalette.accent_soft : ThemePalette.panel_solid;
                            Text { width: parent.width; height: parent.height; text: "Panel"; color: root.ce_selected_token == 2 ? ThemePalette.accent_strong : ThemePalette.text_muted; font-size: 11px; vertical-alignment: center; horizontal-alignment: center; }
                            TouchArea { mouse-cursor: pointer; clicked => { root.ce_select_token(2); } }
                        }
                        Rectangle {
                            width: 58px;
                            height: 26px;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: root.ce_selected_token == 8 ? ThemePalette.accent : ThemePalette.border;
                            background: root.ce_selected_token == 8 ? ThemePalette.accent_soft : ThemePalette.panel_solid;
                            Text { width: parent.width; height: parent.height; text: "Accent"; color: root.ce_selected_token == 8 ? ThemePalette.accent_strong : ThemePalette.text_muted; font-size: 11px; vertical-alignment: center; horizontal-alignment: center; }
                            TouchArea { mouse-cursor: pointer; clicked => { root.ce_select_token(8); } }
                        }
                    }
                    HorizontalLayout {
                        height: 44px;
                        spacing: 8px;
                        alignment: start;
                        padding-top: 8px;
                        padding-bottom: 8px;
                        for col[ci] in root.ce_token_colors: Rectangle {
                            width: 28px;
                            border-radius: 14px;
                            background: col;
                            border-width: root.ce_selected_token == ci ? 2px : 1px;
                            border-color: root.ce_selected_token == ci ? ThemePalette.accent : ThemePalette.border_strong;
                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.ce_select_token(ci); }
                            }
                        }
                    }
                    if root.ce_selected_token >= 0: Rectangle {
                        height: 34px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 12px; width: 96px; height: parent.height; text: "Quick colors"; color: ThemePalette.text_muted; font-size: 12px; vertical-alignment: center; }
                        Rectangle { x: 112px; y: 7px; width: 20px; height: 20px; border-radius: 10px; background: #101318; TouchArea { mouse-cursor: pointer; clicked => { root.ce_color_changed(root.ce_selected_token, "#101318"); } } }
                        Rectangle { x: 140px; y: 7px; width: 20px; height: 20px; border-radius: 10px; background: #f6f8fb; TouchArea { mouse-cursor: pointer; clicked => { root.ce_color_changed(root.ce_selected_token, "#f6f8fb"); } } }
                        Rectangle { x: 168px; y: 7px; width: 20px; height: 20px; border-radius: 10px; background: #4f9cff; TouchArea { mouse-cursor: pointer; clicked => { root.ce_color_changed(root.ce_selected_token, "#4f9cff"); } } }
                        Rectangle { x: 196px; y: 7px; width: 20px; height: 20px; border-radius: 10px; background: #8b6cff; TouchArea { mouse-cursor: pointer; clicked => { root.ce_color_changed(root.ce_selected_token, "#8b6cff"); } } }
                        Rectangle { x: 224px; y: 7px; width: 20px; height: 20px; border-radius: 10px; background: #e45578; TouchArea { mouse-cursor: pointer; clicked => { root.ce_color_changed(root.ce_selected_token, "#e45578"); } } }
                        Rectangle { x: 252px; y: 7px; width: 20px; height: 20px; border-radius: 10px; background: #d98a24; TouchArea { mouse-cursor: pointer; clicked => { root.ce_color_changed(root.ce_selected_token, "#d98a24"); } } }
                        Rectangle { x: 280px; y: 7px; width: 20px; height: 20px; border-radius: 10px; background: #2aa96b; TouchArea { mouse-cursor: pointer; clicked => { root.ce_color_changed(root.ce_selected_token, "#2aa96b"); } } }
                        Rectangle { x: 308px; y: 7px; width: 20px; height: 20px; border-radius: 10px; background: #1aa6a6; TouchArea { mouse-cursor: pointer; clicked => { root.ce_color_changed(root.ce_selected_token, "#1aa6a6"); } } }
                        Rectangle { x: 336px; y: 7px; width: 20px; height: 20px; border-radius: 10px; background: #f2f6fb; TouchArea { mouse-cursor: pointer; clicked => { root.ce_color_changed(root.ce_selected_token, "#f2f6fb"); } } }
                        Rectangle { x: 364px; y: 7px; width: 20px; height: 20px; border-radius: 10px; background: #19202a; TouchArea { mouse-cursor: pointer; clicked => { root.ce_color_changed(root.ce_selected_token, "#19202a"); } } }
                    }
                    if root.ce_selected_token >= 0: Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text {
                            x: 14px;
                            width: 136px;
                            height: parent.height;
                            text: root.ce_token_label;
                            color: ThemePalette.text;
                            font-size: 13px;
                            overflow: elide;
                            vertical-alignment: center;
                        }
                        LineEdit {
                            x: 158px;
                            y: 6px;
                            width: 130px;
                            height: 26px;
                            text: root.ce_token_hex;
                            font-family: AppMetrics.mono_font;
                            font-size: 12px;
                            placeholder-text: "#rrggbb";
                            edited(val) => { root.ce_color_changed(root.ce_selected_token, val); }
                        }
                        Rectangle {
                            x: parent.width - 46px;
                            y: 7px;
                            width: 24px;
                            height: 24px;
                            border-radius: 12px;
                            background: root.ce_token_colors.length > root.ce_selected_token && root.ce_selected_token >= 0
                                ? root.ce_token_colors[root.ce_selected_token]
                                : ThemePalette.border_strong;
                            border-width: 1px;
                            border-color: ThemePalette.border_strong;
                        }
                    }

                    // Feel
                    Text { text: "FEEL"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; width: 140px; height: parent.height; text: "Corner radius"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                        Slider {
                            x: 158px;
                            y: 9px;
                            width: parent.width - 230px;
                            height: 20px;
                            minimum: 0;
                            maximum: 16;
                            value: root.ce_radius;
                            changed(v) => { root.ce_radius_changed(v); }
                        }
                        Text {
                            x: parent.width - 60px;
                            width: 50px;
                            height: parent.height;
                            text: Math.round(root.ce_radius) + "px";
                            color: ThemePalette.text_muted;
                            font-family: AppMetrics.mono_font;
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                    }
                    Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; width: 130px; height: parent.height; text: "Animations"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                        HorizontalLayout {
                            x: 148px;
                            y: 6px;
                            width: parent.width - 162px;
                            height: parent.height - 12px;
                            spacing: 4px;
                            for speed_label[si] in ["Off", "Fast", "Normal", "Slow"]: Rectangle {
                                property <float> sv: si == 0 ? 0.0 : (si == 1 ? 0.5 : (si == 2 ? 1.0 : 2.0));
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: root.ce_anim_speed == self.sv ? ThemePalette.accent : ThemePalette.border;
                                background: root.ce_anim_speed == self.sv ? ThemePalette.accent_soft : ThemePalette.panel_solid;
                                Text {
                                    width: parent.width;
                                    height: parent.height;
                                    text: speed_label;
                                    color: root.ce_anim_speed == parent.sv ? ThemePalette.accent_strong : ThemePalette.text_muted;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                TouchArea { mouse-cursor: pointer; clicked => { root.ce_anim_changed(sv); } }
                            }
                        }
                    }
                    Text { text: "BACKGROUND STYLE"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Text {
                        text: "Gradient blends Background and Surface from top to bottom for a soft sky look. Solid uses the Background color edge to edge.";
                        color: ThemePalette.text_muted;
                        font-size: 11.5px;
                        wrap: word-wrap;
                        height: self.preferred-height;
                    }
                    Rectangle {
                        height: 42px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        HorizontalLayout {
                            x: 8px;
                            y: 6px;
                            width: parent.width - 16px;
                            height: parent.height - 12px;
                            spacing: 8px;
                            Rectangle {
                                border-radius: 5px;
                                border-width: 1px;
                                border-color: !root.ce_gradient_background ? ThemePalette.accent : ThemePalette.border;
                                background: !root.ce_gradient_background ? ThemePalette.accent_soft : ThemePalette.panel_solid;
                                horizontal-stretch: 1;
                                Text {
                                    width: parent.width;
                                    height: parent.height;
                                    text: "Solid";
                                    color: !root.ce_gradient_background ? ThemePalette.accent_strong : ThemePalette.text_muted;
                                    font-size: 12.5px;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                TouchArea { mouse-cursor: pointer; clicked => { root.ce_gradient_changed(false); } }
                            }
                            Rectangle {
                                border-radius: 5px;
                                border-width: 1px;
                                border-color: root.ce_gradient_background ? ThemePalette.accent : ThemePalette.border;
                                background: root.ce_gradient_background ? ThemePalette.accent_soft : ThemePalette.panel_solid;
                                horizontal-stretch: 1;
                                Text {
                                    width: parent.width;
                                    height: parent.height;
                                    text: "Gradient";
                                    color: root.ce_gradient_background ? ThemePalette.accent_strong : ThemePalette.text_muted;
                                    font-size: 12.5px;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                TouchArea { mouse-cursor: pointer; clicked => { root.ce_gradient_changed(true); } }
                            }
                        }
                    }
                    if root.ce_gradient_background: Rectangle {
                        height: 40px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text {
                            x: 14px;
                            y: 0;
                            width: parent.width - 28px;
                            height: parent.height;
                            text: "Blend accent into the background gradient (bottom glow).";
                            color: ThemePalette.text_muted;
                            font-size: 11.5px;
                            vertical-alignment: center;
                            wrap: word-wrap;
                        }
                        Rectangle {
                            x: parent.width - 52px;
                            y: (parent.height - 22px) / 2;
                            width: 40px;
                            height: 22px;
                            border-radius: 11px;
                            background: root.ce_gradient_accent ? ThemePalette.accent : ThemePalette.border_strong;
                            Rectangle {
                                x: root.ce_gradient_accent ? 20px : 2px;
                                y: 2px;
                                width: 18px;
                                height: 18px;
                                border-radius: 9px;
                                background: white;
                            }
                            TouchArea { mouse-cursor: pointer; clicked => { root.ce_gradient_accent_changed(!root.ce_gradient_accent); } }
                        }
                    }

                    // Finish
                    Text { text: "FINISH"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    HorizontalLayout {
                        height: 38px;
                        spacing: 6px;
                        for finish_label[fi] in ["Mica Dark", "Mica Light", "Flat", "Solid"]: Rectangle {
                            property <string> fid: fi == 0 ? "mica-dark" : (fi == 1 ? "mica-light" : (fi == 2 ? "flat" : "solid"));
                            border-radius: AppMetrics.radius_small;
                            border-width: 1px;
                            border-color: root.ce_finish == self.fid ? ThemePalette.accent : ThemePalette.border;
                            background: root.ce_finish == self.fid ? ThemePalette.accent_soft : ThemePalette.panel;
                            Text {
                                width: parent.width;
                                height: parent.height;
                                text: finish_label;
                                color: root.ce_finish == parent.fid ? ThemePalette.accent_strong : ThemePalette.text_muted;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            TouchArea { mouse-cursor: pointer; clicked => { root.ce_finish_changed(fid); } }
                        }
                    }

                    // Typography (bundled fonts only)
                    Text { text: "Typography"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Text {
                        text: "Fonts ship inside Pathfinder so the UI always matches your pick (no reliance on Windows font names).";
                        color: ThemePalette.text_muted;
                        font-size: 11.5px;
                        wrap: word-wrap;
                        height: self.preferred-height;
                    }
                    Text { text: "UI FONT"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    HorizontalLayout {
                        spacing: 6px;
                        height: 34px;
                        Rectangle {
                            border-radius: 5px;
                            border-width: 1px;
                            border-color: root.ce_ui_font == "noto-sans" ? ThemePalette.accent : ThemePalette.border;
                            background: root.ce_ui_font == "noto-sans" ? ThemePalette.accent_soft : ThemePalette.panel_solid;
                            horizontal-stretch: 1;
                            Text { width: parent.width; height: parent.height; text: "Noto Sans"; color: root.ce_ui_font == "noto-sans" ? ThemePalette.accent_strong : ThemePalette.text_muted; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; font-family: "Noto Sans"; }
                            TouchArea { mouse-cursor: pointer; clicked => { root.ce_font_preset("ui", "noto-sans"); } }
                        }
                        Rectangle {
                            border-radius: 5px;
                            border-width: 1px;
                            border-color: root.ce_ui_font == "inter" ? ThemePalette.accent : ThemePalette.border;
                            background: root.ce_ui_font == "inter" ? ThemePalette.accent_soft : ThemePalette.panel_solid;
                            horizontal-stretch: 1;
                            Text { width: parent.width; height: parent.height; text: "Inter"; color: root.ce_ui_font == "inter" ? ThemePalette.accent_strong : ThemePalette.text_muted; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; font-family: "Inter"; }
                            TouchArea { mouse-cursor: pointer; clicked => { root.ce_font_preset("ui", "inter"); } }
                        }
                        Rectangle {
                            border-radius: 5px;
                            border-width: 1px;
                            border-color: root.ce_ui_font == "lora" ? ThemePalette.accent : ThemePalette.border;
                            background: root.ce_ui_font == "lora" ? ThemePalette.accent_soft : ThemePalette.panel_solid;
                            horizontal-stretch: 1;
                            Text { width: parent.width; height: parent.height; text: "Lora"; color: root.ce_ui_font == "lora" ? ThemePalette.accent_strong : ThemePalette.text_muted; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; font-family: "Lora"; }
                            TouchArea { mouse-cursor: pointer; clicked => { root.ce_font_preset("ui", "lora"); } }
                        }
                    }
                    Text { text: "MONO FONT"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    HorizontalLayout {
                        spacing: 6px;
                        height: 34px;
                        Rectangle {
                            border-radius: 5px;
                            border-width: 1px;
                            border-color: root.ce_mono_font == "noto-sans-mono" ? ThemePalette.accent : ThemePalette.border;
                            background: root.ce_mono_font == "noto-sans-mono" ? ThemePalette.accent_soft : ThemePalette.panel_solid;
                            horizontal-stretch: 1;
                            Text { width: parent.width; height: parent.height; text: "Noto Sans Mono"; color: root.ce_mono_font == "noto-sans-mono" ? ThemePalette.accent_strong : ThemePalette.text_muted; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; font-family: "Noto Sans Mono"; }
                            TouchArea { mouse-cursor: pointer; clicked => { root.ce_font_preset("mono", "noto-sans-mono"); } }
                        }
                        Rectangle {
                            border-radius: 5px;
                            border-width: 1px;
                            border-color: root.ce_mono_font == "jetbrains-mono" ? ThemePalette.accent : ThemePalette.border;
                            background: root.ce_mono_font == "jetbrains-mono" ? ThemePalette.accent_soft : ThemePalette.panel_solid;
                            horizontal-stretch: 1;
                            Text { width: parent.width; height: parent.height; text: "JetBrains Mono"; color: root.ce_mono_font == "jetbrains-mono" ? ThemePalette.accent_strong : ThemePalette.text_muted; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; font-family: "JetBrains Mono"; }
                            TouchArea { mouse-cursor: pointer; clicked => { root.ce_font_preset("mono", "jetbrains-mono"); } }
                        }
                        Rectangle {
                            border-radius: 5px;
                            border-width: 1px;
                            border-color: root.ce_mono_font == "fira-code" ? ThemePalette.accent : ThemePalette.border;
                            background: root.ce_mono_font == "fira-code" ? ThemePalette.accent_soft : ThemePalette.panel_solid;
                            horizontal-stretch: 1;
                            Text { width: parent.width; height: parent.height; text: "Fira Code"; color: root.ce_mono_font == "fira-code" ? ThemePalette.accent_strong : ThemePalette.text_muted; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; font-family: "Fira Code"; }
                            TouchArea { mouse-cursor: pointer; clicked => { root.ce_font_preset("mono", "fira-code"); } }
                        }
                    }
                    Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; width: 100px; height: parent.height; text: "Size"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                        HorizontalLayout {
                            x: 114px;
                            y: 6px;
                            width: parent.width - 128px;
                            height: parent.height - 12px;
                            spacing: 4px;
                            for size_label[sz] in ["Small", "Normal", "Large"]: Rectangle {
                                property <int> sdv: sz - 1;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: root.ce_font_size_delta == self.sdv ? ThemePalette.accent : ThemePalette.border;
                                background: root.ce_font_size_delta == self.sdv ? ThemePalette.accent_soft : ThemePalette.panel_solid;
                                Text {
                                    width: parent.width;
                                    height: parent.height;
                                    text: size_label;
                                    color: root.ce_font_size_delta == parent.sdv ? ThemePalette.accent_strong : ThemePalette.text_muted;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                TouchArea { mouse-cursor: pointer; clicked => { root.ce_font_size_changed(sdv); } }
                            }
                        }
                    }

                    // Icons
                    Text { text: "ICONS"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        height: 72px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; y: 0; width: 120px; height: 38px; text: "Folder color"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                        LineEdit {
                            x: 134px;
                            y: 6px;
                            width: 130px;
                            height: 26px;
                            text: root.ce_icon_folder_hex;
                            font-family: AppMetrics.mono_font;
                            font-size: 12px;
                            placeholder-text: "#e2a934";
                            edited(val) => { root.ce_icon_tint_changed(val); }
                        }
                        Rectangle {
                            x: parent.width - 46px;
                            y: 7px;
                            width: 24px;
                            height: 24px;
                            border-radius: 12px;
                            background: ThemePalette.icon_folder_2;
                            border-width: 1px;
                            border-color: ThemePalette.border_strong;
                        }
                        Text { x: 14px; y: 41px; width: 90px; height: 20px; text: "Presets"; color: ThemePalette.text_faint; font-size: 11px; vertical-alignment: center; }
                        Rectangle { x: 104px; y: 42px; width: 20px; height: 20px; border-radius: 10px; background: #e2a934; TouchArea { mouse-cursor: pointer; clicked => { root.ce_icon_tint_changed("#e2a934"); } } }
                        Rectangle { x: 132px; y: 42px; width: 20px; height: 20px; border-radius: 10px; background: #4f9cff; TouchArea { mouse-cursor: pointer; clicked => { root.ce_icon_tint_changed("#4f9cff"); } } }
                        Rectangle { x: 160px; y: 42px; width: 20px; height: 20px; border-radius: 10px; background: #2aa96b; TouchArea { mouse-cursor: pointer; clicked => { root.ce_icon_tint_changed("#2aa96b"); } } }
                        Rectangle { x: 188px; y: 42px; width: 20px; height: 20px; border-radius: 10px; background: #8b6cff; TouchArea { mouse-cursor: pointer; clicked => { root.ce_icon_tint_changed("#8b6cff"); } } }
                        Rectangle { x: 216px; y: 42px; width: 20px; height: 20px; border-radius: 10px; background: #e45578; TouchArea { mouse-cursor: pointer; clicked => { root.ce_icon_tint_changed("#e45578"); } } }
                        Rectangle { x: 244px; y: 42px; width: 20px; height: 20px; border-radius: 10px; background: #1aa6a6; TouchArea { mouse-cursor: pointer; clicked => { root.ce_icon_tint_changed("#1aa6a6"); } } }
                    }
                    Rectangle {
                        height: 38px;
                        border-radius: AppMetrics.radius_small;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; width: 100px; height: parent.height; text: "Icon set"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                        LineEdit {
                            x: 114px;
                            y: 6px;
                            width: parent.width - 128px;
                            height: 26px;
                            text: root.ce_icon_set;
                            placeholder-text: "Path to icon set folder...";
                            font-size: 11.5px;
                            edited(val) => { root.ce_icon_set = val; }
                        }
                    }

                    // Actions
                    HorizontalLayout {
                        height: 36px;
                        spacing: 8px;
                        alignment: end;
                        DialogButton {
                            label: "Reset";
                            clicked => { root.ce_reset_to_active(); }
                        }
                        DialogButton {
                            label: "Delete";
                            danger: true;
                            visible: root.ce_saved_themes.length > 0;
                            clicked => { root.ce_delete(root.ce_name); }
                        }
                        DialogButton {
                            label: "Save Theme";
                            primary: true;
                            clicked => { root.ce_save(root.ce_name); }
                        }
                    }
                }
            }

            if root.settings_tab == "view": ScrollView {
                x: 20px;
                y: 124px;
                width: parent.width - 40px;
                height: parent.height - 136px;

                VerticalLayout {
                width: parent.width - 20px;
                spacing: 12px;
                padding-bottom: 16px;

                Text { text: "DEFAULT VIEW MODE"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                Text {
                    text: "Pathfinder remembers this for every folder you open until you change the view from the toolbar.";
                    color: ThemePalette.text_muted;
                    font-size: 11.5px;
                    wrap: word-wrap;
                    height: self.preferred-height;
                }
                HorizontalLayout {
                    spacing: 8px;
                    width: parent.width;
                    for vm_label[vi] in ["Grid", "Compact", "List", "Gallery"]: Rectangle {
                        width: (parent.width - 24px) / 4;
                        height: AppMetrics.row_h;
                        property <string> vm_id: vi == 0 ? "grid" : (vi == 1 ? "compact" : (vi == 2 ? "list" : "gallery"));
                        border-width: 1px;
                        border-color: root.view_mode == self.vm_id ? ThemePalette.accent : ThemePalette.border;
                        border-radius: AppMetrics.radius;
                        background: root.view_mode == self.vm_id ? ThemePalette.accent_soft : ThemePalette.panel;
                        Text {
                            width: parent.width;
                            height: parent.height;
                            text: vm_label;
                            color: root.view_mode == parent.vm_id ? ThemePalette.accent_strong : ThemePalette.text_muted;
                            font-size: 13px;
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                        TouchArea { mouse-cursor: pointer; clicked => { root.set_view(vm_id); } }
                    }
                }

                Text { text: "OPTIONS"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                Rectangle {
                    height: AppMetrics.row_h;
                    border-radius: AppMetrics.radius;
                    background: ThemePalette.panel;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    Text { x: 14px; width: parent.width - 60px; height: parent.height; text: "Show hidden files"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                    Rectangle {
                        x: parent.width - 52px;
                        y: (parent.height - 22px) / 2;
                        width: 40px;
                        height: 22px;
                        border-radius: 11px;
                        background: root.show_hidden ? ThemePalette.accent : ThemePalette.border_strong;
                        animate background { duration: 60ms; easing: ease-out; }
                        Rectangle {
                            x: root.show_hidden ? 20px : 2px;
                            y: 2px;
                            width: 18px;
                            height: 18px;
                            border-radius: 9px;
                            background: white;
                            animate x { duration: 60ms; easing: ease-out; }
                        }
                        TouchArea { mouse-cursor: pointer; clicked => { root.toggle_hidden(); } }
                    }
                }
                Rectangle {
                    height: AppMetrics.row_h;
                    border-radius: AppMetrics.radius;
                    background: ThemePalette.panel;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    Text { x: 14px; width: parent.width - 60px; height: parent.height; text: "Show preview panel"; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                    Rectangle {
                        x: parent.width - 52px;
                        y: (parent.height - 22px) / 2;
                        width: 40px;
                        height: 22px;
                        border-radius: 11px;
                        background: root.preview_visible ? ThemePalette.accent : ThemePalette.border_strong;
                        animate background { duration: 60ms; easing: ease-out; }
                        Rectangle {
                            x: root.preview_visible ? 20px : 2px;
                            y: 2px;
                            width: 18px;
                            height: 18px;
                            border-radius: 9px;
                            background: white;
                            animate x { duration: 60ms; easing: ease-out; }
                        }
                        TouchArea { mouse-cursor: pointer; clicked => { root.toggle_preview(); } }
                    }
                }

                if root.show_windows_integration: VerticalLayout {
                    spacing: 10px;
                    Text { text: "WINDOWS INTEGRATION"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Text {
                        text: "Registers Pathfinder for your user account only (HKCU). Double-clicking a folder in Explorer opens it in Pathfinder. This does not replace every Explorer surface on Windows 11.";
                        color: ThemePalette.text_muted;
                        font-size: 11.5px;
                        wrap: word-wrap;
                        height: self.preferred-height;
                    }
                    HorizontalLayout {
                        spacing: 10px;
                        height: 36px;
                        alignment: start;
                        DialogButton {
                            label: "Set as default folder handler";
                            primary: true;
                            clicked => { root.windows_set_default_folder_handler(); }
                        }
                        DialogButton {
                            label: "Restore Explorer defaults";
                            clicked => { root.windows_restore_folder_handler(); }
                        }
                    }
                    Text {
                        text: "Alternative: import extras/set-pathfinder-default-folder-handler.reg and replace CHANGEME_EXE with your pathfinder.exe path.";
                        color: ThemePalette.text_faint;
                        font-size: 11px;
                        wrap: word-wrap;
                        height: self.preferred-height;
                    }
                }
                }
            }

            if root.settings_tab == "performance": ScrollView {
                x: 20px;
                y: 124px;
                width: parent.width - 40px;
                height: parent.height - 136px;

                VerticalLayout {
                    width: parent.width - 20px;
                    spacing: 14px;
                    padding-bottom: 16px;

                    Text { text: "SEARCH PERFORMANCE"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Text {
                        text: root.performance_intro;
                        color: ThemePalette.text_muted;
                        font-size: 12px;
                        wrap: word-wrap;
                        width: parent.width;
                        height: self.preferred-height;
                    }
                    Rectangle {
                        width: parent.width;
                        height: Math.ceil(root.index_choices.length / 2) * AppMetrics.index_chip_row_stride;
                        for mode[i] in root.index_choices: ChoiceChip {
                            x: Math.mod(i, 2) == 0 ? 0px : (parent.width / 2 + 3px);
                            y: Math.floor(i / 2) * AppMetrics.index_chip_row_stride;
                            width: parent.width / 2 - 3px;
                            item: mode;
                            active: root.active_index_mode == mode.id;
                            picked(id) => { root.index_mode_selected(id); }
                        }
                    }

                    Rectangle {
                        height: 92px;
                        border-radius: AppMetrics.radius;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; y: 12px; width: parent.width - 28px; height: 20px; text: "Index estimate"; color: ThemePalette.text; font-size: 13px; font-weight: 700; }
                        Text { x: 14px; y: 36px; width: parent.width - 28px; height: 44px; text: root.index_status; color: ThemePalette.text_muted; font-size: 12px; wrap: word-wrap; }
                    }

                    Text { text: "THUMBNAIL CACHE"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Rectangle {
                        height: 76px;
                        border-radius: AppMetrics.radius;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        Text { x: 14px; y: 12px; width: parent.width - 112px; height: 20px; text: "Automatic thumbnail cleanup"; color: ThemePalette.text; font-size: 13px; font-weight: 700; }
                        Text { x: 14px; y: 36px; width: parent.width - 112px; height: 22px; text: root.thumbnail_status; color: ThemePalette.text_muted; font-size: 12px; overflow: elide; }
                        DialogButton { x: parent.width - 92px; y: 22px; label: "Clear"; clicked => { root.clear_thumbnail_cache(); } }
                    }

                    Rectangle {
                        height: footprint_label.preferred-height + footprint_text.preferred-height + 36px;
                        border-radius: AppMetrics.radius;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.panel;
                        footprint_label := Text { x: 14px; y: 12px; width: parent.width - 28px; height: 20px; text: "Storage and memory footprint"; color: ThemePalette.text; font-size: 13px; font-weight: 700; }
                        footprint_text := Text {
                            x: 14px;
                            y: 36px;
                            width: parent.width - 28px;
                            text: root.performance_footprint;
                            color: ThemePalette.text_muted;
                            font-size: 11.5px;
                            font-family: AppMetrics.mono_font;
                            wrap: word-wrap;
                            height: self.preferred-height;
                        }
                    }

                    HorizontalLayout {
                        height: 34px;
                        spacing: 8px;
                        DialogButton { label: "Rebuild"; primary: true; clicked => { root.rebuild_index(); } }
                        DialogButton { label: "Debug"; clicked => { root.command("performance-debug"); } }
                    }
                }
            }

            if root.settings_tab == "ai" && !root.is_simple: ScrollView {
                x: 20px;
                y: 124px;
                width: parent.width - 40px;
                height: parent.height - 136px;

                VerticalLayout {
                    width: parent.width - 20px;
                    spacing: 14px;
                    padding-bottom: 16px;

                Text { text: "AI CAPABILITIES"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                Text {
                    width: parent.width;
                    text: "On-device only. Semantic ranking uses filename embeddings. Image tags are approximate ImageNet labels — there is no OCR for text inside screenshots.";
                    color: ThemePalette.text_muted;
                    font-size: 11.5px;
                    wrap: word-wrap;
                    height: self.preferred-height;
                }
                Rectangle {
                    width: parent.width;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    border-radius: AppMetrics.radius;
                    background: ThemePalette.panel;
                    clip: true;
                    VerticalLayout {
                        padding: 14px;
                        spacing: 8px;
                        width: parent.width;
                        Text {
                            width: parent.width - 28px;
                            text: root.ai_label;
                            color: ThemePalette.text;
                            font-size: 14px;
                            font-weight: 700;
                            wrap: word-wrap;
                        }
                        Text {
                            width: parent.width - 28px;
                            text: root.ai_device;
                            color: ThemePalette.accent_strong;
                            font-size: 12px;
                            font-family: AppMetrics.mono_font;
                            wrap: word-wrap;
                        }
                        Text {
                            width: parent.width - 28px;
                            text: root.ai_gpu_status;
                            color: ThemePalette.text_muted;
                            font-size: 11.5px;
                            font-family: AppMetrics.mono_font;
                            wrap: word-wrap;
                        }
                        Text {
                            width: parent.width - 28px;
                            text: "Thumbnails, content search, and image analysis use the best detected device.";
                            color: ThemePalette.text_muted;
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                    }
                }

                Text { text: "OPTIONAL SEARCH"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                Text {
                    width: parent.width;
                    text: "CLIP visual search is reserved but not bundled in this build. The control below is disabled.";
                    color: ThemePalette.text_muted;
                    font-size: 11.5px;
                    wrap: word-wrap;
                }
                Rectangle {
                    width: parent.width;
                    height: AppMetrics.row_h;
                    border-radius: AppMetrics.radius;
                    background: ThemePalette.panel;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    Text { x: 14px; width: parent.width - 60px; height: parent.height; text: "Image tags / CLIP search (unavailable in this build)"; color: ThemePalette.text_muted; font-size: 13px; vertical-alignment: center; overflow: elide; }
                    Rectangle {
                        x: parent.width - 52px;
                        y: (parent.height - 22px) / 2;
                        width: 40px;
                        height: 22px;
                        border-radius: 11px;
                        background: ThemePalette.border_strong;
                        opacity: 0.45;
                        Rectangle {
                            x: 2px;
                            y: 2px;
                            width: 18px;
                            height: 18px;
                            border-radius: 9px;
                            background: white;
                        }
                    }
                }

                // Pathfinder Local AI install / uninstall area.
                Text { text: "PATHFINDER LOCAL AI"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                Rectangle {
                    width: parent.width;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    border-radius: AppMetrics.radius;
                    background: ThemePalette.panel;
                    clip: true;
                    VerticalLayout {
                        padding: 14px;
                        spacing: 10px;
                        width: parent.width;

                        Text {
                            width: parent.width - 28px;
                            text: root.ai_install_state == "installed"
                                ? "Local AI is installed"
                                : (root.ai_install_state == "downloading" || root.ai_install_state == "updating"
                                    ? "Downloading models …"
                                    : (root.ai_install_state == "error" ? "Local AI needs attention" : "Local AI is not installed"));
                            color: ThemePalette.text;
                            font-size: 13px;
                            font-weight: 700;
                            wrap: word-wrap;
                        }
                        Text {
                            width: parent.width - 28px;
                            text: "Profile: " + root.ai_profile_label;
                            color: ThemePalette.accent_strong;
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                        if root.ai_model_versions != "": Text {
                            width: parent.width - 28px;
                            text: root.ai_model_versions;
                            color: ThemePalette.text_muted;
                            font-size: 11px;
                            font-family: AppMetrics.mono_font;
                            wrap: word-wrap;
                        }
                        if root.ai_disk_usage != "": Text {
                            width: parent.width - 28px;
                            text: root.ai_disk_usage;
                            color: ThemePalette.text_muted;
                            font-size: 11.5px;
                            wrap: word-wrap;
                        }
                        if root.ai_update_status != "": Text {
                            width: parent.width - 28px;
                            text: root.ai_update_status;
                            color: ThemePalette.text_muted;
                            font-size: 11.5px;
                            wrap: word-wrap;
                        }
                        if root.ai_install_state == "not_installed": Text {
                            width: parent.width - 28px;
                            text: "Adds about " + root.ai_install_size_mb + " MB on disk for the selected profile. Models run entirely on your machine.";
                            color: ThemePalette.text_muted;
                            font-size: 11.5px;
                            wrap: word-wrap;
                        }
                        if root.ai_install_state == "downloading" || root.ai_install_state == "updating" || root.ai_install_state == "error": CopyableMessageText {
                            content-width: parent.width - 28px;
                            text: root.ai_install_message;
                            font-size: 11.5px;
                            text-color: root.ai_install_state == "error" ? ThemePalette.danger : ThemePalette.text_muted;
                            cap-height: 160px;
                        }

                        if root.ai_install_state == "downloading" || root.ai_install_state == "updating": Rectangle {
                            width: parent.width - 28px;
                            height: 6px;
                            border-radius: 3px;
                            background: rgba(127, 127, 127, 0.18);
                            clip: true;
                            Rectangle {
                                x: 0; y: 0;
                                width: parent.width * Math.clamp(root.ai_download_progress, 0, 1);
                                height: parent.height;
                                border-radius: 3px;
                                background: ThemePalette.accent;
                                animate width { duration: 120ms; easing: ease-out; }
                            }
                        }

                        // Profile picker (compact / balanced / quality)
                        if root.ai_install_state == "not_installed" || root.ai_install_state == "installed" || root.ai_install_state == "error": HorizontalLayout {
                            spacing: 8px;
                            Rectangle {
                                width: 88px; height: 30px; border-radius: AppMetrics.radius_small;
                                background: root.ai_profile == "compact" ? ThemePalette.accent : ThemePalette.panel_alt;
                                border-width: 1px; border-color: ThemePalette.border;
                                Text { width: parent.width; height: parent.height; text: "Compact"; color: root.ai_profile == "compact" ? ThemePalette.on_accent : ThemePalette.text; font-size: 11px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                                TouchArea { mouse-cursor: pointer; clicked => { root.ai_set_profile("compact"); } }
                            }
                            Rectangle {
                                width: 96px; height: 30px; border-radius: AppMetrics.radius_small;
                                background: root.ai_profile == "balanced" ? ThemePalette.accent : ThemePalette.panel_alt;
                                border-width: 1px; border-color: ThemePalette.border;
                                Text { width: parent.width; height: parent.height; text: "Balanced"; color: root.ai_profile == "balanced" ? ThemePalette.on_accent : ThemePalette.text; font-size: 11px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                                TouchArea { mouse-cursor: pointer; clicked => { root.ai_set_profile("balanced"); } }
                            }
                            Rectangle {
                                width: 88px; height: 30px; border-radius: AppMetrics.radius_small;
                                background: root.ai_profile == "quality" ? ThemePalette.accent : ThemePalette.panel_alt;
                                border-width: 1px; border-color: ThemePalette.border;
                                Text { width: parent.width; height: parent.height; text: "Quality"; color: root.ai_profile == "quality" ? ThemePalette.on_accent : ThemePalette.text; font-size: 11px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                                TouchArea { mouse-cursor: pointer; clicked => { root.ai_set_profile("quality"); } }
                            }
                        }

                        if root.ai_install_state == "installed": Rectangle {
                            width: parent.width - 28px;
                            height: AppMetrics.row_h;
                            border-radius: AppMetrics.radius;
                            background: ThemePalette.panel_alt;
                            Text { x: 14px; width: parent.width - 60px; height: parent.height; text: "Keep models up to date"; color: ThemePalette.text; font-size: 12.5px; vertical-alignment: center; overflow: elide; }
                            Rectangle {
                                x: parent.width - 52px;
                                y: (parent.height - 22px) / 2;
                                width: 40px; height: 22px; border-radius: 11px;
                                background: root.ai_auto_update ? ThemePalette.accent : ThemePalette.border_strong;
                                Rectangle {
                                    x: root.ai_auto_update ? 20px : 2px; y: 2px; width: 18px; height: 18px; border-radius: 9px; background: white;
                                    animate x { duration: 120ms; easing: ease-out; }
                                }
                                TouchArea { mouse-cursor: pointer; clicked => { root.ai_toggle_auto_update(); } }
                            }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            if root.ai_install_state == "not_installed" || root.ai_install_state == "error": Rectangle {
                                width: 126px;
                                height: 36px;
                                border-radius: AppMetrics.radius_small;
                                background: install_touch.has-hover ? ThemePalette.accent_strong : ThemePalette.accent;
                                Text {
                                    width: parent.width; height: parent.height;
                                    text: root.ai_install_state == "error" ? "Retry" : "Install AI";
                                    color: ThemePalette.on_accent; font-size: 12.5px; font-weight: 700;
                                    horizontal-alignment: center; vertical-alignment: center;
                                }
                                install_touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        if (root.ai_install_state == "error") {
                                            root.ai_repair();
                                        } else {
                                            root.ai_install_explainer_visible = true;
                                        }
                                    }
                                }
                            }
                            if root.ai_install_state == "installed": Rectangle {
                                width: 118px; height: 36px; border-radius: AppMetrics.radius_small;
                                border-width: 1px; border-color: ThemePalette.border_strong;
                                background: repair_touch.has-hover ? ThemePalette.panel_alt : transparent;
                                Text { width: parent.width; height: parent.height; text: "Verify & repair"; color: ThemePalette.text; font-size: 12px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                                repair_touch := TouchArea { mouse-cursor: pointer; clicked => { root.ai_repair(); } }
                            }
                            if root.ai_install_state == "installed": Rectangle {
                                width: 118px; height: 36px; border-radius: AppMetrics.radius_small;
                                border-width: 1px; border-color: ThemePalette.border_strong;
                                background: upd_touch.has-hover ? ThemePalette.panel_alt : transparent;
                                Text { width: parent.width; height: parent.height; text: "Update models"; color: ThemePalette.text; font-size: 12px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                                upd_touch := TouchArea { mouse-cursor: pointer; clicked => { root.ai_update_models(); } }
                            }
                            if root.ai_install_state == "installed": Rectangle {
                                width: 100px; height: 36px; border-radius: AppMetrics.radius_small;
                                border-width: 1px; border-color: ThemePalette.border_strong;
                                background: uninstall_touch.has-hover ? ThemePalette.panel_alt : transparent;
                                Text { width: parent.width; height: parent.height; text: "Remove"; color: ThemePalette.text; font-size: 12.5px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                                uninstall_touch := TouchArea { mouse-cursor: pointer; clicked => { root.ai_uninstall(); } }
                            }
                        }
                    }
                }

                Text { text: "FEATURES"; color: ThemePalette.text_faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                Rectangle {
                    width: parent.width; height: 58px;
                    border-width: 1px; border-color: ThemePalette.border; border-radius: AppMetrics.radius; background: ThemePalette.panel;
                    Text { x: 14px; y: 10px; width: parent.width - 28px; height: 18px; text: "Semantic content search"; color: ThemePalette.text; font-size: 13px; font-weight: 600; overflow: elide; }
                    Text { x: 14px; y: 32px; width: parent.width - 28px; height: 16px; text: root.ai_feature_semantic; color: ThemePalette.text_muted; font-size: 11.5px; overflow: elide; }
                }
                Rectangle {
                    width: parent.width; height: 58px;
                    border-width: 1px; border-color: ThemePalette.border; border-radius: AppMetrics.radius; background: ThemePalette.panel;
                    Text { x: 14px; y: 10px; width: parent.width - 28px; height: 18px; text: "Image classification"; color: ThemePalette.text; font-size: 13px; font-weight: 600; overflow: elide; }
                    Text { x: 14px; y: 32px; width: parent.width - 28px; height: 16px; text: root.ai_feature_classify; color: ThemePalette.text_muted; font-size: 11.5px; overflow: elide; }
                }
                Rectangle {
                    width: parent.width; height: 58px;
                    border-width: 1px; border-color: ThemePalette.border; border-radius: AppMetrics.radius; background: ThemePalette.panel;
                    Text { x: 14px; y: 10px; width: parent.width - 28px; height: 18px; text: "Perceptual duplicate detection"; color: ThemePalette.text; font-size: 13px; font-weight: 600; overflow: elide; }
                    Text { x: 14px; y: 32px; width: parent.width - 28px; height: 16px; text: root.ai_feature_dupes; color: ThemePalette.text_muted; font-size: 11.5px; overflow: elide; }
                }
                }
            }

            // AI installer explainer dialog.
            if root.ai_install_explainer_visible: Rectangle {
                x: 0; y: 0;
                width: parent.width; height: parent.height;
                background: rgba(0, 0, 0, 0.5);
                TouchArea { clicked => { root.ai_install_explainer_visible = false; } }
                Rectangle {
                    x: (parent.width - 480px) / 2;
                    y: (parent.height - 380px) / 2;
                    width: 480px;
                    height: 380px;
                    border-width: 1px;
                    border-color: ThemePalette.border_strong;
                    border-radius: AppMetrics.radius;
                    background: ThemePalette.panel_solid;
                    drop-shadow-blur: 20px;
                    drop-shadow-color: rgba(0, 0, 0, 0.45);
                    TouchArea {}

                    Text { x: 22px; y: 22px; width: parent.width - 44px; height: 28px; text: "Install Pathfinder Local AI"; color: ThemePalette.text; font-size: 17px; font-weight: 700; }
                    Text {
                        x: 22px; y: 58px;
                        width: parent.width - 44px;
                        height: 240px;
                        text: "Profile: " + root.ai_profile_label + "\n\n" +
                              "What you get\n" +
                              "  Semantic search across your files using a local embedding model.\n" +
                              "  Image classification that suggests tags for photos.\n" +
                              "  Near-duplicate detection for resized and lightly edited copies.\n\n" +
                              "What gets downloaded (~" + root.ai_install_size_mb + " MB)\n" +
                              "  Text embedding model + tokenizer for the selected profile.\n" +
                              "  Image classifier for the selected profile.\n" +
                              "  ONNX Runtime with DirectML (NPU / GPU / CPU).\n\n" +
                              "Models can self-update later without re-downloading unchanged files.";
                        color: ThemePalette.text_muted;
                        font-size: 12.5px;
                        wrap: word-wrap;
                    }
                    DialogButton {
                        x: parent.width - 240px;
                        y: parent.height - 50px;
                        label: "Cancel";
                        clicked => { root.ai_install_explainer_visible = false; }
                    }
                    DialogButton {
                        x: parent.width - 130px;
                        y: parent.height - 50px;
                        label: "Install (~" + root.ai_install_size_mb + " MB)";
                        primary: true;
                        clicked => {
                            root.ai_install_explainer_visible = false;
                            root.ai_install_confirm();
                        }
                    }
                }
            }
        }
    }

    if root.confirm_visible: Rectangle {
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0.42);
        TouchArea {
            width: parent.width;
            height: parent.height;
            // Block all mouse events from passing through to elements behind the dialog
            clicked => { }
        }
        confirm_panel := Rectangle {
            x: (parent.width - 460px) / 2;
            y: (parent.height - self.height) / 2;
            width: 460px;
            height: confirm_body.preferred-height + 120px;
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            clip: true;
            Text { x: 18px; y: 16px; width: parent.width - 36px; text: "Confirm delete"; color: ThemePalette.text; font-size: 18px; font-weight: 700; }
            confirm_body := CopyableMessageText {
                x: 18px;
                y: 50px;
                content-width: parent.width - 36px;
                text: root.confirm_text;
                font-size: 13px;
                text-color: ThemePalette.text_muted;
                cap-height: 220px;
            }
            DialogButton { x: parent.width - 180px; y: parent.height - 48px; label: "Cancel"; clicked => { root.confirm_visible = false; } }
            DialogButton { x: parent.width - 90px; y: parent.height - 48px; label: "Delete"; primary: true; danger: true; clicked => { root.confirm_visible = false; root.confirm_delete(); } }
        }
    }

    if root.prompt_visible: Rectangle {
        z: 160;
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0.42);
        TouchArea {
            width: parent.width;
            height: parent.height;
            // Block all mouse events from passing through to elements behind the dialog
            clicked => { }
        }

        if root.prompt_kind == "conflict": Rectangle {
            x: (parent.width - min(460px, parent.width - 32px)) / 2;
            y: (parent.height - min(220px, parent.height - 32px)) / 2;
            width: min(460px, parent.width - 32px);
            height: min(220px, parent.height - 32px);
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            Text { x: 18px; y: 16px; width: parent.width - 36px; height: 26px; text: root.prompt_title; color: ThemePalette.text; font-size: 18px; font-weight: 700; }
            CopyableMessageText {
                x: 18px;
                y: 50px;
                content-width: parent.width - 36px;
                text: "A file with the same name already exists.\n\nKeep both: save with a new name like \"file (1).txt\".\nReplace: overwrite the existing file.\nSkip: don't copy this file.";
                font-size: 12.5px;
                cap-height: 88px;
            }
            DialogButton { x: 18px; y: parent.height - 48px; label: "Skip"; clicked => { root.prompt_visible = false; root.prompt_kind = "text"; root.prompt_accept("skip"); } }
            DialogButton { x: parent.width - 240px; y: parent.height - 48px; label: "Replace"; clicked => { root.prompt_visible = false; root.prompt_kind = "text"; root.prompt_accept("replace"); } }
            DialogButton { x: parent.width - 120px; y: parent.height - 48px; label: "Keep both"; primary: true; clicked => { root.prompt_visible = false; root.prompt_kind = "text"; root.prompt_accept("keep"); } }
        }

        if root.prompt_kind == "rename-conflict": Rectangle {
            x: (parent.width - min(460px, parent.width - 32px)) / 2;
            y: (parent.height - min(220px, parent.height - 32px)) / 2;
            width: min(460px, parent.width - 32px);
            height: min(220px, parent.height - 32px);
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            Text { x: 18px; y: 16px; width: parent.width - 36px; height: 26px; text: root.prompt_title; color: ThemePalette.text; font-size: 18px; font-weight: 700; }
            CopyableMessageText {
                x: 18px; y: 50px; content-width: parent.width - 36px;
                text: "A file with that name already exists.\n\nKeep both saves with a numbered suffix.\nReplace overwrites the existing file.\nSkip cancels the rename.";
                font-size: 12.5px; cap-height: 88px;
            }
            DialogButton { x: 18px; y: parent.height - 48px; label: "Skip"; clicked => { root.prompt_visible = false; root.prompt_kind = "text"; root.prompt_accept("skip"); } }
            DialogButton { x: parent.width - 240px; y: parent.height - 48px; label: "Replace"; clicked => { root.prompt_visible = false; root.prompt_kind = "text"; root.prompt_accept("replace"); } }
            DialogButton { x: parent.width - 120px; y: parent.height - 48px; label: "Keep both"; primary: true; clicked => { root.prompt_visible = false; root.prompt_kind = "text"; root.prompt_accept("keep"); } }
        }

        if root.prompt_kind == "batch-rename": Rectangle {
            x: (parent.width - min(560px, parent.width - 24px)) / 2;
            y: (parent.height - min(520px, parent.height - 24px)) / 2;
            width: min(560px, parent.width - 24px);
            height: min(520px, parent.height - 24px);
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            clip: true;
            Text { x: 18px; y: 14px; width: parent.width - 36px; height: 24px; text: "Batch rename"; color: ThemePalette.text; font-size: 18px; font-weight: 700; }
            Text { x: 18px; y: 44px; width: 80px; height: 20px; text: "Find (regex)"; color: ThemePalette.text_faint; font-size: 11px; }
            br_find := LineEdit { x: 18px; y: 64px; width: parent.width - 36px; height: 30px; text <=> root.batch_rename_find; edited => { root.batch_rename_preview_refresh(); } }
            Text { x: 18px; y: 100px; width: 80px; height: 20px; text: "Replace"; color: ThemePalette.text_faint; font-size: 11px; }
            br_repl := LineEdit { x: 18px; y: 120px; width: parent.width - 36px; height: 30px; text <=> root.batch_rename_replace; edited => { root.batch_rename_preview_refresh(); } }
            Text { x: 18px; y: 156px; width: 60px; height: 20px; text: "Prefix"; color: ThemePalette.text_faint; font-size: 11px; }
            br_pre := LineEdit { x: 18px; y: 176px; width: (parent.width - 48px) / 2; height: 30px; text <=> root.batch_rename_prefix; edited => { root.batch_rename_preview_refresh(); } }
            Text { x: parent.width / 2 + 6px; y: 156px; width: 60px; height: 20px; text: "Suffix"; color: ThemePalette.text_faint; font-size: 11px; }
            br_suf := LineEdit { x: parent.width / 2 + 6px; y: 176px; width: (parent.width - 48px) / 2; height: 30px; text <=> root.batch_rename_suffix; edited => { root.batch_rename_preview_refresh(); } }
            Text { x: 18px; y: 212px; width: 120px; height: 20px; text: "Template"; color: ThemePalette.text_faint; font-size: 11px; }
            br_tmpl := LineEdit { x: 18px; y: 232px; width: parent.width - 36px; height: 30px; text <=> root.batch_rename_template; edited => { root.batch_rename_preview_refresh(); } }
            Text { x: 18px; y: 270px; width: parent.width - 36px; height: 16px; text: "Preview"; color: ThemePalette.text_faint; font-size: 11px; font-weight: 700; }
            CopyableMessageText {
                x: 18px; y: 288px; content-width: parent.width - 36px;
                text: root.batch_rename_preview;
                font-size: 11px; mono: true; cap-height: max(72px, parent.height - 360px);
            }
            Text { x: 18px; y: parent.height - 72px; width: parent.width - 36px; height: 28px;
                text: "Tokens: {n} {n:04} {name} {ext}  ·  Find uses regex";
                color: ThemePalette.text_faint; font-size: 10px; wrap: word-wrap; }
            DialogButton { x: parent.width - 180px; y: parent.height - 44px; label: "Cancel"; clicked => { root.prompt_cancel(); } }
            DialogButton { x: parent.width - 90px; y: parent.height - 44px; label: "Rename"; primary: true; clicked => { root.prompt_visible = false; root.prompt_kind = "text"; root.prompt_accept("apply"); } }
        }

        // Standard text-input prompt (rename / new folder / etc.)
        if root.prompt_kind != "conflict" && root.prompt_kind != "rename-conflict" && root.prompt_kind != "batch-rename": Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(440px, parent.width - 40px);
            height: 188px;
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            drop-shadow-blur: 18px;
            drop-shadow-color: rgba(0, 0, 0, 0.4);
            clip: true;

            VerticalLayout {
                padding: 18px;
                spacing: 12px;
                alignment: stretch;

                Text {
                    text: root.prompt_title;
                    color: ThemePalette.text;
                    font-size: 18px;
                    font-weight: 700;
                    overflow: elide;
                }

                prompt := LineEdit {
                    height: 36px;
                    text <=> root.prompt_value;
                    font-size: 13px;
                    font-family: AppMetrics.ui_font;
                    accepted(value) => { root.prompt_visible = false; root.prompt_accept(value); }
                    key-pressed(e) => {
                        if (e.text == Key.Escape) { root.prompt_cancel(); return accept; }
                        return reject;
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;
                    DialogButton {
                        label: "Cancel";
                        clicked => { root.prompt_cancel(); }
                    }
                    DialogButton {
                        label: "OK";
                        primary: true;
                        clicked => {
                            root.prompt_visible = false;
                            root.prompt_accept(root.prompt_value);
                        }
                    }
                }
            }
        }
    }

    if root.rename_presets_visible: Rectangle {
        z: 110;
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0.42);
        TouchArea { clicked => { root.prompt_cancel(); } }
        Rectangle {
            x: (parent.width - min(380px, parent.width - 32px)) / 2;
            y: (parent.height - min(320px, parent.height - 32px)) / 2;
            width: min(380px, parent.width - 32px);
            height: min(320px, parent.height - 32px);
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            Text { x: 18px; y: 14px; width: parent.width - 36px; height: 24px; text: "Rename presets"; color: ThemePalette.text; font-size: 17px; font-weight: 700; }
            Text { x: 18px; y: 40px; width: parent.width - 36px; height: 18px; text: "Click a preset to apply to the selection"; color: ThemePalette.text_faint; font-size: 11px; }
            ScrollView {
                x: 12px; y: 64px; width: parent.width - 24px; height: parent.height - 76px;
                for preset[i] in root.rename_preset_names: Rectangle {
                    width: parent.width - 8px;
                    height: 36px;
                    border-radius: AppMetrics.radius_small;
                    background: preset_touch.has-hover ? ThemePalette.accent_soft : rgba(0,0,0,0);
                    Text { x: 12px; width: parent.width - 24px; height: parent.height; text: preset; color: ThemePalette.text; font-size: 13px; vertical-alignment: center; }
                    preset_touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.rename_presets_visible = false; root.rename_preset_picked(preset); }
                    }
                }
            }
        }
    }

    if root.tool_overlay_visible: Rectangle {
        z: 110;
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0.42);
        TouchArea { clicked => { root.tool_overlay_close(); } }
        Rectangle {
            x: (parent.width - min(520px, parent.width - 32px)) / 2;
            y: (parent.height - min(420px, parent.height - 32px)) / 2;
            width: min(520px, parent.width - 32px);
            height: min(420px, parent.height - 32px);
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            drop-shadow-blur: 20px;
            drop-shadow-color: rgba(0, 0, 0, 0.45);
            TouchArea {}
            Text {
                x: 18px; y: 14px; width: parent.width - 36px; height: 24px;
                text: root.tool_overlay_title;
                color: ThemePalette.text; font-size: 17px; font-weight: 700; overflow: elide;
            }
            Text {
                x: 18px; y: 40px; width: parent.width - 36px; height: 18px;
                text: root.tool_overlay_subtitle;
                color: ThemePalette.text_faint; font-size: 11px; overflow: elide;
            }
            if root.tool_overlay_kind == "shortcuts": ScrollView {
                x: 12px; y: 64px; width: parent.width - 24px; height: parent.height - 120px;
                for sc[si] in root.shortcut_edit_items: Rectangle {
                    width: parent.width - 8px;
                    height: 56px;
                    border-radius: AppMetrics.radius_small;
                    background: Math.mod(si, 2) == 0 ? ThemePalette.panel : rgba(0, 0, 0, 0);
                    Text {
                        x: 12px; y: 6px; width: parent.width - 24px; height: 18px;
                        text: sc.label + (sc.group != "" ? (" · " + sc.group) : "");
                        color: ThemePalette.text; font-size: 12.5px; font-weight: 600; overflow: elide;
                    }
                    LineEdit {
                        x: 12px; y: 26px; width: parent.width - 24px; height: 24px;
                        text: sc.hint;
                        placeholder-text: "Shortcut hint";
                        font-size: 12px;
                        font-family: AppMetrics.mono_font;
                        edited(val) => { root.shortcut_hint_changed(sc.command, val); }
                    }
                }
            }
            if root.tool_overlay_kind != "shortcuts": ScrollView {
                x: 12px; y: 64px; width: parent.width - 24px; height: parent.height - 120px;
                for item[ti] in root.tool_overlay_items: Rectangle {
                    width: parent.width - 8px;
                    height: 52px;
                    border-radius: AppMetrics.radius_small;
                    background: tool_row_ta.has-hover ? ThemePalette.accent_soft : rgba(0, 0, 0, 0);
                    Rectangle {
                        x: 8px; y: 16px; width: 4px; height: 20px;
                        border-radius: 2px;
                        background: item.accent;
                    }
                    Text {
                        x: 20px; y: 8px; width: parent.width - (root.tool_overlay_kind == "rules" ? 120px : 90px); height: 20px;
                        text: item.title;
                        color: ThemePalette.text; font-size: 13px; font-weight: 600; overflow: elide;
                    }
                    Text {
                        x: 20px; y: 28px; width: parent.width - (root.tool_overlay_kind == "rules" ? 120px : 90px); height: 16px;
                        text: item.subtitle;
                        color: ThemePalette.text_faint; font-size: 11px; overflow: elide;
                    }
                    if root.tool_overlay_kind == "rules": Rectangle {
                        x: parent.width - 108px; y: 14px; width: 52px; height: 24px;
                        border-radius: 12px;
                        background: item.enabled ? ThemePalette.success : ThemePalette.border_strong;
                        Text {
                            width: parent.width; height: parent.height;
                            text: item.enabled ? "On" : "Off";
                            color: white; font-size: 10px; font-weight: 700;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                        TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.tool_overlay_toggle(item.id); }
                        }
                    }
                    if item.meta != "": Text {
                        x: parent.width - 48px; y: 0; width: 36px; height: parent.height;
                        text: item.meta;
                        color: ThemePalette.text_faint; font-size: 11px;
                        horizontal-alignment: right; vertical-alignment: center; overflow: elide;
                    }
                    ToolButton {
                        x: parent.width - 36px; y: 10px;
                        button_width: 28px; button_height: 28px;
                        visible: item.meta == "";
                        text_label: "···";
                        tooltip: "More";
                        clicked => { root.tool_overlay_secondary(item.id); }
                    }
                    tool_row_ta := TouchArea {
                        x: 0; y: 0;
                        width: parent.width - (root.tool_overlay_kind == "rules" ? 112px : 40px);
                        height: parent.height;
                        mouse-cursor: pointer;
                        clicked => { root.tool_overlay_activate(item.id); }
                    }
                }
            }
            DialogButton {
                x: 18px; y: parent.height - 48px;
                label: "Close";
                clicked => { root.tool_overlay_close(); }
            }
            if root.tool_overlay_kind == "rules" || root.tool_overlay_kind == "shortcuts" || root.tool_overlay_kind == "workspaces" || root.tool_overlay_kind == "smart-folders": DialogButton {
                x: parent.width - self.preferred-width - 18px; y: parent.height - 48px;
                label: root.tool_overlay_kind == "rules" ? "Run enabled"
                    : (root.tool_overlay_kind == "shortcuts" ? "Save"
                    : (root.tool_overlay_kind == "workspaces" ? "Open" : "Close"));
                primary: true;
                clicked => {
                    if (root.tool_overlay_kind == "smart-folders") {
                        root.tool_overlay_close();
                    } else {
                        root.tool_overlay_primary_action();
                    }
                }
            }
        }
    }

    if root.compare_overlay_visible: Rectangle {
        z: 110;
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0.42);
        TouchArea { clicked => { root.compare_overlay_close(); } }
        Rectangle {
            x: (parent.width - min(560px, parent.width - 32px)) / 2;
            y: (parent.height - min(440px, parent.height - 32px)) / 2;
            width: min(560px, parent.width - 32px);
            height: min(440px, parent.height - 32px);
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            drop-shadow-blur: 20px;
            drop-shadow-color: rgba(0, 0, 0, 0.45);
            TouchArea {}
            Text {
                x: 18px; y: 14px; width: parent.width - 36px; height: 24px;
                text: root.compare_overlay_title != "" ? root.compare_overlay_title : "Compare folders";
                color: ThemePalette.text; font-size: 17px; font-weight: 700; overflow: elide;
            }
            Text {
                x: 18px; y: 40px; width: parent.width - 36px; height: 16px;
                text: root.compare_overlay_left + "  ↔  " + root.compare_overlay_right;
                color: ThemePalette.text_faint; font-size: 11px; overflow: elide;
            }
            Rectangle {
                x: 18px; y: 62px; width: 160px; height: 26px;
                border-radius: AppMetrics.radius_small;
                border-width: 1px;
                border-color: root.compare_overlay_hide_same ? ThemePalette.accent : ThemePalette.border;
                background: root.compare_overlay_hide_same ? ThemePalette.accent_soft : ThemePalette.panel_alt;
                Text {
                    x: 10px; width: parent.width - 20px; height: parent.height;
                    text: root.compare_overlay_hide_same ? "Hide same: On" : "Hide same: Off";
                    color: root.compare_overlay_hide_same ? ThemePalette.accent_strong : ThemePalette.text_muted;
                    font-size: 11.5px; vertical-alignment: center;
                }
                TouchArea { mouse-cursor: pointer; clicked => { root.compare_toggle_hide_same(); } }
            }
            ScrollView {
                x: 12px; y: 96px; width: parent.width - 24px; height: parent.height - 152px;
                for row[ri] in root.compare_rows: Rectangle {
                    width: parent.width - 8px;
                    height: 40px;
                    border-radius: AppMetrics.radius_small;
                    background: cmp_ta.has-hover ? ThemePalette.accent_soft : rgba(0, 0, 0, 0);
                    property <color> status_color:
                        row.status == "same" ? ThemePalette.success :
                        (row.status == "left-only" || row.status == "newer-left" ? ThemePalette.accent :
                        (row.status == "right-only" || row.status == "newer-right" ? ThemePalette.warning : ThemePalette.danger));
                    Rectangle {
                        x: 8px; y: 12px; width: 8px; height: 8px;
                        border-radius: 4px;
                        background: parent.status_color;
                    }
                    Text {
                        x: 24px; y: 4px; width: parent.width - 160px; height: 18px;
                        text: row.path;
                        color: ThemePalette.text; font-size: 12.5px; overflow: elide;
                    }
                    Text {
                        x: 24px; y: 22px; width: parent.width - 160px; height: 14px;
                        text: row.status + " · L " + row.left_size + " · R " + row.right_size;
                        color: ThemePalette.text_faint; font-size: 10.5px; overflow: elide;
                    }
                    cmp_ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.compare_row_activate(row.path); }
                    }
                }
            }
            DialogButton {
                x: parent.width - self.preferred-width - 18px; y: parent.height - 48px;
                label: "Close";
                primary: true;
                clicked => { root.compare_overlay_close(); }
            }
        }
    }

    if root.dupe_overlay_visible: Rectangle {
        z: 110;
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0.42);
        TouchArea { clicked => { root.dupe_overlay_close(); } }
        Rectangle {
            x: (parent.width - min(640px, parent.width - 32px)) / 2;
            y: (parent.height - min(520px, parent.height - 32px)) / 2;
            width: min(640px, parent.width - 32px);
            height: min(520px, parent.height - 32px);
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            drop-shadow-blur: 20px;
            drop-shadow-color: rgba(0, 0, 0, 0.45);
            TouchArea {}
            Text {
                x: 18px; y: 14px; width: parent.width - 36px; height: 24px;
                text: root.dupe_overlay_title != "" ? root.dupe_overlay_title : "Duplicate files";
                color: ThemePalette.text; font-size: 17px; font-weight: 700; overflow: elide;
            }
            Text {
                x: 18px; y: 40px; width: parent.width - 36px; height: 18px;
                text: root.dupe_overlay_subtitle;
                color: ThemePalette.text_faint; font-size: 11px; overflow: elide;
            }
            HorizontalLayout {
                x: 18px; y: 58px; spacing: 8px; height: 28px;
                DialogButton { label: "Keep newest"; clicked => { root.dupe_keep_strategy("newest"); } }
                DialogButton { label: "Keep largest"; clicked => { root.dupe_keep_strategy("largest"); } }
            }
            ScrollView {
                x: 12px; y: 90px; width: parent.width - 24px; height: parent.height - 146px;
                for grp[gi] in root.dupe_groups: Rectangle {
                    width: parent.width - 8px;
                    height: 118px;
                    border-radius: AppMetrics.radius_small;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    background: ThemePalette.panel;
                    Rectangle {
                        x: 12px; y: 12px; width: 4px; height: 40px;
                        border-radius: 2px;
                        background: ThemePalette.accent;
                    }
                    Text {
                        x: 24px; y: 10px; width: parent.width - 36px; height: 18px;
                        text: grp.title;
                        color: ThemePalette.text; font-size: 13px; font-weight: 600; overflow: elide;
                    }
                    Text {
                        x: 24px; y: 30px; width: parent.width - 36px; height: 14px;
                        text: grp.detail + " · keep " + grp.keep_size + " · reclaim " + grp.reclaimable;
                        color: ThemePalette.text_muted; font-size: 11px; overflow: elide;
                    }
                    Text {
                        x: 24px; y: 48px; width: parent.width - 36px; height: 14px;
                        text: "Keep: " + grp.keep_path;
                        color: ThemePalette.text_faint; font-size: 10.5px; font-family: AppMetrics.mono_font; overflow: elide;
                    }
                    Text {
                        x: 24px; y: 64px; width: parent.width - 36px; height: 14px;
                        text: grp.paths_preview;
                        color: ThemePalette.text_faint; font-size: 10.5px; font-family: AppMetrics.mono_font; overflow: elide;
                    }
                    DialogButton {
                        x: 12px; y: parent.height - 38px;
                        label: "Keep first";
                        clicked => { root.dupe_group_keep(grp.id); }
                    }
                    DialogButton {
                        x: 118px; y: parent.height - 38px;
                        label: "Delete others";
                        danger: true;
                        clicked => { root.dupe_group_delete_others(grp.id); }
                    }
                }
            }
            DialogButton {
                x: parent.width - self.preferred-width - 18px; y: parent.height - 48px;
                label: "Close";
                primary: true;
                clicked => { root.dupe_overlay_close(); }
            }
        }
    }

    if root.quick_look_visible: Rectangle {
        z: 120;
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0.55);
        TouchArea { clicked => { root.quick_look_close(); } }
        Rectangle {
            x: (parent.width - min(640px, parent.width - 48px)) / 2;
            y: (parent.height - min(480px, parent.height - 48px)) / 2;
            width: min(640px, parent.width - 48px);
            height: min(480px, parent.height - 48px);
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            Text { x: 20px; y: 16px; width: parent.width - 80px; height: 28px; text: root.preview_title; color: ThemePalette.text; font-size: 20px; font-weight: 700; overflow: elide; }
            ToolButton { x: parent.width - 44px; y: 10px; button_width: 32px; button_height: 32px; icon_data: "M18 6L6 18 M6 6l12 12"; tooltip: "Close"; clicked => { root.quick_look_close(); } }
            if root.preview_is_image: Image {
                x: (parent.width - 420px) / 2; y: 56px;
                width: 420px; height: 320px;
                source: root.preview_image;
                image-fit: contain;
            }
            if root.preview_is_pdf || root.preview_is_media: Rectangle {
                x: 20px; y: 56px; width: parent.width - 40px; height: 56px;
                border-radius: AppMetrics.radius_small;
                background: ThemePalette.panel_alt;
                Text {
                    x: 16px; width: parent.width - 32px; height: parent.height;
                    text: root.preview_is_pdf ? "PDF document — first page text preview below" : "Media file — press Play to open in your default app";
                    color: ThemePalette.text_muted; font-size: 12.5px; vertical-alignment: center;
                }
            }
            if root.preview_is_media: DialogButton {
                x: 20px; y: 120px; label: "Play";
                clicked => { root.quick_look_play(); }
            }
            CopyableMessageText {
                x: 20px;
                y: root.preview_is_image ? 308px : (root.preview_is_media ? 168px : 56px);
                content-width: parent.width - 40px;
                text: root.preview_body != "" ? root.preview_body : root.preview_meta;
                font-size: 12px;
                mono: !root.preview_is_pdf;
                cap-height: root.preview_is_image ? 140px : 280px;
            }
        }
    }

    if root.op_drawer_visible: Rectangle {
        x: (parent.width - min(420px, parent.width - 32px)) / 2;
        y: parent.height - root.status_h - 76px;
        width: min(420px, parent.width - 32px);
        height: 60px;
        border-width: 1px;
        border-color: ThemePalette.border_strong;
        border-radius: AppMetrics.radius;
        background: ThemePalette.panel_solid;
        drop-shadow-blur: 18px;
        drop-shadow-color: rgba(0, 0, 0, 0.35);

        Rectangle {
            x: 0; y: 0; width: 3px; height: parent.height;
            border-radius: AppMetrics.radius;
            background: ThemePalette.accent;
        }

        SvgIcon {
            x: 14px; y: 12px;
            icon_size: 16px;
            data: "M12 2v4 M12 18v4 M4.93 4.93l2.83 2.83 M16.24 16.24l2.83 2.83 M2 12h4 M18 12h4 M4.93 19.07l2.83-2.83 M16.24 7.76l2.83-2.83";
            tint: ThemePalette.accent;
        }

        Text {
            x: 38px;
            y: 8px;
            width: parent.width - 74px;
            height: 22px;
            text: root.op_drawer_text;
            color: ThemePalette.text;
            font-size: 12.5px;
            vertical-alignment: center;
            overflow: elide;
        }

        // Progress track + fill. Determinate when progress is between 0 and 1,
        // indeterminate (a moving 30% bar) when negative.
        Rectangle {
            x: 38px;
            y: parent.height - 18px;
            width: parent.width - 80px;
            height: 6px;
            border-radius: 3px;
            background: rgba(127, 127, 127, 0.18);
            clip: true;
            if root.op_drawer_progress >= 0: Rectangle {
                x: 0; y: 0;
                width: parent.width * Math.clamp(root.op_drawer_progress, 0, 1);
                height: parent.height;
                border-radius: 3px;
                background: ThemePalette.accent;
                animate width { duration: 120ms; easing: ease-out; }
            }
            if root.op_drawer_progress < 0: Rectangle {
                width: parent.width * 0.30;
                height: parent.height;
                border-radius: 3px;
                background: ThemePalette.accent;
                x: 0;
                animate x { duration: 1200ms; easing: ease-in-out; }
            }
        }

        ToolButton {
            x: parent.width - 34px;
            y: 8px;
            button_width: 26px;
            button_height: 26px;
            icon_data: "M18 6L6 18 M6 6l12 12";
            clicked => { root.op_drawer_visible = false; }
        }
    }

    // -- FIRST RUN WELCOME ---------------------------------------------
    // Shown the first time Pathfinder launches. Offers to register as the
    // default folder handler in one click, and explains the manual steps for
    // pinning Pathfinder to the taskbar / unpinning File Explorer since
    // Windows 11 does not expose those verbs to third party apps.
    if root.welcome_visible: Rectangle {
        x: 0; y: 0;
        width: parent.width; height: parent.height;
        background: rgba(0, 0, 0, 0.55);
        // Higher than ui_mode_prompt (120) and all other modal overlays so
        // the welcome is always on top if both ever flip visible at once.
        z: 200;
        TouchArea {
            // Block clicks behind the dialog so the underlying UI doesn't
            // react while the welcome is open.
            mouse-cursor: default;
        }

        Rectangle {
            x: (parent.width - min(600px, parent.width - 32px)) / 2;
            y: (parent.height - min(580px, parent.height - 32px)) / 2;
            width: min(600px, parent.width - 32px);
            height: min(580px, parent.height - 32px);
            border-radius: AppMetrics.radius;
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            background: ThemePalette.panel_solid;
            drop-shadow-blur: 28px;
            drop-shadow-color: rgba(0, 0, 0, 0.5);
            clip: true;

            VerticalLayout {
                x: 28px;
                y: 24px;
                width: parent.width - 56px;
                spacing: 14px;

                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;
                    Text {
                        text: "Welcome to Pathfinder";
                        color: ThemePalette.text;
                        font-size: 20px;
                        font-weight: 700;
                        vertical-alignment: center;
                        height: self.preferred-height;
                    }
                    if ThemePalette.active_theme == "fantasy": FantasyChestGlyph {
                        pixels: FantasyIconBank.chest;
                        cell: 3px;
                        interactive: true;
                    }
                }
                Text {
                    text: root.welcome_step == 0
                        ? "Three quick steps to make Pathfinder feel like your everyday file manager. You can finish them all here, or come back later from Settings."
                        : (root.welcome_step == 1
                            ? "Pick how much of Pathfinder you want up front. You can change this any time in Settings → Appearance."
                            : "A couple of shortcuts that pay off immediately.");
                    color: ThemePalette.text_muted;
                    font-size: 12.5px;
                    wrap: word-wrap;
                    width: parent.width;
                    height: self.preferred-height;
                }

                // Step 0: default folder handler + pin tips
                if root.welcome_step == 0: Rectangle {
                    height: w1_title.preferred-height + w1_body.preferred-height + 68px;
                    border-radius: AppMetrics.radius_small;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    background: ThemePalette.panel;
                    w1_title := Text { x: 14px; y: 12px; width: parent.width - 28px; text: "1. Set Pathfinder as your default folder handler"; color: ThemePalette.text; font-size: 13px; font-weight: 700; wrap: word-wrap; height: self.preferred-height; }
                    w1_body := CopyableMessageText {
                        x: 14px;
                        y: w1_title.y + w1_title.preferred-height + 4px;
                        content-width: parent.width - 28px;
                        text: root.welcome_default_status;
                        font-size: 11.5px;
                        text-color: ThemePalette.text_muted;
                        cap-height: 120px;
                    }
                    DialogButton {
                        x: parent.width - self.preferred-width - 18px;
                        y: parent.height - 42px;
                        label: root.welcome_default_handler_set ? "Done" : "Set as default";
                        primary: !root.welcome_default_handler_set;
                        clicked => { root.welcome_set_default_handler(); }
                    }
                }
                if root.welcome_step == 0: Rectangle {
                    height: w2_title.preferred-height + w2_body.preferred-height + 28px;
                    border-radius: AppMetrics.radius_small;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    background: ThemePalette.panel;
                    w2_title := Text { x: 14px; y: 12px; width: parent.width - 28px; text: "2. Pin Pathfinder to your taskbar"; color: ThemePalette.text; font-size: 13px; font-weight: 700; wrap: word-wrap; height: self.preferred-height; }
                    w2_body := Text {
                        x: 14px;
                        y: w2_title.y + w2_title.preferred-height + 4px;
                        width: parent.width - 28px;
                        text: "Windows 11 doesn't let apps pin themselves. Open the Start menu, find Pathfinder, right click it, then choose Pin to taskbar.";
                        color: ThemePalette.text_muted;
                        font-size: 11.5px;
                        wrap: word-wrap;
                        height: self.preferred-height;
                    }
                }
                if root.welcome_step == 0: Rectangle {
                    height: w3_title.preferred-height + w3_body.preferred-height + 28px;
                    border-radius: AppMetrics.radius_small;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    background: ThemePalette.panel;
                    w3_title := Text { x: 14px; y: 12px; width: parent.width - 28px; text: "3. Unpin File Explorer (optional)"; color: ThemePalette.text; font-size: 13px; font-weight: 700; wrap: word-wrap; height: self.preferred-height; }
                    w3_body := Text {
                        x: 14px;
                        y: w3_title.y + w3_title.preferred-height + 4px;
                        width: parent.width - 28px;
                        text: "Right click File Explorer on the taskbar and pick Unpin from taskbar so Pathfinder is the one you open by reflex.";
                        color: ThemePalette.text_muted;
                        font-size: 11.5px;
                        wrap: word-wrap;
                        height: self.preferred-height;
                    }
                }

                // Step 1: interface mode
                if root.welcome_step == 1: Rectangle {
                    height: 148px;
                    border-radius: AppMetrics.radius_small;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    background: ThemePalette.panel;
                    Text {
                        x: 14px; y: 12px; width: parent.width - 28px; height: 20px;
                        text: "Choose your starting mode";
                        color: ThemePalette.text; font-size: 13px; font-weight: 700;
                    }
                    HorizontalLayout {
                        x: 14px; y: 44px; width: parent.width - 28px; height: AppMetrics.row_h;
                        spacing: 8px;
                        for mode_label[mi] in ["Simple", "Normal"]: Rectangle {
                            width: (parent.width - 8px) / 2;
                            height: AppMetrics.row_h;
                            property <string> mode_id: mi == 0 ? "simple" : "normal";
                            border-width: 1px;
                            border-color: root.ui_mode == self.mode_id ? ThemePalette.accent : ThemePalette.border;
                            border-radius: AppMetrics.radius;
                            background: root.ui_mode == self.mode_id ? ThemePalette.accent_soft : ThemePalette.panel_solid;
                            Text {
                                width: parent.width; height: parent.height;
                                text: mode_label;
                                color: root.ui_mode == parent.mode_id ? ThemePalette.accent_strong : ThemePalette.text_muted;
                                font-size: 13px; horizontal-alignment: center; vertical-alignment: center;
                            }
                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.welcome_set_mode(mode_id); }
                            }
                        }
                    }
                    Text {
                        x: 14px; y: 96px; width: parent.width - 28px;
                        text: root.ui_mode == "simple"
                            ? "Essential features only — dual pane, power tools, and AI stay tucked away."
                            : "Full access including dual pane, power tools, command palette, and AI.";
                        color: ThemePalette.text_faint; font-size: 11.5px; wrap: word-wrap;
                        height: self.preferred-height;
                    }
                }

                // Step 2: tips
                if root.welcome_step == 2: Rectangle {
                    height: tip1.preferred-height + tip2.preferred-height + 48px;
                    border-radius: AppMetrics.radius_small;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    background: ThemePalette.panel;
                    tip1 := Text {
                        x: 14px; y: 14px; width: parent.width - 28px;
                        text: "Press Ctrl+P to open the command palette — search any action, theme, or folder jump without leaving the keyboard.";
                        color: ThemePalette.text_muted; font-size: 12px; wrap: word-wrap;
                        height: self.preferred-height;
                    }
                    tip2 := Text {
                        x: 14px; y: tip1.y + tip1.preferred-height + 12px; width: parent.width - 28px;
                        text: "Optional AI features (semantic search & helpers) live under Settings → AI. Install only if you want them — Pathfinder works fully without.";
                        color: ThemePalette.text_muted; font-size: 12px; wrap: word-wrap;
                        height: self.preferred-height;
                    }
                }

                HorizontalLayout {
                    height: 36px;
                    spacing: 10px;
                    alignment: end;
                    if root.welcome_step == 0: DialogButton {
                        label: "Open Taskbar settings";
                        clicked => { root.welcome_open_taskbar_settings(); }
                    }
                    if root.welcome_step < 2: DialogButton {
                        label: "Next";
                        primary: true;
                        clicked => { root.welcome_next_step(); }
                    }
                    if root.welcome_step >= 2: DialogButton {
                        label: "Got it";
                        primary: true;
                        clicked => { root.welcome_dismiss(); }
                    }
                    if root.welcome_step < 2: DialogButton {
                        label: "Skip";
                        clicked => { root.welcome_dismiss(); }
                    }
                }
            }
        }
    }

    if root.toast_text != "": Rectangle {
        z: 150;
        width: parent.width;
        height: parent.height;

        toast_box := Rectangle {
            x: (parent.width - self.width) / 2;
            y: parent.height - self.height - 18px;
            width: min(560px, parent.width - 28px);
            height: toast_body.preferred-height + ((root.toast_kind == "error" || root.toast_kind == "warning" || root.toast_action != "") ? 52px : 36px);
            border-width: 1px;
            border-color: root.toast_kind == "error" ? ThemePalette.danger :
                          root.toast_kind == "success" ? ThemePalette.success :
                          root.toast_kind == "warning" ? ThemePalette.warning :
                          ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            drop-shadow-blur: 14px;
            drop-shadow-color: rgba(0, 0, 0, 0.38);
            clip: true;

            Rectangle {
                x: 0; y: 0; width: 3px; height: parent.height;
                border-radius: AppMetrics.radius;
                background: root.toast_kind == "error" ? ThemePalette.danger :
                            root.toast_kind == "success" ? ThemePalette.success :
                            root.toast_kind == "warning" ? ThemePalette.warning :
                            ThemePalette.accent;
            }

            toast_body := CopyableMessageText {
                x: 13px;
                y: 10px;
                content-width: parent.width - (root.toast_action != "" ? 100px : 26px);
                text: root.toast_text;
                font-size: 12.5px;
                text-color: ThemePalette.text;
                cap-height: root.toast_kind == "error" || root.toast_kind == "warning" ? 220px : 140px;
            }

            if root.toast_action != "": DialogButton {
                x: parent.width - self.preferred-width - 12px;
                y: parent.height - 38px;
                label: root.toast_action;
                primary: true;
                clicked => { root.toast_action_clicked(); }
            }

            if root.toast_kind == "error" || root.toast_kind == "warning": HorizontalLayout {
                x: parent.width - 148px;
                y: parent.height - 38px;
                width: 136px;
                height: 32px;
                spacing: 8px;
                DialogButton {
                    label: "Copy";
                    clicked => { root.toast_copy(); }
                }
                DialogButton {
                    label: "Dismiss";
                    clicked => { root.toast_dismiss(); }
                }
            }
        }
    }

    // -- DRAG GHOST OVERLAY -------------------------------------------
    // Explorer-style drag preview that tracks the cursor during in-window
    // drags. Outgoing drags also use IDragSourceHelper (Win32 shell image);
    // this overlay covers internal moves and Explorer -> Pathfinder drops.
    if ThemePalette.is_dragging && root.drag_label != "": Rectangle {
        x: root.drag_cursor_x + 12px;
        y: root.drag_cursor_y + 12px;
        width: Math.min(340px, Math.max(220px, drag_ghost_label.preferred-width + 88px));
        height: ThemePalette.drag_count > 1 ? 58px : 52px;
        border-radius: 8px;
        border-width: 1px;
        border-color: rgba(255, 255, 255, 0.14);
        background: rgba(24, 24, 26, 0.94);
        drop-shadow-blur: 28px;
        drop-shadow-color: rgba(0, 0, 0, 0.55);
        z: 200;

        NodeVisual {
            x: 10px;
            y: (parent.height - self.height) / 2;
            visual_width: 36px;
            visual_height: root.drag_ghost_is_dir ? 30px : 36px;
            is_dir: root.drag_ghost_is_dir;
            extension: root.drag_ghost_ext;
            has_system_icon: false;
            system_icon: @image-url("");
        }

        drag_ghost_label := Text {
            x: 54px;
            y: ThemePalette.drag_count > 1 ? 10px : 0px;
            width: parent.width - 62px;
            height: ThemePalette.drag_count > 1 ? 22px : parent.height;
            text: root.drag_label;
            color: rgba(255, 255, 255, 0.96);
            font-size: 13px;
            font-weight: 600;
            vertical-alignment: center;
            overflow: elide;
        }

        if ThemePalette.drag_count > 1: Text {
            x: 54px;
            y: 32px;
            width: parent.width - 62px;
            height: 20px;
            text: ThemePalette.drag_count + " items";
            color: rgba(255, 255, 255, 0.62);
            font-size: 11px;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    // -- UI mode first-run prompt --------------------------------------
    if root.ui_mode_prompt_visible: Rectangle {
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 0.46);
        z: 120;

        Rectangle {
            x: (parent.width - min(500px, parent.width - 32px)) / 2;
            y: (parent.height - min(310px, parent.height - 32px)) / 2;
            width: min(500px, parent.width - 32px);
            height: min(310px, parent.height - 32px);
            border-width: 1px;
            border-color: ThemePalette.border_strong;
            border-radius: AppMetrics.radius;
            background: ThemePalette.panel_solid;
            drop-shadow-blur: 20px;
            drop-shadow-color: rgba(0, 0, 0, 0.45);
            TouchArea {}

            Text {
                x: 24px; y: 22px;
                width: parent.width - 48px; height: 28px;
                text: "Choose your experience";
                color: ThemePalette.text;
                font-size: 18px; font-weight: 700;
            }
            Text {
                x: 24px; y: 62px;
                width: parent.width - 48px; height: 44px;
                text: "Pick how much of Pathfinder you want to see. You can change this anytime in Settings -> Appearance.";
                color: ThemePalette.text_muted;
                font-size: 12.5px;
                wrap: word-wrap;
            }

            Rectangle {
                x: 24px; y: 122px;
                width: (parent.width - 64px) / 2; height: 130px;
                border-width: 1px;
                border-color: simple_card_touch.has-hover ? ThemePalette.accent : ThemePalette.border;
                border-radius: AppMetrics.radius;
                background: simple_card_touch.has-hover ? ThemePalette.accent_soft : ThemePalette.panel;
                animate background { duration: 40ms; easing: ease-out; }
                Text {
                    x: 16px; y: 16px; width: parent.width - 32px; height: 22px;
                    text: "Simple";
                    color: simple_card_touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text;
                    font-size: 14px; font-weight: 700;
                }
                Text {
                    x: 16px; y: 44px; width: parent.width - 32px;
                    text: "Essential features only.\nClean, focused experience.\nNo dual pane or power tools.";
                    color: ThemePalette.text_muted; font-size: 12px; wrap: word-wrap;
                    height: self.preferred-height;
                }
                simple_card_touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.ui_mode_prompt_visible = false;
                        root.ui_mode = "simple";
                        root.ui_mode_prompt_choice("simple");
                    }
                }
            }

            Rectangle {
                x: parent.width / 2 + 8px; y: 122px;
                width: (parent.width - 64px) / 2; height: 130px;
                border-width: 1px;
                border-color: normal_card_touch.has-hover ? ThemePalette.accent : ThemePalette.border;
                border-radius: AppMetrics.radius;
                background: normal_card_touch.has-hover ? ThemePalette.accent_soft : ThemePalette.panel;
                animate background { duration: 40ms; easing: ease-out; }
                Text {
                    x: 16px; y: 16px; width: parent.width - 32px; height: 22px;
                    text: "Normal";
                    color: normal_card_touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text;
                    font-size: 14px; font-weight: 700;
                }
                Text {
                    x: 16px; y: 44px; width: parent.width - 32px;
                    text: "Full access to every feature:\ndual pane, power tools,\narchive tools, and AI.";
                    color: ThemePalette.text_muted; font-size: 12px; wrap: word-wrap;
                    height: self.preferred-height;
                }
                normal_card_touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.ui_mode_prompt_visible = false;
                        root.ui_mode = "normal";
                        root.ui_mode_prompt_choice("normal");
                    }
                }
            }
        }
    }

    keys := FocusScope {
        KeyBinding { keys: @keys(Control+T); activated => { root.new_tab(); } }
        KeyBinding { keys: @keys(Control+W); activated => { root.tab_closed(-1); } }
        KeyBinding { keys: @keys(Control+L); activated => { root.address_text = root.current_path; root.address_editing = true; } }
        KeyBinding { keys: @keys(Control+Shift+F); activated => { root.command("focus-search"); } }
        KeyBinding { keys: @keys(Control+P); activated => { root.command_filter = ""; root.filter_commands(""); root.command_visible = true; } }
        KeyBinding { keys: @keys(Control+Comma); activated => { root.settings_visible = true; } }
        KeyBinding { keys: @keys(Control+"1"); activated => { root.set_view("grid"); } }
        KeyBinding { keys: @keys(Control+"2"); activated => { root.set_view("list"); } }
        KeyBinding { keys: @keys(Control+"3"); activated => { root.set_view("gallery"); } }
        KeyBinding { keys: @keys(Control+I); activated => { root.toggle_preview(); } }
        KeyBinding { keys: @keys(Control+C); activated => { root.command("copy"); } }
        KeyBinding { keys: @keys(Control+X); activated => { root.command("cut"); } }
        KeyBinding { keys: @keys(Control+V); activated => { root.command("paste"); } }
        KeyBinding { keys: @keys(Control+A); activated => { root.command("select-all"); } }
        KeyBinding { keys: @keys(Control+Z); activated => { root.command("undo"); } }
        KeyBinding { keys: @keys(Control+Y); activated => { root.command("redo"); } }
        KeyBinding { keys: @keys(Control+N); activated => { root.command("new-window"); } }
        KeyBinding { keys: @keys(Control+Shift+N); activated => { root.command("new-folder"); } }
        KeyBinding { keys: @keys(Alt+LeftArrow); activated => { root.go_back(); } }
        KeyBinding { keys: @keys(Alt+RightArrow); activated => { root.go_forward(); } }
        KeyBinding { keys: @keys(Alt+UpArrow); activated => { root.go_up(); } }
        KeyBinding { keys: @keys(F3); activated => { root.toggle_dual_pane(); } }
        KeyBinding { keys: @keys(F5); activated => { root.refresh(); } }
        KeyBinding { keys: @keys(Delete); activated => { root.command("delete"); } }
        KeyBinding { keys: @keys(Shift+Delete); activated => { root.command("purge"); } }
        KeyBinding { keys: @keys(Alt+Return); activated => { root.command("properties"); } }
        KeyBinding { keys: @keys(F2); activated => { root.command("rename"); } }
        KeyBinding { keys: @keys(Return); activated => { root.file_opened(root.selected_index); } }
        KeyBinding { keys: @keys(Space); activated => { root.toggle_quick_look(); } }
        KeyBinding { keys: @keys(Control+D); activated => { root.command("duplicates"); } }
        KeyBinding { keys: @keys(Control+Shift+C); activated => { root.command("checksum"); } }
        KeyBinding { keys: @keys(UpArrow); activated => { root.file_selected(max(0, root.selected_index - 1), false, false); } }
        KeyBinding { keys: @keys(DownArrow); activated => { root.file_selected(min(root.files.length - 1, root.selected_index + 1), false, false); } }
        KeyBinding { keys: @keys(Escape); activated => {
            if (root.command_visible) { root.command_visible = false; }
            else if (root.settings_visible) { root.settings_visible = false; }
            else if (root.confirm_visible) { root.confirm_visible = false; }
            else if (root.tool_overlay_visible) { root.tool_overlay_close(); }
            else if (root.compare_overlay_visible) { root.compare_overlay_close(); }
            else if (root.dupe_overlay_visible) { root.dupe_overlay_close(); }
            else if (root.quick_look_visible) { root.quick_look_close(); }
            else if (root.rename_presets_visible) { root.prompt_cancel(); }
            else if (root.prompt_visible) {
                if (root.prompt_kind == "conflict" || root.prompt_kind == "rename-conflict") {
                    root.prompt_visible = false;
                    root.prompt_kind = "text";
                    root.prompt_accept("skip");
                } else {
                    root.prompt_cancel();
                }
            }
            else if (root.rename_index >= 0) { root.rename_index = -1; }
            else if (root.image_tools_visible) { root.image_tools_visible = false; }
            else if (root.context_visible) { root.context_visible = false; }
            else if (root.search_help_visible) { root.search_help_toggle(); }
            else if (root.address_editing) { root.address_editing = false; root.addr_suggestions = []; }
            else if (root.search_text != "") { root.search_text = ""; root.search_requested(""); }
            else if (root.selected_count > 0) { root.clear_selection(); }
        } }
    }
}

export global AppMetrics {
    in-out property <length> radius: 8px;
    in-out property <length> radius_small: 5px;
    in-out property <length> row_h: 38px;
    // Vertical stride for ChoiceChip grids (chip height is 46px; stride must not shrink below it).
    in-out property <length> choice_chip_row_stride: 52px;
    in-out property <length> index_chip_row_stride: 54px;
    in-out property <length> grid_w: 136px;
    in-out property <length> grid_h: 122px;
    in-out property <length> pad: 16px;
    in-out property <length> outer_border: 0px;
    in-out property <string> ui_font: "Noto Sans";
    in-out property <string> mono_font: "JetBrains Mono";
    in-out property <bool> light_controls: false;
    in-out property <string> icon_set: "";
}
