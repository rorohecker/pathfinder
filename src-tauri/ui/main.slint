import { LineEdit, ListView, ScrollView, Slider } from "std-widgets.slint";

// Bundled OFL fonts (embedded via build.rs). Family names come from font metadata.
import "fonts/PressStart2P-Regular.ttf";
import "fonts/NotoSans-Regular.ttf";
import "fonts/NotoSansMono-Regular.ttf";
import "fonts/JetBrainsMono-Variable.ttf";

export struct FileItem {
    name: string,
    file_path: string,
    is_dir: bool,
    size_text: string,
    modified_text: string,
    type_text: string,
    extension: string,
    has_tag: bool,
    tag_color: color,
    git_badge: string,
    git_color: color,
    has_note: bool,
    is_selected: bool,
    has_thumbnail: bool,
    thumbnail: image,
    // System-extracted icon (the file's actual shell icon - .exe embedded
    // icons, .lnk targets, type associations for .docx / .pdf / etc.).
    // When non-empty (width > 0), NodeVisual draws this instead of the
    // procedural file glyph so executables and document types look correct.
    has_system_icon: bool,
    system_icon: image,
    // Date grouping for the details view when sorted by Date Modified. Mirrors
    // what File Explorer does: each row carries the bucket it falls into
    // (Today, Yesterday, This week, etc) and a flag that is true on the first
    // row of a new bucket so the list view can draw a section divider above it.
    date_group_text: string,
    show_date_group_header: bool,
}

export struct SideItem {
    label: string,
    path: string,
    icon: string,
    count: string,
    color: color,
    is_header: bool,
    active: bool,
}

export struct TabItem {
    title: string,
    path: string,
    active: bool,
}

export struct ChoiceItem {
    id: string,
    label: string,
    description: string,
    color: color,
}

export struct CommandItem {
    group: string,
    label: string,
    hint: string,
    command: string,
}

export global ThemePalette {
    in-out property <color> bg: #101318;
    in-out property <color> bg_soft: #171b22;
    in-out property <color> panel: rgba(28, 33, 42, 0.82);
    in-out property <color> panel_solid: #1c212a;
    in-out property <color> panel_alt: #232936;
    in-out property <color> titlebar: rgba(18, 22, 29, 0.92);
    in-out property <color> sidebar: rgba(22, 26, 34, 0.84);
    in-out property <color> border: rgba(157, 172, 196, 0.16);
    in-out property <color> border_strong: rgba(185, 198, 220, 0.26);
    in-out property <color> text: #f2f6fb;
    in-out property <color> text_muted: #b5c0cf;
    in-out property <color> text_faint: #7f8b9d;
    in-out property <color> accent: #4f9cff;
    in-out property <color> accent_soft: rgba(79, 156, 255, 0.16);
    in-out property <color> accent_strong: #72b3ff;
    in-out property <color> danger: #e5484d;
    in-out property <color> success: #37b26c;
    in-out property <color> warning: #e3a524;
    in-out property <color> icon_folder_1: #ffd86a;
    in-out property <color> icon_folder_2: #e2a934;
    in-out property <string> active_theme: "mica-dark";
    // Custom themes: soft vertical gradient between bg_soft and bg instead of flat bg.
    in-out property <bool> bg_gradient_enabled: false;
    // When true, window background gradient blends toward accent at the bottom.
    in-out property <bool> bg_gradient_accent_tip: false;
    // Runtime-loaded folder icon image. Set from Rust by reading
    // %APPDATA%\Pathfinder\theme_icons\{theme}.png. If width is 0px the
    // file wasn't found and NodeVisual falls back to its drawn shape.
    in-out property <image> folder_icon_image;
    // True while DoDragDrop is blocking the UI thread - selected items show glow
    in-out property <bool> is_dragging: false;
    in-out property <int> drag_count: 0;
}

component SvgIcon {
    in property <string> data;
    in property <color> tint: ThemePalette.text_muted;
    in property <length> icon_size: 16px;
    width: root.icon_size;
    height: root.icon_size;

    Path {
        width: root.icon_size;
        height: root.icon_size;
        commands: root.data;
        fill: rgba(0, 0, 0, 0);
        stroke: root.tint;
        stroke-width: 1.6px;
        stroke-line-cap: round;
        stroke-line-join: round;
    }
}

component HoverTip inherits Rectangle {
    in property <string> tip_text;
    in property <length> tip_max_width: 340px;

    width: Math.min(root.tip_max_width, text_node.preferred-width + 16px);
    height: 26px;
    border-radius: AppMetrics.radius_small;
    border-width: 1px;
    border-color: ThemePalette.border_strong;
    background: ThemePalette.panel_solid;
    drop-shadow-blur: 18px;
    drop-shadow-color: rgba(0, 0, 0, 0.35);

    text_node := Text {
        x: 8px;
        width: parent.width - 16px;
        height: parent.height;
        text: root.tip_text;
        color: ThemePalette.text;
        font-size: 11.5px;
        vertical-alignment: center;
        overflow: elide;
    }
}

component ToolButton inherits Rectangle {
    in property <string> icon_data;
    in property <string> text_label;
    in property <string> tooltip;
    in property <bool> active;
    in property <bool> danger;
    // In simple mode the main window sets this true so every toolbar button
    // shows its label under the icon at all times instead of only on hover.
    in property <bool> show_caption;
    in property <length> button_width: 31px;
    in property <length> button_height: 31px;
    callback clicked();

    width: root.button_width;
    height: root.button_height;
    border-radius: AppMetrics.radius_small;
    border-width: root.active ? 1px : 0px;
    border-color: root.active ? ThemePalette.accent : rgba(0, 0, 0, 0);
    background: root.danger && touch.has-hover ? ThemePalette.danger :
        (touch.pressed ? rgba(255, 255, 255, 0.12) :
        (root.active ? ThemePalette.accent_soft :
        (touch.has-hover ? rgba(255, 255, 255, 0.06) : rgba(0, 0, 0, 0))));

    // Two captioned layouts:
    //   - Wide button (width > height + 12 px): icon on the left, label to the
    //     right. Used by the simple-mode toolbar where each button is 88x38 and
    //     the caption needs to read like a normal button label.
    //   - Tall button (default captioned form): icon on top, label beneath.
    property <bool> caption_inline: root.show_caption && root.width > root.height + 12px;

    SvgIcon {
        x: root.caption_inline ? 10px : (parent.width - 16px) / 2;
        y: root.caption_inline
            ? (parent.height - 16px) / 2
            : (root.show_caption ? 4px : (parent.height - 16px) / 2);
        icon_size: 16px;
        data: root.icon_data;
        tint: root.danger && touch.has-hover ? white : (root.active || touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text_muted);
    }

    // Icon-less button: centered glyph or letter.
    Text {
        visible: root.icon_data == "" && !root.show_caption;
        text: root.text_label;
        color: root.danger && touch.has-hover ? white : (root.active || touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text_muted);
        font-size: 16px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    // Inline caption (icon-left layout) — wider buttons use this form so the
    // text has breathing room and reads naturally.
    if root.show_caption && root.text_label != "" && root.caption_inline: Text {
        x: 32px;
        y: 0;
        width: parent.width - 36px;
        height: parent.height;
        text: root.text_label;
        color: root.active || touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text_muted;
        font-size: 12px;
        font-weight: 600;
        horizontal-alignment: left;
        vertical-alignment: center;
        overflow: elide;
    }

    // Stacked caption (icon-on-top layout) — kept for narrow captioned buttons
    // where there isn't room for the inline form.
    if root.show_caption && root.text_label != "" && !root.caption_inline: Text {
        x: 0;
        y: 22px;
        width: parent.width;
        height: parent.height - 22px;
        text: root.text_label;
        color: root.active || touch.has-hover ? ThemePalette.accent_strong : ThemePalette.text_muted;
        font-size: 9.5px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: top;
        overflow: elide;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    if root.tooltip != "" && touch.has-hover: Rectangle {
        // Anchor the tooltip so its right edge lines up with the button's
        // right edge. Tooltip always extends to the left from there. For
        // buttons near the right edge of the window this keeps the tooltip
        // inside the visible area; for buttons elsewhere the tooltip is
        // wider than the button anyway so the slight left-shift is fine.
        x: parent.width - (tip_text.preferred-width + 16px);
        y: parent.height + 6px;
        width: tip_text.preferred-width + 16px;
        height: 26px;
        border-radius: AppMetrics.radius_small;
        border-width: 1px;
        border-color: ThemePalette.border_strong;
        background: ThemePalette.panel_solid;
        drop-shadow-blur: 18px;
        drop-shadow-color: rgba(0, 0, 0, 0.35);

        tip_text := Text {
            x: 8px;
            width: parent.width - 16px;
            height: parent.height;
            text: root.tooltip;
            color: ThemePalette.text;
            font-size: 11.5px;
            vertical-alignment: center;
        }
    }
}

component TabButton inherits Rectangle {
    in property <TabItem> tab;
    in property <int> index;
    in property <string> drag_target_path;
    callback activated(int);
    callback closed(int);

    // True when the cursor is hovering this tab during a drag-and-drop. We
    // light the tab up with an accent border so the user can see exactly
    // which tab the drop will route into before they release.
    property <bool> is_drop_target: root.drag_target_path != "" && root.drag_target_path == root.tab.path;

    width: Math.min(240px, Math.max(132px, title_text.preferred-width + 50px));
    height: 30px;
    border-radius: 7px;
    border-width: root.is_drop_target ? 2px : (root.tab.active ? 1px : 0px);
    border-color: root.is_drop_target ? ThemePalette.accent_strong : ThemePalette.border;
    background: root.is_drop_target
        ? ThemePalette.accent_soft
        : (root.tab.active ? ThemePalette.panel : (touch.has-hover ? ThemePalette.panel_alt : rgba(0, 0, 0, 0)));
    animate background { duration: 40ms; easing: linear; }
    animate border-color { duration: 120ms; easing: ease-out; }

    title_text := Text {
        x: 10px;
        y: 0;
        width: parent.width - 38px;
        height: parent.height;
        text: root.tab.title;
        color: root.tab.active ? ThemePalette.text : ThemePalette.text_muted;
        font-size: 12px;
        overflow: elide;
        vertical-alignment: center;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.activated(root.index); }
    }

    ToolButton {
        x: parent.width - 28px;
        y: 3px;
        button_width: 24px;
        button_height: 24px;
        icon_data: "M18 6L6 18 M6 6l12 12";
        tooltip: "Close tab";
        visible: touch.has-hover || root.tab.active;
        clicked => { root.closed(root.index); }
    }

    if touch.has-hover && root.tab.path != "": HoverTip {
        x: 4px;
        y: parent.height + 6px;
        tip_max_width: 420px;
        tip_text: root.tab.path;
    }
}

component SideRow inherits Rectangle {
    in property <SideItem> item;
    in property <int> index;
    in property <string> drag_target_path;
    callback activated(int);
    callback rename_activated(string);

    property <bool> is_drop_target: !root.item.is_header
        && root.drag_target_path != ""
        && root.drag_target_path == root.item.path;

    height: root.item.is_header ? 24px : 32px;
    background: rgba(0, 0, 0, 0);

    // Visual highlight pill. Sits inside the row but pulls a 20 px gutter
    // in from the right edge so the sidebar ListView's scroll bar paints
    // in its own lane with visible breathing room from the pill. When this
    // row is the current drop target, a brighter accent_soft fills the pill
    // and a thin accent border outlines it so the user can tell exactly
    // where the file will land.
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width - 20px;
        height: parent.height;
        border-radius: AppMetrics.radius_small;
        border-width: root.is_drop_target ? 2px : 0px;
        border-color: root.is_drop_target ? ThemePalette.accent_strong : rgba(0, 0, 0, 0);
        background: root.is_drop_target
            ? ThemePalette.accent_soft
            : (!root.item.is_header && root.item.active
                ? ThemePalette.accent_soft
                : (!root.item.is_header && touch.has-hover
                    ? rgba(255, 255, 255, 0.06)
                    : rgba(0, 0, 0, 0)));
        animate background { duration: 120ms; easing: ease-out; }
        animate border-color { duration: 120ms; easing: ease-out; }
    }

    Text {
        visible: root.item.is_header;
        x: 8px;
        width: parent.width - 16px;
        height: parent.height;
        text: root.item.label;
        color: ThemePalette.text_faint;
        font-size: 11px;
        font-weight: 700;
        vertical-alignment: center;
    }

    Rectangle {
        visible: !root.item.is_header && root.item.icon == "tag";
        x: 12px;
        y: (parent.height - 9px) / 2;
        width: 9px;
        height: 9px;
        border-radius: 5px;
        background: root.item.color;
        border-width: 1px;
        border-color: rgba(0, 0, 0, 0.14);
    }

    SvgIcon {
        visible: !root.item.is_header && root.item.icon != "tag";
        x: 9px;
        y: (parent.height - 16px) / 2;
        icon_size: 16px;
        data: root.item.icon == "drive" ? "M22 12H2 M5.5 5.2 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.5-6.8A2 2 0 0 0 16.7 4H7.3a2 2 0 0 0-1.8 1.2z" :
              root.item.icon == "home" ? "M3 10l9-7 9 7v10a2 2 0 0 1-2 2h-4v-7H9v7H5a2 2 0 0 1-2-2z" :
              root.item.icon == "download" ? "M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M7 10l5 5 5-5 M12 15V3" :
              root.item.icon == "image" ? "M21 15V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2z M8 11a2 2 0 1 0 0-4 2 2 0 0 0 0 4z M21 19l-6-6-9 9" :
              // Music: eighth note (Lucide "music" glyph)
              root.item.icon == "music" ? "M9 18V5l12-2v13 M9 18a3 3 0 1 1-6 0 3 3 0 0 1 6 0z M21 16a3 3 0 1 1-6 0 3 3 0 0 1 6 0z" :
              // Video: filmstrip / play screen (Lucide "video" glyph)
              root.item.icon == "video" ? "M22 8l-6 4 6 4V8z M14 6H4a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2z" :
              // Documents: page with text lines (Lucide "file-text" glyph)
              root.item.icon == "documents" ? "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8" :
              // Trash: bin with lid + handle (Lucide "trash-2" glyph)
              root.item.icon == "trash" ? "M3 6h18 M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6 M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2 M10 11v6 M14 11v6" :
              "M3 7.5A2.5 2.5 0 0 1 5.5 5H10l2 2h6.5A2.5 2.5 0 0 1 21 9.5v7A2.5 2.5 0 0 1 18.5 19h-13A2.5 2.5 0 0 1 3 16.5z";
        tint: root.item.active ? ThemePalette.accent_strong : ThemePalette.text_muted;
    }

    Text {
        visible: !root.item.is_header;
        x: 38px;
        width: parent.width - 78px;
        height: parent.height;
        text: root.item.label;
        color: root.item.active ? ThemePalette.accent_strong : (touch.has-hover ? ThemePalette.text : ThemePalette.text_muted);
        font-size: 13px;
        overflow: elide;
        vertical-alignment: center;
    }

    Text {
        visible: !root.item.is_header && !(root.item.icon == "tag" && touch.has-hover);
        // Count text (tag counts, drive labels like "local") sits inside the
        // highlight pill, not past its right edge. The pill ends 20 px from
        // the row's right edge, so the count is anchored to parent.width - 62
        // and ends at parent.width - 24, leaving a small inset inside the pill.
        x: parent.width - 62px;
        width: 38px;
        height: parent.height;
        text: root.item.count;
        color: ThemePalette.text_faint;
        font-family: AppMetrics.mono_font;
        font-size: 10px;
        horizontal-alignment: right;
        vertical-alignment: center;
        overflow: elide;
    }

    // Rename button - shown on hover for tag items; click handled via touch.mouse-x
    // Positioned inside the highlight pill so the click target is visible
    // when the row is highlighted.
    if !root.item.is_header && root.item.icon == "tag" && touch.has-hover: Rectangle {
        x: parent.width - 44px;
        y: (parent.height - 22px) / 2;
        width: 22px; height: 22px;
        border-radius: AppMetrics.radius_small;
        background: rgba(255, 255, 255, 0.1);
        SvgIcon {
            x: 4px; y: 4px;
            icon_size: 14px;
            data: "M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7 M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z";
            tint: ThemePalette.text_muted;
        }
    }

    touch := TouchArea {
        enabled: !root.item.is_header;
        mouse-cursor: pointer;
        clicked => {
            if (root.item.icon == "tag" && touch.mouse-x >= touch.width - 28px) {
                root.rename_activated(root.item.path);
            } else {
                root.activated(root.index);
            }
        }
        double-clicked => {
            if (root.item.icon == "tag") { root.rename_activated(root.item.path); }
        }
    }

}

component NodeVisual {
    in property <bool> is_dir;
    in property <string> extension;
    // Folders use a clearly wider-than-tall outline so they read as a folder
    // silhouette and not a square tile. Iterations: 54x44 (1.23) was near square,
    // 62x40 (1.55) was wider but still chunky, 68x36 (1.89) is closer to the
    // proportions of a real manila folder.
    in property <length> visual_width: root.is_dir ? 68px : 46px;
    in property <length> visual_height: root.is_dir ? 36px : 54px;

    width: root.visual_width;
    height: root.visual_height;

    property <color> ext_color:
        root.extension == "pdf" ? #e5474c :
        (root.extension == "doc" || root.extension == "docx" || root.extension == "odt" || root.extension == "rtf" ? #4f9cff :
        (root.extension == "xls" || root.extension == "xlsx" || root.extension == "csv" || root.extension == "ods" ? #2db87c :
        (root.extension == "ppt" || root.extension == "pptx" || root.extension == "odp" ? #e3a524 :
        (root.extension == "png" || root.extension == "jpg" || root.extension == "jpeg" || root.extension == "gif" || root.extension == "svg" || root.extension == "webp" || root.extension == "bmp" || root.extension == "ico" ? #a87ef8 :
        (root.extension == "rs" || root.extension == "js" || root.extension == "ts" || root.extension == "py" || root.extension == "c" || root.extension == "cpp" || root.extension == "h" || root.extension == "hpp" || root.extension == "go" || root.extension == "java" || root.extension == "kt" || root.extension == "cs" || root.extension == "rb" || root.extension == "lua" || root.extension == "zig" ? #2dd4bf :
        (root.extension == "zip" || root.extension == "tar" || root.extension == "gz" || root.extension == "7z" || root.extension == "rar" || root.extension == "xz" ? #f59e0b :
        (root.extension == "mp3" || root.extension == "mp4" || root.extension == "wav" || root.extension == "flac" || root.extension == "ogg" || root.extension == "mkv" || root.extension == "avi" || root.extension == "mov" ? #f472b6 :
        (root.extension == "exe" || root.extension == "msi" || root.extension == "bat" || root.extension == "cmd" ? #fb923c :
        ThemePalette.accent))))))));

    // True when a per-theme PNG is loaded - shapes below are skipped so transparent
    // areas of the PNG don't reveal the standard yellow folder underneath.
    property <bool> use_image: ThemePalette.folder_icon_image.width > 0;

    // ── IMAGE OVERLAY ─────────────────────────────────────────────────────
    // PNG saved to %APPDATA%\Pathfinder\theme_icons\<theme>.png renders here.
    if root.is_dir && root.use_image: Image {
        x: 0; y: 0;
        width: parent.width; height: parent.height;
        source: ThemePalette.folder_icon_image;
        image-fit: contain;
    }

    // Standard folder shape - used by every theme except terminal and
    // cyberpunk (which have non-folder custom shapes whose black border
    // can't be removed). Each theme provides its own color pair via
    // ThemePalette.icon_folder_1 / icon_folder_2 so the result reads as a
    // folder but matches the theme palette.
    property <bool> uses_standard_folder:
        ThemePalette.active_theme != "terminal" &&
        ThemePalette.active_theme != "cyberpunk" &&
        ThemePalette.active_theme != "retro" &&
        ThemePalette.active_theme != "fantasy";

    // Standard folder. Modeled on the reference shape: a rounded rectangular
    // body with a darker tab in the upper-left that has a diagonal right edge.
    // Drawn in three layers so the silhouette reads at any size and renders
    // crisply on HiDPI without rasterised assets.
    //
    //   1. Darker back edge — thin strip at the bottom that peeks below the
    //      body, suggesting the rear flap of a manila folder.
    //   2. Tab — darker amber rectangle at top-left, ~42% wide, with the right
    //      edge angled by a 1.5x-wide triangle-ish rectangle slanted in.
    //   3. Body — full-width rounded rectangle covering ~80% of the height,
    //      overlapping the bottom edge of the tab so only the tab's top sticks
    //      up like an actual manila folder tab.
    //   4. Subtle top highlight stripe inside the body for depth.

    // Back edge strip (a darker tone showing under the body)
    if root.is_dir && !root.use_image && root.uses_standard_folder: Rectangle {
        x: 0; y: parent.height - 4px;
        width: parent.width; height: 4px;
        border-radius: 3px;
        background: ThemePalette.icon_folder_2.darker(0.25);
    }
    // Tab on top-left, darker than the body
    if root.is_dir && !root.use_image && root.uses_standard_folder: Rectangle {
        x: 0; y: 0;
        width: parent.width * 0.42;
        height: parent.height * 0.28;
        border-radius: 4px;
        background: ThemePalette.icon_folder_2.darker(0.15);
    }
    // Tab right-edge taper — a smaller rectangle just to the right of the tab
    // body extends it with a stepped silhouette that reads as an angled cut.
    if root.is_dir && !root.use_image && root.uses_standard_folder: Rectangle {
        x: parent.width * 0.42 - 6px;
        y: 0;
        width: parent.width * 0.10;
        height: parent.height * 0.20;
        border-radius: 3px;
        background: ThemePalette.icon_folder_2.darker(0.15);
    }
    // Body — overlaps the tab from below so only the tab's top sticks up.
    if root.is_dir && !root.use_image && root.uses_standard_folder: Rectangle {
        x: 0;
        y: parent.height * 0.20;
        width: parent.width;
        height: parent.height * 0.78;
        border-radius: 6px;
        background: @linear-gradient(180deg,
            ThemePalette.icon_folder_1 0%,
            ThemePalette.icon_folder_2 100%);
        // Subtle inner top highlight for depth.
        Rectangle {
            x: 2px; y: 1px;
            width: parent.width - 4px;
            height: parent.height * 0.22;
            border-radius: 4px;
            background: rgba(255, 255, 255, 0.18);
        }
    }

    // ── TERMINAL: CRT monitor ─────────────────────────────────────────────
    if root.is_dir && !root.use_image && ThemePalette.active_theme == "terminal": Rectangle {
        x: 0; y: 0; width: parent.width; height: parent.height * 0.74;
        border-radius: 3px; background: #1c2820;
        Rectangle {
            x: parent.width * 0.09; y: parent.height * 0.10;
            width: parent.width * 0.82; height: parent.height * 0.62;
            background: #041008;
            Rectangle { x: parent.width * 0.07; y: parent.height * 0.16; width: parent.width * 0.58; height: 1px; background: #7cff9d; }
            Rectangle { x: parent.width * 0.07; y: parent.height * 0.28; width: parent.width * 0.38; height: 1px; background: #7cff9d; opacity: 0.85; }
            Rectangle { x: parent.width * 0.07; y: parent.height * 0.40; width: parent.width * 0.48; height: 1px; background: #7cff9d; opacity: 0.75; }
            Rectangle { x: parent.width * 0.07; y: parent.height * 0.52; width: parent.width * 0.28; height: 1px; background: #7cff9d; opacity: 0.60; }
        }
        Rectangle { x: parent.width * 0.07; y: parent.height * 0.83; width: 3px; height: 3px; border-radius: 1.5px; background: #7cff9d; }
    }
    if root.is_dir && !root.use_image && ThemePalette.active_theme == "terminal": Rectangle {
        x: parent.width * 0.39; y: parent.height * 0.74; width: parent.width * 0.22; height: parent.height * 0.09; background: #1c2820;
    }
    if root.is_dir && !root.use_image && ThemePalette.active_theme == "terminal": Rectangle {
        x: parent.width * 0.12; y: parent.height * 0.83; width: parent.width * 0.76; height: parent.height * 0.17; border-radius: 2px; background: #1c2820;
    }

    // ── CYBERPUNK: data terminal ──────────────────────────────────────────
    if root.is_dir && !root.use_image && ThemePalette.active_theme == "cyberpunk": Rectangle {
        x: 0; y: 0; width: parent.width; height: parent.height; border-radius: 2px; background: #080220; border-width: 1px; border-color: #00fff2;
        Rectangle { x: parent.width*0.34; y: parent.height*0.30; width: parent.width*0.32; height: parent.height*0.40; border-radius: 1px; background: #1a0440; border-width: 1px; border-color: #00fff2; }
    }

    // ── RETRO: chunky pixel-art folder with floppy disk centerpiece ──────
    // Reads as a folder silhouette but rendered with visible blocky pixels,
    // a magenta-on-yellow palette, and a tiny 8-bit floppy disk dropped on top.
    if root.is_dir && !root.use_image && ThemePalette.active_theme == "retro": Rectangle {
        x: 0; y: 0; width: parent.width; height: parent.height;
        // Folder tab - chunky block on top-left
        Rectangle {
            x: parent.width * 0.06;
            y: parent.height * 0.08;
            width: parent.width * 0.46;
            height: parent.height * 0.20;
            background: ThemePalette.icon_folder_1;
            border-width: 2px;
            border-color: #12081c;
        }
        // Folder body - main yellow block with thick pixel border
        Rectangle {
            x: parent.width * 0.04;
            y: parent.height * 0.22;
            width: parent.width * 0.92;
            height: parent.height * 0.72;
            background: ThemePalette.icon_folder_2;
            border-width: 2px;
            border-color: #12081c;
            // Top highlight pixel row (lighter)
            Rectangle {
                x: 2px; y: 2px;
                width: parent.width - 4px;
                height: parent.height * 0.16;
                background: ThemePalette.icon_folder_1;
            }
            // Bottom shadow pixel row (darker)
            Rectangle {
                x: 2px;
                y: parent.height - parent.height * 0.18 - 2px;
                width: parent.width - 4px;
                height: parent.height * 0.14;
                background: #c02890;
                opacity: 0.55;
            }
            // Floppy disk centerpiece
            Rectangle {
                x: parent.width * 0.30;
                y: parent.height * 0.30;
                width: parent.width * 0.40;
                height: parent.height * 0.44;
                background: #2a1840;
                border-width: 1px;
                border-color: #12081c;
                // Disk label
                Rectangle {
                    x: parent.width * 0.16;
                    y: parent.height * 0.18;
                    width: parent.width * 0.68;
                    height: parent.height * 0.36;
                    background: #f8f0d4;
                }
                // Metal shutter
                Rectangle {
                    x: parent.width * 0.30;
                    y: parent.height * 0.62;
                    width: parent.width * 0.40;
                    height: parent.height * 0.22;
                    background: #cfd8e8;
                }
            }
        }
    }

    // ── FANTASY: ornate wooden treasure chest with gold bands ────────────
    // Clearly distinct from a folder shape: rounded lid on top of trapezoidal
    // body, two gold horizontal bands, and a small gold lock plate.
    if root.is_dir && !root.use_image && ThemePalette.active_theme == "fantasy": Rectangle {
        x: 0; y: 0; width: parent.width; height: parent.height;
        // Lid (rounded top half)
        Rectangle {
            x: parent.width * 0.06;
            y: parent.height * 0.10;
            width: parent.width * 0.88;
            height: parent.height * 0.42;
            border-radius: parent.width * 0.30;
            background: @linear-gradient(180deg, #6b4520 0%, #4a2c12 100%);
            border-width: 1px;
            border-color: #2a1808;
        }
        // Cover the bottom half of the lid so it sits flat on the body
        Rectangle {
            x: parent.width * 0.06;
            y: parent.height * 0.40;
            width: parent.width * 0.88;
            height: parent.height * 0.14;
            background: #4a2c12;
        }
        // Chest body
        Rectangle {
            x: parent.width * 0.04;
            y: parent.height * 0.48;
            width: parent.width * 0.92;
            height: parent.height * 0.48;
            border-radius: 2px;
            background: @linear-gradient(180deg, #5a3818 0%, #36200c 100%);
            border-width: 1px;
            border-color: #1a0c04;
        }
        // Gold band - top of body
        Rectangle {
            x: parent.width * 0.04;
            y: parent.height * 0.50;
            width: parent.width * 0.92;
            height: parent.height * 0.07;
            background: @linear-gradient(180deg, ThemePalette.icon_folder_1 0%, ThemePalette.icon_folder_2 100%);
            border-width: 1px;
            border-color: rgba(0, 0, 0, 0.35);
        }
        // Gold band - bottom of body
        Rectangle {
            x: parent.width * 0.04;
            y: parent.height * 0.86;
            width: parent.width * 0.92;
            height: parent.height * 0.07;
            background: @linear-gradient(180deg, ThemePalette.icon_folder_1 0%, ThemePalette.icon_folder_2 100%);
            border-width: 1px;
            border-color: rgba(0, 0, 0, 0.35);
        }
        // Lock plate
        Rectangle {
            x: parent.width * 0.42;
            y: parent.height * 0.56;
            width: parent.width * 0.16;
            height: parent.height * 0.24;
            border-radius: 2px;
            background: @linear-gradient(180deg, ThemePalette.icon_folder_1 0%, ThemePalette.icon_folder_2 100%);
            border-width: 1px;
            border-color: rgba(0, 0, 0, 0.40);
            // Keyhole dot
            Rectangle {
                x: parent.width / 2 - 1.5px;
                y: parent.height / 2 - 1.5px;
                width: 3px; height: 3px;
                border-radius: 1.5px;
                background: #2a1808;
            }
        }
    }

    // ── SHELL-EXTRACTED ICON (replaces procedural icon when available) ───
    // Used for .exe (embedded icons), .lnk (target icon), and registered
    // file types like .docx/.pdf/.xlsx where the shell knows the brand icon.
    in property <image> system_icon;
    in property <bool> has_system_icon: false;
    if !root.is_dir && root.has_system_icon: Image {
        x: 3px; y: 1px;
        width: parent.width - 6px;
        height: parent.height - 2px;
        source: root.system_icon;
        image-fit: contain;
    }

    // ── FILE ICON (same for all themes - used when no shell icon exists) ─
    if !root.is_dir && !root.has_system_icon: Rectangle {
        x: 7px; y: 3px;
        width: parent.width - 14px;
        height: parent.height - 6px;
        border-radius: 4px;
        border-width: 1px;
        border-color: rgba(0, 0, 0, 0.08);
        background: #cfd8e8;
    }
    if !root.is_dir && !root.has_system_icon: Rectangle {
        x: parent.width - 20px; y: 4px;
        width: 13px; height: 13px;
        background: ThemePalette.bg;
        border-width: 1px;
        border-color: rgba(0, 0, 0, 0.08);
    }
    if !root.is_dir && !root.has_system_icon: Rectangle {
        x: 7px;
        y: parent.height - 18px;
        width: parent.width - 14px;
        height: 15px;
        border-radius: 3px;
        background: root.ext_color;
        Text {
            text: root.extension == "" ? "FILE" : root.extension;
            color: white;
            font-family: AppMetrics.mono_font;
            font-size: 8px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // Type-specific glyph overlay on the file body. Small vector marks that
    // make at-a-glance recognition faster than reading the extension label.
    // EXE / MSI / BAT / CMD: triangle "play" mark (executable)
    if !root.is_dir && !root.has_system_icon && (root.extension == "exe" || root.extension == "msi" || root.extension == "bat" || root.extension == "cmd"): Rectangle {
        x: parent.width / 2 - 6px;
        y: parent.height / 2 - 9px;
        width: 12px; height: 12px;
        background: transparent;
        Rectangle { x: 1px; y: 0; width: 0px; height: 0px;
            border-width: 6px;
            border-color: #fb923c;
        }
        // Triangle approximated by two stacked thin rectangles + a wider middle bar.
        Rectangle { x: 3px; y: 0; width: 2px; height: 12px; background: #ffffff; }
        Rectangle { x: 5px; y: 2px; width: 2px; height: 8px; background: #ffffff; }
        Rectangle { x: 7px; y: 4px; width: 2px; height: 4px; background: #ffffff; }
    }
    // DLL / SYS: gear-like circle + cross marks (library)
    if !root.is_dir && !root.has_system_icon && (root.extension == "dll" || root.extension == "sys" || root.extension == "drv" || root.extension == "lib"): Rectangle {
        x: parent.width / 2 - 7px;
        y: parent.height / 2 - 9px;
        width: 14px; height: 14px;
        border-radius: 7px;
        background: transparent;
        border-width: 2px; border-color: #ffffff;
        Rectangle { x: parent.width / 2 - 1px; y: parent.height / 2 - 1px; width: 2px; height: 2px; border-radius: 1px; background: #ffffff; }
        Rectangle { x: parent.width / 2 - 4px; y: -2px; width: 2px; height: 4px; background: #ffffff; }
        Rectangle { x: parent.width / 2 + 2px; y: -2px; width: 2px; height: 4px; background: #ffffff; }
        Rectangle { x: parent.width / 2 - 4px; y: parent.height - 2px; width: 2px; height: 4px; background: #ffffff; }
        Rectangle { x: parent.width / 2 + 2px; y: parent.height - 2px; width: 2px; height: 4px; background: #ffffff; }
    }
    // ZIP / 7Z / RAR / TAR / GZ: zipper teeth (archive)
    if !root.is_dir && !root.has_system_icon && (root.extension == "zip" || root.extension == "7z" || root.extension == "rar" || root.extension == "tar" || root.extension == "gz" || root.extension == "xz"): Rectangle {
        x: parent.width / 2 - 1px;
        y: parent.height / 2 - 10px;
        width: 2px; height: 16px;
        background: #ffffff;
        Rectangle { x: -3px; y: 1px; width: 8px; height: 2px; background: #ffffff; }
        Rectangle { x: -3px; y: 5px; width: 8px; height: 2px; background: #ffffff; }
        Rectangle { x: -3px; y: 9px; width: 8px; height: 2px; background: #ffffff; }
        Rectangle { x: -3px; y: 13px; width: 8px; height: 2px; background: #ffffff; }
    }
    // PDF: bold red corner badge stays as the colored band - also add a folded corner mark
    if !root.is_dir && !root.has_system_icon && root.extension == "pdf": Rectangle {
        x: parent.width / 2 - 6px;
        y: parent.height / 2 - 8px;
        width: 12px; height: 12px;
        background: #ffffff;
        border-radius: 1px;
        Text {
            width: parent.width; height: parent.height;
            text: "P";
            color: #e5474c;
            font-size: 10px;
            font-weight: 900;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
    // CODE: angle brackets
    if !root.is_dir && !root.has_system_icon && (root.extension == "rs" || root.extension == "js" || root.extension == "ts" || root.extension == "tsx" || root.extension == "jsx" || root.extension == "py" || root.extension == "c" || root.extension == "cpp" || root.extension == "h" || root.extension == "hpp" || root.extension == "go" || root.extension == "java" || root.extension == "kt" || root.extension == "cs" || root.extension == "rb" || root.extension == "lua" || root.extension == "zig" || root.extension == "html" || root.extension == "css"): Rectangle {
        x: parent.width / 2 - 8px;
        y: parent.height / 2 - 7px;
        width: 16px; height: 12px;
        background: transparent;
        // Left chevron <
        Rectangle { x: 0; y: 5px; width: 2px; height: 2px; background: #ffffff; }
        Rectangle { x: 2px; y: 3px; width: 2px; height: 2px; background: #ffffff; }
        Rectangle { x: 2px; y: 7px; width: 2px; height: 2px; background: #ffffff; }
        Rectangle { x: 4px; y: 1px; width: 2px; height: 2px; background: #ffffff; }
        Rectangle { x: 4px; y: 9px; width: 2px; height: 2px; background: #ffffff; }
        // Right chevron >
        Rectangle { x: 14px; y: 5px; width: 2px; height: 2px; background: #ffffff; }
        Rectangle { x: 12px; y: 3px; width: 2px; height: 2px; background: #ffffff; }
        Rectangle { x: 12px; y: 7px; width: 2px; height: 2px; background: #ffffff; }
        Rectangle { x: 10px; y: 1px; width: 2px; height: 2px; background: #ffffff; }
        Rectangle { x: 10px; y: 9px; width: 2px; height: 2px; background: #ffffff; }
    }
    // VIDEO: play triangle
    if !root.is_dir && !root.has_system_icon && (root.extension == "mp4" || root.extension == "mkv" || root.extension == "avi" || root.extension == "mov" || root.extension == "webm"): Rectangle {
        x: parent.width / 2 - 5px;
        y: parent.height / 2 - 7px;
        width: 12px; height: 12px;
        background: transparent;
        Rectangle { x: 2px; y: 0; width: 2px; height: 12px; background: #ffffff; }
        Rectangle { x: 4px; y: 2px; width: 2px; height: 8px; background: #ffffff; }
        Rectangle { x: 6px; y: 4px; width: 2px; height: 4px; background: #ffffff; }
    }
    // AUDIO: eighth-note (eighth note simplified)
    if !root.is_dir && !root.has_system_icon && (root.extension == "mp3" || root.extension == "wav" || root.extension == "flac" || root.extension == "ogg" || root.extension == "m4a" || root.extension == "aac"): Rectangle {
        x: parent.width / 2 - 6px;
        y: parent.height / 2 - 8px;
        width: 12px; height: 14px;
        background: transparent;
        Rectangle { x: 8px; y: 0; width: 2px; height: 10px; background: #ffffff; }
        Rectangle { x: 2px; y: 8px; width: 6px; height: 4px; border-radius: 2px; background: #ffffff; }
    }
    // IMAGE: small landscape rectangle with sun
    if !root.is_dir && !root.has_system_icon && (root.extension == "png" || root.extension == "jpg" || root.extension == "jpeg" || root.extension == "gif" || root.extension == "webp" || root.extension == "bmp" || root.extension == "ico" || root.extension == "tiff" || root.extension == "tif"): Rectangle {
        x: parent.width / 2 - 7px;
        y: parent.height / 2 - 7px;
        width: 14px; height: 12px;
        border-radius: 1px;
        background: transparent;
        border-width: 1px; border-color: #ffffff;
        Rectangle { x: 8px; y: 1px; width: 3px; height: 3px; border-radius: 1.5px; background: #ffffff; }
        Rectangle { x: 1px; y: 7px; width: 4px; height: 2px; background: #ffffff; }
        Rectangle { x: 5px; y: 5px; width: 4px; height: 4px; background: #ffffff; }
        Rectangle { x: 9px; y: 6px; width: 4px; height: 3px; background: #ffffff; }
    }
    // DOC / DOCX / TXT / MD: text lines
    if !root.is_dir && !root.has_system_icon && (root.extension == "doc" || root.extension == "docx" || root.extension == "txt" || root.extension == "md" || root.extension == "rtf" || root.extension == "odt"): Rectangle {
        x: parent.width / 2 - 6px;
        y: parent.height / 2 - 7px;
        width: 12px; height: 12px;
        background: transparent;
        Rectangle { x: 0; y: 1px; width: 10px; height: 1px; background: #ffffff; }
        Rectangle { x: 0; y: 4px; width: 12px; height: 1px; background: #ffffff; }
        Rectangle { x: 0; y: 7px; width: 8px; height: 1px; background: #ffffff; }
        Rectangle { x: 0; y: 10px; width: 11px; height: 1px; background: #ffffff; }
    }
    // SPREADSHEET: grid pattern
    if !root.is_dir && !root.has_system_icon && (root.extension == "xls" || root.extension == "xlsx" || root.extension == "csv" || root.extension == "ods"): Rectangle {
        x: parent.width / 2 - 6px;
        y: parent.height / 2 - 6px;
        width: 12px; height: 10px;
        background: transparent;
        border-width: 1px; border-color: #ffffff;
        Rectangle { x: 5px; y: 0; width: 1px; height: parent.height; background: #ffffff; }
        Rectangle { x: 0; y: 4px; width: parent.width; height: 1px; background: #ffffff; }
    }
}

component FileRow inherits Rectangle {
    in property <FileItem> item;
    in property <int> index;
    in property <string> view_mode;
    in property <int> rename_index: -1;
    callback selected(int, bool, bool);
    callback opened(int);
    callback context(int, length, length);
    callback rename_commit(int, string);
    callback file_drag_requested(int);

    // Drag-target path comes from the MainWindow root and a FileRow renders a
    // pulsing accent border when its own file_path matches. Drop highlight only
    // applies to folder rows since dropping onto a file is a no-op.
    in property <string> drag_target_path;

    property <bool> ctrl_held: false;
    property <bool> shift_held: false;
    property <bool> is_renaming: root.rename_index == root.index;
    property <bool> drag_started: false;
    property <bool> is_drop_target: root.item.is_dir
        && root.drag_target_path != ""
        && root.drag_target_path == root.item.file_path;
    // Date grouping header sits above the row in the details view only. The
    // backend sets show_date_group_header=true on the first row of every new
    // bucket (Today, Yesterday, This week, etc) when sorted by Date modified.
    property <bool> has_group_header: root.view_mode == "list" && root.item.show_date_group_header;
    property <length> group_header_h: root.has_group_header ? 26px : 0px;

    height: (root.view_mode == "list" ? AppMetrics.row_h : (root.view_mode == "gallery" ? 154px : (root.view_mode == "compact" ? 32px : AppMetrics.grid_h))) + root.group_header_h;

    // Group header at the top of the row, only when this row starts a new bucket.
    if root.has_group_header: Rectangle {
        x: 0; y: 0;
        width: parent.width; height: root.group_header_h;
        Text {
            x: 6px;
            y: 0;
            width: parent.width - 12px;
            height: parent.height - 4px;
            text: root.item.date_group_text;
            color: ThemePalette.text_faint;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.5px;
            vertical-alignment: bottom;
            overflow: elide;
        }
        Rectangle {
            x: 6px;
            y: parent.height - 3px;
            width: parent.width - 12px;
            height: 1px;
            background: ThemePalette.border;
        }
    }
    // The root has no background or border. Selection and hover paint into
    // inner rectangles that start BELOW the date-group header strip, so the
    // highlight visually matches the file row rather than spilling over the
    // "Today" / "Yesterday" / "This week" label above it.
    border-radius: 0px;
    border-width: 0px;
    background: rgba(0, 0, 0, 0);

    if root.item.is_selected: Rectangle {
        x: 0;
        y: root.group_header_h;
        width: parent.width;
        height: parent.height - root.group_header_h;
        border-radius: AppMetrics.radius;
        border-width: 1px;
        border-color: ThemePalette.accent;
        background: ThemePalette.accent_soft;
    }

    // Hover glow - instant on, instant off. File Explorer doesn't fade either.
    // Wrapped in `if` so non-hovered rows skip rendering this entirely.
    if touch.has-hover && !root.item.is_selected: Rectangle {
        x: 0;
        y: root.group_header_h;
        width: parent.width;
        height: parent.height - root.group_header_h;
        border-radius: AppMetrics.radius;
        background: rgba(255, 255, 255, 0.07);
    }

    // Drag glow - shown on selected items while DoDragDrop is active
    if ThemePalette.is_dragging && root.item.is_selected: Rectangle {
        x: -3px; y: -3px;
        width: parent.width + 6px; height: parent.height + 6px;
        border-radius: parent.border-radius + 2px;
        border-width: 2px;
        border-color: ThemePalette.accent_strong;
        background: ThemePalette.accent_soft;
    }

    // Drop-target glow - pulses on the folder row the cursor is currently over
    // during a drag, so the user can tell exactly where the drop will land. The
    // ScaleEffect-style pulse is approximated with a static accent border for
    // now since Slint 1.x does not have a built-in keyframe animation property
    // for repeating glows.
    if root.is_drop_target: Rectangle {
        x: -3px; y: root.group_header_h - 3px;
        width: parent.width + 6px;
        height: parent.height - root.group_header_h + 6px;
        border-radius: parent.border-radius + 2px;
        border-width: 2px;
        border-color: ThemePalette.accent_strong;
        background: ThemePalette.accent_soft;
        animate border-color { duration: 240ms; easing: ease-in-out; }
    }

    if root.view_mode == "list": NodeVisual {
        x: 8px;
        y: root.group_header_h + (parent.height - root.group_header_h - self.height) / 2;
        visual_width: ThemePalette.is_dragging && root.item.is_selected ? 32px : 28px;
        visual_height: root.item.is_dir
            ? (ThemePalette.is_dragging && root.item.is_selected ? 26px : 22px)
            : (ThemePalette.is_dragging && root.item.is_selected ? 32px : 28px);
        is_dir: root.item.is_dir;
        extension: root.item.extension;
        has_system_icon: root.item.has_system_icon;
        system_icon: root.item.system_icon;
    }

    // List view responsive layout - three breakpoints:
    //   < 360px: name only (size/modified/type all hidden; name fills the row)
    //   < 480px: name + modified
    //   < 600px: name + size + modified
    //   ≥ 600px: name + size + modified + type
    property <bool> show_list_size: root.width >= 360px;
    property <bool> show_list_modified: root.width >= 480px;
    property <bool> show_list_type: root.width >= 600px;
    property <length> list_right_zone:
        root.show_list_type ? 320px :
        (root.show_list_modified ? (root.show_list_size ? 220px : 140px) :
        (root.show_list_size ? 90px : 0px));

    if root.view_mode == "list" && !root.is_renaming: Text {
        x: 44px;
        y: root.group_header_h;
        // Name always gets at least 80px; right column slides in when the row gets wider.
        width: max(80px, parent.width - 44px - root.list_right_zone - 16px);
        height: parent.height - root.group_header_h;
        text: root.item.name;
        color: root.item.is_selected ? ThemePalette.text : ThemePalette.text_muted;
        font-size: 12.5px;
        overflow: elide;
        vertical-alignment: center;
    }

    // List view: inline rename input
    if root.view_mode == "list" && root.is_renaming: rename_list := LineEdit {
        x: 44px;
        y: root.group_header_h + 4px;
        width: max(80px, parent.width - 48px - root.list_right_zone - 16px);
        height: parent.height - root.group_header_h - 8px;
        text: root.item.name;
        font-size: 12.5px;
        accepted(val) => { root.rename_commit(root.index, val); }
        key-pressed(event) => {
            if (event.text == Key.Escape) { root.rename_commit(root.index, ""); accept }
            else { reject }
        }
    }

    // SIZE column - right-aligned, monospaced
    if root.view_mode == "list" && root.show_list_size: Text {
        x: parent.width - root.list_right_zone;
        y: root.group_header_h;
        width: 80px;
        height: parent.height - root.group_header_h;
        text: root.item.size_text;
        color: ThemePalette.text_faint;
        font-family: AppMetrics.mono_font;
        font-size: 11.5px;
        overflow: elide;
        vertical-alignment: center;
        horizontal-alignment: right;
    }

    // MODIFIED column
    if root.view_mode == "list" && root.show_list_modified: Text {
        x: parent.width - root.list_right_zone + (root.show_list_size ? 88px : 0px);
        y: root.group_header_h;
        width: 130px;
        height: parent.height - root.group_header_h;
        text: root.item.modified_text;
        color: ThemePalette.text_faint;
        font-family: AppMetrics.mono_font;
        font-size: 11.5px;
        overflow: elide;
        vertical-alignment: center;
    }

    // TYPE column
    if root.view_mode == "list" && root.show_list_type: Text {
        x: parent.width - root.list_right_zone + (root.show_list_size ? 88px : 0px) + 138px;
        y: root.group_header_h;
        width: 80px;
        height: parent.height - root.group_header_h;
        text: root.item.type_text;
        color: ThemePalette.text_faint;
        font-size: 11.5px;
        overflow: elide;
        vertical-alignment: center;
    }

    if root.view_mode == "list": Rectangle {
        visible: root.item.has_tag;
        // Pull the dot 28px in from the right edge so it does not get hidden
        // by the ListView's scroll bar (~14px wide on a Mica window).
        x: parent.width - 28px;
        y: root.group_header_h + (parent.height - root.group_header_h - 9px) / 2;
        width: 9px;
        height: 9px;
        border-radius: 5px;
        background: root.item.tag_color;
    }

    if root.view_mode != "list" && root.view_mode != "compact" && root.item.has_thumbnail: Rectangle {
        x: (parent.width - (root.view_mode == "gallery" ? 64px : 54px)) / 2;
        y: root.view_mode == "gallery" ? 18px : 12px;
        width: root.view_mode == "gallery" ? 64px : 54px;
        height: root.view_mode == "gallery" ? 70px : 54px;
        border-radius: 4px;
        clip: true;
        Image {
            width: parent.width;
            height: parent.height;
            source: root.item.thumbnail;
            image-fit: cover;
        }
    }

    if root.view_mode != "list" && root.view_mode != "compact" && !root.item.has_thumbnail: NodeVisual {
        x: (parent.width - (root.view_mode == "gallery"
            ? (ThemePalette.is_dragging && root.item.is_selected ? 72px : 64px)
            : (ThemePalette.is_dragging && root.item.is_selected ? 62px : 54px))) / 2;
        y: (root.view_mode == "gallery" ? 18px : 12px) - (ThemePalette.is_dragging && root.item.is_selected ? 4px : 0px);
        visual_width: root.view_mode == "gallery"
            ? (ThemePalette.is_dragging && root.item.is_selected ? 72px : 64px)
            : (ThemePalette.is_dragging && root.item.is_selected ? 62px : 54px);
        visual_height: root.view_mode == "gallery"
            ? (ThemePalette.is_dragging && root.item.is_selected ? 78px : 70px)
            : (ThemePalette.is_dragging && root.item.is_selected ? 62px : 54px);
        is_dir: root.item.is_dir;
        extension: root.item.extension;
        has_system_icon: root.item.has_system_icon;
        system_icon: root.item.system_icon;
    }

    // Grid/gallery: name as text (not renaming)
    if root.view_mode != "list" && root.view_mode != "compact" && !root.is_renaming: Text {
        x: 18px;
        y: parent.height - 38px;
        width: parent.width - 36px;
        height: 30px;
        text: root.item.name;
        color: root.item.is_selected ? ThemePalette.text : ThemePalette.text_muted;
        font-size: 12px;
        wrap: word-wrap;
        horizontal-alignment: center;
    }

    // Grid/gallery: inline rename input
    if root.view_mode != "list" && root.view_mode != "compact" && root.is_renaming: rename_grid := LineEdit {
        x: 8px;
        y: parent.height - 40px;
        width: parent.width - 16px;
        height: 32px;
        text: root.item.name;
        font-size: 12px;
        horizontal-alignment: center;
        accepted(val) => { root.rename_commit(root.index, val); }
        key-pressed(event) => {
            if (event.text == Key.Escape) { root.rename_commit(root.index, ""); accept }
            else { reject }
        }
    }

    Rectangle {
        visible: root.item.has_tag && root.view_mode != "list";
        x: parent.width - 22px;
        y: 8px;
        width: 9px;
        height: 9px;
        border-radius: 5px;
        background: root.item.tag_color;
    }

    Rectangle {
        visible: root.item.git_badge != "";
        x: 8px;
        y: 8px;
        height: 15px;
        width: 10px + git-text.preferred-width;
        border-radius: 3px;
        background: root.item.git_color;
        git-text := Text {
            x: 5px;
            y: 0;
            height: parent.height;
            text: root.item.git_badge;
            color: white;
            font-family: AppMetrics.mono_font;
            font-size: 9px;
            font-weight: 700;
            vertical-alignment: center;
        }
    }

    // Compact view: small icon + name in one horizontal row
    if root.view_mode == "compact": NodeVisual {
        x: 4px;
        y: (parent.height - 18px) / 2;
        visual_width: root.item.is_dir ? 22px : 18px;
        visual_height: 18px;
        is_dir: root.item.is_dir;
        extension: root.item.extension;
        has_system_icon: root.item.has_system_icon;
        system_icon: root.item.system_icon;
    }

    if root.view_mode == "compact" && !root.is_renaming: Text {
        x: 30px;
        y: 0;
        width: parent.width - 38px;
        height: parent.height;
        text: root.item.name;
        color: root.item.is_selected ? ThemePalette.text : ThemePalette.text_muted;
        font-size: 12px;
        overflow: elide;
        vertical-alignment: center;
    }

    if root.view_mode == "compact" && root.is_renaming: rename_compact := LineEdit {
        x: 30px;
        y: 3px;
        width: parent.width - 38px;
        height: parent.height - 6px;
        text: root.item.name;
        font-size: 12px;
        accepted(val) => { root.rename_commit(root.index, val); }
        key-pressed(event) => {
            if (event.text == Key.Escape) { root.rename_commit(root.index, ""); accept }
            else { reject }
        }
    }

    Rectangle {
        visible: root.item.has_note;
        x: parent.width - 15px;
        y: parent.height - 15px;
        width: 6px;
        height: 6px;
        border-radius: 3px;
        background: ThemePalette.accent_strong;
    }

    // TouchArea is constrained to the file-content area, NOT the date-group
    // header strip that sits above it. Without this constraint, clicks on the
    // "Today" / "Yesterday" / "This week" labels were treated as clicks on the
    // file below, making the click box appear misaligned from the visual row
    // when sorted by Date modified.
    //
    // Drag-start behaviour: SELECTED rows start a file drag-out (DoDragDrop).
    // UNSELECTED rows fire marquee_started/moved/finished so the parent pane
    // can rubber-band select from anywhere in the file list, not just the
    // empty strip above the list header. Absolute coordinates are reported
    // because the pane subtracts its own absolute position to translate them
    // into pane-local space for the marquee rect.
    callback marquee_started(length, length);
    callback marquee_moved(length, length);
    callback marquee_finished();

    touch := TouchArea {
        x: 0;
        y: root.group_header_h;
        width: parent.width;
        height: parent.height - root.group_header_h;
        mouse-cursor: pointer;
        clicked => { root.selected(root.index, root.ctrl_held, root.shift_held); }
        double-clicked => { root.opened(root.index); }
        moved => {
            if (self.pressed) {
                if (!root.drag_started && (
                    (self.mouse-x - self.pressed-x > 6px) ||
                    (self.pressed-x - self.mouse-x > 6px) ||
                    (self.mouse-y - self.pressed-y > 6px) ||
                    (self.pressed-y - self.mouse-y > 6px))) {
                    root.drag_started = true;
                    if (root.item.is_selected) {
                        root.file_drag_requested(root.index);
                    } else {
                        root.marquee_started(
                            self.absolute-position.x + self.pressed-x,
                            self.absolute-position.y + self.pressed-y);
                    }
                }
                if (root.drag_started && !root.item.is_selected) {
                    root.marquee_moved(
                        self.absolute-position.x + self.mouse-x,
                        self.absolute-position.y + self.mouse-y);
                }
            }
        }
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                root.ctrl_held = event.modifiers.control;
                root.shift_held = event.modifiers.shift;
                root.drag_started = false;
            }
            if (event.kind == PointerEventKind.up && event.button == PointerEventButton.left) {
                if (root.drag_started && !root.item.is_selected) {
                    root.marquee_finished();
                }
                root.drag_started = false;
            }
            if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                root.context(root.index,
                    self.absolute-position.x + self.mouse-x,
                    self.absolute-position.y + self.mouse-y);
            }
        }
    }

}

component ListHeader inherits Rectangle {
    in property <string> sort_by: "name";
    in property <string> sort_dir: "asc";
    callback sort_col(string);

    // Match FileRow's responsive layout exactly.
    property <bool> show_size: root.width >= 360px;
    property <bool> show_modified: root.width >= 480px;
    property <bool> show_type: root.width >= 600px;
    property <length> right_zone:
        root.show_type ? 320px :
        (root.show_modified ? (root.show_size ? 220px : 140px) :
        (root.show_size ? 90px : 0px));

    height: 32px;
    background: ThemePalette.panel_solid;
    border-width: 0px;

    // NAME
    Rectangle {
        x: 44px;
        width: max(60px, parent.width - 44px - root.right_zone - 16px);
        height: parent.height;
        background: nh.has-hover ? rgba(255,255,255,0.04) : transparent;
        Text { x: 0; width: parent.width - 14px; height: parent.height; text: "NAME"; color: root.sort_by == "name" ? ThemePalette.text_muted : ThemePalette.text_faint; font-size: 11px; font-weight: 700; vertical-alignment: center; }
        Text { visible: root.sort_by == "name"; x: parent.width - 13px; width: 12px; height: parent.height; text: root.sort_dir == "asc" ? "↑" : "↓"; color: ThemePalette.accent; font-size: 10px; vertical-alignment: center; }
        nh := TouchArea { mouse-cursor: pointer; clicked => { root.sort_col("name"); } }
    }
    // SIZE - right-aligned to align with file size text
    if root.show_size: Rectangle {
        x: parent.width - root.right_zone;
        width: 80px;
        height: parent.height;
        background: sh.has-hover ? rgba(255,255,255,0.04) : transparent;
        Text { x: 0; width: parent.width - 14px; height: parent.height; text: "SIZE"; color: root.sort_by == "size" ? ThemePalette.text_muted : ThemePalette.text_faint; font-size: 11px; font-weight: 700; horizontal-alignment: right; vertical-alignment: center; }
        Text { visible: root.sort_by == "size"; x: parent.width - 12px; width: 12px; height: parent.height; text: root.sort_dir == "asc" ? "↑" : "↓"; color: ThemePalette.accent; font-size: 10px; vertical-alignment: center; }
        sh := TouchArea { mouse-cursor: pointer; clicked => { root.sort_col("size"); } }
    }
    // MODIFIED
    if root.show_modified: Rectangle {
        x: parent.width - root.right_zone + (root.show_size ? 88px : 0px);
        width: 130px;
        height: parent.height;
        background: mh.has-hover ? rgba(255,255,255,0.04) : transparent;
        Text { x: 0; width: parent.width - 14px; height: parent.height; text: "MODIFIED"; color: root.sort_by == "modified" ? ThemePalette.text_muted : ThemePalette.text_faint; font-size: 11px; font-weight: 700; vertical-alignment: center; }
        Text { visible: root.sort_by == "modified"; x: parent.width - 12px; width: 12px; height: parent.height; text: root.sort_dir == "asc" ? "↑" : "↓"; color: ThemePalette.accent; font-size: 10px; vertical-alignment: center; }
        mh := TouchArea { mouse-cursor: pointer; clicked => { root.sort_col("modified"); } }
    }
    // TYPE
    if root.show_type: Rectangle {
        x: parent.width - root.right_zone + (root.show_size ? 88px : 0px) + 138px;
        width: 80px;
        height: parent.height;
        background: th.has-hover ? rgba(255,255,255,0.04) : transparent;
        Text { x: 0; width: parent.width - 14px; height: parent.height; text: "TYPE"; color: root.sort_by == "type" ? ThemePalette.text_muted : ThemePalette.text_faint; font-size: 11px; font-weight: 700; vertical-alignment: center; }
        Text { visible: root.sort_by == "type"; x: parent.width - 12px; width: 12px; height: parent.height; text: root.sort_dir == "asc" ? "↑" : "↓"; color: ThemePalette.accent; font-size: 10px; vertical-alignment: center; }
        th := TouchArea { mouse-cursor: pointer; clicked => { root.sort_col("type"); } }
    }

    Rectangle { y: parent.height - 1px; height: 1px; width: parent.width; background: ThemePalette.border; }
}

component ChoiceChip inherits Rectangle {
    in property <ChoiceItem> item;
    in property <bool> active;
    callback picked(string);

    property <bool> no_desc: root.item.description == "";
    height: root.no_desc ? 34px : 46px;
    border-radius: AppMetrics.radius_small;
    border-width: 1px;
    border-color: root.active ? ThemePalette.accent : ThemePalette.border;
    background: root.active ? ThemePalette.accent_soft : (touch.has-hover ? ThemePalette.panel_alt : ThemePalette.panel);

    Rectangle {
        x: 10px;
        y: (parent.height - 24px) / 2;
        width: 24px;
        height: 24px;
        border-radius: 12px;
        background: root.item.color;
        border-width: 1px;
        border-color: ThemePalette.border_strong;
    }

    Text {
        // Pulled in from the icon circle (right edge at x=34) with a real
        // 14 px gap so the label can never lean on the icon, even with
        // long localized strings or wide-glyph theme fonts.
        x: 48px;
        y: root.no_desc ? 8px : 6px;
        width: parent.width - 58px;
        height: root.no_desc ? 20px : 18px;
        text: root.item.label;
        color: ThemePalette.text;
        font-size: root.no_desc ? 12.5px : 13px;
        font-weight: 700;
        vertical-alignment: root.no_desc ? center : top;
        overflow: elide;
    }

    Text {
        visible: !root.no_desc;
        x: 48px;
        y: 24px;
        width: parent.width - 58px;
        height: 16px;
        text: root.item.description;
        color: ThemePalette.text_faint;
        font-size: 11px;
        overflow: elide;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.picked(root.item.id); }
    }
}

component ChoiceMenuRow inherits Rectangle {
    in property <string> label;
    in property <string> command_name;
    in property <bool> danger;
    callback picked(string);

    property <string> cmd_icon: root.command_name == "open" ? "M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6 M15 3h6v6 M10 14L21 3"
        : root.command_name == "rename" ? "M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7 M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"
