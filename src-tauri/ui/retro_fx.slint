// Lean Retro Arcade atmosphere for Pathfinder.
// CRT scanline only — companion to retro_icons.slint.
// Theme-gated by the caller via `active`. No TouchArea: clicks pass through.
//
// Earlier builds also drew sparse magenta VHS glitch bands; those read as a
// broken purple bar flickering near pane edges/dividers, so they were removed.

export component RetroAtmosphere inherits Rectangle {
    in property <bool> active: false;
    in property <bool> running: true;

    width: 100%;
    height: 100%;
    background: transparent;
    visible: root.active;

    property <bool> anim_on: root.active && root.running;

    // CRT scanline sweeping down the window (quiet cyan, not magenta).
    Rectangle {
        width: root.width;
        height: 2px;
        background: #2fe0ff;
        opacity: 0.10;
        property <bool> down: false;
        Timer {
            interval: 3400ms;
            running: root.anim_on;
            triggered => { down = !down; }
        }
        y: down ? root.height - 2px : -2px;
        animate y { duration: 3400ms; easing: linear; }
    }
}
