{
  "productName": "Pathfinder",
  "version": "0.1.0",
  "identifier": "com.fusntuff.pathfinder",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Pathfinder",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 550,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
